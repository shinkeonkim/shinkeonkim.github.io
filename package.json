{
  "name": "shinkeonkim-log",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.5",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "bun scripts/check-no-em-dash.mjs && bun scripts/validate-mermaid.mjs && bun scripts/validate-animations.mjs && bun scripts/sync-wiki-category.mjs --strict && bun scripts/download-pretendard.mjs && bun scripts/fetch-giscus-counts.mjs && bun scripts/fetch-url-previews.mjs && bun scripts/generate-search-tags.mjs && bun scripts/generate-changelog.mjs && bun scripts/validate-content.mjs",
    "predev": "bun scripts/download-pretendard.mjs && bun scripts/fetch-url-previews.mjs --quiet && bun scripts/generate-search-tags.mjs && bun scripts/generate-changelog.mjs",
    "fonts:refresh": "bun scripts/download-pretendard.mjs --force",
    "counts:refresh": "bun scripts/fetch-giscus-counts.mjs",
    "previews:refresh": "bun scripts/fetch-url-previews.mjs --force",
    "build": "NODE_OPTIONS='--max-old-space-size=7168' astro build",
    "build:pagefind": "pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "astro check",
    "clean": "rm -rf dist .astro node_modules/.vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "check:links": "bun scripts/check-links.mjs",
    "check:links:internal": "bun scripts/check-links.mjs --internal-only",
    "check:links:strict": "bun scripts/check-links.mjs --fail-on-external",
    "validate:content": "bun scripts/validate-content.mjs",
    "validate:content:strict": "bun scripts/validate-content.mjs --strict",
    "validate:mermaid": "bun scripts/validate-mermaid.mjs",
    "validate:animations": "bun scripts/validate-animations.mjs",
    "validate:wiki-category": "bun scripts/sync-wiki-category.mjs --strict",
    "sync:wiki-category": "bun scripts/sync-wiki-category.mjs --write",
    "audit:alt": "bun scripts/audit-alt-text.mjs",
    "audit:alt:strict": "bun scripts/audit-alt-text.mjs --strict",
    "lint:no-em-dash": "bun scripts/check-no-em-dash.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.6",
    "@astrojs/react": "^5.0.5",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.0.0",
    "@types/d3": "^7.4.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "astro": "6.3.7",
    "astro-pagefind": "^2.0.0",
    "chart.js": "4.5.1",
    "cmdk": "^1.1.1",
    "d3": "^7.9.0",
    "katex": "^0.17.0",
    "open-graph-scraper": "^6.11.0",
    "pagefind": "^1.5.0",
    "react": "^19.0.0",
    "react-chartjs-2": "5.3.1",
    "react-dom": "^19.0.0",
    "react-force-graph-3d": "^1.27.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.0.0",
    "three": "^0.185.1",
    "unist-util-visit": "^5.0.0",
    "web-vitals": "^5.2.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.9.1",
    "@types/qrcode-svg": "^1.1.5",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "^4.1.7",
    "astro-auto-import": "^0.5.1",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^1.3.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "linkinator": "^7.6.1",
    "mermaid": "11.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "qrcode-svg": "^1.1.0",
    "rehype-external-links": "^3.0.0",
    "satori": "^0.26.0",
    "simple-git": "^3.36.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.7"
  },
  "trustedDependencies": [
    "esbuild"
  ]
}
