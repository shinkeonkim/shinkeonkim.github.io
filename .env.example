# Copy this file to `.env` and fill in your values.
# Vars prefixed `PUBLIC_` are inlined into the static client bundle.

# --- Comments (https://giscus.app) ---
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=
PUBLIC_GISCUS_CATEGORY_ID=

# --- Google Analytics 4 ---
PUBLIC_GA_MEASUREMENT_ID=
PUBLIC_GA_ID=

# --- Search Console / Search Advisor verification ---
# See manual-docs/seo-setup.md for setup steps
PUBLIC_GOOGLE_VERIFY=
PUBLIC_NAVER_VERIFY=

# --- Dev-only stats fetcher (scripts/fetch-project-stats.py) ---
# Optional: a PAT with `public_repo` scope lifts the unauthenticated 60/hr rate limit.
# GITHUB_TOKEN=
# GITHUB_USERNAME=shinkeonkim
