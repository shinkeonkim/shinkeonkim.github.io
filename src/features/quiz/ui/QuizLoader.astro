---
import '@/features/quiz/ui/Quiz.css';

interface Props {
  slug: string;
}

const { slug } = Astro.props as Props;
---

<div data-quiz-anchor={slug} aria-hidden="true" hidden></div>

<script>
  import { setupQuizzes } from '@/features/quiz/lib/hydrate-quizzes';

  if (document.readyState !== 'loading') setupQuizzes();
  else document.addEventListener('DOMContentLoaded', setupQuizzes);
  document.addEventListener('astro:page-load', setupQuizzes);
</script>
