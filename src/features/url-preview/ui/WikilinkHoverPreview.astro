---
---

<div
  id="wikilink-popover"
  class="wikilink-popover"
  role="tooltip"
  hidden
  aria-hidden="true"
>
  <span class="wikilink-popover-badge" data-popover-badge></span>
  <span class="wikilink-popover-title" data-popover-title></span>
  <span class="wikilink-popover-preview" data-popover-preview></span>
</div>

<style is:global>
  .wikilink-popover {
    position: absolute;
    z-index: 1000;
    max-width: 22rem;
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background-color: var(--color-surface-elevated);
    box-shadow: 0 8px 24px -8px rgba(0, 0, 0, 0.18);
    display: grid;
    gap: 0.3rem;
    pointer-events: none;
    color: var(--color-fg);
  }
  .wikilink-popover[hidden] {
    display: none;
  }
  .wikilink-popover-badge {
    justify-self: start;
    font-size: 0.65rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    color: var(--color-fg-muted);
    background-color: var(--color-code-bg);
    padding: 0.05rem 0.4rem;
    border-radius: 999px;
    letter-spacing: 0.04em;
  }
  .wikilink-popover-title {
    font-size: 0.9rem;
    font-weight: 600;
  }
  .wikilink-popover-preview {
    font-size: 0.8rem;
    color: var(--color-fg-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script is:inline>
  (function () {
    if (window.__wikilinkPreviewBound) return;
    window.__wikilinkPreviewBound = true;

    const HOVER_DELAY = 300;
    const POPOVER_MARGIN = 12;
    const PREVIEW_URL = '/wikilink-previews.json';
    const BADGES = { posts: '글', wiki: '위키', notes: '노트' };

    let cache = null;
    let cachePromise = null;
    let hoverTimer = null;
    let activeAnchor = null;

    function popover() {
      return document.getElementById('wikilink-popover');
    }

    function normKey(s) {
      return String(s).normalize('NFC').toLowerCase();
    }

    async function loadIndex() {
      if (cache) return cache;
      if (!cachePromise) {
        cachePromise = fetch(PREVIEW_URL)
          .then((r) => (r.ok ? r.json() : {}))
          .catch(() => ({}));
      }
      cache = await cachePromise;
      return cache;
    }

    async function show(anchor) {
      const target = anchor.dataset.wikilinkTarget;
      if (!target) return;
      const idx = await loadIndex();
      const data = idx[normKey(target)];
      if (!data || activeAnchor !== anchor) return;
      const el = popover();
      if (!el) return;
      el.querySelector('[data-popover-badge]').textContent = BADGES[data.collection] || '';
      el.querySelector('[data-popover-title]').textContent = data.title;
      el.querySelector('[data-popover-preview]').textContent = data.preview;
      el.hidden = false;
      el.setAttribute('aria-hidden', 'false');
      el.style.visibility = 'hidden';
      const popRect = el.getBoundingClientRect();
      const rect = anchor.getBoundingClientRect();
      const left = Math.max(
        POPOVER_MARGIN,
        Math.min(window.innerWidth - popRect.width - POPOVER_MARGIN, rect.left),
      );
      const spaceBelow = window.innerHeight - rect.bottom;
      const top =
        spaceBelow > popRect.height + POPOVER_MARGIN
          ? window.scrollY + rect.bottom + POPOVER_MARGIN
          : window.scrollY + rect.top - popRect.height - POPOVER_MARGIN;
      el.style.left = `${left}px`;
      el.style.top = `${top}px`;
      el.style.visibility = 'visible';
    }

    function hide() {
      const el = popover();
      if (el) {
        el.hidden = true;
        el.setAttribute('aria-hidden', 'true');
      }
      activeAnchor = null;
      if (hoverTimer) {
        clearTimeout(hoverTimer);
        hoverTimer = null;
      }
    }

    function bindAnchor(anchor) {
      activeAnchor = anchor;
      if (hoverTimer) clearTimeout(hoverTimer);
      hoverTimer = setTimeout(() => show(anchor), HOVER_DELAY);
    }

    document.addEventListener('mouseover', (e) => {
      const a = e.target.closest('a.wikilink:not(.broken)');
      if (!a) return;
      bindAnchor(a);
    });

    document.addEventListener('mouseout', (e) => {
      const a = e.target.closest('a.wikilink');
      if (!a) return;
      if (e.relatedTarget && a.contains(e.relatedTarget)) return;
      if (activeAnchor === a) hide();
    });

    document.addEventListener('focusin', (e) => {
      const a = e.target.closest && e.target.closest('a.wikilink:not(.broken)');
      if (!a) return;
      bindAnchor(a);
    });

    document.addEventListener('focusout', (e) => {
      const a = e.target.closest && e.target.closest('a.wikilink');
      if (!a) return;
      if (activeAnchor === a) hide();
    });

    document.addEventListener('astro:before-swap', hide);
  })();
</script>
