---
import {
  getContentGraph,
  canonicalId,
  type Collection,
  type ContentNode,
} from '@/shared/lib/content/content-graph';

interface Props {
  slug: string;
  collection: Collection;
}

const { slug, collection } = Astro.props as Props;

const graph = await getContentGraph();
const matches = graph.backlinks.get(canonicalId(collection, slug)) ?? [];

const groups: { label: string; entries: ContentNode[] }[] = [];
if (collection === 'wiki') {
  const wikiRefs = matches.filter((m) => m.collection === 'wiki');
  const postRefs = matches.filter((m) => m.collection === 'posts');
  const noteRefs = matches.filter((m) => m.collection === 'notes');
  if (wikiRefs.length > 0) {
    groups.push({ label: '이 개념을 다룬 위키 페이지', entries: wikiRefs });
  }
  if (postRefs.length > 0) {
    groups.push({ label: '이 개념을 사용하는 글', entries: postRefs });
  }
  if (noteRefs.length > 0) {
    groups.push({ label: '이 개념을 언급한 노트', entries: noteRefs });
  }
} else if (matches.length > 0) {
  groups.push({ label: '이 페이지를 참조하는 글', entries: matches });
}
---

{
  groups.length > 0 && (
    <section class="mt-12 border-t border-border pt-6">
      {groups.map((g) => (
        <div class="mb-5 last:mb-0">
          <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-fg-muted">
            {g.label} ({g.entries.length})
          </h3>
          <ul class="space-y-1">
            {g.entries.map((m) => (
              <li>
                <a href={m.url} class="text-sm">
                  <span class="mr-2 inline-block rounded bg-surface-elevated px-1.5 py-0.5 text-xs uppercase text-fg-muted">
                    {m.collection}
                  </span>
                  {m.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </section>
  )
}
