---
import {
  getMembershipsFor,
  type CollectionKind,
} from '@/shared/lib/content/course-membership';

interface Props {
  collection: CollectionKind;
  slug: string;
}

const { collection, slug } = Astro.props as Props;
const memberships = await getMembershipsFor(collection, slug);
---

{
  memberships.length > 0 && (
    <aside class="course-badges not-prose" aria-label="이 페이지가 속한 학습 코스">
      {memberships.map((m) => (
        <a
          href={`/courses/${m.courseId}/#chapter-${m.chapterIndex + 1}`}
          class="course-badge"
          data-course-badge={m.courseId}
          data-course-chapter-index={m.chapterIndex}
          data-course-chapter-total={m.total}
        >
          <span class="course-badge-icon" aria-hidden="true">🎓</span>
          <span class="course-badge-label">
            <span class="course-badge-course">{m.courseTitle}</span>
            <span class="course-badge-progress">
              {m.chapterIndex + 1} / {m.total}
            </span>
          </span>
        </a>
      ))}
    </aside>
  )
}

<style is:global>
  .course-badges {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin: 1rem 0 1.25rem;
  }
  .course-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: 0.4rem;
    background-color: var(--color-surface-elevated);
    color: var(--color-fg);
    text-decoration: none;
    font-size: 0.82rem;
  }
  .course-badge:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .course-badge-icon {
    flex-shrink: 0;
  }
  .course-badge-label {
    display: inline-flex;
    align-items: baseline;
    gap: 0.55rem;
    min-width: 0;
  }
  .course-badge-course {
    font-weight: 500;
  }
  .course-badge-progress {
    color: var(--color-fg-muted);
    font-size: 0.72rem;
    font-family: var(--font-mono);
  }
</style>
