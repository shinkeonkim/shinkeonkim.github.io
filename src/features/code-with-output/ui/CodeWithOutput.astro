---
import '@/styles/code-with-output.css';
import { codeToHtml } from 'shiki';

interface Variant {
  language: string;
  label?: string;
  code: string;
}

interface CaseSpec {
  label?: string;
  input?: string;
  output: string;
  inputLanguage?: string;
  inputLabel?: string;
  outputLanguage?: string;
  outputLabel?: string;
}

interface Props {
  code?: string;
  language?: string;
  label?: string;
  variants?: Variant[];
  // Single-pair mode (backwards-compat shorthand).
  input?: string;
  output?: string;
  inputLanguage?: string;
  inputLabel?: string;
  outputLanguage?: string;
  outputLabel?: string;
  // Multi-pair mode.
  cases?: CaseSpec[];
  title?: string;
  codeWidth?: number | string;
}

const props = Astro.props as Props;
const {
  code,
  language,
  label,
  variants,
  input,
  output,
  inputLanguage = 'text',
  inputLabel = 'stdin',
  outputLanguage = 'text',
  outputLabel = '결과',
  cases,
  title,
  codeWidth,
} = props;

const finalVariants: Variant[] =
  variants && variants.length > 0
    ? variants
    : code !== undefined && language !== undefined
      ? [{ language, label, code }]
      : [];

if (finalVariants.length === 0) {
  throw new Error('<CodeWithOutput> requires either `variants` or both `code` + `language`');
}

const resolvedCases: CaseSpec[] = (() => {
  if (cases && cases.length > 0) return cases;
  if (typeof output !== 'string') {
    throw new Error('<CodeWithOutput> requires `output` or a non-empty `cases` array');
  }
  return [
    {
      input,
      output,
      inputLanguage,
      inputLabel,
      outputLanguage,
      outputLabel,
    },
  ];
})();
const isMultiCase = resolvedCases.length > 1;

function parseCodeWidth(value: number | string | undefined): number | null {
  if (value === undefined || value === null) return null;
  if (typeof value === 'number') return Math.max(0, Math.min(100, value));
  const m = String(value).match(/^(\d+(?:\.\d+)?)%?$/);
  if (!m) return null;
  return Math.max(0, Math.min(100, parseFloat(m[1])));
}
const initialPct = parseCodeWidth(codeWidth) ?? 50;
const startVertical = initialPct >= 99;

async function render(text: string, lang: string): Promise<string> {
  try {
    return await codeToHtml(text, {
      lang,
      themes: { light: 'github-light', dark: 'one-dark-pro' },
    });
  } catch {
    return await codeToHtml(text, {
      lang: 'text',
      themes: { light: 'github-light', dark: 'one-dark-pro' },
    });
  }
}

const variantHtml = await Promise.all(
  finalVariants.map(async (v) => ({
    label: v.label ?? v.language,
    language: v.language,
    html: await render(v.code.trimEnd(), v.language),
  })),
);

const renderedCases = await Promise.all(
  resolvedCases.map(async (c, i) => {
    const caseInput = c.input;
    const hasInput = typeof caseInput === 'string' && caseInput.length > 0;
    return {
      label: c.label ?? (isMultiCase ? `예제 ${i + 1}` : null),
      showLabel: isMultiCase || typeof c.label === 'string',
      hasInput,
      inputLabel: c.inputLabel ?? inputLabel,
      outputLabel: c.outputLabel ?? outputLabel,
      inputHtml: hasInput ? await render(caseInput!.trimEnd(), c.inputLanguage ?? inputLanguage) : '',
      outputHtml: await render(c.output.trimEnd(), c.outputLanguage ?? outputLanguage),
    };
  }),
);

const uid = Math.random().toString(36).slice(2, 8);
---

<figure
  class="code-with-output not-prose my-6"
  data-cwo
  data-cwo-id={uid}
  data-vertical={startVertical ? 'true' : 'false'}
  data-multi-case={isMultiCase ? 'true' : 'false'}
  style={`--cwo-code-pct:${initialPct}%`}
>
  {
    title && (
      <figcaption class="mb-2 text-sm font-medium text-[color:var(--color-fg-muted)]">
        {title}
      </figcaption>
    )
  }
  <div class="cwo-panes" data-cwo-panes>
    <div class="cwo-pane cwo-pane-code">
      <div class="cwo-header">
        <span class="cwo-dot cwo-dot-input"></span>
        {
          variantHtml.length > 1 ? (
            <div class="cwo-tabs" role="tablist" aria-label="코드 언어 선택">
              {variantHtml.map((v, i) => (
                <button
                  type="button"
                  role="tab"
                  data-cwo-tab={String(i)}
                  aria-selected={i === 0 ? 'true' : 'false'}
                  class:list={['cwo-tab', i === 0 && 'is-active']}
                >
                  {v.label}
                </button>
              ))}
            </div>
          ) : (
            <span class="cwo-label">{variantHtml[0].label}</span>
          )
        }
      </div>
      <div class="cwo-body cwo-code-body">
        {
          variantHtml.map((v, i) => (
            <div
              class:list={['cwo-variant', i === 0 && 'is-active']}
              data-cwo-variant={String(i)}
              role="tabpanel"
              aria-hidden={i === 0 ? 'false' : 'true'}
              set:html={v.html}
            />
          ))
        }
      </div>
    </div>
    <button
      type="button"
      class="cwo-splitter"
      aria-label="패널 너비 조절 (화살표 키, 더블클릭으로 50% 리셋)"
      data-cwo-splitter
    >
      <span class="cwo-splitter-grip" aria-hidden="true"></span>
    </button>
    <div class="cwo-pane cwo-pane-output">
      {
        isMultiCase && (
          <div class="cwo-header cwo-case-tabs-header">
            <span class="cwo-dot cwo-dot-output" />
            <div class="cwo-tabs cwo-case-tabs" role="tablist" aria-label="테스트 케이스 선택">
              {renderedCases.map((c, i) => (
                <button
                  type="button"
                  role="tab"
                  data-cwo-case-tab={String(i)}
                  aria-selected={i === 0 ? 'true' : 'false'}
                  class:list={['cwo-tab', i === 0 && 'is-active']}
                >
                  {c.label}
                </button>
              ))}
            </div>
          </div>
        )
      }
      <div class="cwo-case-panels">
        {
          renderedCases.map((c, i) => (
            <div
              class:list={['cwo-case', i === 0 && 'is-active']}
              data-cwo-case-panel={String(i)}
              data-has-input={c.hasInput ? 'true' : 'false'}
              role="tabpanel"
              aria-hidden={i === 0 ? 'false' : 'true'}
            >
              {c.hasInput && (
                <div class="cwo-subpane cwo-subpane-stdin">
                  <div class="cwo-header">
                    <span class="cwo-dot cwo-dot-stdin" />
                    <span class="cwo-label">{c.inputLabel}</span>
                  </div>
                  <div class="cwo-body" set:html={c.inputHtml} />
                </div>
              )}
              <div class="cwo-subpane cwo-subpane-stdout">
                <div class="cwo-header">
                  <span class="cwo-dot cwo-dot-output" />
                  <span class="cwo-label">{c.outputLabel}</span>
                </div>
                <div class="cwo-body" set:html={c.outputHtml} />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</figure>
