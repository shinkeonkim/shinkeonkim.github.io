---
import { getGlossaryFor } from '@/features/glossary/lib/build-glossary';
import type { Collection } from '@/shared/lib/content/content-graph';

interface Props {
  slug: string;
  collection: Collection;
}

const { slug, collection } = Astro.props as Props;
const terms = await getGlossaryFor(collection, slug);
const MIN_TERMS = 3;
---

{terms.length >= MIN_TERMS && (
  <details class="post-glossary not-prose" data-pagefind-ignore="all">
    <summary class="post-glossary-summary">
      <span class="post-glossary-icon" aria-hidden="true">📚</span>
      <span>이 글의 용어 <span class="post-glossary-count">({terms.length}개)</span></span>
      <span class="post-glossary-chevron" aria-hidden="true">▾</span>
    </summary>
    <dl class="post-glossary-list">
      {terms.map((t) => (
        <div class="post-glossary-item">
          <dt class="post-glossary-term">
            <a href={t.url} class="post-glossary-link">{t.title}</a>
            {t.category && (
              <span class="post-glossary-badge" title={`카테고리: ${t.category}`}>
                {t.category}
              </span>
            )}
          </dt>
          {t.summary && <dd class="post-glossary-summary-text">{t.summary}</dd>}
        </div>
      ))}
    </dl>
  </details>
)}

<style is:global>
  .post-glossary {
    margin-top: 2.5rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.6rem;
    background-color: var(--color-surface-elevated);
  }
  .post-glossary[open] {
    padding-bottom: 1.1rem;
  }
  .post-glossary-summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-fg);
    list-style: none;
    user-select: none;
  }
  .post-glossary-summary::-webkit-details-marker {
    display: none;
  }
  .post-glossary-count {
    color: var(--color-fg-muted);
    font-weight: 500;
    font-size: 0.85rem;
  }
  .post-glossary-chevron {
    margin-left: auto;
    color: var(--color-fg-muted);
    transition: transform 0.15s ease;
    font-size: 0.8rem;
  }
  .post-glossary[open] .post-glossary-chevron {
    transform: rotate(180deg);
  }
  .post-glossary-list {
    margin: 0.9rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .post-glossary-item {
    padding: 0.55rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
    background-color: var(--color-surface);
  }
  .post-glossary-term {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0;
    font-weight: 500;
  }
  .post-glossary-link {
    color: var(--color-fg);
    text-decoration: none;
    border-bottom: 1px dotted var(--color-border);
  }
  .post-glossary-link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .post-glossary-badge {
    padding: 0.05rem 0.45rem;
    font-size: 0.68rem;
    font-family: var(--font-mono);
    border-radius: 999px;
    background-color: var(--color-code-bg);
    color: var(--color-fg-muted);
    text-transform: lowercase;
  }
  .post-glossary-summary-text {
    margin: 0.35rem 0 0;
    font-size: 0.82rem;
    color: var(--color-fg-muted);
    line-height: 1.5;
  }
  @media (max-width: 640px) {
    .post-glossary {
      padding: 0.75rem 0.85rem;
    }
    .post-glossary-summary {
      font-size: 0.9rem;
    }
    .post-glossary-item {
      padding: 0.5rem 0.6rem;
    }
    .post-glossary-summary-text {
      font-size: 0.78rem;
    }
  }
</style>
