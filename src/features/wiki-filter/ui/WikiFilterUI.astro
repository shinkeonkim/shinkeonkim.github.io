---
interface TagOption {
  tag: string;
  count: number;
}

interface Props {
  tags: TagOption[];
}

const { tags } = Astro.props as Props;
---
<section
  class="wiki-filter mb-4"
  data-wiki-filter-ui
  data-pagefind-ignore="all"
  aria-label="위키 필터"
>
  <label class="block">
    <span class="sr-only">위키 페이지 검색</span>
    <input
      type="search"
      data-wiki-search
      placeholder="제목, 별칭, 태그로 검색…"
      autocomplete="off"
      class="w-full rounded-md border border-border bg-surface px-3 py-2 text-sm placeholder:text-fg-muted focus:border-accent focus:outline-none"
    />
  </label>
  {tags.length > 0 && (
    <details class="mt-2 wiki-filter-tags" data-wiki-tag-panel>
      <summary class="cursor-pointer select-none text-xs text-fg-muted hover:text-accent">
        태그로 필터 ({tags.length})
        <span data-wiki-active-tag-label class="ml-1 hidden text-accent"></span>
      </summary>
      <div class="mt-2 flex flex-wrap gap-1.5" data-wiki-tag-chips>
        {tags.map(({ tag, count }) => (
          <button
            type="button"
            data-wiki-tag={tag}
            aria-pressed="false"
            class="wiki-tag-chip inline-flex items-baseline gap-1 rounded-full border border-border bg-transparent px-2.5 py-0.5 text-xs hover:border-accent hover:text-accent"
          >
            #{tag} <span class="opacity-60">{count}</span>
          </button>
        ))}
      </div>
    </details>
  )}
</section>

<style>
  .wiki-tag-chip[aria-pressed='true'] {
    border-color: var(--color-accent);
    background: var(--color-surface-elevated);
    color: var(--color-accent);
  }
</style>
