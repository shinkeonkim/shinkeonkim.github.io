---
interface Props {
  slug: string;
  collection: 'posts' | 'wiki' | 'notes';
  contentSelector?: string;
}

const {
  slug,
  collection,
  contentSelector = '.prose-content',
} = Astro.props as Props;
---

<details
  class="tts-controls not-prose"
  data-tts-controls
  data-tts-slug={slug}
  data-tts-collection={collection}
  data-tts-content-selector={contentSelector}
  aria-label="낭독 컨트롤"
>
  <summary class="tts-summary">
    <span class="tts-summary-icon" aria-hidden="true">🎧</span>
    <span>낭독 (Web Speech)</span>
    <span class="tts-summary-status" data-tts-status>준비 안 됨</span>
  </summary>
  <div class="tts-body" data-tts-body>
    <div class="tts-toolbar">
      <button
        type="button"
        class="tts-btn tts-btn-primary"
        data-tts-play
        aria-label="재생"
        disabled
      >
        <span class="tts-btn-icon" aria-hidden="true">▶</span>
        <span data-tts-play-label>재생</span>
      </button>
      <button
        type="button"
        class="tts-btn"
        data-tts-stop
        aria-label="정지"
        disabled
      >
        <span aria-hidden="true">■</span>
        정지
      </button>
      <label class="tts-select-label">
        속도
        <select data-tts-rate class="tts-select">
          <option value="0.75">0.75x</option>
          <option value="1.0" selected>1.0x</option>
          <option value="1.25">1.25x</option>
          <option value="1.5">1.5x</option>
          <option value="1.75">1.75x</option>
          <option value="2.0">2.0x</option>
        </select>
      </label>
      <label class="tts-select-label">
        음성
        <select data-tts-voice class="tts-select">
          <option value="">불러오는 중…</option>
        </select>
      </label>
    </div>
    <p class="tts-hint" data-tts-hint>
      브라우저 음성 목록을 불러오려면 아무 버튼이든 눌러주세요. Safari/Firefox 는 한국어 음성이 없을 수 있습니다.
    </p>
  </div>
</details>

<style is:global>
  .tts-controls {
    margin: 1rem 0 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background-color: var(--color-surface-elevated);
    font-size: 0.85rem;
  }
  .tts-summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.85rem;
    cursor: pointer;
    color: var(--color-fg);
    list-style: none;
    user-select: none;
  }
  .tts-summary::-webkit-details-marker {
    display: none;
  }
  .tts-summary-status {
    margin-left: auto;
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--color-fg-muted);
  }
  .tts-controls[open] .tts-summary {
    border-bottom: 1px dashed var(--color-border);
  }
  .tts-body {
    padding: 0.7rem 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .tts-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }
  .tts-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.35rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 0.35rem;
    background: var(--color-surface);
    color: var(--color-fg);
    font-size: 0.82rem;
    cursor: pointer;
    font-family: inherit;
  }
  .tts-btn:not(:disabled):hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .tts-btn:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }
  .tts-btn-primary {
    background: var(--color-accent);
    color: #ffffff;
    border-color: var(--color-accent);
  }
  .tts-btn-primary:not(:disabled):hover {
    background: color-mix(in srgb, var(--color-accent) 85%, black);
    color: #ffffff;
  }
  .tts-select-label {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    color: var(--color-fg-muted);
  }
  .tts-select {
    padding: 0.25rem 0.4rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-fg);
    border-radius: 0.3rem;
    font-size: 0.8rem;
    font-family: inherit;
  }
  .tts-hint {
    margin: 0;
    font-size: 0.72rem;
    color: var(--color-fg-muted);
    line-height: 1.4;
  }
  .tts-active {
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    outline: 2px solid color-mix(in srgb, var(--color-accent) 40%, transparent);
    outline-offset: 3px;
    border-radius: 0.2rem;
    transition: background-color 0.2s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    .tts-active {
      transition: none;
    }
  }
</style>

<script>
  import { setupTtsControls } from '@/features/tts/lib/setup-controls';

  if (document.readyState !== 'loading') setupTtsControls();
  else document.addEventListener('DOMContentLoaded', setupTtsControls);
  document.addEventListener('astro:page-load', setupTtsControls);
</script>
