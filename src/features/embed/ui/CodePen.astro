---
interface Props {
  id: string;
  user: string;
  title?: string;
  tab?: 'html' | 'css' | 'js' | 'result';
  height?: number;
  theme?: 'dark' | 'light';
}

const { id, user, title = 'CodePen embed', tab = 'result', height = 360, theme } = Astro.props as Props;
const themeSlug = theme ?? 'default';
const src = `https://codepen.io/${encodeURIComponent(user)}/embed/${encodeURIComponent(id)}?default-tab=${tab}&theme-id=${themeSlug}`;
const fallback = `https://codepen.io/${encodeURIComponent(user)}/pen/${encodeURIComponent(id)}`;
---
<div class="codepen-embed" style={`--cp-h:${height}px`}>
  <iframe
    src={src}
    title={title}
    loading="lazy"
    allowtransparency
    allowfullscreen
  ></iframe>
  <noscript>
    <a href={fallback} rel="noopener" target="_blank">CodePen 열기 ↗</a>
  </noscript>
</div>

<style is:global>
  .codepen-embed {
    margin: 1.25rem 0;
    border: 1px solid var(--color-border);
    border-radius: 0.55rem;
    overflow: hidden;
    background-color: var(--color-code-bg);
  }
  .codepen-embed iframe {
    width: 100%;
    height: var(--cp-h, 360px);
    display: block;
    border: 0;
  }
</style>
