---
interface Props {
  embedUrl?: string;
  fileUrl?: string;
  title?: string;
  height?: number;
}

const { embedUrl, fileUrl, title = 'Figma embed', height = 450 } = Astro.props as Props;

function buildSrc(): string | null {
  if (embedUrl) return embedUrl;
  if (fileUrl) {
    return `https://www.figma.com/embed?embed_host=astro&url=${encodeURIComponent(fileUrl)}`;
  }
  return null;
}

const src = buildSrc();
---
{src ? (
  <div class="figma-embed" style={`--figma-h:${height}px`}>
    <iframe
      src={src}
      title={title}
      loading="lazy"
      allowfullscreen
    ></iframe>
  </div>
) : (
  <p class="figma-embed-fallback">Figma embed: 'fileUrl' 또는 'embedUrl' 이 필요합니다.</p>
)}

<style is:global>
  .figma-embed {
    margin: 1.25rem 0;
    border: 1px solid var(--color-border);
    border-radius: 0.55rem;
    overflow: hidden;
    background-color: var(--color-code-bg);
  }
  .figma-embed iframe {
    width: 100%;
    height: var(--figma-h, 450px);
    display: block;
    border: 0;
  }
  .figma-embed-fallback {
    margin: 1.25rem 0;
    padding: 0.75rem 1rem;
    border: 1px dashed var(--color-border);
    border-radius: 0.55rem;
    color: var(--color-fg-muted);
    font-size: 0.85rem;
  }
</style>
