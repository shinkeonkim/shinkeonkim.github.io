---
interface Props {
  id: string;
  user?: string;
  file?: string;
}

const { id, user, file } = Astro.props as Props;
const path = user ? `${user}/${id}` : id;
const src = `https://gist.github.com/${path}.js${file ? `?file=${encodeURIComponent(file)}` : ''}`;
---
<div class="gist-embed" data-gist-src={src}>
  <noscript>
    <a href={`https://gist.github.com/${path}`} rel="noopener" target="_blank">GitHub Gist 보기 ↗</a>
  </noscript>
</div>

<script>
  function initGists() {
    document.querySelectorAll<HTMLElement>('.gist-embed').forEach((el) => {
      if (el.dataset.loaded === 'true') return;
      const src = el.dataset.gistSrc;
      if (!src) return;
      const s = document.createElement('script');
      s.src = src;
      s.async = true;
      el.appendChild(s);
      el.dataset.loaded = 'true';
    });
  }
  initGists();
  document.addEventListener('astro:page-load', initGists);
</script>

<style is:global>
  .gist-embed {
    margin: 1.25rem 0;
    border-radius: 0.55rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-surface);
    padding: 0.4rem;
    overflow-x: auto;
  }
  .gist-embed .gist {
    margin: 0 !important;
  }
</style>
