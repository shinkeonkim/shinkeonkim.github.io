---
import '@/features/mermaid/styles/mermaid.css';
---

<dialog id="mermaid-zoom" class="mermaid-zoom" aria-label="다이어그램 확대 보기">
  <div class="mermaid-zoom-toolbar">
    <span class="mermaid-zoom-hint"
      >스크롤 = 확대/축소 · 드래그 = 이동 · 0 = 원래 크기 · ESC = 닫기</span
    >
    <button type="button" data-zoom-export-svg class="mermaid-zoom-action" aria-label="SVG 다운로드">⤓ SVG</button>
    <button type="button" data-zoom-export-png class="mermaid-zoom-action" aria-label="PNG 다운로드">⤓ PNG</button>
    <button type="button" data-zoom-close aria-label="닫기" class="mermaid-zoom-close">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="6" y1="6" x2="18" y2="18"></line>
        <line x1="6" y1="18" x2="18" y2="6"></line>
      </svg>
    </button>
  </div>
  <div class="mermaid-zoom-viewport">
    <div class="mermaid-zoom-content"></div>
  </div>
</dialog>

<script>
  import { setupMermaid } from '@/features/mermaid/lib/setup-mermaid';
  setupMermaid();
</script>
