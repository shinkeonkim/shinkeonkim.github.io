---
interface CategoryOption {
  cat: string;
  count: number;
  label: string;
}

interface TagOption {
  tag: string;
  count: number;
}

interface Props {
  totalCount: number;
  categories: CategoryOption[];
  tags: TagOption[];
}

const { totalCount, categories, tags } = Astro.props as Props;
---
<section
  class="anim-filter mb-6"
  data-anim-filter-ui
  data-pagefind-ignore="all"
  aria-label="애니메이션 필터"
>
  <label class="block">
    <span class="sr-only">애니메이션 검색</span>
    <input
      type="search"
      data-anim-search
      placeholder="제목, 설명, ID, 태그로 검색…"
      autocomplete="off"
      class="w-full rounded-md border border-border bg-surface px-3 py-2 text-sm placeholder:text-fg-muted focus:border-accent focus:outline-none"
    />
  </label>

  <div class="mt-3 flex flex-wrap gap-1.5" data-anim-category-chips>
    <button
      type="button"
      data-anim-category=""
      aria-pressed="true"
      class="anim-cat-chip inline-flex items-baseline gap-1 rounded-full border border-accent bg-surface-elevated px-2.5 py-0.5 text-xs text-accent"
    >
      전체 <span class="opacity-70">({totalCount})</span>
    </button>
    {categories.map(({ cat, count, label }) => (
      <button
        type="button"
        data-anim-category={cat}
        aria-pressed="false"
        class="anim-cat-chip inline-flex items-baseline gap-1 rounded-full border border-border bg-transparent px-2.5 py-0.5 text-xs hover:border-accent hover:text-accent"
      >
        {label} <span class="opacity-60">({count})</span>
      </button>
    ))}
  </div>

  {tags.length > 0 && (
    <details class="mt-3 anim-tag-panel" data-anim-tag-panel>
      <summary class="cursor-pointer select-none text-xs text-fg-muted hover:text-accent">
        태그로 필터 ({tags.length})
        <span data-anim-active-tag-label class="ml-1 hidden text-accent"></span>
      </summary>
      <div class="mt-2 flex flex-wrap gap-1.5" data-anim-tag-chips>
        {tags.slice(0, 60).map(({ tag, count }) => (
          <button
            type="button"
            data-anim-tag={tag}
            aria-pressed="false"
            class="anim-tag-chip inline-flex items-baseline gap-1 rounded-full border border-border bg-transparent px-2.5 py-0.5 text-xs hover:border-accent hover:text-accent"
          >
            #{tag} <span class="opacity-60">({count})</span>
          </button>
        ))}
      </div>
    </details>
  )}
</section>

<style>
  .anim-cat-chip[aria-pressed='true'] {
    border-color: var(--color-accent);
    background: var(--color-surface-elevated);
    color: var(--color-accent);
  }
  .anim-tag-chip[aria-pressed='true'] {
    border-color: var(--color-accent);
    background: var(--color-surface-elevated);
    color: var(--color-accent);
  }
</style>
