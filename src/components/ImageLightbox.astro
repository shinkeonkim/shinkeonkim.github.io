---
---

<dialog id="image-lightbox" class="image-lightbox" aria-label="이미지 확대 보기">
  <button type="button" data-lightbox-close class="image-lightbox-close" aria-label="닫기">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <line x1="6" y1="6" x2="18" y2="18"></line>
      <line x1="6" y1="18" x2="18" y2="6"></line>
    </svg>
  </button>
  <div class="image-lightbox-content">
    <img alt="" />
    <figcaption class="image-lightbox-caption"></figcaption>
  </div>
</dialog>

<style is:global>
  .post-article img:not([data-no-zoom]) {
    cursor: zoom-in;
    transition: transform 120ms ease-out;
  }
  .image-lightbox {
    width: 96vw;
    height: 92vh;
    max-width: 1800px;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background-color: var(--color-surface);
    color: var(--color-fg);
    overflow: hidden;
    position: relative;
  }
  .image-lightbox::backdrop {
    background-color: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(4px);
  }
  .image-lightbox-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.25rem;
    width: 2.25rem;
    border-radius: 0.375rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-surface);
    color: var(--color-fg);
    cursor: pointer;
  }
  .image-lightbox-close:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .image-lightbox-content {
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    gap: 0.75rem;
  }
  .image-lightbox-content img {
    max-width: 100%;
    max-height: calc(100% - 3rem);
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 0.25rem;
  }
  .image-lightbox-caption {
    font-size: 0.85rem;
    color: var(--color-fg-muted);
    text-align: center;
    max-width: 80ch;
  }
  .image-lightbox-caption:empty {
    display: none;
  }
</style>

<script is:inline>
  (function () {
    if (window.__imageLightboxBound) return;
    window.__imageLightboxBound = true;

    function dialog() {
      return document.getElementById('image-lightbox');
    }

    function openLightbox(imgEl) {
      const d = dialog();
      if (!d) return;
      const target = d.querySelector('img');
      const caption = d.querySelector('.image-lightbox-caption');
      if (!target) return;
      target.src = imgEl.currentSrc || imgEl.src;
      target.alt = imgEl.alt || '';
      const altText = imgEl.alt && imgEl.alt.trim();
      if (caption) caption.textContent = altText || '';
      if (typeof d.showModal === 'function') d.showModal();
      else d.setAttribute('open', '');
    }

    function closeLightbox() {
      const d = dialog();
      if (!d) return;
      if (typeof d.close === 'function') d.close();
      else d.removeAttribute('open');
      const target = d.querySelector('img');
      if (target) target.src = '';
    }

    function isZoomable(img) {
      if (img.hasAttribute('data-no-zoom')) return false;
      if (!img.closest('.post-article')) return false;
      if (img.closest('a')) return false;
      if (img.closest('.mermaid')) return false;
      const w = img.naturalWidth;
      if (w > 0 && w < 200) return false;
      return true;
    }

    document.addEventListener('click', function (e) {
      if (e.target.closest('[data-lightbox-close]')) {
        closeLightbox();
        return;
      }
      const d = dialog();
      if (d && d.open && e.target === d) {
        closeLightbox();
        return;
      }
      const img = e.target.closest('.post-article img');
      if (img && isZoomable(img)) {
        e.preventDefault();
        openLightbox(img);
      }
    });

    document.addEventListener('astro:before-swap', closeLightbox);
  })();
</script>
