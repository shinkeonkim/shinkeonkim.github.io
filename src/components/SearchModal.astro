---
import PagefindConfig from 'astro-pagefind/components/PagefindConfig.astro';
---
<dialog
  id="search-modal"
  class="search-modal"
  aria-labelledby="search-modal-title"
  data-pagefind-ignore="all"
>
  <header class="search-modal-header">
    <h2 id="search-modal-title" class="sr-only">사이트 검색</h2>
    <input
      type="search"
      id="search-modal-input"
      placeholder="검색 (ESC 로 닫기)"
      autocomplete="off"
      aria-label="글, 한줄 노트, 위키에서 검색"
      aria-describedby="search-modal-stats"
      class="search-modal-input"
    />
    <button
      type="button"
      data-search-modal-close
      class="search-modal-close"
      aria-label="검색 닫기"
    >✕</button>
  </header>
  <p id="search-modal-stats" class="search-modal-stats" aria-live="polite"></p>
  <div
    id="search-modal-results"
    class="search-modal-results"
    role="region"
    aria-label="검색 결과"
  ></div>
  <footer class="search-modal-footer">
    <span><kbd>↑</kbd><kbd>↓</kbd> 이동</span>
    <span><kbd>Enter</kbd> 열기</span>
    <span><kbd>Esc</kbd> 닫기</span>
    <a href="/search/" class="search-modal-fullpage">전체 페이지에서 보기 →</a>
  </footer>
</dialog>

<PagefindConfig />

<script is:inline>
  (function () {
    if (window.__searchModalBound) return;
    window.__searchModalBound = true;

    const SECTION_LABELS = { posts: '글', notes: '한줄 노트', wiki: '위키' };
    let pagefindModule = null;
    let pagefindReady = false;
    let searchToken = 0;
    let selectedIndex = -1;
    let resultUrls = [];

    function escapeHtml(s) {
      return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    async function loadPagefind() {
      if (pagefindReady) return pagefindModule;
      try {
        pagefindModule = await import('/pagefind/pagefind.js');
        await pagefindModule.options({});
        await pagefindModule.init();
        pagefindReady = true;
        return pagefindModule;
      } catch (e) {
        console.error('Pagefind load failed:', e);
        return null;
      }
    }

    function openModal() {
      const dialog = document.getElementById('search-modal');
      if (!dialog) return;
      if (typeof dialog.showModal === 'function' && !dialog.open) {
        dialog.showModal();
      }
      const input = document.getElementById('search-modal-input');
      if (input) setTimeout(() => input.focus(), 30);
      if (window.gtag) window.gtag('event', 'search_open');
    }

    function closeModal() {
      const dialog = document.getElementById('search-modal');
      if (dialog && dialog.open) dialog.close();
    }

    function renderResults(hits, query) {
      const container = document.getElementById('search-modal-results');
      if (!container) return;
      resultUrls = hits.map((h) => h.url);
      if (!hits.length) {
        container.innerHTML = `<p class="search-modal-empty">"${escapeHtml(query)}" 에 대한 결과가 없습니다.</p>`;
        return;
      }
      container.innerHTML = hits
        .map((h, i) => {
          const section =
            h.filters && h.filters.section
              ? Array.isArray(h.filters.section)
                ? h.filters.section[0]
                : h.filters.section
              : '';
          const label = SECTION_LABELS[section] || '';
          const title = escapeHtml(h.meta && h.meta.title ? h.meta.title : h.url);
          const excerpt = h.excerpt || '';
          return `
            <a href="${escapeHtml(h.url)}" class="search-modal-hit" data-index="${i}">
              ${label ? `<span class="search-modal-hit-badge">${label}</span>` : ''}
              <span class="search-modal-hit-body">
                <span class="search-modal-hit-title">${title}</span>
                <span class="search-modal-hit-excerpt">${excerpt}</span>
              </span>
            </a>
          `;
        })
        .join('');
      selectedIndex = -1;
      updateSelection();
    }

    function updateSelection() {
      const hits = document.querySelectorAll('.search-modal-hit');
      hits.forEach((el, i) => {
        if (i === selectedIndex) {
          el.classList.add('is-selected');
          el.scrollIntoView({ block: 'nearest' });
        } else {
          el.classList.remove('is-selected');
        }
      });
    }

    async function doSearch(query) {
      const trimmed = query.trim();
      const token = ++searchToken;
      const stats = document.getElementById('search-modal-stats');
      const container = document.getElementById('search-modal-results');
      if (!stats || !container) return;
      if (!trimmed) {
        stats.textContent = '';
        container.innerHTML = '';
        resultUrls = [];
        selectedIndex = -1;
        return;
      }
      stats.textContent = '검색 중…';
      const pf = await loadPagefind();
      if (!pf || token !== searchToken) return;
      const start = performance.now();
      const result = await pf.search(trimmed);
      if (token !== searchToken) return;
      const elapsed = (performance.now() - start).toFixed(0);
      if (!result || result.results.length === 0) {
        stats.textContent = `결과 없음 (${elapsed}ms)`;
        renderResults([], trimmed);
        return;
      }
      stats.textContent = `${result.results.length}개 결과 (${elapsed}ms)`;
      const hits = await Promise.all(result.results.slice(0, 12).map((r) => r.data()));
      if (token !== searchToken) return;
      renderResults(hits, trimmed);
      if (window.gtag) {
        window.gtag('event', 'search', {
          search_term: trimmed,
          result_count: result.results.length,
        });
      }
    }

    document.addEventListener('keydown', (e) => {
      const target = e.target;
      const inEditable =
        target instanceof HTMLElement &&
        (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA' || target.isContentEditable);

      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        openModal();
        return;
      }
      if (e.key === '/' && !inEditable) {
        e.preventDefault();
        openModal();
        return;
      }

      const dialog = document.getElementById('search-modal');
      if (!dialog || !dialog.open) return;

      if (e.key === 'Escape') {
        closeModal();
        return;
      }
      if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
        if (resultUrls.length === 0) return;
        e.preventDefault();
        const delta = e.key === 'ArrowDown' ? 1 : -1;
        selectedIndex = (selectedIndex + delta + resultUrls.length) % resultUrls.length;
        updateSelection();
        return;
      }
      if (e.key === 'Enter' && selectedIndex >= 0 && resultUrls[selectedIndex]) {
        e.preventDefault();
        window.location.href = resultUrls[selectedIndex];
      }
    });

    document.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof HTMLElement)) return;
      if (target.closest('[data-search-modal-open]')) {
        e.preventDefault();
        openModal();
        return;
      }
      if (target.closest('[data-search-modal-close]')) {
        e.preventDefault();
        closeModal();
        return;
      }
      const dialog = document.getElementById('search-modal');
      if (dialog && dialog.open && target === dialog) {
        closeModal();
      }
    });

    document.addEventListener('input', (e) => {
      const target = e.target;
      if (target instanceof HTMLInputElement && target.id === 'search-modal-input') {
        doSearch(target.value);
      }
    });
  })();
</script>

<style is:global>
  .search-modal {
    width: min(640px, 92vw);
    max-width: none;
    max-height: 80vh;
    padding: 0;
    margin: 6rem auto;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background-color: var(--color-surface);
    color: var(--color-fg);
    display: none;
    flex-direction: column;
    overflow: hidden;
  }
  .search-modal[open] {
    display: flex;
  }
  .search-modal::backdrop {
    background-color: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(3px);
  }
  .search-modal-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--color-border);
  }
  .search-modal-input {
    flex: 1;
    border: 0;
    background: transparent;
    color: var(--color-fg);
    font-size: 1rem;
    outline: none;
  }
  .search-modal-close {
    flex-shrink: 0;
    width: 1.85rem;
    height: 1.85rem;
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
    background-color: var(--color-surface-elevated);
    color: var(--color-fg-muted);
    cursor: pointer;
  }
  .search-modal-close:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
  .search-modal-stats {
    margin: 0;
    padding: 0.45rem 0.95rem 0;
    font-size: 0.72rem;
    color: var(--color-fg-muted);
  }
  .search-modal-results {
    flex: 1;
    overflow-y: auto;
    padding: 0.4rem 0.55rem 0.7rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .search-modal-hit {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    padding: 0.45rem 0.6rem;
    border-radius: 0.4rem;
    border: 1px solid transparent;
    color: var(--color-fg);
    text-decoration: none;
  }
  .search-modal-hit:hover,
  .search-modal-hit.is-selected {
    background-color: var(--color-surface-elevated);
    border-color: var(--color-accent);
  }
  .search-modal-hit-badge {
    flex-shrink: 0;
    padding: 0.05rem 0.45rem;
    font-size: 0.65rem;
    font-family: var(--font-mono);
    border-radius: 999px;
    background-color: var(--color-code-bg);
    color: var(--color-fg-muted);
    margin-top: 0.15rem;
  }
  .search-modal-hit-body {
    display: flex;
    flex-direction: column;
    min-width: 0;
    flex: 1;
  }
  .search-modal-hit-title {
    font-weight: 500;
    font-size: 0.92rem;
  }
  .search-modal-hit-excerpt {
    font-size: 0.78rem;
    color: var(--color-fg-muted);
    margin-top: 0.1rem;
    line-height: 1.5;
  }
  .search-modal-hit-excerpt mark {
    background-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    color: var(--color-fg);
    padding: 0 0.1rem;
    border-radius: 0.15rem;
  }
  .search-modal-empty {
    padding: 1rem;
    color: var(--color-fg-muted);
    font-size: 0.85rem;
  }
  .search-modal-footer {
    border-top: 1px solid var(--color-border);
    padding: 0.45rem 0.85rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.7rem;
    color: var(--color-fg-muted);
  }
  .search-modal-footer kbd {
    display: inline-block;
    padding: 0.05rem 0.3rem;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    background-color: var(--color-surface-elevated);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    margin-right: 0.15rem;
  }
  .search-modal-fullpage {
    margin-left: auto;
    color: var(--color-accent);
    text-decoration: none;
  }
  .search-modal-fullpage:hover {
    text-decoration: underline;
  }
  @media (max-width: 600px) {
    .search-modal {
      width: 100vw;
      max-height: 100vh;
      margin: 0;
      border-radius: 0;
      height: 100vh;
    }
  }
</style>
