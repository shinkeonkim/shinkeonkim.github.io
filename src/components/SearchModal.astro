---
import PagefindConfig from 'astro-pagefind/components/PagefindConfig.astro';
import { getPublishedNotes, getPublishedPosts, getPublishedWiki } from '../lib/content-queries';

const [posts, notes, wiki] = await Promise.all([
  getPublishedPosts(),
  getPublishedNotes(),
  getPublishedWiki(),
]);

const tagCounts = new Map<string, number>();
for (const p of posts) for (const t of p.data.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
for (const w of wiki) for (const t of w.data.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
for (const n of notes) for (const t of n.data.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);

const tagList = Array.from(tagCounts.entries())
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([name, count]) => ({ name, count }));

interface CommandEntry {
  id: string;
  label: string;
  hint?: string;
  href?: string;
  action?: 'toggle-theme' | 'copy-url' | 'print' | 'top' | 'rss';
  keywords?: string[];
  shortcut?: string;
}

const commandList: CommandEntry[] = [
  { id: 'go-home', label: '홈', href: '/', keywords: ['home', 'index', '메인'] },
  { id: 'go-posts', label: '글 (목록)', href: '/posts/', keywords: ['blog', 'posts'] },
  { id: 'go-notes', label: '한줄 노트', href: '/notes/', keywords: ['notes', '메모'] },
  { id: 'go-wiki', label: '위키', href: '/wiki/', keywords: ['wiki'] },
  { id: 'go-projects', label: '프로젝트', href: '/projects/', keywords: ['projects', 'portfolio'] },
  { id: 'go-tags', label: '태그', href: '/tags/', keywords: ['tags'] },
  { id: 'go-graph', label: '그래프', href: '/graph/', keywords: ['graph', 'network'] },
  { id: 'go-sources', label: '출처 / 인용', href: '/sources/', keywords: ['sources', 'bibliography', 'citation'] },
  { id: 'go-about', label: '소개', href: '/about/', keywords: ['about', 'profile'] },
  { id: 'toggle-theme', label: '테마 전환 (다크/라이트)', action: 'toggle-theme', keywords: ['theme', 'dark', 'light', 'mode'] },
  { id: 'copy-url', label: '현재 페이지 URL 복사', action: 'copy-url', keywords: ['copy', 'link', 'url'] },
  { id: 'scroll-top', label: '맨 위로', action: 'top', keywords: ['top', 'scroll'], shortcut: 'g g' },
  { id: 'rss', label: 'RSS 피드 보기', action: 'rss', keywords: ['rss', 'feed', '구독'] },
  { id: 'print', label: '현재 페이지 인쇄', action: 'print', keywords: ['print', '인쇄'] },
];
---

<dialog
  id="search-modal"
  class="search-modal"
  aria-labelledby="search-modal-title"
  data-pagefind-ignore="all"
>
  <header class="search-modal-header">
    <h2 id="search-modal-title" class="sr-only">사이트 검색 / 명령어</h2>
    <span id="search-modal-mode-badge" class="search-modal-mode" data-mode="search">검색</span>
    <input
      type="search"
      id="search-modal-input"
      placeholder="검색  ·  > 명령  ·  # 태그  ·  ? 도움말"
      autocomplete="off"
      aria-label="검색, 명령어, 태그, 도움말 (prefix 로 모드 전환)"
      aria-describedby="search-modal-stats"
      class="search-modal-input"
    />
    <button
      type="button"
      data-search-modal-close
      class="search-modal-close"
      aria-label="검색 닫기"
    >✕</button>
  </header>
  <p id="search-modal-stats" class="search-modal-stats" aria-live="polite"></p>
  <div
    id="search-modal-results"
    class="search-modal-results"
    role="region"
    aria-label="검색 결과"
  ></div>
  <footer class="search-modal-footer">
    <span><kbd>↑</kbd><kbd>↓</kbd> 이동</span>
    <span><kbd>Enter</kbd> 실행</span>
    <span><kbd>Esc</kbd> 닫기</span>
    <span class="search-modal-prefix-hint"><kbd>&gt;</kbd> 명령 · <kbd>#</kbd> 태그 · <kbd>?</kbd> 도움말</span>
  </footer>
</dialog>

<PagefindConfig />

<script is:inline define:vars={{ tagList, commandList }}>
  (function () {
    if (window.__searchModalBound) return;
    window.__searchModalBound = true;

    const SECTION_LABELS = { posts: '글', notes: '한줄 노트', wiki: '위키' };
    const MODE_LABELS = { search: '검색', command: '명령', tag: '태그', help: '도움말' };

    const HELP_ITEMS = [
      { keys: ['⌘+K', '/'], desc: '검색 / 명령 팔레트 열기' },
      { keys: ['Esc'], desc: '모달 닫기' },
      { keys: ['↑', '↓'], desc: '결과 이동' },
      { keys: ['Enter'], desc: '선택 실행' },
      { keys: ['>'], desc: '명령 팔레트 모드' },
      { keys: ['#'], desc: '태그 점프 모드' },
      { keys: ['?'], desc: '이 도움말' },
      { keys: ['⌘+S'], desc: '저장 (에디터 안에서)' },
      { keys: ['⌘+B', '⌘+I', '⌘+K'], desc: '굵게 / 기울임 / 링크 (에디터 안에서)' },
    ];

    let pagefindModule = null;
    let pagefindReady = false;
    let searchToken = 0;
    let selectedIndex = -1;
    let currentItems = [];
    let _currentMode = 'search';

    function escapeHtml(s) {
      return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    async function loadPagefind() {
      if (pagefindReady) return pagefindModule;
      try {
        pagefindModule = await import('/pagefind/pagefind.js');
        await pagefindModule.options({});
        await pagefindModule.init();
        pagefindReady = true;
        return pagefindModule;
      } catch (e) {
        console.error('Pagefind load failed:', e);
        return null;
      }
    }

    function detectMode(raw) {
      if (!raw) return { mode: 'search', query: '' };
      const first = raw[0];
      if (first === '>') return { mode: 'command', query: raw.slice(1).trimStart() };
      if (first === '#') return { mode: 'tag', query: raw.slice(1).trimStart() };
      if (first === '?') return { mode: 'help', query: raw.slice(1).trimStart() };
      return { mode: 'search', query: raw };
    }

    function setModeBadge(mode) {
      const badge = document.getElementById('search-modal-mode-badge');
      if (!badge) return;
      badge.textContent = MODE_LABELS[mode] || '검색';
      badge.dataset.mode = mode;
    }

    function fuzzy(haystack, needle) {
      const hay = haystack.toLowerCase();
      const need = needle.toLowerCase();
      if (!need) return true;
      let i = 0;
      for (const ch of need) {
        const idx = hay.indexOf(ch, i);
        if (idx === -1) return false;
        i = idx + 1;
      }
      return true;
    }

    function openModal(prefill) {
      const dialog = document.getElementById('search-modal');
      if (!dialog) return;
      if (typeof dialog.showModal === 'function' && !dialog.open) {
        dialog.showModal();
      }
      const input = document.getElementById('search-modal-input');
      if (input) {
        if (typeof prefill === 'string' && prefill) {
          input.value = prefill;
          dispatch(prefill);
        } else {
          dispatch(input.value);
        }
        setTimeout(() => input.focus(), 30);
      }
      if (window.gtag) window.gtag('event', 'search_open');
    }

    function closeModal() {
      const dialog = document.getElementById('search-modal');
      if (dialog && dialog.open) dialog.close();
    }

    function renderHelp(query) {
      const container = document.getElementById('search-modal-results');
      const stats = document.getElementById('search-modal-stats');
      if (!container || !stats) return;
      const q = (query || '').toLowerCase();
      const items = HELP_ITEMS.filter(
        (h) => !q || h.desc.toLowerCase().includes(q) || h.keys.join(' ').toLowerCase().includes(q),
      );
      currentItems = items.map(() => ({ kind: 'help' }));
      stats.textContent = `${items.length}개 단축키`;
      container.innerHTML = items
        .map(
          (h, i) => `
          <div class="search-modal-hit search-modal-help" data-index="${i}">
            <span class="search-modal-hit-body">
              <span class="search-modal-hit-title">${escapeHtml(h.desc)}</span>
              <span class="search-modal-hit-excerpt">
                ${h.keys.map((k) => `<kbd>${escapeHtml(k)}</kbd>`).join(' ')}
              </span>
            </span>
          </div>
        `,
        )
        .join('') || '<p class="search-modal-empty">일치하는 단축키 없음</p>';
      selectedIndex = items.length > 0 ? 0 : -1;
      updateSelection();
    }

    function renderCommands(query) {
      const container = document.getElementById('search-modal-results');
      const stats = document.getElementById('search-modal-stats');
      if (!container || !stats) return;
      const q = (query || '').toLowerCase();
      const filtered = commandList.filter((c) => {
        if (!q) return true;
        const hay = [c.label, c.hint, ...(c.keywords || [])].filter(Boolean).join(' ').toLowerCase();
        return fuzzy(hay, q);
      });
      currentItems = filtered.map((c) => ({ kind: 'command', ref: c }));
      stats.textContent = `${filtered.length}개 명령`;
      container.innerHTML = filtered.length === 0
        ? '<p class="search-modal-empty">일치하는 명령 없음</p>'
        : filtered
            .map(
              (c, i) => `
              <div class="search-modal-hit" data-index="${i}">
                <span class="search-modal-hit-badge">명령</span>
                <span class="search-modal-hit-body">
                  <span class="search-modal-hit-title">${escapeHtml(c.label)}</span>
                  ${
                    c.href || c.shortcut
                      ? `<span class="search-modal-hit-excerpt">
                          ${c.href ? `<code>${escapeHtml(c.href)}</code>` : ''}
                          ${c.shortcut ? `<kbd>${escapeHtml(c.shortcut)}</kbd>` : ''}
                        </span>`
                      : ''
                  }
                </span>
              </div>
            `,
            )
            .join('');
      selectedIndex = filtered.length > 0 ? 0 : -1;
      updateSelection();
    }

    function renderTags(query) {
      const container = document.getElementById('search-modal-results');
      const stats = document.getElementById('search-modal-stats');
      if (!container || !stats) return;
      const q = (query || '').toLowerCase();
      const filtered = tagList.filter((t) => !q || fuzzy(t.name.toLowerCase(), q));
      const top = filtered.slice(0, 30);
      currentItems = top.map((t) => ({
        kind: 'tag',
        href: `/tags/${encodeURIComponent(t.name.toLowerCase())}/`,
      }));
      stats.textContent = `${filtered.length}개 태그`;
      container.innerHTML = top.length === 0
        ? '<p class="search-modal-empty">일치하는 태그 없음</p>'
        : top
            .map(
              (t, i) => `
              <a href="/tags/${encodeURIComponent(t.name.toLowerCase())}/" class="search-modal-hit" data-index="${i}">
                <span class="search-modal-hit-badge">#${escapeHtml(t.name)}</span>
                <span class="search-modal-hit-body">
                  <span class="search-modal-hit-title">${escapeHtml(t.name)} (${t.count})</span>
                </span>
              </a>
            `,
            )
            .join('');
      selectedIndex = top.length > 0 ? 0 : -1;
      updateSelection();
    }

    async function doSearch(query) {
      const trimmed = (query || '').trim();
      const token = ++searchToken;
      const stats = document.getElementById('search-modal-stats');
      const container = document.getElementById('search-modal-results');
      if (!stats || !container) return;
      if (!trimmed) {
        stats.textContent = '';
        container.innerHTML = '';
        currentItems = [];
        selectedIndex = -1;
        return;
      }
      stats.textContent = '검색 중…';
      const pf = await loadPagefind();
      if (!pf || token !== searchToken) return;
      const start = performance.now();
      const result = await pf.search(trimmed);
      if (token !== searchToken) return;
      const elapsed = (performance.now() - start).toFixed(0);
      if (!result || result.results.length === 0) {
        stats.textContent = `결과 없음 (${elapsed}ms)`;
        container.innerHTML = `<p class="search-modal-empty">"${escapeHtml(trimmed)}" 에 대한 결과 없음</p>`;
        currentItems = [];
        selectedIndex = -1;
        return;
      }
      stats.textContent = `${result.results.length}개 결과 (${elapsed}ms)`;
      const hits = await Promise.all(result.results.slice(0, 12).map((r) => r.data()));
      if (token !== searchToken) return;
      currentItems = hits.map((h) => ({ kind: 'search', href: h.url }));
      container.innerHTML = hits
        .map((h, i) => {
          const section =
            h.filters && h.filters.section
              ? Array.isArray(h.filters.section)
                ? h.filters.section[0]
                : h.filters.section
              : '';
          const label = SECTION_LABELS[section] || '';
          const title = escapeHtml(h.meta && h.meta.title ? h.meta.title : h.url);
          const excerpt = h.excerpt || '';
          return `
            <a href="${escapeHtml(h.url)}" class="search-modal-hit" data-index="${i}">
              ${label ? `<span class="search-modal-hit-badge">${label}</span>` : ''}
              <span class="search-modal-hit-body">
                <span class="search-modal-hit-title">${title}</span>
                <span class="search-modal-hit-excerpt">${excerpt}</span>
              </span>
            </a>
          `;
        })
        .join('');
      selectedIndex = hits.length > 0 ? 0 : -1;
      updateSelection();
      if (window.gtag) {
        window.gtag('event', 'search', {
          search_term: trimmed,
          result_count: result.results.length,
        });
      }
    }

    function dispatch(rawValue) {
      const { mode, query } = detectMode(rawValue);
      _currentMode = mode;
      setModeBadge(mode);
      if (mode === 'command') return renderCommands(query);
      if (mode === 'tag') return renderTags(query);
      if (mode === 'help') return renderHelp(query);
      return doSearch(query);
    }

    function runCommand(cmd) {
      if (!cmd) return;
      if (cmd.action === 'toggle-theme') {
        const root = document.documentElement;
        const isDark = root.classList.toggle('dark');
        try {
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        } catch {
          /* ignore */
        }
        document.querySelectorAll('[data-theme-toggle]').forEach((b) => {
          b.setAttribute('aria-pressed', isDark ? 'true' : 'false');
        });
        closeModal();
        return;
      }
      if (cmd.action === 'copy-url') {
        navigator.clipboard?.writeText(location.href).catch(() => {});
        closeModal();
        return;
      }
      if (cmd.action === 'print') {
        closeModal();
        setTimeout(() => window.print(), 100);
        return;
      }
      if (cmd.action === 'top') {
        window.scrollTo({ top: 0, behavior: 'smooth' });
        closeModal();
        return;
      }
      if (cmd.action === 'rss') {
        closeModal();
        window.location.href = '/rss.xml';
        return;
      }
      if (cmd.href) {
        closeModal();
        window.location.href = cmd.href;
      }
    }

    function updateSelection() {
      const hits = document.querySelectorAll('.search-modal-hit');
      hits.forEach((el, i) => {
        if (i === selectedIndex) {
          el.classList.add('is-selected');
          el.scrollIntoView({ block: 'nearest' });
        } else {
          el.classList.remove('is-selected');
        }
      });
    }

    function activateSelection() {
      if (selectedIndex < 0 || !currentItems[selectedIndex]) return;
      const item = currentItems[selectedIndex];
      if (item.kind === 'command' && item.ref) {
        runCommand(item.ref);
        return;
      }
      if (item.href) {
        closeModal();
        window.location.href = item.href;
      }
    }

    document.addEventListener('keydown', (e) => {
      const target = e.target;
      const inEditable =
        target instanceof HTMLElement &&
        (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA' || target.isContentEditable);

      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        openModal();
        return;
      }
      if (e.key === '/' && !inEditable) {
        e.preventDefault();
        openModal();
        return;
      }

      const dialog = document.getElementById('search-modal');
      if (!dialog || !dialog.open) return;

      if (e.key === 'Escape') {
        closeModal();
        return;
      }
      if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
        if (currentItems.length === 0) return;
        e.preventDefault();
        const delta = e.key === 'ArrowDown' ? 1 : -1;
        selectedIndex = (selectedIndex + delta + currentItems.length) % currentItems.length;
        updateSelection();
        return;
      }
      if (e.key === 'Enter') {
        if (currentItems.length === 0) return;
        e.preventDefault();
        activateSelection();
      }
    });

    document.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof HTMLElement)) return;
      if (target.closest('[data-search-modal-open]')) {
        e.preventDefault();
        openModal();
        return;
      }
      if (target.closest('[data-search-modal-close]')) {
        e.preventDefault();
        closeModal();
        return;
      }
      const dialog = document.getElementById('search-modal');
      if (dialog && dialog.open && target === dialog) {
        closeModal();
      }
    });

    document.addEventListener('input', (e) => {
      const target = e.target;
      if (target instanceof HTMLInputElement && target.id === 'search-modal-input') {
        dispatch(target.value);
      }
    });

    function autoOpenFromQuery() {
      const params = new URLSearchParams(location.search);
      const q = params.get('q');
      if (q && q.trim()) {
        openModal(q.trim());
        const cleaned = new URL(location.href);
        cleaned.searchParams.delete('q');
        history.replaceState({}, '', cleaned.toString());
      }
    }
    autoOpenFromQuery();
    document.addEventListener('astro:page-load', autoOpenFromQuery);
  })();
</script>

<style is:global>
  .search-modal {
    width: min(640px, 92vw);
    max-width: none;
    max-height: 80vh;
    padding: 0;
    margin: 6rem auto;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background-color: var(--color-surface);
    color: var(--color-fg);
    display: none;
    flex-direction: column;
    overflow: hidden;
  }
  .search-modal[open] {
    display: flex;
  }
  .search-modal::backdrop {
    background-color: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(3px);
  }
  .search-modal-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--color-border);
  }
  .search-modal-mode {
    flex-shrink: 0;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    background-color: var(--color-code-bg);
    color: var(--color-fg-muted);
    font-size: 0.7rem;
    font-weight: 500;
  }
  .search-modal-mode[data-mode='command'] {
    background-color: color-mix(in srgb, var(--color-accent) 18%, transparent);
    color: var(--color-accent);
  }
  .search-modal-mode[data-mode='tag'] {
    background-color: color-mix(in srgb, #f59e0b 22%, transparent);
    color: #d97706;
  }
  .search-modal-mode[data-mode='help'] {
    background-color: color-mix(in srgb, #10b981 22%, transparent);
    color: #059669;
  }
  .search-modal-input {
    flex: 1;
    border: 0;
    background: transparent;
    color: var(--color-fg);
    font-size: 1rem;
    outline: none;
  }
  .search-modal-close {
    flex-shrink: 0;
    width: 1.85rem;
    height: 1.85rem;
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
    background-color: var(--color-surface-elevated);
    color: var(--color-fg-muted);
    cursor: pointer;
  }
  .search-modal-close:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
  .search-modal-stats {
    margin: 0;
    padding: 0.45rem 0.95rem 0;
    font-size: 0.72rem;
    color: var(--color-fg-muted);
  }
  .search-modal-results {
    flex: 1;
    overflow-y: auto;
    padding: 0.4rem 0.55rem 0.7rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .search-modal-hit {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    padding: 0.45rem 0.6rem;
    border-radius: 0.4rem;
    border: 1px solid transparent;
    color: var(--color-fg);
    text-decoration: none;
    cursor: pointer;
  }
  .search-modal-hit:hover,
  .search-modal-hit.is-selected {
    background-color: var(--color-surface-elevated);
    border-color: var(--color-accent);
  }
  .search-modal-hit-badge {
    flex-shrink: 0;
    padding: 0.05rem 0.45rem;
    font-size: 0.65rem;
    font-family: var(--font-mono);
    border-radius: 999px;
    background-color: var(--color-code-bg);
    color: var(--color-fg-muted);
    margin-top: 0.15rem;
  }
  .search-modal-hit-body {
    display: flex;
    flex-direction: column;
    min-width: 0;
    flex: 1;
  }
  .search-modal-hit-title {
    font-weight: 500;
    font-size: 0.92rem;
  }
  .search-modal-hit-excerpt {
    font-size: 0.78rem;
    color: var(--color-fg-muted);
    margin-top: 0.1rem;
    line-height: 1.5;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    align-items: baseline;
  }
  .search-modal-hit-excerpt mark {
    background-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    color: var(--color-fg);
    padding: 0 0.1rem;
    border-radius: 0.15rem;
  }
  .search-modal-hit-excerpt kbd {
    padding: 0.05rem 0.35rem;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    background-color: var(--color-surface-elevated);
    font-family: var(--font-mono);
    font-size: 0.65rem;
  }
  .search-modal-hit-excerpt code {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.05rem 0.3rem;
    background-color: var(--color-code-bg);
    border-radius: 0.25rem;
  }
