---
import { SITE_TITLE, NAV_ITEMS } from '../consts';
import ThemeToggle from './ThemeToggle.astro';
import MobileNav from './MobileNav.astro';
import SearchButton from './SearchButton.astro';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
function isActive(href: string): boolean {
  const target = href.replace(/\/$/, '') || '/';
  if (target === '/') return pathname === '/';
  return pathname === target || pathname.startsWith(target + '/');
}
---

<header
  class="sticky top-0 z-40 border-b border-[color:var(--color-border)] bg-[color:var(--color-surface)]/85 backdrop-blur"
  data-pagefind-ignore="all"
  transition:name="site-header"
>
  <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-5 py-3">
    <a
      href="/"
      class="flex items-center gap-2 text-base font-semibold text-[color:var(--color-fg)] no-underline hover:text-[color:var(--color-accent)]"
    >
      <img src="/favicon-32x32.png" alt="" width="28" height="28" class="h-7 w-7 rounded-md" />
      <span>{SITE_TITLE}</span>
    </a>
    <nav class="hidden items-center gap-1 text-sm md:flex" aria-label="주 네비게이션">
      {
        NAV_ITEMS.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-md px-2.5 py-1.5 no-underline transition',
              isActive(item.href)
                ? 'bg-[color:var(--color-surface-elevated)] text-[color:var(--color-accent)]'
                : 'text-[color:var(--color-fg-muted)] hover:bg-[color:var(--color-surface-elevated)] hover:text-[color:var(--color-fg)]',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <SearchButton class="ml-1" />
      <ThemeToggle class="ml-1" />
    </nav>
    <div class="flex items-center gap-1.5 md:hidden">
      <SearchButton />
      <ThemeToggle />
      <MobileNav />
    </div>
  </div>
</header>
