---
import { SITE_TITLE, NAV_ITEMS, EXTERNAL_NAV_ITEMS, DEV_NAV_ITEMS } from '../consts';
import ThemeToggle from './ThemeToggle.astro';
import MobileNav from './MobileNav.astro';
import SearchButton from './SearchButton.astro';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isDev = import.meta.env.DEV;
function isActive(href: string): boolean {
  const target = href.replace(/\/$/, '') || '/';
  if (target === '/') return pathname === '/';
  return pathname === target || pathname.startsWith(target + '/');
}
---

<header
  class="sticky top-0 z-40 border-b border-[color:var(--color-border)] bg-[color:var(--color-surface)]/85 backdrop-blur"
  data-pagefind-ignore="all"
  transition:name="site-header"
>
  <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-5 py-3">
    <a
      href="/"
      class="flex items-center gap-2 text-base font-semibold text-[color:var(--color-fg)] no-underline hover:text-[color:var(--color-accent)]"
    >
      <img src="/favicon-32x32.png" alt="" width="28" height="28" class="h-7 w-7 rounded-md" />
      <span>{SITE_TITLE}</span>
    </a>
    <nav class="hidden items-center gap-1 text-sm md:flex" aria-label="주 네비게이션">
      {
        NAV_ITEMS.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-md px-2.5 py-1.5 no-underline transition',
              isActive(item.href)
                ? 'bg-[color:var(--color-surface-elevated)] text-[color:var(--color-accent)]'
                : 'text-[color:var(--color-fg-muted)] hover:bg-[color:var(--color-surface-elevated)] hover:text-[color:var(--color-fg)]',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      {
        EXTERNAL_NAV_ITEMS.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-md px-2.5 py-1.5 no-underline transition text-[color:var(--color-fg-muted)] hover:bg-[color:var(--color-surface-elevated)] hover:text-[color:var(--color-fg)]"
          >
            {item.label}
            <span class="inline-block ml-0.5 text-[0.6rem] align-top" aria-hidden="true">↗</span>
          </a>
        ))
      }
      {isDev && (
        <Fragment>
          <span class="header-dev-divider" aria-hidden="true" />
          <span class="header-dev-tag" title="개발 환경에서만 표시됩니다">DEV</span>
          {DEV_NAV_ITEMS.map((item) => (
            <a
              href={item.href}
              data-astro-reload
              class:list={[
                'header-dev-link rounded-md px-2.5 py-1.5 no-underline transition',
                isActive(item.href) && 'is-active',
              ]}
              title={`${item.label} (dev only - full reload)`}
            >
              <span aria-hidden="true">{item.icon}</span>
              <span>{item.label}</span>
            </a>
          ))}
        </Fragment>
      )}
      <SearchButton class="ml-1" />
      <ThemeToggle class="ml-1" />
    </nav>
    <div class="flex items-center gap-1.5 md:hidden">
      <SearchButton />
      <ThemeToggle />
      <MobileNav />
    </div>
  </div>
</header>

<style is:global>
  .header-dev-divider {
    display: inline-block;
    width: 1px;
    height: 1.1rem;
    margin: 0 0.25rem;
    background-color: var(--color-border);
  }
  .header-dev-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 0.1rem 0.35rem;
    background-color: color-mix(in srgb, var(--color-accent) 15%, transparent);
    color: var(--color-accent);
    border-radius: 3px;
    line-height: 1.2;
  }
  .header-dev-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--color-fg-muted);
    border: 1px dashed transparent;
  }
  .header-dev-link:hover {
    background-color: var(--color-surface-elevated);
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
  }
  .header-dev-link.is-active {
    background-color: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
  }
</style>
