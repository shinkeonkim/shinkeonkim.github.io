---
interface Props {
  currentPage: number;
  lastPage: number;
  baseUrl: string;
}

const { currentPage, lastPage, baseUrl } = Astro.props as Props;
const base = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;

function pageUrl(page: number): string {
  if (page <= 1) return base;
  return `${base}${page}/`;
}

function buildPages(): (number | 'ellipsis')[] {
  if (lastPage <= 7) {
    return Array.from({ length: lastPage }, (_, i) => i + 1);
  }
  const out: (number | 'ellipsis')[] = [1];
  if (currentPage > 3) out.push('ellipsis');
  const start = Math.max(2, currentPage - 1);
  const end = Math.min(lastPage - 1, currentPage + 1);
  for (let i = start; i <= end; i++) out.push(i);
  if (currentPage < lastPage - 2) out.push('ellipsis');
  out.push(lastPage);
  return out;
}

const pages = buildPages();
const prevUrl = currentPage > 1 ? pageUrl(currentPage - 1) : null;
const nextUrl = currentPage < lastPage ? pageUrl(currentPage + 1) : null;
---

{
  lastPage > 1 && (
    <nav
      class="mt-10 flex flex-wrap items-center justify-center gap-1.5 text-sm"
      aria-label="페이지 네비게이션"
      data-pagefind-ignore
    >
      {prevUrl ? (
        <a
          href={prevUrl}
          class="rounded-md border border-[color:var(--color-border)] px-3 py-1.5 no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
          rel="prev"
        >
          ← 이전
        </a>
      ) : (
        <span class="rounded-md border border-[color:var(--color-border)] px-3 py-1.5 text-[color:var(--color-fg-muted)] opacity-50">
          ← 이전
        </span>
      )}
      {pages.map((p) =>
        p === 'ellipsis' ? (
          <span class="px-2 text-[color:var(--color-fg-muted)]">…</span>
        ) : (
          <a
            href={pageUrl(p)}
            aria-current={p === currentPage ? 'page' : undefined}
            class:list={[
              'rounded-md border px-3 py-1.5 no-underline',
              p === currentPage
                ? 'border-[color:var(--color-accent)] bg-[color:var(--color-surface-elevated)] text-[color:var(--color-accent)]'
                : 'border-[color:var(--color-border)] hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]',
            ]}
          >
            {p}
          </a>
        ),
      )}
      {nextUrl ? (
        <a
          href={nextUrl}
          class="rounded-md border border-[color:var(--color-border)] px-3 py-1.5 no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
          rel="next"
        >
          다음 →
        </a>
      ) : (
        <span class="rounded-md border border-[color:var(--color-border)] px-3 py-1.5 text-[color:var(--color-fg-muted)] opacity-50">
          다음 →
        </span>
      )}
    </nav>
  )
}
