---

<div id="top-progress-bar" class="top-progress-bar" aria-hidden="true">
  <div class="top-progress-bar-fill"></div>
</div>

<style is:global>
  .top-progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 9999;
    pointer-events: none;
    opacity: 0;
    transition: opacity 200ms ease-out;
  }
  .top-progress-bar.is-active {
    opacity: 1;
  }
  .top-progress-bar.is-done {
    opacity: 0;
    transition: opacity 400ms ease-out 100ms;
  }
  .top-progress-bar-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(
      90deg,
      var(--color-accent, #6366f1) 0%,
      color-mix(in srgb, var(--color-accent, #6366f1) 60%, white) 50%,
      var(--color-accent, #6366f1) 100%
    );
    box-shadow:
      0 0 8px color-mix(in srgb, var(--color-accent, #6366f1) 70%, transparent),
      0 0 2px color-mix(in srgb, var(--color-accent, #6366f1) 80%, transparent);
    transition: width 300ms cubic-bezier(0.2, 0.6, 0.3, 1);
  }
  .top-progress-bar.is-active .top-progress-bar-fill {
    animation: top-progress-shimmer 1.6s linear infinite;
    background-size: 200% 100%;
  }
  @keyframes top-progress-shimmer {
    0% { background-position: 0% 0; }
    100% { background-position: -200% 0; }
  }
</style>

<script is:inline>
  (function () {
    if (window.__topProgressBound) return;
    window.__topProgressBound = true;

    const bar = () => document.getElementById('top-progress-bar');
    const fill = () => bar()?.querySelector('.top-progress-bar-fill');

    let trickleTimer = null;
    let percent = 0;

    function set(p) {
      const f = fill();
      if (!f) return;
      percent = Math.max(percent, Math.min(99, p));
      f.style.width = percent + '%';
    }

    function start() {
      const b = bar();
      if (!b) return;
      b.classList.remove('is-done');
      b.classList.add('is-active');
      percent = 0;
      set(15);
      if (trickleTimer) clearInterval(trickleTimer);
      trickleTimer = window.setInterval(() => {
        const remaining = 99 - percent;
        const inc = Math.max(0.5, remaining * 0.08);
        set(percent + inc);
      }, 300);
    }

    function done() {
      const b = bar();
      const f = fill();
      if (!b || !f) return;
      if (trickleTimer) {
        clearInterval(trickleTimer);
        trickleTimer = null;
      }
      f.style.width = '100%';
      b.classList.add('is-done');
      b.classList.remove('is-active');
      window.setTimeout(() => {
        if (b.classList.contains('is-done')) {
          f.style.width = '0%';
          percent = 0;
        }
      }, 500);
    }

    let startTimer = null;
    document.addEventListener('astro:before-preparation', () => {
      if (startTimer) clearTimeout(startTimer);
      startTimer = window.setTimeout(start, 80);
    });
    document.addEventListener('astro:page-load', () => {
      if (startTimer) clearTimeout(startTimer);
      done();
    });
    document.addEventListener('astro:after-swap', () => {
      if (startTimer) clearTimeout(startTimer);
      done();
    });
  })();
</script>
