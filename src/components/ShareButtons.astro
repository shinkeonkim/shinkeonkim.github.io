---
import { SITE_URL } from '../consts';

interface Props {
  title: string;
  path: string;
}

const { title, path } = Astro.props as Props;
const url = new URL(path, SITE_URL).toString();
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
const twitterHref = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
const blueskyHref = `https://bsky.app/intent/compose?text=${encodedTitle}%20${encodedUrl}`;
---

<aside class="share-buttons not-prose" aria-label="공유" data-pagefind-ignore="all">
  <span class="share-buttons-label">공유</span>
  <a
    class="share-buttons-link"
    href={twitterHref}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="X (Twitter) 에 공유"
  >
    X
  </a>
  <a
    class="share-buttons-link"
    href={blueskyHref}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Bluesky 에 공유"
  >
    Bluesky
  </a>
  <button
    type="button"
    class="share-buttons-link"
    data-share-copy
    data-share-url={url}
    aria-label="링크 복사"
  >
    <span data-share-copy-label>링크 복사</span>
  </button>
</aside>

<style is:global>
  .share-buttons {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
  }
  .share-buttons-label {
    font-size: 0.7rem;
    color: var(--color-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-right: 0.25rem;
  }
  .share-buttons-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background-color: var(--color-surface);
    color: var(--color-fg);
    font-size: 0.72rem;
    text-decoration: none;
    cursor: pointer;
    font-family: inherit;
  }
  .share-buttons-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .share-buttons-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .share-buttons-link[data-copied='true'] {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>

<script is:inline>
  (function () {
    if (window.__shareCopyBound) return;
    window.__shareCopyBound = true;

    document.addEventListener('click', async (e) => {
      const btn = e.target.closest && e.target.closest('[data-share-copy]');
      if (!btn) return;
      const url = btn.dataset.shareUrl;
      const label = btn.querySelector('[data-share-copy-label]');
      if (!url || !label) return;
      try {
        await navigator.clipboard.writeText(url);
        const prev = label.textContent;
        label.textContent = '복사됨';
        btn.dataset.copied = 'true';
        setTimeout(() => {
          label.textContent = prev;
          delete btn.dataset.copied;
        }, 1400);
      } catch {
        label.textContent = '복사 실패';
        setTimeout(() => {
          label.textContent = '링크 복사';
        }, 1400);
      }
    });
  })();
</script>
