---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { noteColorClass, notePreview } from '@/shared/lib/content/notes';

interface Props {
  entry: CollectionEntry<'notes'>;
  preview?: boolean;
  showDate?: boolean;
  showTime?: boolean;
  showTags?: boolean;
}

const {
  entry,
  preview = false,
  showDate = true,
  showTime = false,
  showTags = true,
} = Astro.props;

const colorClass = noteColorClass(entry.id);
const tags = entry.data.tags ?? [];
const dateObj = entry.data.date;

const dateStr = showDate
  ? dateObj.toLocaleDateString('ko-KR', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      weekday: 'short',
    })
  : '';

const timeStr = showTime
  ? dateObj.toLocaleTimeString('ko-KR', {
      hour: '2-digit',
      minute: '2-digit',
    })
  : '';

const href = `/notes/${entry.id}/`;

const body = (entry as { body?: string }).body ?? '';
const previewText = preview ? notePreview(body, 120) : '';
const rendered = preview ? null : await render(entry);
const Content = rendered?.Content;
---

<article class={`note-card ${colorClass}`} data-href={href}>
  <header class="note-card-meta">
    {showDate && <time datetime={dateObj.toISOString()}>{dateStr}</time>}
    {showTime && <time datetime={dateObj.toISOString()}>{timeStr}</time>}
    {showTags && tags.length > 0 && (
      <span class="note-card-tags">
        {tags.map((t: string) => <span>#{t}</span>)}
      </span>
    )}
  </header>

  <div class="note-card-body prose-content">
    {preview ? <p class="note-card-preview">{previewText}</p> : Content && <Content />}
  </div>

  <footer class="note-card-footer">
    <a href={href} class="note-card-link">자세히 보기 &rarr;</a>
  </footer>
</article>
