---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { noteColorClass } from '../lib/notes';

interface Props {
  entry: CollectionEntry<'notes'>;
  showDate?: boolean;
  showTime?: boolean;
  showTags?: boolean;
}

const { entry, showDate = true, showTime = false, showTags = true } = Astro.props;

const { Content } = await render(entry);

const colorClass = noteColorClass(entry.id);
const tags = entry.data.tags || [];

const dateObj = entry.data.date;

const dateStr = showDate
  ? dateObj.toLocaleDateString('ko-KR', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      weekday: 'short',
    })
  : '';

const timeStr = showTime
  ? dateObj.toLocaleTimeString('ko-KR', {
      hour: '2-digit',
      minute: '2-digit',
    })
  : '';

const href = `/notes/${entry.id}/`;
---

<article class={`note-card ${colorClass}`} data-href={href}>
  <header class="note-card-meta">
    {showDate && <time datetime={dateObj.toISOString()}>{dateStr}</time>}
    {showTime && <time datetime={dateObj.toISOString()}>{timeStr}</time>}
    {showTags && tags.length > 0 && (
      <span class="note-card-tags">
        {tags.map((t: string) => <span>#{t}</span>)}
      </span>
    )}
  </header>
  
  <div class="note-card-body prose-content">
    <Content />
  </div>
  
  <footer class="note-card-footer">
    <a href={href} class="note-card-link">자세히 보기 &rarr;</a>
  </footer>
</article>

<script>
  function handleNoteCardClick(e: MouseEvent) {
    const target = e.target as HTMLElement | null;
    if (!target) return;
    const card = target.closest<HTMLElement>('.note-card[data-href]');
    if (!card) return;
    if (target.closest('a, button, input, textarea, select, .wikilink')) return;
    const href = card.dataset.href;
    if (href) window.location.href = href;
  }

  document.addEventListener('astro:page-load', () => {
    document.removeEventListener('click', handleNoteCardClick);
    document.addEventListener('click', handleNoteCardClick);
  });
</script>
