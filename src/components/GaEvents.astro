<script is:inline>
  (function () {
    if (window.__gaEventsBound) return;
    window.__gaEventsBound = true;

    function track(name, params) {
      if (typeof window.gtag !== 'function') return;
      try {
        window.gtag('event', name, params || {});
      } catch {
        /* ignore */
      }
    }

    function pathOf(anchor) {
      try {
        return new URL(anchor.href, window.location.href).pathname;
      } catch {
        return anchor.getAttribute('href') || '';
      }
    }

    function hostOf(anchor) {
      try {
        return new URL(anchor.href, window.location.href).hostname;
      } catch {
        return '';
      }
    }

    document.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof Element)) return;

      const wikilink = target.closest('a.wikilink:not(.broken)');
      if (wikilink) {
        track('wikilink_click', {
          link_target: wikilink.dataset.wikilinkTarget || '',
          link_path: pathOf(wikilink),
        });
        return;
      }

      const share = target.closest('.share-buttons-link');
      if (share) {
        const label = share.getAttribute('aria-label') || share.textContent?.trim() || '';
        track('share_click', { method: label });
        return;
      }

      const copyBtn = target.closest('.code-copy-button, [data-code-copy]');
      if (copyBtn) {
        track('code_copy', {});
        return;
      }

      const themeBtn = target.closest('#theme-toggle, [data-theme-toggle]');
      if (themeBtn) {
        const pressed = themeBtn.getAttribute('aria-pressed');
        track('theme_toggle', { next_state: pressed === 'true' ? 'light' : 'dark' });
        return;
      }

      const externalAnchor = target.closest('a[href^="http"]');
      if (externalAnchor && !externalAnchor.classList.contains('wikilink')) {
        const host = hostOf(externalAnchor);
        if (host && host !== window.location.hostname) {
          track('external_link_click', {
            host,
            link_url: externalAnchor.href,
          });
        }
      }
    });

    document.addEventListener('animationengine:play', (e) => {
      const detail = (e && e.detail) || {};
      track('anim_play', { anim_id: detail.id || '' });
    });

    document.addEventListener('pagefind:search', (e) => {
      const detail = (e && e.detail) || {};
      track('search_query', {
        search_term: detail.term || '',
        result_count: detail.count ?? 0,
      });
    });
  })();
</script>
