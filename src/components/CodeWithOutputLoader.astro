<script is:inline>
  (function () {
    if (window.__cwoBound) return;
    window.__cwoBound = true;

    function initFigure(fig) {
      if (fig.dataset.cwoInit === '1') return;
      fig.dataset.cwoInit = '1';

      const uid = fig.dataset.cwoId;
      const tabs = fig.querySelectorAll('[data-cwo-tab]');
      const variants = fig.querySelectorAll('[data-cwo-variant]');
      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const idx = tab.getAttribute('data-cwo-tab');
          tabs.forEach((t) => {
            const active = t === tab;
            t.classList.toggle('is-active', active);
            t.setAttribute('aria-selected', active ? 'true' : 'false');
          });
          variants.forEach((v) => {
            const active = v.getAttribute('data-cwo-variant') === idx;
            v.classList.toggle('is-active', active);
            v.setAttribute('aria-hidden', active ? 'false' : 'true');
          });
        });
      });

      const storageKey = uid ? 'cwo-w:' + uid : null;
      if (storageKey) {
        try {
          const saved = localStorage.getItem(storageKey);
          if (saved !== null) {
            const v = parseFloat(saved);
            if (!Number.isNaN(v)) applyPct(fig, v, false);
          }
        } catch {
          /* storage unavailable - ignore */
        }
      }

      const panes = fig.querySelector('[data-cwo-panes]');
      const splitter = fig.querySelector('[data-cwo-splitter]');
      if (!panes || !splitter) return;

      function applyPct(figEl, pct, persist) {
        pct = Math.max(0, Math.min(100, pct));
        const vertical = pct >= 99;
        figEl.setAttribute('data-vertical', vertical ? 'true' : 'false');
        figEl.style.setProperty('--cwo-code-pct', pct + '%');
        if (persist && storageKey) {
          try {
            localStorage.setItem(storageKey, String(pct));
          } catch {
            /* storage unavailable - ignore */
          }
        }
      }

      let dragging = false;
      function onMove(clientX, clientY) {
        const rect = panes.getBoundingClientRect();
        const vertical = fig.getAttribute('data-vertical') === 'true';
        let pct;
        if (vertical) {
          pct = ((clientY - rect.top) / rect.height) * 100;
        } else {
          pct = ((clientX - rect.left) / rect.width) * 100;
        }
        applyPct(fig, pct, true);
      }

      splitter.addEventListener('mousedown', (e) => {
        e.preventDefault();
        dragging = true;
        splitter.setAttribute('data-dragging', 'true');
        document.body.style.userSelect = 'none';
      });
      splitter.addEventListener('touchstart', (e) => {
        if (!e.touches[0]) return;
        dragging = true;
        splitter.setAttribute('data-dragging', 'true');
      }, { passive: true });

      document.addEventListener('mousemove', (e) => {
        if (!dragging) return;
        onMove(e.clientX, e.clientY);
      });
      document.addEventListener('touchmove', (e) => {
        if (!dragging || !e.touches[0]) return;
        onMove(e.touches[0].clientX, e.touches[0].clientY);
      }, { passive: true });

      function endDrag() {
        if (!dragging) return;
        dragging = false;
        splitter.removeAttribute('data-dragging');
        document.body.style.userSelect = '';
      }
      document.addEventListener('mouseup', endDrag);
      document.addEventListener('touchend', endDrag);

      splitter.addEventListener('dblclick', () => applyPct(fig, 50, true));
      splitter.addEventListener('keydown', (e) => {
        const current = parseFloat(getComputedStyle(fig).getPropertyValue('--cwo-code-pct')) || 50;
        const step = e.shiftKey ? 10 : 2;
        if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
          e.preventDefault();
          applyPct(fig, current - step, true);
        } else if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
          e.preventDefault();
          applyPct(fig, current + step, true);
        } else if (e.key === 'Home') {
          e.preventDefault();
          applyPct(fig, 20, true);
        } else if (e.key === 'End') {
          e.preventDefault();
          applyPct(fig, 100, true);
        } else if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          applyPct(fig, 50, true);
        }
      });
    }

    function init() {
      document.querySelectorAll('[data-cwo]').forEach(initFigure);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    document.addEventListener('astro:after-swap', init);
    document.addEventListener('preview-updated', init);
  })();
</script>
