---
import { SITE_AUTHOR, SITE_SOCIAL } from '../consts';
const year = new Date().getFullYear();

function labelFor(href: string): string {
  if (href.includes('github.com')) return 'GitHub';
  if (href.includes('acmicpc.net')) return 'Baekjoon';
  if (href.includes('linkedin.com')) return 'LinkedIn';
  if (href.includes('mastodon')) return 'Mastodon';
  if (href.includes('bsky.app') || href.includes('bluesky')) return 'Bluesky';
  try {
    return new URL(href).hostname;
  } catch {
    return href;
  }
}
---

<footer
  class="mt-20 border-t border-[color:var(--color-border)]"
  data-pagefind-ignore="all"
  transition:persist
  transition:name="site-footer"
>
  <div
    class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-2 px-5 py-6 text-sm text-[color:var(--color-fg-muted)] md:flex-row"
  >
    <span>&copy; {year} {SITE_AUTHOR}</span>
    {SITE_SOCIAL.length > 0 && (
      <span class="flex flex-wrap items-center gap-2">
        {SITE_SOCIAL.map((href) => (
          <a
            href={href}
            target="_blank"
            rel="noopener me"
            class="hover:text-[color:var(--color-accent)]"
          >
            {labelFor(href)}
          </a>
        ))}
      </span>
    )}
    <span>dev.shinkeonkim@gmail.com</span>
  </div>
</footer>
