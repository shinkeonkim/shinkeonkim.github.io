---
import { SITE_AUTHOR, SITE_SOCIAL } from '../consts';
import { EXTERNAL_PROFILES } from '../lib/external-profiles';
const year = new Date().getFullYear();

function labelFor(href: string): string {
  if (href.includes('github.com')) return 'GitHub';
  if (href.includes('acmicpc.net')) return 'Baekjoon';
  if (href.includes('linkedin.com')) return 'LinkedIn';
  if (href.includes('mastodon')) return 'Mastodon';
  if (href.includes('bsky.app') || href.includes('bluesky')) return 'Bluesky';
  try {
    return new URL(href).hostname;
  } catch {
    return href;
  }
}
---

<footer
  class="mt-20 border-t border-[color:var(--color-border)]"
  data-pagefind-ignore="all"
  transition:persist
  transition:name="site-footer"
>
  <div class="mx-auto max-w-5xl px-5 py-6 text-sm text-[color:var(--color-fg-muted)]">
    {EXTERNAL_PROFILES.length > 0 && (
      <div class="mb-4 flex flex-wrap items-center justify-center gap-x-3 gap-y-1.5 border-b border-[color:var(--color-border)] pb-4 md:justify-end">
        <span class="text-xs uppercase tracking-wider opacity-70">소개 자료</span>
        {EXTERNAL_PROFILES.map((p) =>
          p.status === 'live' ? (
            <a
              href={p.url}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] px-2.5 py-0.5 text-xs no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
              title={p.description ?? p.label}
            >
              <span aria-hidden="true">{p.icon}</span>
              <span>{p.label}</span>
            </a>
          ) : (
            <span
              class="inline-flex items-center gap-1 rounded-full border border-dashed border-[color:var(--color-border)] px-2.5 py-0.5 text-xs opacity-60"
              title={`${p.label} — 준비 중`}
              aria-disabled="true"
            >
              <span aria-hidden="true">{p.icon}</span>
              <span>{p.label}</span>
              <span class="opacity-70">(준비 중)</span>
            </span>
          ),
        )}
      </div>
    )}
    <div class="flex flex-col items-center justify-between gap-2 md:flex-row">
      <span>&copy; {year} {SITE_AUTHOR}</span>
      {SITE_SOCIAL.length > 0 && (
        <span class="flex flex-wrap items-center gap-2">
          {SITE_SOCIAL.map((href) => (
            <a
              href={href}
              target="_blank"
              rel="noopener me"
              class="hover:text-[color:var(--color-accent)]"
            >
              {labelFor(href)}
            </a>
          ))}
        </span>
      )}
      <span>dev.shinkeonkim@gmail.com</span>
    </div>
  </div>
</footer>
