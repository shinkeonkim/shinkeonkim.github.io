---
interface Props {
  id: string;
  title?: string;
  start?: string | number;
  cookieless?: boolean;
}

const { id, title = 'YouTube video', start, cookieless = true } = Astro.props as Props;
const domain = cookieless ? 'youtube-nocookie.com' : 'youtube.com';

function parseStart(s: string | number | undefined): number | null {
  if (s === undefined || s === null) return null;
  if (typeof s === 'number') return s;
  const trimmed = s.trim();
  if (/^\d+$/.test(trimmed)) return Number(trimmed);
  let total = 0;
  const re = /(\d+)\s*(h|m|s)/gi;
  let match: RegExpExecArray | null;
  while ((match = re.exec(trimmed)) !== null) {
    const n = Number(match[1]);
    const unit = match[2].toLowerCase();
    if (unit === 'h') total += n * 3600;
    else if (unit === 'm') total += n * 60;
    else total += n;
  }
  if (total > 0) return total;
  const colon = trimmed.split(':').map(Number);
  if (colon.every((x) => !Number.isNaN(x))) {
    if (colon.length === 3) return colon[0] * 3600 + colon[1] * 60 + colon[2];
    if (colon.length === 2) return colon[0] * 60 + colon[1];
  }
  return null;
}

const startSeconds = parseStart(start);
const src = `https://www.${domain}/embed/${encodeURIComponent(id)}${startSeconds ? `?start=${startSeconds}` : ''}`;
---
<div class="yt-embed">
  <iframe
    src={src}
    title={title}
    loading="lazy"
    referrerpolicy="strict-origin-when-cross-origin"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
  ></iframe>
</div>

<style is:global>
  .yt-embed {
    position: relative;
    margin: 1.25rem 0;
    aspect-ratio: 16 / 9;
    border-radius: 0.55rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background-color: var(--color-code-bg);
  }
  .yt-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
