---
interface Props {
  id: string;
  title?: string;
}

const { id, title = 'Vimeo video' } = Astro.props as Props;
const src = `https://player.vimeo.com/video/${encodeURIComponent(id)}`;
---
<div class="vimeo-embed">
  <iframe
    src={src}
    title={title}
    loading="lazy"
    allow="autoplay; fullscreen; picture-in-picture"
    allowfullscreen
  ></iframe>
</div>

<style is:global>
  .vimeo-embed {
    position: relative;
    margin: 1.25rem 0;
    aspect-ratio: 16 / 9;
    border-radius: 0.55rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background-color: var(--color-code-bg);
  }
  .vimeo-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
