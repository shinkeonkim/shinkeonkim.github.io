---
import UrlPreview from './UrlPreview.astro';
import type { ExternalProfile } from '../lib/external-profiles';

interface Props {
  profile: ExternalProfile;
}

const { profile } = Astro.props as Props;
---

{
  profile.status === 'live' ? (
    <UrlPreview url={profile.url} />
  ) : (
    <div class="external-profile-planned not-prose" aria-disabled="true">
      <span class="external-profile-icon">{profile.icon}</span>
      <span class="external-profile-body">
        <span class="external-profile-label">
          {profile.label}
          <span class="external-profile-badge">준비 중</span>
        </span>
        {profile.description && (
          <span class="external-profile-description">{profile.description}</span>
        )}
        <span class="external-profile-url">{profile.url}</span>
      </span>
    </div>
  )
}

<style is:global>
  .external-profile-planned {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.9rem;
    align-items: center;
    margin: 1.25rem 0;
    border: 1px dashed var(--color-border);
    border-radius: 0.6rem;
    background-color: color-mix(in srgb, var(--color-fg) 2%, transparent);
    color: var(--color-fg-muted);
    padding: 0.9rem 1.1rem;
    opacity: 0.85;
  }
  .external-profile-icon {
    font-size: 1.6rem;
    line-height: 1;
  }
  .external-profile-body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }
  .external-profile-label {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-fg);
  }
  .external-profile-badge {
    display: inline-block;
    padding: 0.1rem 0.45rem;
    border-radius: 9999px;
    background-color: color-mix(in srgb, var(--color-accent) 14%, transparent);
    color: var(--color-accent);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  .external-profile-description {
    font-size: 0.82rem;
    line-height: 1.5;
  }
  .external-profile-url {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-fg-muted);
    opacity: 0.7;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
