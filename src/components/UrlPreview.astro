---
import { loadUrlPreviews, cacheKeyFor, hostnameFor } from '../lib/url-preview';

interface Props {
  url: string;
}

const { url } = Astro.props as Props;
const cache = await loadUrlPreviews();
const data = cache[cacheKeyFor(url)];
const hostname = hostnameFor(url);
const hasMeta = data && (data.title || data.description || data.image);
---
<a
  class="url-preview-card not-prose"
  href={url}
  target="_blank"
  rel="noopener"
  data-url-preview={url}
>
  {data?.image && (
    <span class="url-preview-image" style={`background-image: url(${JSON.stringify(data.image)})`}></span>
  )}
  <span class="url-preview-body">
    <span class="url-preview-host">
      {data?.favicon && (
        <img src={data.favicon} alt="" width="14" height="14" class="url-preview-favicon" loading="lazy" />
      )}
      <span>{data?.siteName ?? hostname}</span>
    </span>
    <span class="url-preview-title">
      {hasMeta ? data!.title ?? url : url}
    </span>
    {data?.description && (
      <span class="url-preview-description">{data.description}</span>
    )}
    {!hasMeta && (
      <span class="url-preview-description url-preview-empty">
        (캐시 없음 — 빌드 시 `bun scripts/fetch-url-previews.mjs` 로 메타 채우기)
      </span>
    )}
  </span>
</a>

<style is:global>
  .url-preview-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    margin: 1.25rem 0;
    border: 1px solid var(--color-border);
    border-radius: 0.6rem;
    background-color: var(--color-surface-elevated);
    color: var(--color-fg);
    text-decoration: none !important;
    overflow: hidden;
    transition: border-color 120ms, transform 120ms;
  }
  .url-preview-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  @media (min-width: 600px) {
    .url-preview-card:has(.url-preview-image) {
      grid-template-columns: 12rem minmax(0, 1fr);
    }
  }
  .url-preview-image {
    display: block;
    background-size: cover;
    background-position: center;
    background-color: var(--color-code-bg);
    aspect-ratio: 1.6 / 1;
  }
  @media (min-width: 600px) {
    .url-preview-card:has(.url-preview-image) .url-preview-image {
      aspect-ratio: auto;
      min-height: 100%;
    }
  }
  .url-preview-body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.9rem 1.1rem;
    min-width: 0;
  }
  .url-preview-host {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    color: var(--color-fg-muted);
  }
  .url-preview-favicon {
    border-radius: 0.2rem;
  }
  .url-preview-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-fg);
    line-height: 1.35;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .url-preview-description {
    font-size: 0.82rem;
    color: var(--color-fg-muted);
    line-height: 1.5;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .url-preview-empty {
    font-style: italic;
  }
</style>
