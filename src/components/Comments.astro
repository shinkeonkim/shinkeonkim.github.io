---
interface Props {
  slug: string;
}

const { slug } = Astro.props as Props;
const repo = import.meta.env.PUBLIC_GISCUS_REPO ?? '';
const repoId = import.meta.env.PUBLIC_GISCUS_REPO_ID ?? '';
const category = import.meta.env.PUBLIC_GISCUS_CATEGORY ?? 'Announcements';
const categoryId = import.meta.env.PUBLIC_GISCUS_CATEGORY_ID ?? '';
const enabled = repo && repoId && categoryId;
---
{enabled && (
  <section class="post-comments not-prose" data-pagefind-ignore="all">
    <h2 class="post-comments-title">💬 댓글</h2>
    <div class="post-comments-mount" data-giscus-mount data-giscus-slug={slug}></div>
  </section>
  <script
    define:vars={{ repo, repoId, category, categoryId }}
    is:inline
  >
    (function () {
      function currentTheme() {
        return document.documentElement.classList.contains('dark') ? 'dark_dimmed' : 'light';
      }
      function mount() {
        const node = document.querySelector('[data-giscus-mount]');
        if (!node) return;
        node.innerHTML = '';
        const slug = node.getAttribute('data-giscus-slug') || '';
        const script = document.createElement('script');
        script.src = 'https://giscus.app/client.js';
        script.async = true;
        script.crossOrigin = 'anonymous';
        script.setAttribute('data-repo', repo);
        script.setAttribute('data-repo-id', repoId);
        script.setAttribute('data-category', category);
        script.setAttribute('data-category-id', categoryId);
        script.setAttribute('data-mapping', 'specific');
        script.setAttribute('data-term', slug);
        script.setAttribute('data-strict', '0');
        script.setAttribute('data-reactions-enabled', '1');
        script.setAttribute('data-emit-metadata', '0');
        script.setAttribute('data-input-position', 'bottom');
        script.setAttribute('data-theme', currentTheme());
        script.setAttribute('data-lang', 'ko');
        script.setAttribute('data-loading', 'lazy');
        node.appendChild(script);
      }
      function sendTheme() {
        const frame = document.querySelector('iframe.giscus-frame');
        if (!frame || !frame.contentWindow) return;
        frame.contentWindow.postMessage(
          { giscus: { setConfig: { theme: currentTheme() } } },
          'https://giscus.app',
        );
      }
      mount();
      const mo = new MutationObserver(function () { sendTheme(); });
      mo.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      document.addEventListener('astro:before-swap', function () { mo.disconnect(); }, { once: true });
    })();
  </script>
)}

<style is:global>
  .post-comments {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  .post-comments-title {
    margin: 0 0 1rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-fg);
  }
</style>
