---
import {
  getReferenceIndex,
  resolveReferences,
  formatSourceLabel,
  type ResolvedReference,
} from '../lib/references';

interface Props {
  references?: unknown[];
}

const { references } = Astro.props as Props;
const index = await getReferenceIndex();
const resolved: ResolvedReference[] = resolveReferences(references, index);
---

{
  resolved.length > 0 && (
    <aside class="post-references not-prose" data-pagefind-ignore="all">
      <h3 class="post-references-title">참고 자료</h3>
      <ol class="post-references-list">
        {resolved.map((ref) => {
          if (ref.kind === 'inline') {
            return (
              <li class="post-references-item">
                {ref.url ? (
                  <a
                    href={ref.url}
                    target="_blank"
                    rel="noopener"
                    class="post-references-title-link"
                  >
                    {ref.title}
                  </a>
                ) : (
                  <span class="post-references-title-link">{ref.title}</span>
                )}
                {ref.author && <span class="post-references-meta"> · {ref.author}</span>}
                {ref.note && <p class="post-references-note">{ref.note}</p>}
              </li>
            );
          }
          if (ref.kind === 'missing') {
            return (
              <li class="post-references-item">
                <span class="post-references-title-link post-references-broken">{ref.id}</span>
                <span class="post-references-meta"> · (sources 컬렉션에 정의 없음)</span>
                {ref.note && <p class="post-references-note">{ref.note}</p>}
              </li>
            );
          }
          const source = ref.source.data;
          const sourceUrl = `/sources/${ref.source.id}/`;
          return (
            <li class="post-references-item">
              <a href={sourceUrl} class="post-references-title-link">
                {formatSourceLabel(ref.source)}
              </a>
              {source.year && <span class="post-references-meta"> · {source.year}</span>}
              {ref.page !== undefined && <span class="post-references-meta"> · p.{ref.page}</span>}
              {source.url && (
                <a
                  href={source.url}
                  target="_blank"
                  rel="noopener"
                  class="post-references-extlink"
                  title="외부 링크"
                >
                  ↗
                </a>
              )}
              {ref.note && <p class="post-references-note">{ref.note}</p>}
            </li>
          );
        })}
      </ol>
    </aside>
  )
}

<style is:global>
  .post-references {
    margin-top: 2.5rem;
    padding: 1.1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 0.6rem;
    background-color: var(--color-surface-elevated);
  }
  .post-references-title {
    margin: 0 0 0.75rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-fg);
    letter-spacing: 0.01em;
  }
  .post-references-list {
    margin: 0;
    padding-left: 1.25rem;
    list-style: decimal;
  }
  .post-references-item {
    margin: 0.35rem 0;
    font-size: 0.88rem;
    line-height: 1.55;
  }
  .post-references-title-link {
    color: var(--color-fg);
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px dashed var(--color-border);
  }
  a.post-references-title-link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .post-references-meta {
    color: var(--color-fg-muted);
    font-size: 0.82rem;
  }
  .post-references-broken {
    color: #ef4444;
    border-bottom-color: #ef4444;
  }
  .post-references-extlink {
    margin-left: 0.4rem;
    color: var(--color-fg-muted);
    text-decoration: none;
    font-size: 0.82rem;
  }
  .post-references-extlink:hover {
    color: var(--color-accent);
  }
  .post-references-note {
    margin: 0.2rem 0 0;
    color: var(--color-fg-muted);
    font-size: 0.82rem;
  }
</style>
