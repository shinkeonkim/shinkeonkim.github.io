---
import { SITE_AUTHOR, SITE_SOCIAL, SITE_URL } from '../consts';

const AUTHOR_BIO =
  'koa(김신건). Python · Django · Astro 로 작업하는 개발자. 알고리즘 문제 풀이, 웹 개발, 데이터베이스를 기록합니다.';

interface SocialLink {
  href: string;
  label: string;
  icon: string;
}

function socialLinks(): SocialLink[] {
  return SITE_SOCIAL.map((href) => {
    if (href.includes('github.com'))
      return { href, label: 'GitHub', icon: 'gh' };
    if (href.includes('linkedin.com'))
      return { href, label: 'LinkedIn', icon: 'in' };
    return { href, label: new URL(href).hostname, icon: 'link' };
  });
}

const links = socialLinks();
---
<aside class="author-card not-prose" data-pagefind-ignore="all">
  <div class="author-card-row">
    <img src="/apple-touch-icon.png" alt="" width="48" height="48" loading="lazy" class="author-card-avatar" />
    <div class="author-card-info">
      <p class="author-card-name">
        <a href={`${SITE_URL}/about/`} class="author-card-name-link">{SITE_AUTHOR}</a>
      </p>
      <p class="author-card-bio">{AUTHOR_BIO}</p>
    </div>
  </div>
  {links.length > 0 && (
    <ul class="author-card-links">
      {links.map((l) => (
        <li>
          <a href={l.href} target="_blank" rel="noopener me" class="author-card-link">
            <span class="author-card-icon">{l.icon}</span>
            <span>{l.label}</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</aside>

<style is:global>
  .author-card {
    margin-top: 2rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.6rem;
    background-color: var(--color-surface-elevated);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .author-card-row {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }
  .author-card-avatar {
    flex-shrink: 0;
    border-radius: 50%;
    border: 1px solid var(--color-border);
  }
  .author-card-info {
    flex: 1;
    min-width: 0;
  }
  .author-card-name {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .author-card-name-link {
    color: var(--color-fg);
    text-decoration: none;
  }
  .author-card-name-link:hover {
    color: var(--color-accent);
  }
  .author-card-bio {
    margin: 0.2rem 0 0;
    font-size: 0.8rem;
    color: var(--color-fg-muted);
    line-height: 1.55;
  }
  .author-card-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .author-card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.75rem;
    color: var(--color-fg-muted);
    text-decoration: none;
    background-color: var(--color-surface);
  }
  .author-card-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .author-card-icon {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 0.05rem 0.3rem;
    border-radius: 999px;
    background-color: var(--color-code-bg);
    color: var(--color-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
</style>
