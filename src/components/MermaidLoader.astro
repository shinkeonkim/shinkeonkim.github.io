---

---

<dialog id="mermaid-zoom" class="mermaid-zoom" aria-label="다이어그램 확대 보기">
  <div class="mermaid-zoom-toolbar">
    <span class="mermaid-zoom-hint"
      >스크롤 = 확대/축소 · 드래그 = 이동 · 0 = 원래 크기 · ESC = 닫기</span
    >
    <button type="button" data-zoom-export-svg class="mermaid-zoom-action" aria-label="SVG 다운로드">⤓ SVG</button>
    <button type="button" data-zoom-export-png class="mermaid-zoom-action" aria-label="PNG 다운로드">⤓ PNG</button>
    <button type="button" data-zoom-close aria-label="닫기" class="mermaid-zoom-close">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="6" y1="6" x2="18" y2="18"></line>
        <line x1="6" y1="18" x2="18" y2="6"></line>
      </svg>
    </button>
  </div>
  <div class="mermaid-zoom-viewport">
    <div class="mermaid-zoom-content"></div>
  </div>
</dialog>

<style is:global>
  .mermaid[data-mermaid-source] {
    cursor: zoom-in;
    transition: transform 120ms ease-out;
  }
  .mermaid[data-mermaid-source]:not([data-mermaid-rendered]) {
    min-height: 160px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--color-fg-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    background-color: var(--color-surface);
    border: 1px dashed var(--color-border);
    border-radius: 0.5rem;
    padding: 1rem;
    white-space: normal;
    overflow: hidden;
    text-overflow: ellipsis;
    cursor: progress;
  }
  .mermaid[data-mermaid-source]:not([data-mermaid-rendered])::before {
    content: '⟳ Mermaid 다이어그램 로드 대기 중…';
    display: block;
    margin-bottom: 0.5rem;
    opacity: 0.8;
  }
  .mermaid[data-mermaid-source].is-loading:not([data-mermaid-rendered])::before {
    content: '⟳ Mermaid 렌더링 중…';
    animation: mermaid-spin 1.2s linear infinite;
    display: inline-block;
  }
  @keyframes mermaid-spin {
    0% { opacity: 0.5; }
    50% { opacity: 1; }
    100% { opacity: 0.5; }
  }
  .mermaid[data-mermaid-source]:hover {
    transform: scale(1.005);
  }
  .mermaid-zoom {
    width: 96vw;
    height: 92vh;
    max-width: 1600px;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background-color: var(--color-surface);
    color: var(--color-fg);
    overflow: hidden;
  }
  .mermaid-zoom::backdrop {
    background-color: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
  }
  .mermaid-zoom-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.6rem 0.85rem;
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-surface-elevated);
  }
  .mermaid-zoom-hint {
    font-size: 0.75rem;
    color: var(--color-fg-muted);
  }
  .mermaid-zoom-action {
    padding: 0.35rem 0.7rem;
    border-radius: 0.375rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-surface);
    color: var(--color-fg-muted);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .mermaid-zoom-action:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .mermaid-zoom-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.25rem;
    width: 2.25rem;
    border-radius: 0.375rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-surface);
    color: var(--color-fg);
    cursor: pointer;
  }
  .mermaid-zoom-close:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .mermaid-zoom-viewport {
    height: calc(100% - 3.5rem);
    overflow: hidden;
    display: grid;
    place-items: center;
    background-color: var(--color-surface);
    cursor: grab;
  }
  .mermaid-zoom-viewport:active {
    cursor: grabbing;
  }
  .mermaid-zoom-content {
    transform-origin: center center;
    transition: transform 120ms ease-out;
    user-select: none;
  }
  .mermaid-zoom-content svg {
    max-width: none;
    max-height: none;
    width: min(90vw, 1400px);
    height: auto;
    background: transparent !important;
  }
</style>

<script is:inline>
  (function () {
    if (window.__mermaidBound) return;
    window.__mermaidBound = true;

    let mermaidPromise = null;
    function loadMermaid() {
      if (!mermaidPromise) {
        mermaidPromise =
          import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs').then(
            (m) => m.default,
          );
      }
      return mermaidPromise;
    }

    let renderToken = 0;
    let initialized = false;

    function snapshotSources() {
      document.querySelectorAll('.mermaid[data-mermaid-source]').forEach((el) => {
        if (!el.hasAttribute('data-mermaid-original')) {
          el.setAttribute('data-mermaid-original', el.textContent || '');
        }
      });
    }

    async function renderNodes(nodes) {
      if (!nodes || nodes.length === 0) return;
      const token = ++renderToken;
      const mermaid = await loadMermaid();
      if (token !== renderToken) return;

      if (!initialized) {
        const isDark = document.documentElement.classList.contains('dark');
        mermaid.initialize({
          startOnLoad: false,
          theme: isDark ? 'dark' : 'default',
          securityLevel: 'strict',
          fontFamily:
            'ui-sans-serif,system-ui,-apple-system,"Apple SD Gothic Neo","Noto Sans KR",sans-serif',
        });
        initialized = true;
      }

      for (const el of nodes) {
        const source = el.getAttribute('data-mermaid-original') || el.textContent || '';
        el.setAttribute('data-mermaid-original', source);
        el.removeAttribute('data-processed');
        el.textContent = source;
        el.classList.add('is-loading');
      }

      try {
        await mermaid.run({ nodes });
        for (const el of nodes) {
          el.setAttribute('data-mermaid-rendered', '1');
          el.classList.remove('is-loading');
        }
        attachZoomHandlers();
      } catch (err) {
        console.error('[mermaid] render failed:', err);
        for (const el of nodes) el.classList.remove('is-loading');
      }
    }

    let observer = null;
    let viewportObserver = null;
    function setupLazyMermaid() {
      const all = Array.from(document.querySelectorAll('.mermaid[data-mermaid-source]'));
      if (all.length === 0) return;
      snapshotSources();

      if (viewportObserver) viewportObserver.disconnect();
      viewportObserver = new IntersectionObserver((entries) => {
        const candidates = [];
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const el = entry.target;
            viewportObserver.unobserve(el);
            if (!el.hasAttribute('data-mermaid-rendered')) candidates.push(el);
          }
        }
        if (candidates.length > 0) void renderNodes(candidates);
      }, { rootMargin: '300px 0px' });
      for (const el of all) {
        if (!el.hasAttribute('data-mermaid-rendered')) viewportObserver.observe(el);
      }
    }

    async function renderMermaid() {
      const all = Array.from(document.querySelectorAll('.mermaid[data-mermaid-source]'));
      if (all.length === 0) return;
      // theme change - re-render the ALREADY rendered ones
      const rendered = all.filter((el) => el.hasAttribute('data-mermaid-rendered'));
      if (rendered.length > 0) {
        initialized = false;
        for (const el of rendered) el.removeAttribute('data-mermaid-rendered');
        await renderNodes(rendered);
      }
    }

    void setupLazyMermaid;

    const dialog = () => document.getElementById('mermaid-zoom');
    const viewport = () => dialog()?.querySelector('.mermaid-zoom-viewport');
    const content = () => dialog()?.querySelector('.mermaid-zoom-content');

    let zoomScale = 1;
    let panX = 0;
    let panY = 0;
    function applyTransform() {
      const c = content();
      if (!c) return;
      c.style.transform = `translate(${panX}px, ${panY}px) scale(${zoomScale})`;
    }
    function resetTransform() {
      zoomScale = 1;
      panX = 0;
      panY = 0;
      applyTransform();
    }

    function openZoom(sourceEl) {
      const d = dialog();
      const c = content();
      const svg = sourceEl.querySelector('svg');
      if (!d || !c || !svg) return;
      c.innerHTML = '';
      const clone = svg.cloneNode(true);
      clone.removeAttribute('width');
      clone.removeAttribute('height');
      c.appendChild(clone);
      resetTransform();
      if (typeof d.showModal === 'function') d.showModal();
      else d.setAttribute('open', '');
    }

    function closeZoom() {
      const d = dialog();
      const c = content();
      if (!d) return;
      if (typeof d.close === 'function') d.close();
      else d.removeAttribute('open');
      if (c) c.innerHTML = '';
    }

    function attachZoomHandlers() {
      document.querySelectorAll('.mermaid[data-mermaid-source]').forEach((el) => {
        if (el.dataset.zoomBound === '1') return;
        el.dataset.zoomBound = '1';
        el.addEventListener('click', (e) => {
          e.preventDefault();
          openZoom(el);
        });
      });
    }

    function downloadBlob(name, blob) {
      const url = URL.createObjectURL(blob);
      const a = Object.assign(document.createElement('a'), { href: url, download: name });
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
    }

    function getZoomSvg() {
      const c = content();
      return c?.querySelector('svg');
    }

    function exportSvg() {
      const svg = getZoomSvg();
      if (!svg) return;
      const xml = new XMLSerializer().serializeToString(svg);
      downloadBlob(
        `mermaid-${Date.now()}.svg`,
        new Blob(['<?xml version="1.0" encoding="UTF-8"?>\n', xml], { type: 'image/svg+xml' }),
      );
    }

    function exportPng() {
      const svg = getZoomSvg();
      if (!svg) return;
      const xml = new XMLSerializer().serializeToString(svg);
      const bbox = svg.getBBox ? svg.getBBox() : { width: 1024, height: 768 };
      const w = Math.max(320, Math.ceil(bbox.width)) * 2;
      const h = Math.max(240, Math.ceil(bbox.height)) * 2;
      const blob = new Blob([xml], { type: 'image/svg+xml;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement('canvas');
        canvas.width = w;
        canvas.height = h;
        const ctx = canvas.getContext('2d');
        if (!ctx) return;
        ctx.fillStyle = document.documentElement.classList.contains('dark') ? '#0b0b0f' : '#ffffff';
        ctx.fillRect(0, 0, w, h);
        ctx.drawImage(img, 0, 0, w, h);
        canvas.toBlob((b) => {
          if (b) downloadBlob(`mermaid-${Date.now()}.png`, b);
          URL.revokeObjectURL(url);
        }, 'image/png');
      };
      img.onerror = () => URL.revokeObjectURL(url);
      img.src = url;
    }

    document.addEventListener('click', (e) => {
      if (e.target.closest('[data-zoom-export-svg]')) {
        exportSvg();
        return;
      }
      if (e.target.closest('[data-zoom-export-png]')) {
        exportPng();
        return;
      }
      if (e.target.closest('[data-zoom-close]')) {
        closeZoom();
        return;
      }
      const d = dialog();
      if (d && d.open && e.target === d) closeZoom();
    });

    document.addEventListener('keydown', (e) => {
      const d = dialog();
      if (!d || !d.open) return;
      if (e.key === '+' || e.key === '=') {
        e.preventDefault();
        zoomScale = Math.min(zoomScale * 1.2, 6);
        applyTransform();
      } else if (e.key === '-') {
        e.preventDefault();
        zoomScale = Math.max(zoomScale / 1.2, 0.3);
        applyTransform();
      } else if (e.key === '0') {
        e.preventDefault();
        resetTransform();
      }
    });

    document.addEventListener(
      'wheel',
      (e) => {
        const v = viewport();
        const d = dialog();
        if (!v || !d || !d.open) return;
        if (!v.contains(e.target) && e.target !== v) return;
        e.preventDefault();
        const factor = e.deltaY < 0 ? 1.1 : 1 / 1.1;
        zoomScale = Math.max(0.3, Math.min(6, zoomScale * factor));
        applyTransform();
      },
      { passive: false },
    );

    let dragging = false;
    let startX = 0;
    let startY = 0;
    let startPanX = 0;
    let startPanY = 0;
    document.addEventListener('mousedown', (e) => {
      const v = viewport();
      const d = dialog();
      if (!v || !d || !d.open || !v.contains(e.target)) return;
      dragging = true;
      startX = e.clientX;
      startY = e.clientY;
      startPanX = panX;
      startPanY = panY;
    });
    document.addEventListener('mousemove', (e) => {
      if (!dragging) return;
      panX = startPanX + (e.clientX - startX);
      panY = startPanY + (e.clientY - startY);
      applyTransform();
    });
    document.addEventListener('mouseup', () => {
      dragging = false;
    });

    setupLazyMermaid();

    observer = new MutationObserver((mutations) => {
      for (const m of mutations) {
        if (m.attributeName === 'class') {
          renderMermaid();
          return;
        }
      }
    });
    observer.observe(document.documentElement, { attributes: true });

    document.addEventListener('astro:after-swap', () => {
      initialized = false;
      setupLazyMermaid();
    });
    document.addEventListener('preview-updated', () => {
      setupLazyMermaid();
    });
  })();
</script>
