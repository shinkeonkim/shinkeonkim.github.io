---
interface Props {
  languages: Record<string, number | undefined>;
  size?: number;
  topN?: number;
}

const { languages, size = 120, topN = 5 } = Astro.props as Props;

const COLORS: Record<string, string> = {
  TypeScript: '#3178c6',
  JavaScript: '#f1e05a',
  Python: '#3572A5',
  Astro: '#ff5d01',
  HTML: '#e34c26',
  CSS: '#563d7c',
  SCSS: '#c6538c',
  Shell: '#89e051',
  Vue: '#41b883',
  Svelte: '#ff3e00',
  MDX: '#fcb32c',
  Go: '#00ADD8',
  Rust: '#dea584',
  Java: '#b07219',
  Kotlin: '#A97BFF',
  C: '#555555',
  'C++': '#f34b7d',
  Ruby: '#701516',
  PHP: '#4F5D95',
  Dockerfile: '#384d54',
  Makefile: '#427819',
  Lua: '#000080',
  Dart: '#00B4AB',
  Swift: '#F05138',
};
const OTHER_COLOR = '#9ca3af';

const entries: [string, number][] = Object.entries(languages)
  .filter((entry): entry is [string, number] => typeof entry[1] === 'number' && entry[1] > 0)
  .sort((a, b) => b[1] - a[1]);

const total = entries.reduce((sum, [, b]) => sum + b, 0);
const top = entries.slice(0, topN);
const rest = entries.slice(topN);
const restBytes = rest.reduce((sum, [, b]) => sum + b, 0);
const segments = [
  ...top.map(([name, bytes]) => ({ name, bytes, color: COLORS[name] ?? OTHER_COLOR })),
  ...(restBytes > 0
    ? [{ name: `+${rest.length} more`, bytes: restBytes, color: OTHER_COLOR }]
    : []),
];

const radius = size / 2;
const innerR = radius * 0.6;
const cx = radius;
const cy = radius;

interface Arc {
  d: string;
  color: string;
  name: string;
  pct: number;
}

function polar(angle: number, r: number): [number, number] {
  const rad = (angle - 90) * (Math.PI / 180);
  return [cx + r * Math.cos(rad), cy + r * Math.sin(rad)];
}

function buildArc(startAngle: number, endAngle: number): string {
  const large = endAngle - startAngle > 180 ? 1 : 0;
  const [sx, sy] = polar(startAngle, radius);
  const [ex, ey] = polar(endAngle, radius);
  const [isx, isy] = polar(endAngle, innerR);
  const [iex, iey] = polar(startAngle, innerR);
  return `M${sx},${sy} A${radius},${radius} 0 ${large} 1 ${ex},${ey} L${isx},${isy} A${innerR},${innerR} 0 ${large} 0 ${iex},${iey} Z`;
}

const arcs: Arc[] = [];
let cursor = 0;
for (const seg of segments) {
  if (total === 0) break;
  const pct = (seg.bytes / total) * 100;
  const angle = (seg.bytes / total) * 360;
  // single-segment 100% special-case (full circle)
  let d: string;
  if (segments.length === 1) {
    d = `M${cx - radius + 0.01},${cy} A${radius},${radius} 0 1 1 ${cx + radius - 0.01},${cy} A${radius},${radius} 0 1 1 ${cx - radius + 0.01},${cy} M${cx - innerR + 0.01},${cy} A${innerR},${innerR} 0 1 0 ${cx + innerR - 0.01},${cy} A${innerR},${innerR} 0 1 0 ${cx - innerR + 0.01},${cy} Z`;
  } else {
    d = buildArc(cursor, cursor + angle);
  }
  arcs.push({ d, color: seg.color, name: seg.name, pct });
  cursor += angle;
}

const formatBytes = (b: number): string => {
  if (b > 1_000_000) return `${(b / 1_000_000).toFixed(1)} MB`;
  if (b > 1000) return `${(b / 1000).toFixed(1)} KB`;
  return `${b} B`;
};
---

{
  segments.length > 0 && (
    <div class="lang-donut">
      <svg
        class="lang-donut-svg"
        viewBox={`0 0 ${size} ${size}`}
        width={size}
        height={size}
        role="img"
        aria-label={`언어 비율: ${segments.map((s) => `${s.name} ${((s.bytes / total) * 100).toFixed(1)}%`).join(', ')}`}
      >
        {arcs.map((a) => (
          <path d={a.d} fill={a.color} fill-rule="evenodd" />
        ))}
      </svg>
      <ul class="lang-donut-legend">
        {segments.map((s) => (
          <li>
            <span class="lang-donut-dot" style={`background:${s.color}`} />
            <span class="lang-donut-name">{s.name}</span>
            <span class="lang-donut-pct">{((s.bytes / total) * 100).toFixed(1)}%</span>
            <span class="lang-donut-bytes">{formatBytes(s.bytes)}</span>
          </li>
        ))}
      </ul>
    </div>
  )
}

<style is:global>
  .lang-donut {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex-wrap: wrap;
  }
  .lang-donut-svg {
    flex-shrink: 0;
    display: block;
  }
  .lang-donut-legend {
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    font-size: 0.78rem;
  }
  .lang-donut-legend li {
    display: grid;
    grid-template-columns: 10px 1fr auto auto;
    align-items: center;
    gap: 0.4rem;
  }
  .lang-donut-dot {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    display: inline-block;
  }
  .lang-donut-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .lang-donut-pct {
    font-family: var(--font-mono);
    color: var(--color-fg);
  }
  .lang-donut-bytes {
    font-family: var(--font-mono);
    color: var(--color-fg-muted);
    font-size: 0.7rem;
  }
</style>
