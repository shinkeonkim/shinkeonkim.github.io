---
import type { RepoContributor } from '../../lib/projects';

interface Props {
  contributors: RepoContributor[];
  myLogin?: string;
  limit?: number;
}

const { contributors, myLogin, limit = 8 } = Astro.props as Props;

const visible = contributors.slice(0, limit);
const totalContributions = contributors.reduce((s, c) => s + c.contributions, 0);
---

{
  visible.length > 0 && (
    <div class="contrib-avatars">
      <h4 class="contrib-avatars-label">기여자 (상위 {visible.length})</h4>
      <ul class="contrib-avatars-list">
        {visible.map((c) => {
          const isMe = !!myLogin && c.login?.toLowerCase() === myLogin.toLowerCase();
          const pct = totalContributions > 0 ? (c.contributions / totalContributions) * 100 : 0;
          return (
            <li class={isMe ? 'contrib-avatar-me' : ''}>
              <a
                href={c.htmlUrl ?? `https://github.com/${c.login ?? ''}`}
                target="_blank"
                rel="noopener"
                class="contrib-avatar-link"
                aria-label={`${c.login ?? '(unknown)'}: ${c.contributions} 커밋`}
              >
                {c.avatarUrl ? (
                  <img
                    src={`${c.avatarUrl}${c.avatarUrl.includes('?') ? '&' : '?'}s=64`}
                    alt=""
                    loading="lazy"
                    width="32"
                    height="32"
                    class="contrib-avatar-img"
                  />
                ) : (
                  <span class="contrib-avatar-fallback">
                    {(c.login ?? '?').slice(0, 1).toUpperCase()}
                  </span>
                )}
                <span class="contrib-avatar-info">
                  <span class="contrib-avatar-name">{c.login ?? '(unknown)'}</span>
                  <span class="contrib-avatar-meta">
                    {c.contributions}회 · {pct.toFixed(0)}%
                  </span>
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  )
}

<style is:global>
  .contrib-avatars {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .contrib-avatars-label {
    margin: 0;
    font-size: 0.78rem;
    color: var(--color-fg-muted);
    font-weight: 500;
  }
  .contrib-avatars-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.4rem;
  }
  .contrib-avatar-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.45rem;
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
    background-color: var(--color-surface);
    color: var(--color-fg);
    text-decoration: none;
    font-size: 0.78rem;
  }
  .contrib-avatar-link:hover {
    border-color: var(--color-accent);
  }
  .contrib-avatar-me .contrib-avatar-link {
    border-color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-accent) 8%, var(--color-surface));
  }
  .contrib-avatar-img {
    border-radius: 50%;
    display: block;
  }
  .contrib-avatar-fallback {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-code-bg);
    color: var(--color-fg-muted);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
  }
  .contrib-avatar-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
    flex: 1;
  }
  .contrib-avatar-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-weight: 500;
  }
  .contrib-avatar-meta {
    color: var(--color-fg-muted);
    font-size: 0.68rem;
    font-family: var(--font-mono);
  }
</style>
