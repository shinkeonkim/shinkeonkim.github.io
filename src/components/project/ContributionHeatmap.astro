---
import type { CommitActivityWeek } from '../../lib/projects';

interface Props {
  weeks: CommitActivityWeek[];
}

const { weeks } = Astro.props as Props;

const CELL = 9;
const GAP = 2;
const ROWS = 7;

const allCounts = weeks.flatMap((w) => w.days ?? []);
const maxCount = Math.max(1, ...allCounts);

function intensity(count: number): number {
  if (count === 0) return 0;
  const ratio = count / maxCount;
  if (ratio < 0.2) return 1;
  if (ratio < 0.4) return 2;
  if (ratio < 0.7) return 3;
  return 4;
}

const cols = weeks.length;
const width = cols * (CELL + GAP) - GAP;
const height = ROWS * (CELL + GAP) - GAP;

const dateFmt = new Intl.DateTimeFormat('ko-KR', { year: 'numeric', month: 'short', day: 'numeric' });

interface Cell {
  x: number;
  y: number;
  count: number;
  level: number;
  date: string;
}

const cells: Cell[] = [];
for (let c = 0; c < weeks.length; c++) {
  const week = weeks[c];
  const days = week.days ?? [];
  for (let r = 0; r < ROWS; r++) {
    const count = days[r] ?? 0;
    const x = c * (CELL + GAP);
    const y = r * (CELL + GAP);
    const date = dateFmt.format(new Date((week.week + r * 86400) * 1000));
    cells.push({ x, y, count, level: intensity(count), date });
  }
}

const totalCommits = allCounts.reduce((a, b) => a + b, 0);
---
{weeks.length > 0 && totalCommits > 0 && (
  <div class="heatmap">
    <header class="heatmap-header">
      <span>52주 기여 히트맵 · 총 {totalCommits}회</span>
      <span class="heatmap-legend">
        <span>적음</span>
        <span class="heatmap-cell heatmap-l0"></span>
        <span class="heatmap-cell heatmap-l1"></span>
        <span class="heatmap-cell heatmap-l2"></span>
        <span class="heatmap-cell heatmap-l3"></span>
        <span class="heatmap-cell heatmap-l4"></span>
        <span>많음</span>
      </span>
    </header>
    <div class="heatmap-scroll">
      <svg
        class="heatmap-svg"
        viewBox={`0 0 ${width} ${height}`}
        width={width}
        height={height}
        role="img"
        aria-label={`52주 기여 히트맵: 총 ${totalCommits}회`}
      >
        {cells.map((c) => (
          <rect
            x={c.x}
            y={c.y}
            width={CELL}
            height={CELL}
            rx="1.5"
            class={`heatmap-rect heatmap-l${c.level}`}
          >
            <title>{c.date}: {c.count}회 커밋</title>
          </rect>
        ))}
      </svg>
    </div>
  </div>
)}

<style is:global>
  .heatmap {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .heatmap-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-fg-muted);
    flex-wrap: wrap;
  }
  .heatmap-legend {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 0.68rem;
  }
  .heatmap-cell {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    display: inline-block;
  }
  .heatmap-scroll {
    overflow-x: auto;
  }
  .heatmap-svg {
    display: block;
  }
  .heatmap-rect {
    transition: opacity 100ms;
  }
  .heatmap-l0 { fill: color-mix(in srgb, var(--color-border) 50%, transparent); background-color: color-mix(in srgb, var(--color-border) 50%, transparent); }
  .heatmap-l1 { fill: color-mix(in srgb, var(--color-accent) 22%, transparent); background-color: color-mix(in srgb, var(--color-accent) 22%, transparent); }
  .heatmap-l2 { fill: color-mix(in srgb, var(--color-accent) 45%, transparent); background-color: color-mix(in srgb, var(--color-accent) 45%, transparent); }
  .heatmap-l3 { fill: color-mix(in srgb, var(--color-accent) 70%, transparent); background-color: color-mix(in srgb, var(--color-accent) 70%, transparent); }
  .heatmap-l4 { fill: var(--color-accent); background-color: var(--color-accent); }
</style>
