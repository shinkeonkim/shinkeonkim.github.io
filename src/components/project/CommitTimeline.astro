---
import type { CommitActivityWeek } from '../../lib/projects';

interface Props {
  weeks: CommitActivityWeek[];
  label?: string;
}

const { weeks, label } = Astro.props as Props;

const VB_WIDTH = 520;
const VB_HEIGHT = 70;
const PADDING_X = 4;
const PADDING_Y = 6;
const plotW = VB_WIDTH - PADDING_X * 2;
const plotH = VB_HEIGHT - PADDING_Y * 2;

const totals = weeks.map((w) => w.total);
const totalCommits = totals.reduce((a, b) => a + b, 0);
const maxTotal = Math.max(1, ...totals);
const lastWeek = weeks[weeks.length - 1]?.week ?? 0;
const firstWeek = weeks[0]?.week ?? 0;

function pointAt(i: number, v: number): [number, number] {
  const x = weeks.length <= 1 ? plotW / 2 : (i / (weeks.length - 1)) * plotW;
  const y = plotH - (v / maxTotal) * plotH;
  return [PADDING_X + x, PADDING_Y + y];
}

const linePath =
  weeks.length === 0
    ? ''
    : weeks
        .map((w, i) => {
          const [x, y] = pointAt(i, w.total);
          return `${i === 0 ? 'M' : 'L'}${x.toFixed(2)},${y.toFixed(2)}`;
        })
        .join(' ');

const areaPath =
  weeks.length === 0
    ? ''
    : `${linePath} L${(PADDING_X + plotW).toFixed(2)},${(PADDING_Y + plotH).toFixed(2)} L${PADDING_X},${(PADDING_Y + plotH).toFixed(2)} Z`;

const dateFmt = new Intl.DateTimeFormat('ko-KR', { year: '2-digit', month: 'numeric' });
const firstLabel = firstWeek ? dateFmt.format(new Date(firstWeek * 1000)) : '';
const lastLabel = lastWeek ? dateFmt.format(new Date(lastWeek * 1000)) : '';
const peakIndex = totals.indexOf(maxTotal);
const peakDate = weeks[peakIndex]?.week
  ? dateFmt.format(new Date(weeks[peakIndex].week * 1000))
  : '';
---

{
  weeks.length > 0 && (
    <div class="commit-timeline">
      {label && <h4 class="commit-timeline-label">{label}</h4>}
      <div class="commit-timeline-meta">
        <span>
          최근 52주 커밋 <strong>{totalCommits}</strong>회
        </span>
        {maxTotal > 0 && peakDate && (
          <span>
            · 최다 주 <strong>{maxTotal}</strong> ({peakDate})
          </span>
        )}
      </div>
      <svg
        class="commit-timeline-svg"
        viewBox={`0 0 ${VB_WIDTH} ${VB_HEIGHT}`}
        preserveAspectRatio="none"
        role="img"
        aria-label={`최근 52주 커밋 활동: 총 ${totalCommits}회, 최다 ${maxTotal}회`}
      >
        <path d={areaPath} class="commit-timeline-area" />
        <path d={linePath} class="commit-timeline-line" />
      </svg>
      {firstLabel && lastLabel && (
        <div class="commit-timeline-axis">
          <span>{firstLabel}</span>
          <span>{lastLabel}</span>
        </div>
      )}
    </div>
  )
}

<style is:global>
  .commit-timeline {
    margin: 0;
  }
  .commit-timeline-label {
    margin: 0 0 0.35rem;
    font-size: 0.78rem;
    color: var(--color-fg-muted);
    font-weight: 500;
  }
  .commit-timeline-meta {
    font-size: 0.72rem;
    color: var(--color-fg-muted);
    margin-bottom: 0.25rem;
  }
  .commit-timeline-meta strong {
    color: var(--color-fg);
  }
  .commit-timeline-svg {
    display: block;
    width: 100%;
    height: 70px;
    overflow: visible;
  }
  .commit-timeline-area {
    fill: color-mix(in srgb, var(--color-accent) 22%, transparent);
  }
  .commit-timeline-line {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 1.5;
    stroke-linejoin: round;
    stroke-linecap: round;
  }
  .commit-timeline-axis {
    display: flex;
    justify-content: space-between;
    font-size: 0.68rem;
    color: var(--color-fg-muted);
    margin-top: 0.15rem;
    font-family: var(--font-mono);
  }
</style>
