---
import type { RepoRelease } from '../../lib/projects';

interface Props {
  releases: RepoRelease[];
  limit?: number;
}

const { releases, limit = 5 } = Astro.props as Props;

const dateFmt = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const items = releases.filter((r) => r.tag && r.publishedAt).slice(0, limit);
---

{
  items.length > 0 && (
    <div class="release-timeline">
      <h4 class="release-timeline-label">최근 릴리스 ({items.length})</h4>
      <ol class="release-timeline-list">
        {items.map((r) => (
          <li class="release-timeline-item">
            <a href={r.url ?? '#'} target="_blank" rel="noopener" class="release-timeline-link">
              <span class="release-timeline-tag">{r.tag}</span>
              {r.prerelease && <span class="release-timeline-pre">pre</span>}
              <span class="release-timeline-name">{r.name && r.name !== r.tag ? r.name : ''}</span>
              <time class="release-timeline-date" datetime={r.publishedAt ?? undefined}>
                {r.publishedAt ? dateFmt.format(new Date(r.publishedAt)) : ''}
              </time>
            </a>
          </li>
        ))}
      </ol>
    </div>
  )
}

<style is:global>
  .release-timeline {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .release-timeline-label {
    margin: 0;
    font-size: 0.78rem;
    color: var(--color-fg-muted);
    font-weight: 500;
  }
  .release-timeline-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .release-timeline-link {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.35rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: 0.35rem;
    background-color: var(--color-surface);
    color: var(--color-fg);
    text-decoration: none;
    font-size: 0.8rem;
  }
  .release-timeline-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .release-timeline-tag {
    font-family: var(--font-mono);
    color: var(--color-accent);
    font-weight: 600;
  }
  .release-timeline-pre {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-fg-muted);
    border: 1px solid var(--color-border);
    padding: 0 0.3rem;
    border-radius: 0.25rem;
  }
  .release-timeline-name {
    flex: 1;
    color: var(--color-fg-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .release-timeline-date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-fg-muted);
  }
</style>
