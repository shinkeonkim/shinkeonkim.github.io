---
import { NAV_ITEMS, DEV_NAV_ITEMS } from '../consts';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isDev = import.meta.env.DEV;
function isActive(href: string): boolean {
  const target = href.replace(/\/$/, '') || '/';
  if (target === '/') return pathname === '/';
  return pathname === target || pathname.startsWith(target + '/');
}
---

<button
  type="button"
  id="mobile-nav-open"
  aria-label="메뉴 열기"
  aria-controls="mobile-drawer"
  aria-expanded="false"
  class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] text-[color:var(--color-fg)] transition hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)] md:hidden"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <line x1="4" y1="6" x2="20" y2="6"></line>
    <line x1="4" y1="12" x2="20" y2="12"></line>
    <line x1="4" y1="18" x2="20" y2="18"></line>
  </svg>
</button>

<div id="mobile-drawer" class="mobile-drawer" aria-hidden="true" data-open="false">
  <div class="mobile-drawer-backdrop" data-drawer-close aria-hidden="true"></div>
  <aside
    class="mobile-drawer-panel"
    role="dialog"
    aria-modal="true"
    aria-label="네비게이션"
    id="mobile-drawer-panel"
  >
    <div class="mobile-drawer-header">
      <span class="mobile-drawer-title">메뉴</span>
      <button
        type="button"
        data-drawer-close
        aria-label="메뉴 닫기"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] text-[color:var(--color-fg)] transition hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="6" y1="6" x2="18" y2="18"></line>
          <line x1="6" y1="18" x2="18" y2="6"></line>
        </svg>
      </button>
    </div>
    <nav class="mobile-drawer-nav" data-drawer-nav aria-label="모바일 네비게이션">
      {
        NAV_ITEMS.map((item) => (
          <a
            href={item.href}
            class:list={['mobile-drawer-link', isActive(item.href) && 'is-active']}
          >
            {item.label}
          </a>
        ))
      }
      {isDev && (
        <Fragment>
          <div class="mobile-drawer-section-divider">
            <span>DEV</span>
          </div>
          {DEV_NAV_ITEMS.map((item) => (
            <a
              href={item.href}
              class:list={['mobile-drawer-link mobile-drawer-link-dev', isActive(item.href) && 'is-active']}
            >
              <span aria-hidden="true">{item.icon}</span>
              <span>{item.label}</span>
            </a>
          ))}
        </Fragment>
      )}
    </nav>
  </aside>
</div>

<style is:global>
  .mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 50;
    pointer-events: none;
  }
  .mobile-drawer[data-open='true'] {
    pointer-events: auto;
  }
  @media (min-width: 768px) {
    .mobile-drawer {
      display: none;
    }
  }

  .mobile-drawer-backdrop {
    position: absolute;
    inset: 0;
    background-color: rgba(8, 8, 12, 0.7);
    backdrop-filter: blur(6px);
    opacity: 0;
    transition: opacity 200ms ease-out;
  }
  .mobile-drawer[data-open='true'] .mobile-drawer-backdrop {
    opacity: 1;
  }

  .mobile-drawer-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    width: 18rem;
    max-width: 85vw;
    padding: 1rem;
    background-color: var(--color-surface);
    color: var(--color-fg);
    border-left: 1px solid var(--color-border);
    box-shadow: -16px 0 40px -12px rgba(0, 0, 0, 0.35);
    transform: translateX(100%);
    transition: transform 220ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .mobile-drawer[data-open='true'] .mobile-drawer-panel {
    transform: translateX(0);
  }

  .mobile-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  .mobile-drawer-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-fg-muted);
  }
  .mobile-drawer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .mobile-drawer-link {
    padding: 0.65rem 0.75rem;
    border-radius: 0.5rem;
    color: var(--color-fg);
    text-decoration: none;
    transition:
      background-color 120ms,
      color 120ms;
  }
  .mobile-drawer-link:hover {
    background-color: var(--color-surface-elevated);
    color: var(--color-accent);
  }
  .mobile-drawer-link.is-active {
    background-color: var(--color-surface-elevated);
    color: var(--color-accent);
  }
  .mobile-drawer-section-divider {
    margin: 0.5rem 0 0.25rem;
    padding: 0 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-fg-muted);
    letter-spacing: 0.1em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .mobile-drawer-section-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background-color: var(--color-border);
  }
  .mobile-drawer-link-dev {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-fg-muted);
    border: 1px dashed transparent;
  }
  .mobile-drawer-link-dev.is-active {
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
  }
</style>

<script is:inline>
  (function () {
    if (window.__mobileNavBound) return;
    window.__mobileNavBound = true;

    const openBtn = () => document.getElementById('mobile-nav-open');
    const drawer = () => document.getElementById('mobile-drawer');
    const panel = () => document.getElementById('mobile-drawer-panel');

    function portalDrawer() {
      const d = drawer();
      if (d && d.parentNode !== document.body) {
        document.body.appendChild(d);
      }
    }
    portalDrawer();
    document.addEventListener('astro:after-swap', portalDrawer);

    let lastFocused = null;

    function open() {
      const d = drawer();
      const p = panel();
      const ob = openBtn();
      if (!d || !p || !ob) return;
      lastFocused = document.activeElement;
      d.setAttribute('data-open', 'true');
      d.setAttribute('aria-hidden', 'false');
      ob.setAttribute('aria-expanded', 'true');
      document.body.classList.add('mobile-drawer-locked');
      const firstLink = p.querySelector('[data-drawer-nav] a');
      if (firstLink && typeof firstLink.focus === 'function') firstLink.focus();
    }

    function close() {
      const d = drawer();
      const ob = openBtn();
      if (!d || !ob) return;
      d.setAttribute('data-open', 'false');
      d.setAttribute('aria-hidden', 'true');
      ob.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('mobile-drawer-locked');
      if (lastFocused && typeof lastFocused.focus === 'function') lastFocused.focus();
    }

    document.addEventListener('click', (e) => {
      if (e.target.closest('#mobile-nav-open')) {
        open();
        return;
      }
      if (e.target.closest('[data-drawer-close]')) {
        close();
        return;
      }
      if (e.target.closest('[data-drawer-nav] a')) close();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      const d = drawer();
      if (d && d.getAttribute('data-open') === 'true') close();
    });

    const mql = window.matchMedia('(min-width: 768px)');
    mql.addEventListener('change', (e) => {
      if (e.matches) close();
    });
  })();
</script>
