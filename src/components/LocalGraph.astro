---
import { canonicalId, getSubgraph } from '../lib/content-graph';
import Graph from './Graph';
import type { GraphLink, GraphLinkKind, GraphNode } from './Graph';

interface Props {
  collection: 'posts' | 'wiki' | 'notes';
  slug: string;
  depth?: number;
  includeTags?: boolean;
}

const { collection, slug, depth = 1, includeTags = true } = Astro.props as Props;
const centerId = canonicalId(collection, slug);
const sub = await getSubgraph(centerId, { depth, includeTags });

const graphNodes: GraphNode[] = sub.nodes.map((n) => ({
  id: n.id,
  title: n.title,
  url: n.url,
  group: n.collection,
  kind: n.kind,
  degree: n.degree,
}));
const graphLinks: GraphLink[] = sub.links.map((l) => ({
  source: String(l.source),
  target: String(l.target),
  kind: l.kind as GraphLinkKind | undefined,
}));

const neighborCount = Math.max(0, graphNodes.length - 1);
const hide = graphNodes.length <= 1;
---
{!hide && (
  <aside class="local-graph not-prose" data-pagefind-ignore="all">
    <header class="local-graph-header">
      <h3 class="local-graph-title">🌐 인접 그래프</h3>
      <span class="local-graph-meta">{neighborCount}개 이웃 노드</span>
      <a href="/graph/" class="local-graph-fullpage">전체 그래프 →</a>
    </header>
    <div class="local-graph-stage">
      <Graph nodes={graphNodes} links={graphLinks} height={280} client:visible />
    </div>
  </aside>
)}

<style is:global>
  .local-graph {
    margin-top: 2.5rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.6rem;
    background-color: var(--color-surface-elevated);
  }
  .local-graph-header {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-bottom: 0.6rem;
  }
  .local-graph-title {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 600;
  }
  .local-graph-meta {
    font-size: 0.72rem;
    color: var(--color-fg-muted);
  }
  .local-graph-fullpage {
    margin-left: auto;
    font-size: 0.78rem;
    color: var(--color-accent);
    text-decoration: none;
  }
  .local-graph-fullpage:hover {
    text-decoration: underline;
  }
  .local-graph-stage {
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
    background-color: var(--color-surface);
    overflow: hidden;
  }
</style>
