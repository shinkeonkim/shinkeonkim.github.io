---
import { loadProjectStats, parseGitHubUrl, type ProjectStatRepo } from '../lib/projects';
import CommitTimeline from './project/CommitTimeline.astro';
import LanguageDonut from './project/LanguageDonut.astro';
import ContributionHeatmap from './project/ContributionHeatmap.astro';
import ContributorAvatars from './project/ContributorAvatars.astro';
import ReleaseTimeline from './project/ReleaseTimeline.astro';

interface Props {
  projectId: string;
  repos: { url: string; label?: string; track: boolean }[];
  myLogin?: string;
}

const { projectId, repos, myLogin = 'shinkeonkim' } = Astro.props as Props;
const cache = await loadProjectStats();
const entry = cache[projectId];

interface RepoView {
  url: string;
  label: string;
  stat?: ProjectStatRepo;
}

const repoViews: RepoView[] = repos.map((r) => {
  const parsed = parseGitHubUrl(r.url);
  const stat = entry?.repos.find((s) => s.owner === parsed?.owner && s.repo === parsed?.repo);
  return {
    url: r.url,
    label: r.label ?? (parsed ? `${parsed.owner}/${parsed.repo}` : r.url),
    stat,
  };
});

const myCommitsTotal = repoViews.reduce((sum, v) => sum + (v.stat?.myCommits ?? 0), 0);
const totalCommitsTotal = repoViews.reduce((sum, v) => sum + (v.stat?.totalCommits ?? 0), 0);
const sharePct = totalCommitsTotal > 0 ? Math.round((myCommitsTotal / totalCommitsTotal) * 100) : 0;
const fetchedAt = entry?.fetchedAt ? new Date(entry.fetchedAt) : null;
const dateFmt = new Intl.DateTimeFormat('ko-KR', { year: 'numeric', month: 'short', day: 'numeric' });
---
<section class="project-stats not-prose" data-pagefind-ignore="all">
  <header class="project-stats-header">
    <h2 class="project-stats-title">📊 GitHub 활동</h2>
    {fetchedAt && (
      <span class="project-stats-fetched">캐시 갱신: {fetchedAt.toLocaleDateString('ko-KR')}</span>
    )}
  </header>

  {totalCommitsTotal > 0 ? (
    <div class="project-stats-summary">
      <div class="project-stats-share-bar">
        <div class="project-stats-share-fill" style={`width:${sharePct}%`}></div>
      </div>
      <p class="project-stats-share-label">
        본인 커밋 <strong>{myCommitsTotal}</strong> / 전체 <strong>{totalCommitsTotal}</strong>
        <span class="project-stats-share-pct">· 기여 비율 {sharePct}%</span>
      </p>
    </div>
  ) : (
    <p class="project-stats-empty">
      통계 캐시가 비어 있습니다. <code>uv run scripts/fetch-project-stats.py --user {myLogin}</code> 로 갱신하세요.
    </p>
  )}

  <div class="project-stats-repos">
    {repoViews.map((v) => (
      <article class="project-stats-repo-card">
        <header class="project-stats-repo-card-header">
          <a href={v.url} target="_blank" rel="noopener" class="project-stats-repo-link">
            <span class="project-stats-repo-icon" aria-hidden="true">⌥</span>
            <span class="project-stats-repo-label">{v.label}</span>
          </a>
          {v.stat ? (
            <div class="project-stats-repo-badges">
              {v.stat.stars !== undefined && v.stat.stars !== null && (
                <span class="project-stats-badge" title="Stars">★ {v.stat.stars}</span>
              )}
              {v.stat.forks !== undefined && v.stat.forks !== null && v.stat.forks > 0 && (
                <span class="project-stats-badge" title="Forks">⑂ {v.stat.forks}</span>
              )}
              {v.stat.license && <span class="project-stats-badge" title="License">⚖ {v.stat.license}</span>}
              {v.stat.pushedAt && (
                <span class="project-stats-badge" title="Last push">⏱ {dateFmt.format(new Date(v.stat.pushedAt))}</span>
              )}
            </div>
          ) : (
            <span class="project-stats-repo-missing">통계 없음</span>
          )}
        </header>

        {v.stat && (
          <div class="project-stats-numbers">
            <span>커밋 <strong>{v.stat.myCommits}</strong> / {v.stat.totalCommits}</span>
            {(v.stat.additions || v.stat.deletions) && (
              <span>
                <span class="project-stats-add">+{v.stat.additions}</span>
                {' / '}
                <span class="project-stats-del">-{v.stat.deletions}</span>
              </span>
            )}
            {v.stat.firstCommitDate && (
              <span>{dateFmt.format(new Date(v.stat.firstCommitDate))} 부터</span>
            )}
          </div>
        )}

        {v.stat?.commitActivity && v.stat.commitActivity.length > 0 && (
          <div class="project-stats-section">
            <CommitTimeline weeks={v.stat.commitActivity} />
          </div>
        )}

        {(v.stat?.languages && Object.keys(v.stat.languages).length > 0) || (v.stat?.topContributors && v.stat.topContributors.length > 0) ? (
          <div class="project-stats-side-by-side">
            {v.stat?.languages && Object.keys(v.stat.languages).length > 0 && (
              <div class="project-stats-section">
                <h4 class="project-stats-section-title">언어 비율</h4>
                <LanguageDonut languages={v.stat.languages} />
              </div>
            )}
            {v.stat?.topContributors && v.stat.topContributors.length > 0 && (
              <div class="project-stats-section">
                <ContributorAvatars contributors={v.stat.topContributors} myLogin={myLogin} />
              </div>
            )}
          </div>
        ) : null}

        {v.stat?.commitActivity && v.stat.commitActivity.some((w) => w.total > 0) && (
          <div class="project-stats-section">
            <ContributionHeatmap weeks={v.stat.commitActivity} />
          </div>
        )}

        {v.stat?.releases && v.stat.releases.length > 0 && (
          <div class="project-stats-section">
            <ReleaseTimeline releases={v.stat.releases} />
          </div>
        )}

        {v.stat?.topics && v.stat.topics.length > 0 && (
          <ul class="project-stats-topics">
            {v.stat.topics.map((t) => (
              <li>#{t}</li>
            ))}
          </ul>
        )}
      </article>
    ))}
  </div>
</section>

<style is:global>
  .project-stats {
    margin-top: 2rem;
    padding: 1rem 1.2rem;
    border: 1px solid var(--color-border);
    border-radius: 0.6rem;
    background-color: var(--color-surface-elevated);
  }
  .project-stats-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .project-stats-title {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 600;
  }
  .project-stats-fetched {
    font-size: 0.72rem;
    color: var(--color-fg-muted);
  }
  .project-stats-empty {
    margin: 0 0 0.75rem;
    padding: 0.5rem 0.65rem;
    font-size: 0.8rem;
    color: var(--color-fg-muted);
    border-radius: 0.35rem;
    background-color: var(--color-code-bg);
  }
  .project-stats-share-bar {
    height: 10px;
    border-radius: 999px;
    background-color: var(--color-code-bg);
    overflow: hidden;
  }
  .project-stats-share-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-hover));
  }
  .project-stats-share-label {
    margin: 0.4rem 0 0;
    font-size: 0.85rem;
    color: var(--color-fg);
  }
  .project-stats-share-pct {
    margin-left: 0.4rem;
    color: var(--color-fg-muted);
  }
  .project-stats-repos {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }
  .project-stats-repo-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 0.85rem 0.95rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background-color: var(--color-surface);
  }
  .project-stats-repo-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .project-stats-repo-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    color: var(--color-fg);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
  }
  .project-stats-repo-link:hover {
    color: var(--color-accent);
  }
  .project-stats-repo-icon {
    color: var(--color-fg-muted);
    font-weight: 400;
  }
  .project-stats-repo-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .project-stats-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.05rem 0.45rem;
    border-radius: 999px;
    background-color: var(--color-code-bg);
    color: var(--color-fg-muted);
    font-size: 0.7rem;
    font-family: var(--font-mono);
  }
  .project-stats-repo-missing {
    font-size: 0.72rem;
    color: var(--color-fg-muted);
    font-style: italic;
  }
  .project-stats-numbers {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    font-size: 0.78rem;
    color: var(--color-fg-muted);
    padding-bottom: 0.25rem;
    border-bottom: 1px dashed var(--color-border);
  }
  .project-stats-numbers strong {
    color: var(--color-fg);
  }
  .project-stats-add {
    color: #10b981;
  }
  .project-stats-del {
    color: #ef4444;
  }
  .project-stats-section {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .project-stats-section-title {
    margin: 0;
    font-size: 0.78rem;
    color: var(--color-fg-muted);
    font-weight: 500;
  }
  .project-stats-side-by-side {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }
  @media (min-width: 600px) {
    .project-stats-side-by-side {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    }
  }
  .project-stats-topics {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    font-size: 0.7rem;
    color: var(--color-fg-muted);
  }
  .project-stats-topics li {
    padding: 0.05rem 0.45rem;
    border-radius: 999px;
    background-color: var(--color-code-bg);
    font-family: var(--font-mono);
  }
</style>
