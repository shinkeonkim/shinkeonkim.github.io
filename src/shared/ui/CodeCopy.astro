<script>
  function initCodeCopy() {
    document.querySelectorAll<HTMLElement>('.prose-content pre.astro-code').forEach((pre) => {
      if (pre.dataset.copyBound === 'true') return;
      pre.dataset.copyBound = 'true';
      pre.style.position = pre.style.position || 'relative';

      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'code-copy-btn';
      button.setAttribute('aria-label', '코드 복사');
      button.textContent = '복사';

      button.addEventListener('click', async (e) => {
        e.stopPropagation();
        const codeEl = pre.querySelector('code');
        const text = codeEl?.textContent ?? pre.textContent ?? '';
        try {
          await navigator.clipboard.writeText(text);
          button.textContent = '복사됨 ✓';
          button.classList.add('is-copied');
        } catch {
          button.textContent = '실패';
        }
        setTimeout(() => {
          button.textContent = '복사';
          button.classList.remove('is-copied');
        }, 1600);
      });

      pre.appendChild(button);
    });
  }
  initCodeCopy();
  document.addEventListener('astro:page-load', initCodeCopy);
</script>

<style is:global>
  .prose-content pre.astro-code {
    position: relative;
  }
  .prose-content pre.astro-code .code-copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.15rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: 0.3rem;
    background-color: color-mix(in srgb, var(--color-surface) 90%, transparent);
    color: var(--color-fg-muted);
    font-size: 0.7rem;
    font-family: var(--font-mono);
    cursor: pointer;
    opacity: 0;
    transition:
      opacity 100ms,
      border-color 100ms,
      color 100ms;
  }
  .prose-content pre.astro-code:hover .code-copy-btn,
  .prose-content pre.astro-code .code-copy-btn:focus-visible {
    opacity: 1;
  }
  .prose-content pre.astro-code .code-copy-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .prose-content pre.astro-code .code-copy-btn.is-copied {
    color: #10b981;
    border-color: #10b981;
    opacity: 1;
  }
</style>
