---
import { type CollectionEntry } from 'astro:content';
import { getPublishedPosts } from '../../lib/content-queries';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Pagination from '../../components/Pagination.astro';
import { SITE_LOCALE, POSTS_PER_PAGE } from '../../consts';
import { listCategoryInfos, listSeriesInfos } from '../../lib/taxonomy';
import { absoluteUrl, breadcrumbSchema, collectionPageSchema } from '../../lib/schema';
import type { GetStaticPaths, Page } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getPublishedPosts()).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  return paginate(posts, { pageSize: POSTS_PER_PAGE });
}) satisfies GetStaticPaths;

type Props = { page: Page<CollectionEntry<'posts'>> };
const { page } = Astro.props as Props;

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const [categories, seriesList] = await Promise.all([listCategoryInfos(), listSeriesInfos()]);
const showIndex = page.currentPage === 1 && (categories.length > 0 || seriesList.length > 0);

const grouped = new Map<number, CollectionEntry<'posts'>[]>();
for (const post of page.data) {
  const y = post.data.date.getFullYear();
  if (!grouped.has(y)) grouped.set(y, []);
  grouped.get(y)!.push(post);
}
const years = Array.from(grouped.keys()).sort((a, b) => b - a);

const pageDescription = page.currentPage === 1
  ? `김신건의 개발 블로그 글 모음 — Python, Django, Astro, 알고리즘, 웹 개발 등 ${page.total}개의 기술 글.`
  : `김신건의 개발 블로그 글 ${page.currentPage}페이지 — 총 ${page.total}개 글의 ${page.currentPage}/${page.lastPage}.`;

const jsonLd = [
  collectionPageSchema({
    name: '글',
    description: pageDescription,
    url: absoluteUrl(page.url.current),
    itemCount: page.total,
  }),
  breadcrumbSchema([
    { name: '글', url: absoluteUrl('/posts/') },
    ...(page.currentPage > 1 ? [{ name: `${page.currentPage}페이지`, url: absoluteUrl(page.url.current) }] : []),
  ]),
];

const prevUrl = page.url.prev ? absoluteUrl(page.url.prev) : undefined;
const nextUrl = page.url.next ? absoluteUrl(page.url.next) : undefined;
---
<BaseLayout
  title={page.currentPage > 1 ? `글 (${page.currentPage}페이지)` : '글'}
  description={pageDescription}
  jsonLd={jsonLd}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
>
  <section class="mx-auto max-w-3xl px-5" data-pagefind-ignore="all">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">글</h1>
    <p class="mb-8 text-[color:var(--color-fg-muted)]">총 {page.total}개의 글 · {page.currentPage} / {page.lastPage} 페이지</p>

    {showIndex && (
      <div class="mb-10 grid gap-4 md:grid-cols-2">
        {categories.length > 0 && (
          <section>
            <h2 class="mb-2 text-sm font-semibold text-[color:var(--color-fg-muted)]">📁 카테고리</h2>
            <ul class="flex flex-wrap gap-1.5">
              {categories.map((c) => (
                <li>
                  <a href={`/posts/category/${encodeURIComponent(c.slug)}/`} class="inline-flex items-center gap-1 rounded-full border border-[color:var(--color-border)] px-2.5 py-0.5 text-sm no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]">
                    {c.label} <span class="opacity-60 text-xs">({c.count})</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}
        {seriesList.length > 0 && (
          <section>
            <h2 class="mb-2 text-sm font-semibold text-[color:var(--color-fg-muted)]">📚 시리즈</h2>
            <ul class="flex flex-wrap gap-1.5">
              {seriesList.map((s) => (
                <li>
                  <a href={`/posts/series/${encodeURIComponent(s.slug)}/`} class="inline-flex items-center gap-1 rounded-full border border-[color:var(--color-border)] px-2.5 py-0.5 text-sm no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]">
                    {s.name} <span class="opacity-60 text-xs">({s.count}편)</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}
      </div>
    )}

    {page.data.length === 0 ? (
      <p class="text-sm text-[color:var(--color-fg-muted)]">아직 작성된 글이 없습니다.</p>
    ) : (
      <div class="space-y-10">
        {years.map((year) => (
          <section>
            <h2 class="mb-3 text-lg font-semibold text-[color:var(--color-fg-muted)]">{year}</h2>
            <ul class="space-y-2">
              {grouped.get(year)!.map((p) => (
                <li class="flex gap-3 border-b border-[color:var(--color-border)] py-3">
                  {(p.data.thumbnail ?? p.data.cover) && (
                    <a href={`/posts/${p.id}/`} class="shrink-0">
                      <img
                        src={p.data.thumbnail ?? p.data.cover}
                        alt=""
                        loading="lazy"
                        class="h-16 w-24 rounded-md border border-[color:var(--color-border)] object-cover"
                      />
                    </a>
                  )}
                  <div class="flex-1 min-w-0">
                    <a href={`/posts/${p.id}/`} class="block text-base font-medium">{p.data.title}</a>
                    {p.data.description && (
                      <p class="mt-0.5 text-sm text-[color:var(--color-fg-muted)]">{p.data.description}</p>
                    )}
                    <div class="mt-1 flex flex-wrap items-center gap-2 text-xs text-[color:var(--color-fg-muted)]">
                      <time datetime={p.data.date.toISOString()}>{fmt.format(p.data.date)}</time>
                      {p.data.series && <span>· 📚 {p.data.series}</span>}
                      {p.data.tags.length > 0 && (
                        <span class="flex flex-wrap gap-1">
                          {p.data.tags.map((t) => <span>#{t}</span>)}
                        </span>
                      )}
                    </div>
                  </div>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    )}

    <Pagination currentPage={page.currentPage} lastPage={page.lastPage} baseUrl="/posts/" />
  </section>
</BaseLayout>
