---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Pagination from '../../components/Pagination.astro';
import { SITE_LOCALE, POSTS_PER_PAGE } from '../../consts';
import type { GetStaticPaths, Page } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection('posts', ({ data }) => !data.draft))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return paginate(posts, { pageSize: POSTS_PER_PAGE });
}) satisfies GetStaticPaths;

type Props = { page: Page<CollectionEntry<'posts'>> };
const { page } = Astro.props as Props;

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const grouped = new Map<number, CollectionEntry<'posts'>[]>();
for (const post of page.data) {
  const y = post.data.date.getFullYear();
  if (!grouped.has(y)) grouped.set(y, []);
  grouped.get(y)!.push(post);
}
const years = Array.from(grouped.keys()).sort((a, b) => b - a);
---
<BaseLayout title={page.currentPage > 1 ? `글 (${page.currentPage}페이지)` : '글'} description="작성된 글 목록">
  <section class="mx-auto max-w-3xl px-5" data-pagefind-ignore="all">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">글</h1>
    <p class="mb-8 text-[color:var(--color-fg-muted)]">총 {page.total}개의 글 · {page.currentPage} / {page.lastPage} 페이지</p>

    {page.data.length === 0 ? (
      <p class="text-sm text-[color:var(--color-fg-muted)]">아직 작성된 글이 없습니다.</p>
    ) : (
      <div class="space-y-10">
        {years.map((year) => (
          <section>
            <h2 class="mb-3 text-lg font-semibold text-[color:var(--color-fg-muted)]">{year}</h2>
            <ul class="space-y-2">
              {grouped.get(year)!.map((p) => (
                <li class="flex flex-col gap-1 border-b border-[color:var(--color-border)] py-3 sm:flex-row sm:items-baseline sm:gap-4">
                  <time datetime={p.data.date.toISOString()} class="shrink-0 text-sm text-[color:var(--color-fg-muted)] sm:w-32">
                    {fmt.format(p.data.date)}
                  </time>
                  <div class="flex-1">
                    <a href={`/posts/${p.id}/`} class="block text-base font-medium">{p.data.title}</a>
                    {p.data.description && (
                      <p class="mt-0.5 text-sm text-[color:var(--color-fg-muted)]">{p.data.description}</p>
                    )}
                    {p.data.tags.length > 0 && (
                      <div class="mt-1 flex flex-wrap gap-1 text-xs text-[color:var(--color-fg-muted)]">
                        {p.data.tags.map((t) => (
                          <span>#{t}</span>
                        ))}
                      </div>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    )}

    <Pagination currentPage={page.currentPage} lastPage={page.lastPage} baseUrl="/posts/" />
  </section>
</BaseLayout>
