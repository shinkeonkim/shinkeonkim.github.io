---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getPostTaxonomy, listCategoryInfos } from '../../../lib/taxonomy';
import { absoluteUrl, breadcrumbSchema, collectionPageSchema } from '../../../lib/schema';
import { SITE_LOCALE } from '@/shared/config';

const RECENT_COUNT = 3;

const [categories, taxonomy] = await Promise.all([listCategoryInfos(), getPostTaxonomy()]);

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const cards = categories.map((c) => ({
  slug: c.slug,
  label: c.label,
  count: c.count,
  recent: (taxonomy.categories.get(c.slug) ?? []).slice(0, RECENT_COUNT),
}));

const total = categories.length;
const description = `김신건의 개발 블로그 글 카테고리 ${total}개, 카테고리별 최근 글을 한눈에.`;

const jsonLd = [
  collectionPageSchema({
    name: '카테고리',
    description,
    url: absoluteUrl('/posts/categories/'),
    itemCount: total,
  }),
  breadcrumbSchema([
    { name: '글', url: absoluteUrl('/posts/') },
    { name: '카테고리', url: absoluteUrl('/posts/categories/') },
  ]),
];
---

<BaseLayout title="카테고리" description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-4xl px-5">
    <nav class="mb-4 text-sm">
      <a
        href="/posts/"
        class="text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-accent)]"
      >
        ← 글
      </a>
    </nav>
    <h1 class="mb-2 text-3xl font-bold tracking-tight">📁 카테고리</h1>
    <p class="mb-8 text-[color:var(--color-fg-muted)]">총 {total}개</p>

    {
      total === 0 ? (
        <p class="text-sm text-[color:var(--color-fg-muted)]">
          아직 카테고리가 없습니다.
        </p>
      ) : (
        <ul class="grid gap-4 md:grid-cols-2">
          {cards.map((c) => (
            <li class="rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-4">
              <div class="flex items-baseline justify-between gap-2">
                <a
                  href={`/posts/category/${encodeURIComponent(c.slug)}/`}
                  class="text-lg font-semibold no-underline hover:text-[color:var(--color-accent)]"
                >
                  {c.label}
                </a>
                <span class="text-xs text-[color:var(--color-fg-muted)]">
                  {c.count}개
                </span>
              </div>
              {c.recent.length > 0 && (
                <ul class="mt-3 space-y-1.5 text-sm">
                  {c.recent.map((p) => (
                    <li class="flex items-baseline justify-between gap-2">
                      <a
                        href={`/posts/${p.id}/`}
                        class="truncate text-[color:var(--color-fg)] no-underline hover:text-[color:var(--color-accent)]"
                      >
                        {p.data.title}
                      </a>
                      <time
                        datetime={p.data.date.toISOString()}
                        class="shrink-0 text-xs text-[color:var(--color-fg-muted)]"
                      >
                        {fmt.format(p.data.date)}
                      </time>
                    </li>
                  ))}
                </ul>
              )}
              {c.count > RECENT_COUNT && (
                <p class="mt-3 text-xs">
                  <a
                    href={`/posts/category/${encodeURIComponent(c.slug)}/`}
                    class="text-[color:var(--color-accent)]"
                  >
                    전체 {c.count}개 보기 →
                  </a>
                </p>
              )}
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
