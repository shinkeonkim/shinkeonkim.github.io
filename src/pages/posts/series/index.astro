---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { listSeriesInfos } from '../../../lib/taxonomy';
import { absoluteUrl, breadcrumbSchema, collectionPageSchema } from '../../../lib/schema';
import { SITE_LOCALE } from '@/shared/config';

const PREVIEW_COUNT = 3;

const seriesList = await listSeriesInfos();

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const cards = seriesList.map((s) => ({
  slug: s.slug,
  name: s.name,
  count: s.count,
  latest: s.posts[s.posts.length - 1]?.data.date,
  recent: s.posts.slice(-PREVIEW_COUNT).reverse(),
}));

const total = seriesList.length;
const description = `김신건의 개발 블로그 시리즈 ${total}개. 알고리즘, 아키텍처, 회고록 등 묶음 글을 한곳에.`;

const jsonLd = [
  collectionPageSchema({
    name: '시리즈',
    description,
    url: absoluteUrl('/posts/series/'),
    itemCount: total,
  }),
  breadcrumbSchema([
    { name: '글', url: absoluteUrl('/posts/') },
    { name: '시리즈', url: absoluteUrl('/posts/series/') },
  ]),
];
---

<BaseLayout title="시리즈" description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-4xl px-5">
    <nav class="mb-4 text-sm">
      <a
        href="/posts/"
        class="text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-accent)]"
      >
        ← 글
      </a>
    </nav>
    <h1 class="mb-2 text-3xl font-bold tracking-tight">📚 시리즈</h1>
    <p class="mb-8 text-[color:var(--color-fg-muted)]">총 {total}개</p>

    {
      total === 0 ? (
        <p class="text-sm text-[color:var(--color-fg-muted)]">
          아직 시리즈가 없습니다.
        </p>
      ) : (
        <ul class="grid gap-4 md:grid-cols-2">
          {cards.map((s) => (
            <li class="rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-4">
              <div class="flex items-baseline justify-between gap-2">
                <a
                  href={`/posts/series/${encodeURIComponent(s.slug)}/`}
                  class="text-lg font-semibold no-underline hover:text-[color:var(--color-accent)]"
                >
                  {s.name}
                </a>
                <span class="text-xs text-[color:var(--color-fg-muted)]">
                  {s.count}편
                </span>
              </div>
              {s.latest && (
                <p class="mt-1 text-xs text-[color:var(--color-fg-muted)]">
                  최근:{' '}
                  <time datetime={s.latest.toISOString()}>{fmt.format(s.latest)}</time>
                </p>
              )}
              {s.recent.length > 0 && (
                <ul class="mt-3 space-y-1.5 text-sm">
                  {s.recent.map((p) => (
                    <li class="flex items-baseline justify-between gap-2">
                      <a
                        href={`/posts/${p.id}/`}
                        class="truncate text-[color:var(--color-fg)] no-underline hover:text-[color:var(--color-accent)]"
                      >
                        {p.data.title}
                      </a>
                      <time
                        datetime={p.data.date.toISOString()}
                        class="shrink-0 text-xs text-[color:var(--color-fg-muted)]"
                      >
                        {fmt.format(p.data.date)}
                      </time>
                    </li>
                  ))}
                </ul>
              )}
              {s.count > PREVIEW_COUNT && (
                <p class="mt-3 text-xs">
                  <a
                    href={`/posts/series/${encodeURIComponent(s.slug)}/`}
                    class="text-[color:var(--color-accent)]"
                  >
                    전체 {s.count}편 보기 →
                  </a>
                </p>
              )}
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
