---
import { type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Pagination from '../../../../components/Pagination.astro';
import { POSTS_PER_PAGE, SITE_LOCALE } from '../../../../consts';
import { getPostTaxonomy } from '../../../../lib/taxonomy';
import { absoluteUrl, breadcrumbSchema, collectionPageSchema } from '../../../../lib/schema';
import type { GetStaticPaths, Page } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const taxonomy = await getPostTaxonomy();
  const all: { params: { series: string }; props: { seriesName: string } }[] = [];
  for (const info of taxonomy.series.values()) {
    const paginated = paginate(info.posts, { pageSize: POSTS_PER_PAGE, params: { series: info.slug } });
    all.push(...paginated.map((p) => ({ ...p, props: { ...p.props, seriesName: info.name } })) as never[]);
  }
  return all;
}) satisfies GetStaticPaths;

type Props = { page: Page<CollectionEntry<'posts'>>; seriesName: string };
const { page, seriesName } = Astro.props as Props;

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const seriesSlug = Astro.params.series;

const seriesBase = `/posts/series/${seriesSlug}/`;
const pageDescription = `'${seriesName}' 시리즈에 속한 글 ${page.total}편. ${page.data[0]?.data.title ? `1편: ${page.data[0].data.title}` : ''}`.trim();

const jsonLd = [
  collectionPageSchema({
    name: `${seriesName} 시리즈`,
    description: pageDescription,
    url: absoluteUrl(page.url.current),
    itemCount: page.total,
  }),
  breadcrumbSchema([
    { name: '글', url: absoluteUrl('/posts/') },
    { name: seriesName, url: absoluteUrl(seriesBase) },
  ]),
];

const prevUrl = page.url.prev ? absoluteUrl(page.url.prev) : undefined;
const nextUrl = page.url.next ? absoluteUrl(page.url.next) : undefined;
---
<BaseLayout
  title={page.currentPage > 1 ? `📚 ${seriesName} (${page.currentPage}페이지)` : `📚 ${seriesName}`}
  description={pageDescription}
  jsonLd={jsonLd}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
  keywords={[seriesName, '시리즈', '글']}
>
  <section class="mx-auto max-w-3xl px-5" data-pagefind-ignore="all">
    <nav class="mb-3 text-xs text-[color:var(--color-fg-muted)]">
      <a href="/posts/" class="hover:text-[color:var(--color-accent)]">글</a>
      <span class="mx-1">/</span>
      <span>시리즈</span>
    </nav>
    <h1 class="mb-2 flex items-center gap-2 text-3xl font-bold tracking-tight">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-[color:var(--color-surface-elevated)] text-base">📚</span>
      <span>{seriesName}</span>
    </h1>
    <p class="mb-8 text-[color:var(--color-fg-muted)]">총 {page.total}편 · {page.currentPage} / {page.lastPage} 페이지</p>

    <ol class="space-y-2">
      {page.data.map((p, i) => {
        const order = (page.currentPage - 1) * POSTS_PER_PAGE + i + 1;
        return (
          <li class="flex items-baseline gap-3 border-b border-[color:var(--color-border)] py-3">
            <span class="shrink-0 w-8 text-right text-sm font-mono text-[color:var(--color-fg-muted)]">{order}.</span>
            <div class="flex-1 min-w-0">
              <a href={`/posts/${p.id}/`} class="block text-base font-medium">{p.data.title}</a>
              {p.data.description && (
                <p class="mt-0.5 text-sm text-[color:var(--color-fg-muted)] truncate">{p.data.description}</p>
              )}
              <time datetime={p.data.date.toISOString()} class="text-xs text-[color:var(--color-fg-muted)]">{fmt.format(p.data.date)}</time>
            </div>
          </li>
        );
      })}
    </ol>

    <Pagination currentPage={page.currentPage} lastPage={page.lastPage} baseUrl={`/posts/series/${seriesSlug}/`} />
  </section>
</BaseLayout>
