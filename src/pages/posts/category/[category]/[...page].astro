---
import { type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Pagination from '../../../../components/Pagination.astro';
import { POSTS_PER_PAGE, SITE_LOCALE } from '../../../../consts';
import { getPostTaxonomy, slugify } from '../../../../lib/taxonomy';
import { absoluteUrl, breadcrumbSchema, collectionPageSchema } from '../../../../lib/schema';
import type { GetStaticPaths, Page } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const taxonomy = await getPostTaxonomy();
  const all: { params: { category: string }; props: { categoryName: string } }[] = [];
  for (const [category, items] of taxonomy.categories) {
    const paginated = paginate(items, { pageSize: POSTS_PER_PAGE, params: { category } });
    all.push(
      ...(paginated.map((p) => ({
        ...p,
        props: { ...p.props, categoryName: category },
      })) as never[]),
    );
  }
  return all;
}) satisfies GetStaticPaths;

type Props = { page: Page<CollectionEntry<'posts'>>; categoryName: string };
const { page, categoryName } = Astro.props as Props;

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryBase = `/posts/category/${encodeURIComponent(categoryName)}/`;
const pageDescription =
  `${categoryName} 카테고리에 속한 글 ${page.total}개 모음. ${page.data[0]?.data.title ? `최신 글: ${page.data[0].data.title}` : ''}`.trim();

const jsonLd = [
  collectionPageSchema({
    name: `${categoryName} 카테고리`,
    description: pageDescription,
    url: absoluteUrl(page.url.current),
    itemCount: page.total,
  }),
  breadcrumbSchema([
    { name: '글', url: absoluteUrl('/posts/') },
    { name: categoryName, url: absoluteUrl(categoryBase) },
  ]),
];

const prevUrl = page.url.prev ? absoluteUrl(page.url.prev) : undefined;
const nextUrl = page.url.next ? absoluteUrl(page.url.next) : undefined;
---

<BaseLayout
  title={page.currentPage > 1
    ? `📁 ${categoryName} (${page.currentPage}페이지)`
    : `📁 ${categoryName}`}
  description={pageDescription}
  jsonLd={jsonLd}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
  keywords={[categoryName, '카테고리', '글']}
>
  <section class="mx-auto max-w-3xl px-5" data-pagefind-ignore="all">
    <nav class="mb-3 text-xs text-[color:var(--color-fg-muted)]">
      <a href="/posts/" class="hover:text-[color:var(--color-accent)]">글</a>
      <span class="mx-1">/</span>
      <span>카테고리</span>
    </nav>
    <h1 class="mb-2 flex items-center gap-2 text-3xl font-bold tracking-tight">
      <span
        class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-[color:var(--color-surface-elevated)] text-base"
        >📁</span
      >
      <span>{categoryName}</span>
    </h1>
    <p class="mb-8 text-[color:var(--color-fg-muted)]">
      총 {page.total}개의 글 · {page.currentPage} / {page.lastPage} 페이지
    </p>

    <ul class="space-y-2">
      {
        page.data.map((p) => (
          <li class="flex gap-4 border-b border-[color:var(--color-border)] py-3">
            {(p.data.thumbnail ?? p.data.cover) && (
              <a href={`/posts/${p.id}/`} class="shrink-0">
                <img
                  src={p.data.thumbnail ?? p.data.cover}
                  alt=""
                  width="96"
                  height="64"
                  class="h-16 w-24 rounded-md object-cover"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            )}
            <div class="flex-1 min-w-0">
              <a href={`/posts/${p.id}/`} class="block text-base font-medium">
                {p.data.title}
              </a>
              {p.data.description && (
                <p class="mt-0.5 text-sm text-[color:var(--color-fg-muted)] truncate">
                  {p.data.description}
                </p>
              )}
              <div class="mt-1 flex flex-wrap gap-2 text-xs text-[color:var(--color-fg-muted)]">
                <time datetime={p.data.date.toISOString()}>{fmt.format(p.data.date)}</time>
                {p.data.series && (
                  <a
                    href={`/posts/series/${encodeURIComponent(slugify(p.data.series))}/`}
                    class="post-list-meta-link post-list-meta-series"
                    title={`시리즈: ${p.data.series}`}
                  >
                    📚 {p.data.series}
                  </a>
                )}
                {p.data.tags.map((t) => (
                  <a
                    href={`/tags/${encodeURIComponent(t.toLowerCase())}/`}
                    class="post-list-meta-link post-list-meta-tag"
                    title={`태그: ${t}`}
                  >
                    #{t}
                  </a>
                ))}
              </div>
            </div>
          </li>
        ))
      }
    </ul>

    <Pagination
      currentPage={page.currentPage}
      lastPage={page.lastPage}
      baseUrl={`/posts/category/${categoryName}/`}
    />
  </section>
</BaseLayout>
