---
import { type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Pagination from '../../../../components/Pagination.astro';
import { POSTS_PER_PAGE, SITE_LOCALE } from '../../../../consts';
import { getPostTaxonomy } from '../../../../lib/taxonomy';
import type { GetStaticPaths, Page } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const taxonomy = await getPostTaxonomy();
  const all: { params: { category: string }; props: { categoryName: string } }[] = [];
  for (const [category, items] of taxonomy.categories) {
    const paginated = paginate(items, { pageSize: POSTS_PER_PAGE, params: { category } });
    all.push(...paginated.map((p) => ({ ...p, props: { ...p.props, categoryName: category } })) as never[]);
  }
  return all;
}) satisfies GetStaticPaths;

type Props = { page: Page<CollectionEntry<'posts'>>; categoryName: string };
const { page, categoryName } = Astro.props as Props;

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<BaseLayout
  title={page.currentPage > 1 ? `📁 ${categoryName} (${page.currentPage}페이지)` : `📁 ${categoryName}`}
  description={`${categoryName} 카테고리의 글 목록`}
>
  <section class="mx-auto max-w-3xl px-5" data-pagefind-ignore="all">
    <nav class="mb-3 text-xs text-[color:var(--color-fg-muted)]">
      <a href="/posts/" class="hover:text-[color:var(--color-accent)]">글</a>
      <span class="mx-1">/</span>
      <span>카테고리</span>
    </nav>
    <h1 class="mb-2 flex items-center gap-2 text-3xl font-bold tracking-tight">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-[color:var(--color-surface-elevated)] text-base">📁</span>
      <span>{categoryName}</span>
    </h1>
    <p class="mb-8 text-[color:var(--color-fg-muted)]">총 {page.total}개의 글 · {page.currentPage} / {page.lastPage} 페이지</p>

    <ul class="space-y-2">
      {page.data.map((p) => (
        <li class="flex gap-4 border-b border-[color:var(--color-border)] py-3">
          {(p.data.thumbnail ?? p.data.cover) && (
            <a href={`/posts/${p.id}/`} class="shrink-0">
              <img src={p.data.thumbnail ?? p.data.cover} alt="" class="h-16 w-24 rounded-md object-cover" loading="lazy" />
            </a>
          )}
          <div class="flex-1 min-w-0">
            <a href={`/posts/${p.id}/`} class="block text-base font-medium">{p.data.title}</a>
            {p.data.description && (
              <p class="mt-0.5 text-sm text-[color:var(--color-fg-muted)] truncate">{p.data.description}</p>
            )}
            <div class="mt-1 flex flex-wrap gap-2 text-xs text-[color:var(--color-fg-muted)]">
              <time datetime={p.data.date.toISOString()}>{fmt.format(p.data.date)}</time>
              {p.data.series && <span>📚 {p.data.series}</span>}
              {p.data.tags.map((t) => <span>#{t}</span>)}
            </div>
          </div>
        </li>
      ))}
    </ul>

    <Pagination currentPage={page.currentPage} lastPage={page.lastPage} baseUrl={`/posts/category/${categoryName}/`} />
  </section>
</BaseLayout>
