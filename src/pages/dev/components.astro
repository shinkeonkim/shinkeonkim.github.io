---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeWithOutput from '../../components/CodeWithOutput.astro';
import UrlPreview from '../../components/UrlPreview.astro';
import YouTube from '../../components/embed/YouTube.astro';
import Vimeo from '../../components/embed/Vimeo.astro';
import Gist from '../../components/embed/Gist.astro';
import Tweet from '../../components/embed/Tweet.astro';
import CodePen from '../../components/embed/CodePen.astro';
import Figma from '../../components/embed/Figma.astro';

interface Section {
  id: string;
  title: string;
  props: string;
  notes?: string;
}

const sections: Section[] = [
  {
    id: 'code-with-output',
    title: 'CodeWithOutput',
    props: '{ code, language, output, outputLanguage, variants?, codeWidth?, title? }',
    notes: 'Shiki 하이라이팅 + 결과 분할. variants 로 다국어 탭.',
  },
  {
    id: 'mermaid',
    title: 'Mermaid (코드 블록)',
    props: '```mermaid 코드블록',
    notes: '클릭 → 줌 다이얼로그, ⤓ SVG/PNG 다운로드.',
  },
  {
    id: 'url-preview',
    title: 'UrlPreview',
    props: '{ url }',
    notes: 'OG 메타데이터 빌드시 캐싱 → src/data/url-previews.json',
  },
  {
    id: 'youtube',
    title: 'YouTube',
    props: '{ id, title?, start?, cookieless? }',
  },
  {
    id: 'vimeo',
    title: 'Vimeo',
    props: '{ id, title? }',
  },
  {
    id: 'gist',
    title: 'GitHub Gist',
    props: '{ id, user?, file? }',
  },
  {
    id: 'tweet',
    title: 'Tweet / X',
    props: '{ id, user?, align?, theme? }',
    notes: 'platform.twitter.com/widgets.js lazy load. SSR 불가, JS 필요.',
  },
  {
    id: 'codepen',
    title: 'CodePen',
    props: '{ id, user, tab?, height?, theme? }',
  },
  {
    id: 'figma',
    title: 'Figma',
    props: '{ fileUrl? | embedUrl?, title?, height? }',
  },
];
---

<BaseLayout
  title="컴포넌트 갤러리"
  description="MDX 안에서 사용할 수 있는 모든 컴포넌트의 라이브 데모와 props 표."
  noIndex
>
  <article class="container-prose prose-content" data-pagefind-ignore="all">
    <nav class="not-prose mb-6 rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-3 text-xs">
      <strong class="block mb-1">목차</strong>
      <ul class="flex flex-wrap gap-x-3 gap-y-1">
        {sections.map((s) => (
          <li><a href={`#${s.id}`} class="hover:text-[color:var(--color-accent)]">{s.title}</a></li>
        ))}
      </ul>
    </nav>

    <h1>컴포넌트 갤러리</h1>
    <p>
      MDX 글 안에서 사용 가능한 모든 reusable 컴포넌트의 라이브 데모. 글
      작성 시 import 후 사용. <code>noIndex</code> — 검색엔진 색인 제외.
    </p>

    <section id="code-with-output">
      <h2>CodeWithOutput</h2>
      <p>{sections[0].notes}</p>
      <p>Props: <code>{sections[0].props}</code></p>
      <CodeWithOutput
        code={`print("hello world")\n# multiple lines\nfor i in range(3):\n    print(i)`}
        language="python"
        output={`hello world\n0\n1\n2`}
        outputLabel="REPL"
      />
    </section>

    <section id="mermaid">
      <h2>Mermaid</h2>
      <p>{sections[1].notes}</p>
      <pre class="mermaid">{`flowchart LR
  A[Idea] --> B(Sketch)
  B --> C{Refine?}
  C -- yes --> B
  C -- no --> D[Ship]`}</pre>
    </section>

    <section id="url-preview">
      <h2>UrlPreview</h2>
      <p>{sections[2].notes}</p>
      <p>Props: <code>{sections[2].props}</code></p>
      <UrlPreview url="https://astro.build" />
    </section>

    <section id="youtube">
      <h2>YouTube</h2>
      <p>Props: <code>{sections[3].props}</code></p>
      <YouTube id="dQw4w9WgXcQ" title="Rick Astley - Never Gonna Give You Up" />
    </section>

    <section id="vimeo">
      <h2>Vimeo</h2>
      <p>Props: <code>{sections[4].props}</code></p>
      <Vimeo id="76979871" title="Vimeo demo" />
    </section>

    <section id="gist">
      <h2>GitHub Gist</h2>
      <p>Props: <code>{sections[5].props}</code></p>
      <Gist id="3866323" />
    </section>

    <section id="tweet">
      <h2>Tweet / X</h2>
      <p>{sections[6].notes}</p>
      <p>Props: <code>{sections[6].props}</code></p>
      <Tweet id="1779574045258997919" user="astrodotbuild" />
    </section>

    <section id="codepen">
      <h2>CodePen</h2>
      <p>Props: <code>{sections[7].props}</code></p>
      <CodePen id="ZYYQoy" user="chriscoyier" title="CodePen demo" />
    </section>

    <section id="figma">
      <h2>Figma</h2>
      <p>Props: <code>{sections[8].props}</code></p>
      <Figma fileUrl="https://www.figma.com/proto/X4SsK5z2P5p5x3D8eA1Yz/Sample" title="Figma proto" />
    </section>

    <hr />

    <h2>Props 요약</h2>
    <table>
      <thead>
        <tr><th>컴포넌트</th><th>Props</th><th>참고</th></tr>
      </thead>
      <tbody>
        {sections.map((s) => (
          <tr>
            <td><a href={`#${s.id}`}>{s.title}</a></td>
            <td><code>{s.props}</code></td>
            <td>{s.notes ?? ''}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </article>
</BaseLayout>
