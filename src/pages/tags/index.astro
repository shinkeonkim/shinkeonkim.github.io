---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { absoluteUrl, breadcrumbSchema, collectionPageSchema } from '@/shared/lib/seo/schema';
import { getPublishedNotes, getPublishedPosts, getPublishedWiki } from '@/shared/lib/content/content-queries';
import { canonicalizeTag, getTagMeta, listTagMetadata } from '../../data/tags';

const [posts, wiki, notes] = await Promise.all([
  getPublishedPosts(),
  getPublishedWiki(),
  getPublishedNotes(),
]);

// counts keyed by canonical tag (PS + 문제풀이 → ps, JavaScript + js → javascript).
// labels: canonical → display label. Meta-registered tags display their canonical
// (e.g. javascript, postgresql); unregistered ones use the first raw spelling seen.
const counts = new Map<string, number>();
const labels = new Map<string, string>();

function bump(raw: string): void {
  const canonical = canonicalizeTag(raw);
  counts.set(canonical, (counts.get(canonical) ?? 0) + 1);
  if (!labels.has(canonical)) {
    const meta = getTagMeta(canonical);
    labels.set(canonical, meta?.canonical ?? raw);
  }
}

for (const p of posts) for (const t of p.data.tags) bump(t);
for (const w of wiki) for (const t of w.data.tags) bump(t);
for (const n of notes) for (const t of n.data.tags) bump(t);

const tags = Array.from(counts.entries()).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
const totalTags = tags.length;
const maxCount = tags[0]?.[1] ?? 1;

function tagSize(count: number): string {
  const ratio = count / maxCount;
  if (ratio > 0.66) return 'text-base font-semibold';
  if (ratio > 0.33) return 'text-sm font-medium';
  return 'text-xs';
}

// 주제별 메타 카드: description 이 등록된 메타만 노출. count 0 인 메타는 숨김.
const featuredMeta = listTagMetadata()
  .filter((m) => m.description && (counts.get(canonicalizeTag(m.canonical)) ?? 0) > 0)
  .map((m) => {
    const canonical = canonicalizeTag(m.canonical);
    return {
      canonical,
      label: labels.get(canonical) ?? m.canonical,
      description: m.description!,
      related: m.related ?? [],
      count: counts.get(canonical) ?? 0,
    };
  })
  .sort((a, b) => b.count - a.count || a.canonical.localeCompare(b.canonical));

const pageDescription = `김신건의 로그에서 사용된 ${totalTags}개의 태그, Python, 알고리즘, Django, Astro, 웹 개발 등 주제별로 글·노트·위키를 모아봅니다.`;

const jsonLd = [
  collectionPageSchema({
    name: '태그',
    description: pageDescription,
    url: absoluteUrl('/tags/'),
    itemCount: totalTags,
  }),
  breadcrumbSchema([{ name: '태그', url: absoluteUrl('/tags/') }]),
];
---

<BaseLayout
  title="태그"
  description={pageDescription}
  jsonLd={jsonLd}
  keywords={['태그', '주제별 글', '아카이브']}
>
  <section class="mx-auto max-w-3xl px-5" data-pagefind-ignore="all">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">태그</h1>
    <p class="mb-2 text-fg-muted">총 {totalTags}개의 태그</p>
    <p class="mb-8 text-sm text-fg-muted">
      관심 주제로 글·노트·위키를 모아봅니다. 자주 다루는 키워드일수록 크게 표시됩니다.
    </p>

    {
      featuredMeta.length > 0 && (
        <section class="mb-10">
          <h2 class="mb-3 text-lg font-semibold">주제별 태그</h2>
          <ul class="grid gap-3 sm:grid-cols-2">
            {featuredMeta.map((m) => (
              <li class="rounded-lg border border-border p-3 hover:border-accent">
                <a
                  href={`/tags/${encodeURIComponent(m.canonical)}/`}
                  class="block no-underline"
                >
                  <span class="mb-1 flex items-baseline justify-between gap-2">
                    <span class="text-base font-medium">#{m.label}</span>
                    <span class="text-xs text-fg-muted">{m.count}</span>
                  </span>
                  <span class="block text-sm text-fg-muted">
                    {m.description}
                  </span>
                </a>
                {m.related.length > 0 && (
                  <p class="mt-2 flex flex-wrap items-baseline gap-1 text-xs text-fg-muted">
                    {m.related.map((r) => (
                      <a
                        href={`/tags/${encodeURIComponent(r.toLowerCase())}/`}
                        class="inline-flex items-center rounded-full border border-border px-2 py-0.5 no-underline hover:border-accent hover:text-accent"
                      >
                        #{r}
                      </a>
                    ))}
                  </p>
                )}
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      tags.length === 0 ? (
        <p class="text-sm text-fg-muted">아직 태그가 없습니다.</p>
      ) : (
        <ul class="flex flex-wrap items-baseline gap-x-3 gap-y-2">
          {tags.map(([canonical, count]) => (
            <li>
              <a
                href={`/tags/${encodeURIComponent(canonical)}/`}
                class:list={[
                  'inline-flex items-baseline gap-1 rounded-md px-2 py-1 no-underline hover:bg-surface-elevated hover:text-accent',
                  tagSize(count),
                ]}
              >
                <span>#{labels.get(canonical) ?? canonical}</span>
                <span class="text-xs opacity-60">{count}</span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
