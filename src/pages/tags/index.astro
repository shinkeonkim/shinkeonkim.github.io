---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { absoluteUrl, breadcrumbSchema, collectionPageSchema } from '../../lib/schema';
import { getPublishedNotes, getPublishedPosts, getPublishedWiki } from '../../lib/content-queries';

const [posts, wiki, notes] = await Promise.all([
  getPublishedPosts(),
  getPublishedWiki(),
  getPublishedNotes(),
]);

const counts = new Map<string, number>();
for (const p of posts) for (const t of p.data.tags) counts.set(t, (counts.get(t) ?? 0) + 1);
for (const w of wiki) for (const t of w.data.tags) counts.set(t, (counts.get(t) ?? 0) + 1);
for (const n of notes) for (const t of n.data.tags) counts.set(t, (counts.get(t) ?? 0) + 1);

const tags = Array.from(counts.entries()).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
const totalTags = tags.length;
const maxCount = tags[0]?.[1] ?? 1;

function tagSize(count: number): string {
  const ratio = count / maxCount;
  if (ratio > 0.66) return 'text-base font-semibold';
  if (ratio > 0.33) return 'text-sm font-medium';
  return 'text-xs';
}

const pageDescription = `김신건의 로그에서 사용된 ${totalTags}개의 태그 — Python, 알고리즘, Django, Astro, 웹 개발 등 주제별로 글·노트·위키를 모아봅니다.`;

const jsonLd = [
  collectionPageSchema({
    name: '태그',
    description: pageDescription,
    url: absoluteUrl('/tags/'),
    itemCount: totalTags,
  }),
  breadcrumbSchema([
    { name: '태그', url: absoluteUrl('/tags/') },
  ]),
];
---
<BaseLayout
  title="태그"
  description={pageDescription}
  jsonLd={jsonLd}
  keywords={['태그', '주제별 글', '아카이브']}
>
  <section class="mx-auto max-w-3xl px-5" data-pagefind-ignore="all">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">태그</h1>
    <p class="mb-2 text-[color:var(--color-fg-muted)]">총 {totalTags}개의 태그</p>
    <p class="mb-8 text-sm text-[color:var(--color-fg-muted)]">
      관심 주제로 글·노트·위키를 모아봅니다. 자주 다루는 키워드일수록 크게 표시됩니다.
    </p>

    {tags.length === 0 ? (
      <p class="text-sm text-[color:var(--color-fg-muted)]">아직 태그가 없습니다.</p>
    ) : (
      <ul class="flex flex-wrap items-baseline gap-x-3 gap-y-2">
        {tags.map(([tag, count]) => (
          <li>
            <a
              href={`/tags/${encodeURIComponent(tag)}/`}
              class:list={[
                'inline-flex items-baseline gap-1 rounded-md px-2 py-1 no-underline hover:bg-[color:var(--color-surface-elevated)] hover:text-[color:var(--color-accent)]',
                tagSize(count),
              ]}
            >
              <span>#{tag}</span>
              <span class="text-xs opacity-60">{count}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
