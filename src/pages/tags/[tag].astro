---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_LOCALE, SITE_URL } from '../../consts';
import { breadcrumbSchema, collectionPageSchema, absoluteUrl } from '../../lib/schema';
import { getPublishedNotes, getPublishedPosts, getPublishedWiki } from '../../lib/content-queries';
import { canonicalizeTag, getTagMeta, tagToSlug } from '../../data/tags';

// Tag routes are keyed by canonical slug (NFC + lowercase, alias-resolved).
// Alias slugs (e.g. /tags/ps/, /tags/문제풀이/) also render the same canonical
// content; their <link rel="canonical"> points to the canonical URL so search
// engines consolidate duplicates. See manual-docs/tag-meta-guide.md.
export async function getStaticPaths() {
  const [posts, wiki, notes] = await Promise.all([
    getPublishedPosts(),
    getPublishedWiki(),
    getPublishedNotes(),
  ]);

  // canonical slug → first-seen display label.
  // Meta-registered canonicals prefer the canonical itself as the label
  // (e.g. javascript, postgresql) for consistency; others use the first raw spelling.
  const canonicalToLabel = new Map<string, string>();
  const addTag = (raw: string): void => {
    const canonical = canonicalizeTag(raw);
    if (!canonicalToLabel.has(canonical)) {
      const meta = getTagMeta(canonical);
      canonicalToLabel.set(canonical, meta?.canonical ?? raw);
    }
  };
  for (const p of posts) p.data.tags.forEach(addTag);
  for (const w of wiki) w.data.tags.forEach(addTag);
  for (const n of notes) n.data.tags.forEach(addTag);

  // Emit canonical slug entries + one entry per registered alias.
  // All alias entries share the same props as the canonical so the rendered
  // content is identical; only `isAlias` differs to drive <link rel="canonical">.
  const entries: {
    params: { tag: string };
    props: { canonicalSlug: string; displayLabel: string; isAlias: boolean };
  }[] = [];
  const seenSlugs = new Set<string>();
  // Raw alias slug preserves the original casing ('PS', 'JavaScript') so direct
  // links like /tags/PS/ resolve. Only strips URL-unsafe characters; no lowercase.
  const rawAliasSlug = (alias: string): string =>
    alias.normalize('NFC').replace(/[\\/?#%]+/g, '-').replace(/^-+|-+$/g, '');

  const pushEntry = (slug: string, canonicalSlug: string, displayLabel: string, isAlias: boolean) => {
    if (!slug || seenSlugs.has(slug)) return;
    seenSlugs.add(slug);
    entries.push({ params: { tag: slug }, props: { canonicalSlug, displayLabel, isAlias } });
  };

  for (const [canonicalSlug, displayLabel] of canonicalToLabel) {
    pushEntry(canonicalSlug, canonicalSlug, displayLabel, false);
    const meta = getTagMeta(canonicalSlug);
    for (const alias of meta?.aliases ?? []) {
      pushEntry(tagToSlug(alias), canonicalSlug, displayLabel, true);
      pushEntry(rawAliasSlug(alias), canonicalSlug, displayLabel, true);
    }
  }

  return entries;
}

interface Props {
  canonicalSlug: string;
  displayLabel: string;
  isAlias: boolean;
}
const { canonicalSlug, displayLabel, isAlias } = Astro.props as Props;
const matchesTag = (raw: string): boolean => canonicalizeTag(raw) === canonicalSlug;

const [posts, wiki, notes] = await Promise.all([
  getCollection('posts', ({ data }) => !data.draft && data.tags.some(matchesTag)),
  getCollection('wiki', ({ data }) => data.tags.some(matchesTag)),
  getCollection('notes', ({ data }) => data.tags.some(matchesTag)),
]);

const tag = displayLabel;

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
wiki.sort((a, b) => a.data.title.localeCompare(b.data.title));
notes.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const tagMeta = getTagMeta(canonicalSlug);
const tagDescription = tagMeta?.description;
const relatedTags = tagMeta?.related ?? [];

const canonicalPath = `/tags/${encodeURIComponent(canonicalSlug)}/`;
const tagUrl = absoluteUrl(canonicalPath);
const totalCount = posts.length + wiki.length + notes.length;
const pageTitle = `#${tag}`;
const pageDescription =
  `'${tag}' 태그가 붙은 글 ${posts.length}개, 위키 ${wiki.length}개, 노트 ${notes.length}개. ${posts[0]?.data.title ? `최근 글: ${posts[0].data.title}` : ''}`.trim();

const jsonLd = [
  collectionPageSchema({
    name: `#${tag}`,
    description: pageDescription,
    url: tagUrl,
    itemCount: totalCount,
  }),
  breadcrumbSchema([
    { name: '태그', url: absoluteUrl('/tags/') },
    { name: `#${tag}`, url: tagUrl },
  ]),
];

void SITE_URL;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  jsonLd={jsonLd}
  keywords={[tag!, '태그', '아카이브']}
  canonicalUrl={isAlias ? canonicalPath : undefined}
>
  <section class="mx-auto max-w-3xl px-5" data-pagefind-ignore="all">
    <nav class="mb-3 text-xs text-[color:var(--color-fg-muted)]">
      <a href="/tags/" class="hover:text-[color:var(--color-accent)]">태그</a>
      <span class="mx-1">/</span>
      <span>#{tag}</span>
    </nav>
    <h1 class="mb-2 text-3xl font-bold tracking-tight">#{tag}</h1>
    <p class="mb-2 text-[color:var(--color-fg-muted)]">
      글 {posts.length}개 · 위키 {wiki.length}개 · 노트 {notes.length}개
    </p>
    {
      tagDescription ? (
        <p class="mb-4 text-sm text-[color:var(--color-fg-muted)]">{tagDescription}</p>
      ) : (
        <p class="mb-4 text-sm text-[color:var(--color-fg-muted)]">
          <code>#{tag}</code> 와 관련된 글과 위키 페이지를 모아둔 곳입니다.
        </p>
      )
    }
    {
      relatedTags.length > 0 && (
        <p class="mb-8 flex flex-wrap items-baseline gap-1.5 text-xs text-[color:var(--color-fg-muted)]">
          <span class="uppercase tracking-wide">관련 태그</span>
          {relatedTags.map((t) => (
            <a
              href={`/tags/${encodeURIComponent(t.toLowerCase())}/`}
              class="inline-flex items-center rounded-full border border-[color:var(--color-border)] px-2 py-0.5 no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
            >
              #{t}
            </a>
          ))}
        </p>
      )
    }
    {!tagDescription && relatedTags.length === 0 && <div class="mb-8" />}

    {
      posts.length > 0 && (
        <section class="mb-10">
          <h2 class="mb-3 text-lg font-semibold">글</h2>
          <ul class="space-y-3">
            {posts.map((p) => (
              <li class="border-b border-[color:var(--color-border)] pb-2">
                <a href={`/posts/${p.id}/`} class="block text-base font-medium">
                  {p.data.title}
                </a>
                <time
                  datetime={p.data.date.toISOString()}
                  class="text-xs text-[color:var(--color-fg-muted)]"
                >
                  {fmt.format(p.data.date)}
                </time>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      wiki.length > 0 && (
        <section class="mb-10">
          <h2 class="mb-3 text-lg font-semibold">위키</h2>
          <ul class="space-y-2">
            {wiki.map((w) => (
              <li>
                <a href={`/wiki/${w.id}/`}>{w.data.title}</a>
                {w.data.updated && (
                  <span class="ml-2 text-xs text-[color:var(--color-fg-muted)]">
                    {fmt.format(w.data.updated)} 업데이트
                  </span>
                )}
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      notes.length > 0 && (
        <section>
          <h2 class="mb-3 text-lg font-semibold">노트</h2>
          <ol class="space-y-1.5 border-l border-[color:var(--color-border)] pl-4">
            {notes.map((n) => (
              <li class="text-sm">
                <a
                  href={`/notes/${n.id}/`}
                  class="text-[color:var(--color-fg)] hover:text-[color:var(--color-accent)]"
                >
                  <time datetime={n.data.date.toISOString()} class="text-xs text-[color:var(--color-fg-muted)]">
                    {fmt.format(n.data.date)}
                  </time>
                  <span class="ml-2">↗ {n.id}</span>
                </a>
              </li>
            ))}
          </ol>
        </section>
      )
    }
  </section>
</BaseLayout>
