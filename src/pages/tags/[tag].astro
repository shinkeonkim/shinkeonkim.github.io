---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_LOCALE, SITE_URL } from '../../consts';
import { breadcrumbSchema, collectionPageSchema, absoluteUrl } from '../../lib/schema';
import { getPublishedNotes, getPublishedPosts, getPublishedWiki } from '../../lib/content-queries';

// Routes use lowercase tag slugs so URLs like /tags/leetcode/ resolve
// regardless of whether the source frontmatter wrote "Leetcode" or "leetcode".
// The display label preserves the first-seen original casing.
export async function getStaticPaths() {
  const [posts, wiki, notes] = await Promise.all([
    getPublishedPosts(),
    getPublishedWiki(),
    getPublishedNotes(),
  ]);
  const slugToLabel = new Map<string, string>();
  const addTag = (raw: string): void => {
    const slug = raw.toLowerCase();
    if (!slugToLabel.has(slug)) slugToLabel.set(slug, raw);
  };
  for (const p of posts) p.data.tags.forEach(addTag);
  for (const w of wiki) w.data.tags.forEach(addTag);
  for (const n of notes) n.data.tags.forEach(addTag);
  return Array.from(slugToLabel.entries()).map(([slug, label]) => ({
    params: { tag: slug },
    props: { tagLabel: label },
  }));
}

interface Props {
  tagLabel: string;
}
const { tagLabel } = Astro.props as Props;
const tagSlug = Astro.params.tag!;
const matchesTag = (t: string): boolean => t.toLowerCase() === tagSlug;

const [posts, wiki, notes] = await Promise.all([
  getCollection('posts', ({ data }) => !data.draft && data.tags.some(matchesTag)),
  getCollection('wiki', ({ data }) => data.tags.some(matchesTag)),
  getCollection('notes', ({ data }) => data.tags.some(matchesTag)),
]);

const tag = tagLabel;

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
wiki.sort((a, b) => a.data.title.localeCompare(b.data.title));
notes.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const tagUrl = absoluteUrl(`/tags/${encodeURIComponent(tagSlug)}/`);
const totalCount = posts.length + wiki.length + notes.length;
const pageTitle = `#${tag}`;
const pageDescription =
  `'${tag}' 태그가 붙은 글 ${posts.length}개, 위키 ${wiki.length}개, 노트 ${notes.length}개. ${posts[0]?.data.title ? `최근 글: ${posts[0].data.title}` : ''}`.trim();

const jsonLd = [
  collectionPageSchema({
    name: `#${tag}`,
    description: pageDescription,
    url: tagUrl,
    itemCount: totalCount,
  }),
  breadcrumbSchema([
    { name: '태그', url: absoluteUrl('/tags/') },
    { name: `#${tag}`, url: tagUrl },
  ]),
];

void SITE_URL;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  jsonLd={jsonLd}
  keywords={[tag!, '태그', '아카이브']}
>
  <section class="mx-auto max-w-3xl px-5" data-pagefind-ignore="all">
    <nav class="mb-3 text-xs text-[color:var(--color-fg-muted)]">
      <a href="/tags/" class="hover:text-[color:var(--color-accent)]">태그</a>
      <span class="mx-1">/</span>
      <span>#{tag}</span>
    </nav>
    <h1 class="mb-2 text-3xl font-bold tracking-tight">#{tag}</h1>
    <p class="mb-2 text-[color:var(--color-fg-muted)]">
      글 {posts.length}개 · 위키 {wiki.length}개 · 노트 {notes.length}개
    </p>
    <p class="mb-8 text-sm text-[color:var(--color-fg-muted)]">
      <code>#{tag}</code> 와 관련된 글과 위키 페이지를 모아둔 곳입니다. 같은 주제의 다른 글을 찾거나,
      시리즈로 이어진 내용을 따라 읽고 싶을 때 사용하세요.
    </p>

    {
      posts.length > 0 && (
        <section class="mb-10">
          <h2 class="mb-3 text-lg font-semibold">글</h2>
          <ul class="space-y-3">
            {posts.map((p) => (
              <li class="border-b border-[color:var(--color-border)] pb-2">
                <a href={`/posts/${p.id}/`} class="block text-base font-medium">
                  {p.data.title}
                </a>
                <time
                  datetime={p.data.date.toISOString()}
                  class="text-xs text-[color:var(--color-fg-muted)]"
                >
                  {fmt.format(p.data.date)}
                </time>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      wiki.length > 0 && (
        <section class="mb-10">
          <h2 class="mb-3 text-lg font-semibold">위키</h2>
          <ul class="space-y-2">
            {wiki.map((w) => (
              <li>
                <a href={`/wiki/${w.id}/`}>{w.data.title}</a>
                {w.data.updated && (
                  <span class="ml-2 text-xs text-[color:var(--color-fg-muted)]">
                    {fmt.format(w.data.updated)} 업데이트
                  </span>
                )}
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      notes.length > 0 && (
        <section>
          <h2 class="mb-3 text-lg font-semibold">노트</h2>
          <ol class="space-y-1.5 border-l border-[color:var(--color-border)] pl-4">
            {notes.map((n) => (
              <li class="text-sm">
                <a
                  href={`/notes/#${n.id}`}
                  class="text-[color:var(--color-fg)] hover:text-[color:var(--color-accent)]"
                >
                  <time datetime={n.data.date.toISOString()} class="text-xs text-[color:var(--color-fg-muted)]">
                    {fmt.format(n.data.date)}
                  </time>
                  <span class="ml-2">↗ {n.id}</span>
                </a>
              </li>
            ))}
          </ol>
        </section>
      )
    }
  </section>
</BaseLayout>
