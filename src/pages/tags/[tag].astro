---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_LOCALE } from '../../consts';

export async function getStaticPaths() {
  const [posts, wiki] = await Promise.all([
    getCollection('posts', ({ data }) => !data.draft),
    getCollection('wiki'),
  ]);
  const tags = new Set<string>();
  for (const p of posts) p.data.tags.forEach((t) => tags.add(t));
  for (const w of wiki) w.data.tags.forEach((t) => tags.add(t));
  return Array.from(tags).map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;

const [posts, wiki] = await Promise.all([
  getCollection('posts', ({ data }) => !data.draft && data.tags.includes(tag!)),
  getCollection('wiki', ({ data }) => data.tags.includes(tag!)),
]);

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
wiki.sort((a, b) => a.data.title.localeCompare(b.data.title));
---
<BaseLayout title={`#${tag}`} description={`#${tag} 태그가 붙은 글과 위키`}>
  <section class="mx-auto max-w-3xl px-5" data-pagefind-ignore="all">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">#{tag}</h1>
    <p class="mb-8 text-[color:var(--color-fg-muted)]">글 {posts.length}개 · 위키 {wiki.length}개</p>

    {posts.length > 0 && (
      <section class="mb-10">
        <h2 class="mb-3 text-lg font-semibold">글</h2>
        <ul class="space-y-3">
          {posts.map((p) => (
            <li class="border-b border-[color:var(--color-border)] pb-2">
              <a href={`/posts/${p.id}/`} class="block text-base font-medium">{p.data.title}</a>
              <time datetime={p.data.date.toISOString()} class="text-xs text-[color:var(--color-fg-muted)]">
                {fmt.format(p.data.date)}
              </time>
            </li>
          ))}
        </ul>
      </section>
    )}

    {wiki.length > 0 && (
      <section>
        <h2 class="mb-3 text-lg font-semibold">위키</h2>
        <ul class="space-y-2">
          {wiki.map((w) => (
            <li>
              <a href={`/wiki/${w.id}/`}>{w.data.title}</a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </section>
</BaseLayout>
