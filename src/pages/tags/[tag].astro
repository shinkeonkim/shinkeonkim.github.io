---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_LOCALE, SITE_URL } from '../../consts';
import { breadcrumbSchema, collectionPageSchema, absoluteUrl } from '../../lib/schema';

export async function getStaticPaths() {
  const [posts, wiki] = await Promise.all([
    getCollection('posts', ({ data }) => !data.draft),
    getCollection('wiki'),
  ]);
  const tags = new Set<string>();
  for (const p of posts) p.data.tags.forEach((t) => tags.add(t));
  for (const w of wiki) w.data.tags.forEach((t) => tags.add(t));
  return Array.from(tags).map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;

const [posts, wiki] = await Promise.all([
  getCollection('posts', ({ data }) => !data.draft && data.tags.includes(tag!)),
  getCollection('wiki', ({ data }) => data.tags.includes(tag!)),
]);

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
wiki.sort((a, b) => a.data.title.localeCompare(b.data.title));

const tagUrl = absoluteUrl(`/tags/${encodeURIComponent(tag!)}/`);
const totalCount = posts.length + wiki.length;
const pageTitle = `#${tag}`;
const pageDescription = `'${tag}' 태그가 붙은 글 ${posts.length}개와 위키 ${wiki.length}개. ${posts[0]?.data.title ? `최근 글: ${posts[0].data.title}` : ''}`.trim();

const jsonLd = [
  collectionPageSchema({
    name: `#${tag}`,
    description: pageDescription,
    url: tagUrl,
    itemCount: totalCount,
  }),
  breadcrumbSchema([
    { name: '태그', url: absoluteUrl('/tags/') },
    { name: `#${tag}`, url: tagUrl },
  ]),
];

void SITE_URL;
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  jsonLd={jsonLd}
  keywords={[tag!, '태그', '아카이브']}
>
  <section class="mx-auto max-w-3xl px-5" data-pagefind-ignore="all">
    <nav class="mb-3 text-xs text-[color:var(--color-fg-muted)]">
      <a href="/tags/" class="hover:text-[color:var(--color-accent)]">태그</a>
      <span class="mx-1">/</span>
      <span>#{tag}</span>
    </nav>
    <h1 class="mb-2 text-3xl font-bold tracking-tight">#{tag}</h1>
    <p class="mb-2 text-[color:var(--color-fg-muted)]">글 {posts.length}개 · 위키 {wiki.length}개</p>
    <p class="mb-8 text-sm text-[color:var(--color-fg-muted)]">
      <code>#{tag}</code> 와 관련된 글과 위키 페이지를 모아둔 곳입니다. 같은 주제의 다른 글을 찾거나, 시리즈로 이어진 내용을 따라 읽고 싶을 때 사용하세요.
    </p>

    {posts.length > 0 && (
      <section class="mb-10">
        <h2 class="mb-3 text-lg font-semibold">글</h2>
        <ul class="space-y-3">
          {posts.map((p) => (
            <li class="border-b border-[color:var(--color-border)] pb-2">
              <a href={`/posts/${p.id}/`} class="block text-base font-medium">{p.data.title}</a>
              <time datetime={p.data.date.toISOString()} class="text-xs text-[color:var(--color-fg-muted)]">
                {fmt.format(p.data.date)}
              </time>
            </li>
          ))}
        </ul>
      </section>
    )}

    {wiki.length > 0 && (
      <section>
        <h2 class="mb-3 text-lg font-semibold">위키</h2>
        <ul class="space-y-2">
          {wiki.map((w) => (
            <li>
              <a href={`/wiki/${w.id}/`}>{w.data.title}</a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </section>
</BaseLayout>
