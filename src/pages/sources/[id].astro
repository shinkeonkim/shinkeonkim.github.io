---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { render } from 'astro:content';
import { getReferenceIndex, formatSourceLabel } from '@/shared/lib/references/references';
import { toBibtex, toRIS } from '@/shared/lib/references/bibtex';
import type { GetStaticPaths } from 'astro';
void formatSourceLabel;

export const getStaticPaths = (async () => {
  const index = await getReferenceIndex();
  return Array.from(index.sources.values()).map((source) => ({
    params: { id: source.id },
    props: { sourceId: source.id },
  }));
}) satisfies GetStaticPaths;

interface Props {
  sourceId: string;
}
const { sourceId } = Astro.props as Props;
const index = await getReferenceIndex();
const lookupKey = sourceId.normalize('NFC');
const source = index.sources.get(lookupKey);
if (!source) {
  throw new Error(`source not found: ${sourceId}`);
}
const citing = index.citingBySourceId.get(lookupKey) ?? [];
const sourceData = source.data;
const { Content } = await render(source);
const bibtex = toBibtex(source);
const ris = toRIS(source);
---

<BaseLayout title={sourceData.title} description={`${sourceData.title} 을(를) 인용한 글 모음`}>
  <article class="mx-auto max-w-3xl px-5" data-pagefind-body>
    <nav class="mb-3 text-xs text-[color:var(--color-fg-muted)]">
      <a href="/sources/" class="hover:text-[color:var(--color-accent)]">출처</a>
      <span class="mx-1">/</span>
      <span>{sourceData.title}</span>
    </nav>
    <h1 class="mb-2 text-3xl font-bold tracking-tight">{sourceData.title}</h1>
    <div
      class="mb-6 flex flex-wrap items-baseline gap-2 text-sm text-[color:var(--color-fg-muted)]"
    >
      <span class="rounded-full border border-[color:var(--color-border)] px-2 py-0.5"
        >{sourceData.type}</span
      >
      {sourceData.author && <span>{sourceData.author}</span>}
      {sourceData.publisher && <span>· {sourceData.publisher}</span>}
      {sourceData.year && <span>· {sourceData.year}</span>}
      {sourceData.isbn && <span>· ISBN {sourceData.isbn}</span>}
      {sourceData.doi && <span>· DOI {sourceData.doi}</span>}
      {
        sourceData.url && (
          <a
            href={sourceData.url}
            target="_blank"
            rel="noopener"
            class="ml-auto rounded-full border border-[color:var(--color-border)] px-2.5 py-0.5 text-xs no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
          >
            원문 보기 ↗
          </a>
        )
      }
    </div>

    <section class="prose-content">
      <Content />
    </section>

    <aside class="mt-8 rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-4" data-pagefind-ignore="all">
      <h2 class="mb-2 text-sm font-semibold">서지 정보 내보내기</h2>
      <div class="flex flex-wrap gap-2">
        <button
          type="button"
          class="cite-copy rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-3 py-1 text-xs hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
          data-cite-format="bibtex"
        >BibTeX 복사</button>
        <button
          type="button"
          class="cite-copy rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-3 py-1 text-xs hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
          data-cite-format="ris"
        >RIS 복사</button>
        <span class="cite-feedback ml-auto text-xs text-[color:var(--color-fg-muted)]" aria-live="polite"></span>
      </div>
      <details class="mt-3 text-xs">
        <summary class="cursor-pointer text-[color:var(--color-fg-muted)]">미리보기</summary>
        <pre class="cite-preview-bibtex mt-2 overflow-auto rounded-md bg-[color:var(--color-code-bg)] p-2 font-mono text-[color:var(--color-fg)]">{bibtex}</pre>
        <pre class="cite-preview-ris mt-2 overflow-auto rounded-md bg-[color:var(--color-code-bg)] p-2 font-mono text-[color:var(--color-fg)]">{ris}</pre>
      </details>
    </aside>

    <script is:inline define:vars={{ bibtex, ris }}>
      (function () {
        document.querySelectorAll('.cite-copy').forEach((btn) => {
          btn.addEventListener('click', async () => {
            const fmt = btn.getAttribute('data-cite-format');
            const text = fmt === 'bibtex' ? bibtex : ris;
            const feedback = btn.closest('aside')?.querySelector('.cite-feedback');
            try {
              await navigator.clipboard.writeText(text);
              if (feedback) feedback.textContent = `${fmt?.toUpperCase()} 복사됨 ✓`;
            } catch {
              if (feedback) feedback.textContent = '복사 실패 (브라우저가 거부)';
            }
            setTimeout(() => {
              if (feedback) feedback.textContent = '';
            }, 2400);
          });
        });
      })();
    </script>

    <aside
      class="mt-10 rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-4"
    >
      <h2 class="mb-3 text-sm font-semibold">이 자료를 인용한 글 ({citing.length})</h2>
      {
        citing.length === 0 ? (
          <p class="text-sm text-[color:var(--color-fg-muted)]">
            아직 이 자료를 인용한 글이 없습니다.
          </p>
        ) : (
          <ul class="space-y-1.5 text-sm">
            {citing.map((doc) => (
              <li>
                <a
                  href={doc.url}
                  class="text-[color:var(--color-fg)] hover:text-[color:var(--color-accent)]"
                >
                  {doc.title}
                </a>
                {doc.page !== undefined && (
                  <span class="ml-1 text-xs text-[color:var(--color-fg-muted)]">p.{doc.page}</span>
                )}
                {doc.note && (
                  <span class="ml-1 text-xs text-[color:var(--color-fg-muted)]">· {doc.note}</span>
                )}
              </li>
            ))}
          </ul>
        )
      }
    </aside>
  </article>
</BaseLayout>
