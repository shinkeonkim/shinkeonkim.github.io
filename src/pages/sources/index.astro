---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getReferenceIndex, formatSourceLabel } from '../../lib/references';
void formatSourceLabel;

const index = await getReferenceIndex();
const entries = Array.from(index.sources.values()).map((source) => ({
  source,
  citingCount: index.citingBySourceId.get(source.id)?.length ?? 0,
}));
entries.sort(
  (a, b) => b.citingCount - a.citingCount || a.source.data.title.localeCompare(b.source.data.title),
);

const total = entries.length;
const totalCitations = entries.reduce((sum, e) => sum + e.citingCount, 0);
---

<BaseLayout title="출처" description="여러 글에서 인용된 책·논문·외부 자료 목록">
  <section class="mx-auto max-w-3xl px-5" data-pagefind-ignore="all">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">출처</h1>
    <p class="mb-8 text-sm text-[color:var(--color-fg-muted)]">
      총 {total}건 · 누적 인용 {totalCitations}회. 같은 자료를 인용한 글들을 통해 글 사이의 연결을
      살펴볼 수 있습니다.
    </p>

    {
      total === 0 ? (
        <p class="text-sm text-[color:var(--color-fg-muted)]">
          아직 등록된 출처가 없습니다. <code>src/content/sources/</code> 에 출처를 추가하세요.
        </p>
      ) : (
        <ul class="space-y-2">
          {entries.map(({ source, citingCount }) => (
            <li class="rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-4">
              <a href={`/sources/${source.id}/`} class="block no-underline">
                <span class="block text-base font-medium text-[color:var(--color-fg)]">
                  {formatSourceLabel(source)}
                </span>
                <span class="mt-1 flex flex-wrap items-baseline gap-2 text-xs text-[color:var(--color-fg-muted)]">
                  <span class="rounded-full border border-[color:var(--color-border)] px-2 py-0.5">
                    {source.data.type}
                  </span>
                  {source.data.year && <span>· {source.data.year}</span>}
                  {source.data.publisher && <span>· {source.data.publisher}</span>}
                  {source.data.url && <span>· 외부 링크 있음</span>}
                  <span class="ml-auto font-mono">인용 {citingCount}회</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
