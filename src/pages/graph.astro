---
import BaseLayout from '../layouts/BaseLayout.astro';
import GraphView from '../components/GraphView';
import type { GraphNode, GraphLink } from '../components/Graph';
import { getContentGraph } from '../lib/content-graph';
import { MAX_GRAPH_NODES } from '../consts';

const graph = await getContentGraph();

const degree = new Map<string, number>();
for (const link of graph.links) {
  degree.set(link.source, (degree.get(link.source) ?? 0) + 1);
  degree.set(link.target, (degree.get(link.target) ?? 0) + 1);
}

const truncated = graph.nodes.length > MAX_GRAPH_NODES;
const sortedNodes = truncated
  ? [...graph.nodes].sort((a, b) => (degree.get(b.id) ?? 0) - (degree.get(a.id) ?? 0)).slice(0, MAX_GRAPH_NODES)
  : graph.nodes;
const keptIds = new Set(sortedNodes.map((n) => n.id));

const nodes: GraphNode[] = sortedNodes.map((n) => ({
  id: n.id,
  title: n.title,
  url: n.url,
  group: n.collection,
  kind: n.kind,
  degree: n.degree,
}));

const links: GraphLink[] = graph.links
  .filter((l) => keptIds.has(l.source) && keptIds.has(l.target))
  .map((l) => ({ source: l.source, target: l.target, kind: l.kind }));

const tagNodeCount = nodes.filter((n) => n.kind === 'tag').length;
---
<BaseLayout title="그래프" description="문서 사이의 위키링크 연결 그래프">
  <section class="mx-auto max-w-5xl px-5" data-pagefind-ignore="all">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">그래프</h1>
    <p class="mb-6 text-sm text-[color:var(--color-fg-muted)]">
      노드 {nodes.length}개 (글 {nodes.length - tagNodeCount} · 태그 {tagNodeCount}) · 링크 {links.length}개
      {truncated && ` · 연결도 상위 ${MAX_GRAPH_NODES}개만 표시 (전체 ${graph.nodes.length}개)`}
      · 드래그로 이동, 휠로 확대/축소, 클릭으로 이동
    </p>
    <GraphView nodes={nodes} links={links} client:only="react" transition:animate="none" />
    <style is:global>
      .graph-legend-tag {
        background-color: #475569;
      }
      :root.dark .graph-legend-tag {
        background-color: #cbd5e1;
      }
    </style>
    <div class="mt-4 flex flex-wrap gap-4 text-xs text-[color:var(--color-fg-muted)]">
      <span class="inline-flex items-center gap-1.5"><span class="inline-block h-2.5 w-2.5 rounded-full" style="background:#4f46e5"></span>글</span>
      <span class="inline-flex items-center gap-1.5"><span class="inline-block h-2.5 w-2.5 rounded-full" style="background:#10b981"></span>한줄 노트</span>
      <span class="inline-flex items-center gap-1.5"><span class="inline-block h-2.5 w-2.5 rounded-full" style="background:#f59e0b"></span>위키</span>
      <span class="inline-flex items-center gap-1.5"><span class="graph-legend-tag inline-block h-3 w-4 rounded-md"></span>태그</span>
    </div>
  </section>
</BaseLayout>
