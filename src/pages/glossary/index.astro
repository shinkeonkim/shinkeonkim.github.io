---
import BaseLayout from '@/layouts/BaseLayout.astro';
import GlossaryIndex from '@/features/glossary/ui/GlossaryIndex.astro';
---

<BaseLayout
  title="용어 사전"
  description="블로그 전체에서 다루는 용어를 A-Z, 카테고리별로 정리한 사전. 위키 페이지 요약과 참조 수를 함께 확인할 수 있습니다."
>
  <section class="mx-auto max-w-3xl px-5">
    <header class="mb-6">
      <h1 class="mb-1 text-3xl font-bold tracking-tight">📚 용어 사전</h1>
      <p class="text-sm text-fg-muted">
        모든 위키 페이지를 한곳에서 찾아보세요. 자모/알파벳으로 이동하거나 검색어로 필터할 수 있습니다.
      </p>
    </header>

    <div data-pagefind-body data-pagefind-filter="section:glossary">
      <GlossaryIndex />
    </div>
  </section>
</BaseLayout>

<script>
  import { setupGlossary } from '@/features/glossary/lib/glossary-filter';

  if (document.readyState !== 'loading') setupGlossary();
  else document.addEventListener('DOMContentLoaded', setupGlossary);
  document.addEventListener('astro:page-load', setupGlossary);
</script>
