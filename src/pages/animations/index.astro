---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadAllAnimations } from '../../animations/loader';

const animations = await loadAllAnimations();

const categoryLabels: Record<string, string> = {
  network: '🌐 네트워크',
  cache: '⚡ 캐시',
  algorithm: '🔢 알고리즘',
  architecture: '🏛 아키텍처',
  flow: '🔀 흐름',
  protocol: '📡 프로토콜',
  general: '🎬 일반',
};

const grouped = new Map<string, typeof animations>();
for (const a of animations) {
  const cat = a.category ?? 'general';
  if (!grouped.has(cat)) grouped.set(cat, []);
  grouped.get(cat)!.push(a);
}
for (const [, items] of grouped) {
  items.sort((a, b) => (a.title || a.id).localeCompare(b.title || b.id, 'ko'));
}
---

<BaseLayout
  title="애니메이션"
  description="본문에 삽입 가능한 인터랙티브 애니메이션 카탈로그"
  ogImage="/og/site.png"
>
  <section class="mx-auto max-w-5xl px-5">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">애니메이션</h1>
    <p class="mb-6 text-[color:var(--color-fg-muted)]">
      총 {animations.length}개. 본문 코드 펜스로 삽입할 수 있습니다:
    </p>
    <pre
      class="mb-8 inline-block rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-3 text-xs"
    ><code>```anim:&lt;id&gt;
{}
```</code></pre>

    {animations.length === 0 ? (
      <p class="text-sm text-[color:var(--color-fg-muted)]">
        아직 등록된 애니메이션이 없습니다. <code>bun dev</code> 후 <a class="text-[color:var(--color-accent)]" href="/_studio/">스튜디오</a> 에서 만들어 보세요.
      </p>
    ) : (
      <div class="space-y-8">
        {Array.from(grouped.entries()).map(([category, items]) => (
          <section>
            <h2 class="mb-3 text-lg font-semibold text-[color:var(--color-fg-muted)]">
              {categoryLabels[category] ?? `🎬 ${category}`}
            </h2>
            <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
              {items.map((a) => (
                <a
                  href={`/animations/${a.id}/`}
                  class="block rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-4 no-underline transition-colors hover:border-[color:var(--color-accent)]"
                >
                  <div class="mb-1 flex items-center gap-2">
                    <span class="text-base font-semibold text-[color:var(--color-fg)]">
                      {a.title}
                    </span>
                  </div>
                  <p class="mb-2 text-sm text-[color:var(--color-fg-muted)]">{a.description}</p>
                  <div class="mt-1 flex flex-wrap items-center gap-2 text-xs text-[color:var(--color-fg-muted)]">
                    <span class="font-mono">{a.id}</span>
                    <span>·</span>
                    <span>{a.elements.length} elements</span>
                    <span>·</span>
                    <span>{a.chapters.length} chapters</span>
                    <span>·</span>
                    <span>{(a.duration / 1000).toFixed(1)}s</span>
                  </div>
                  {a.tags && a.tags.length > 0 && (
                    <div class="mt-2 flex flex-wrap gap-1 text-xs text-[color:var(--color-fg-muted)]">
                      {a.tags.map((t) => (
                        <span class="rounded-md border border-[color:var(--color-border)] px-1.5 py-0.5">
                          #{t}
                        </span>
                      ))}
                    </div>
                  )}
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
