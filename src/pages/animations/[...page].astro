---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Pagination from '../../components/Pagination.astro';
import { loadAllAnimations } from '../../animations/loader';
import { ANIMATIONS_PER_PAGE } from '@/shared/config';
import type { AnimationDef } from '../../animations/schema';
import type { GetStaticPaths, Page } from 'astro';

const CATEGORY_LABELS: Record<string, string> = {
  network: '🌐 네트워크',
  cache: '⚡ 캐시',
  algorithm: '🔢 알고리즘',
  architecture: '🏛 아키텍처',
  flow: '🔀 흐름',
  protocol: '📡 프로토콜',
  general: '🎬 일반',
};

const CATEGORY_ORDER = [
  'algorithm',
  'architecture',
  'flow',
  'protocol',
  'network',
  'cache',
  'general',
];

function catRank(c: string): number {
  const i = CATEGORY_ORDER.indexOf(c);
  return i === -1 ? CATEGORY_ORDER.length : i;
}

export const getStaticPaths = (async ({ paginate }) => {
  const animations = await loadAllAnimations();
  const sorted = animations.sort((a, b) => {
    const ca = a.category ?? 'general';
    const cb = b.category ?? 'general';
    const order = ['algorithm', 'architecture', 'flow', 'protocol', 'network', 'cache', 'general'];
    const r = order.indexOf(ca) - order.indexOf(cb);
    if (r !== 0) return r;
    return (a.title || a.id).localeCompare(b.title || b.id, 'ko');
  });
  return paginate(sorted, { pageSize: ANIMATIONS_PER_PAGE });
}) satisfies GetStaticPaths;

type Props = { page: Page<AnimationDef> };
const { page } = Astro.props as Props;

const allAnimations = await loadAllAnimations();

const categoryCounts = new Map<string, number>();
for (const a of allAnimations) {
  const c = a.category ?? 'general';
  categoryCounts.set(c, (categoryCounts.get(c) ?? 0) + 1);
}
const sortedCategories = Array.from(categoryCounts.entries())
  .sort((a, b) => catRank(a[0]) - catRank(b[0]) || b[1] - a[1])
  .map(([cat, count]) => ({ cat, count, label: CATEGORY_LABELS[cat] ?? `🎬 ${cat}` }));

const tagCounts = new Map<string, number>();
for (const a of allAnimations) {
  for (const t of a.tags ?? []) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
}
const sortedTags = Array.from(tagCounts.entries())
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([tag, count]) => ({ tag, count }));

const isLanding = page.currentPage === 1;

interface AnimIndexEntry {
  id: string;
  title: string;
  description: string;
  category: string;
  categoryLabel: string;
  tags: string[];
  elements: number;
  chapters: number;
  duration: number;
}

const animIndex: AnimIndexEntry[] = allAnimations.map((a) => ({
  id: a.id,
  title: a.title || a.id,
  description: a.description ?? '',
  category: a.category ?? 'general',
  categoryLabel: CATEGORY_LABELS[a.category ?? 'general'] ?? `🎬 ${a.category ?? 'general'}`,
  tags: a.tags ?? [],
  elements: a.elements.length,
  chapters: a.chapters.length,
  duration: a.duration,
}));

const animIndexJson = JSON.stringify(animIndex).replace(/</g, '\\u003c');

const pageStart = (page.currentPage - 1) * ANIMATIONS_PER_PAGE + 1;
const pageEnd = pageStart + page.data.length - 1;

const pageDescription =
  page.currentPage === 1
    ? `본문에 삽입 가능한 인터랙티브 애니메이션 카탈로그, 총 ${page.total}개.`
    : `애니메이션 카탈로그 ${page.currentPage} / ${page.lastPage}페이지.`;
---

<BaseLayout
  title={page.currentPage > 1 ? `애니메이션 (${page.currentPage}페이지)` : '애니메이션'}
  description={pageDescription}
  ogImage="/og/site.png"
>
  <section class="mx-auto max-w-5xl px-5">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">애니메이션</h1>
    <p class="mb-2 text-[color:var(--color-fg-muted)]" data-pagefind-ignore>
      총 {page.total}개 · {page.currentPage} / {page.lastPage} 페이지
      {!isLanding && ` · ${pageStart}–${pageEnd}`}
    </p>
    <p class="mb-6 text-xs text-[color:var(--color-fg-muted)]" data-pagefind-ignore>
      본문 코드 펜스로 삽입: <code class="font-mono">```anim:&lt;id&gt;</code>
    </p>

    <section
      class="anim-filter mb-6"
      data-anim-filter-ui
      data-pagefind-ignore="all"
      aria-label="애니메이션 필터"
    >
      <label class="block">
        <span class="sr-only">애니메이션 검색</span>
        <input
          type="search"
          data-anim-search
          placeholder="제목, 설명, ID, 태그로 검색…"
          autocomplete="off"
          class="w-full rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-3 py-2 text-sm placeholder:text-[color:var(--color-fg-muted)] focus:border-[color:var(--color-accent)] focus:outline-none"
        />
      </label>

      <div class="mt-3 flex flex-wrap gap-1.5" data-anim-category-chips>
        <button
          type="button"
          data-anim-category=""
          aria-pressed="true"
          class="anim-cat-chip inline-flex items-baseline gap-1 rounded-full border border-[color:var(--color-accent)] bg-[color:var(--color-surface-elevated)] px-2.5 py-0.5 text-xs text-[color:var(--color-accent)]"
        >
          전체 <span class="opacity-70">({allAnimations.length})</span>
        </button>
        {sortedCategories.map(({ cat, count, label }) => (
          <button
            type="button"
            data-anim-category={cat}
            aria-pressed="false"
            class="anim-cat-chip inline-flex items-baseline gap-1 rounded-full border border-[color:var(--color-border)] bg-transparent px-2.5 py-0.5 text-xs hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
          >
            {label} <span class="opacity-60">({count})</span>
          </button>
        ))}
      </div>

      {sortedTags.length > 0 && (
        <details class="mt-3 anim-tag-panel" data-anim-tag-panel>
          <summary class="cursor-pointer select-none text-xs text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-accent)]">
            태그로 필터 ({sortedTags.length})
            <span data-anim-active-tag-label class="ml-1 hidden text-[color:var(--color-accent)]"></span>
          </summary>
          <div class="mt-2 flex flex-wrap gap-1.5" data-anim-tag-chips>
            {sortedTags.slice(0, 60).map(({ tag, count }) => (
              <button
                type="button"
                data-anim-tag={tag}
                aria-pressed="false"
                class="anim-tag-chip inline-flex items-baseline gap-1 rounded-full border border-[color:var(--color-border)] bg-transparent px-2.5 py-0.5 text-xs hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
              >
                #{tag} <span class="opacity-60">{count}</span>
              </button>
            ))}
          </div>
        </details>
      )}
    </section>

    {page.data.length === 0 ? (
      <p class="text-sm text-[color:var(--color-fg-muted)]">
        애니메이션이 없습니다.
      </p>
    ) : (
      <div data-anim-default-list>
        <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3" data-pagefind-body data-pagefind-filter="section:animation">
          {page.data.map((a) => (
            <a
              href={`/animations/${a.id}/`}
              class="anim-card group block rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-4 no-underline transition-colors hover:border-[color:var(--color-accent)]"
              data-anim-category={a.category ?? 'general'}
            >
              <div class="mb-1 flex items-start justify-between gap-2">
                <span class="text-base font-semibold text-[color:var(--color-fg)] group-hover:text-[color:var(--color-accent)]">
                  {a.title}
                </span>
                <span class="shrink-0 text-xs text-[color:var(--color-fg-muted)] tabular-nums">
                  {(a.duration / 1000).toFixed(1)}s
                </span>
              </div>
              {a.description && (
                <p class="mb-2 line-clamp-2 text-sm text-[color:var(--color-fg-muted)]">
                  {a.description}
                </p>
              )}
              <div class="mt-1 flex flex-wrap items-center gap-2 text-xs text-[color:var(--color-fg-muted)]">
                <span class="rounded-md border border-[color:var(--color-border)] px-1.5 py-0.5 text-[10px]">
                  {CATEGORY_LABELS[a.category ?? 'general'] ?? a.category}
                </span>
                <span class="font-mono opacity-70">{a.id}</span>
              </div>
              <div class="mt-1 flex flex-wrap items-center gap-2 text-[11px] text-[color:var(--color-fg-muted)]">
                <span>{a.elements.length} elements</span>
                <span>·</span>
                <span>{a.chapters.length} chapters</span>
              </div>
              {a.tags && a.tags.length > 0 && (
                <div class="mt-2 flex flex-wrap gap-1 text-[11px] text-[color:var(--color-fg-muted)]">
                  {a.tags.slice(0, 4).map((t) => (
                    <span class="rounded-md border border-[color:var(--color-border)] px-1.5 py-0.5">
                      #{t}
                    </span>
                  ))}
                  {a.tags.length > 4 && <span class="opacity-60">+{a.tags.length - 4}</span>}
                </div>
              )}
            </a>
          ))}
        </div>
      </div>
    )}

    <section data-anim-filtered hidden data-pagefind-ignore="all" aria-label="필터 결과">
      <p
        class="mb-3 text-sm text-[color:var(--color-fg-muted)]"
        data-anim-filtered-count
        aria-live="polite"
      ></p>
      <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3" data-anim-filtered-list></div>
      <p class="mt-3 hidden text-sm text-[color:var(--color-fg-muted)]" data-anim-filtered-empty>
        일치하는 애니메이션이 없습니다. 다른 검색어나 필터를 시도해보세요.
      </p>
    </section>

    <div data-anim-pagination-wrap>
      <Pagination currentPage={page.currentPage} lastPage={page.lastPage} baseUrl="/animations/" />
    </div>

    <script
      is:inline
      type="application/json"
      id="anim-index-data"
      data-pagefind-ignore="all"
      set:html={animIndexJson}
    />
  </section>
</BaseLayout>

<style>
  .anim-cat-chip[aria-pressed='true'] {
    border-color: var(--color-accent);
    background: var(--color-surface-elevated);
    color: var(--color-accent);
  }
  .anim-tag-chip[aria-pressed='true'] {
    border-color: var(--color-accent);
    background: var(--color-surface-elevated);
    color: var(--color-accent);
  }
  .anim-card {
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .anim-card:hover {
    transform: translateY(-1px);
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  type AnimEntry = {
    id: string;
    title: string;
    description: string;
    category: string;
    categoryLabel: string;
    tags: string[];
    elements: number;
    chapters: number;
    duration: number;
  };

  function setupAnimFilter(): void {
    const filterUi = document.querySelector<HTMLElement>('[data-anim-filter-ui]');
    if (!filterUi || filterUi.dataset.animFilterReady === '1') return;

    const dataEl = document.getElementById('anim-index-data');
    const searchInput = document.querySelector<HTMLInputElement>('[data-anim-search]');
    const defaultList = document.querySelector<HTMLElement>('[data-anim-default-list]');
    const paginationWrap = document.querySelector<HTMLElement>('[data-anim-pagination-wrap]');
    const filteredView = document.querySelector<HTMLElement>('[data-anim-filtered]');
    const filteredCount = document.querySelector<HTMLElement>('[data-anim-filtered-count]');
    const filteredList = document.querySelector<HTMLElement>('[data-anim-filtered-list]');
    const filteredEmpty = document.querySelector<HTMLElement>('[data-anim-filtered-empty]');
    const catButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>('[data-anim-category]'),
    );
    const tagButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>('[data-anim-tag]'),
    );
    const tagLabel = document.querySelector<HTMLElement>('[data-anim-active-tag-label]');
    const tagPanel = document.querySelector<HTMLDetailsElement>('[data-anim-tag-panel]');

    if (
      !dataEl ||
      !searchInput ||
      !filteredView ||
      !filteredCount ||
      !filteredList ||
      !filteredEmpty
    ) {
      return;
    }

    let allEntries: AnimEntry[] = [];
    try {
      allEntries = JSON.parse(dataEl.textContent ?? '[]') as AnimEntry[];
    } catch {
      return;
    }

    filterUi.dataset.animFilterReady = '1';

    const params = new URLSearchParams(window.location.search);
    let query = params.get('search') ?? '';
    let activeCategory = params.get('category') ?? '';
    let activeTag = params.get('tag') ?? '';

    if (query) searchInput.value = query;
    if (activeTag && tagPanel) tagPanel.open = true;

    const escapeHtml = (s: string): string =>
      s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');

    const norm = (s: string): string => s.normalize('NFC').toLowerCase();

    function syncUrl(): void {
      const url = new URL(window.location.href);
      if (query) url.searchParams.set('search', query);
      else url.searchParams.delete('search');
      if (activeCategory) url.searchParams.set('category', activeCategory);
      else url.searchParams.delete('category');
      if (activeTag) url.searchParams.set('tag', activeTag);
      else url.searchParams.delete('tag');
      window.history.replaceState({}, '', url.toString());
    }

    function setFilterState(active: boolean): void {
      if (defaultList) defaultList.hidden = active;
      if (paginationWrap) paginationWrap.hidden = active;
      filteredView!.hidden = !active;
    }

    function render(): void {
      const hasFilter =
        query.trim().length > 0 || activeCategory.length > 0 || activeTag.length > 0;

      for (const btn of catButtons) {
        const v = btn.dataset.animCategory ?? '';
        btn.setAttribute('aria-pressed', v === activeCategory ? 'true' : 'false');
      }
      for (const btn of tagButtons) {
        btn.setAttribute(
          'aria-pressed',
          btn.dataset.animTag === activeTag && activeTag.length > 0 ? 'true' : 'false',
        );
      }

      if (tagLabel) {
        if (activeTag) {
          tagLabel.textContent = `· #${activeTag}`;
          tagLabel.classList.remove('hidden');
        } else {
          tagLabel.textContent = '';
          tagLabel.classList.add('hidden');
        }
      }

      syncUrl();

      if (!hasFilter) {
        setFilterState(false);
        filteredList!.innerHTML = '';
        return;
      }

      const q = norm(query.trim());
      const filtered = allEntries.filter((e) => {
        if (activeCategory && e.category !== activeCategory) return false;
        if (activeTag && !e.tags.includes(activeTag)) return false;
        if (q) {
          const haystack = norm(
            `${e.title} ${e.description} ${e.id} ${e.tags.join(' ')} ${e.categoryLabel}`,
          );
          return haystack.includes(q);
        }
        return true;
      });

      setFilterState(true);

      if (filtered.length === 0) {
        filteredList!.innerHTML = '';
        filteredCount!.textContent = `검색 결과 없음 · 전체 ${allEntries.length}개`;
        filteredEmpty!.classList.remove('hidden');
        return;
      }

      filteredEmpty!.classList.add('hidden');
      filteredCount!.textContent = `검색 결과 ${filtered.length}개 · 전체 ${allEntries.length}개`;
      filteredList!.innerHTML = filtered
        .map((e) => {
          const title = escapeHtml(e.title);
          const desc = e.description
            ? `<p class="mb-2 line-clamp-2 text-sm text-[color:var(--color-fg-muted)]">${escapeHtml(e.description)}</p>`
            : '';
          const tagsRow =
            e.tags.length > 0
              ? `<div class="mt-2 flex flex-wrap gap-1 text-[11px] text-[color:var(--color-fg-muted)]">${e.tags
                  .slice(0, 4)
                  .map(
                    (t) =>
                      `<span class="rounded-md border border-[color:var(--color-border)] px-1.5 py-0.5">#${escapeHtml(t)}</span>`,
                  )
                  .join('')}${e.tags.length > 4 ? `<span class="opacity-60">+${e.tags.length - 4}</span>` : ''}</div>`
              : '';
          return `<a href="/animations/${encodeURIComponent(e.id)}/" class="anim-card group block rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-4 no-underline transition-colors hover:border-[color:var(--color-accent)]">
            <div class="mb-1 flex items-start justify-between gap-2">
              <span class="text-base font-semibold text-[color:var(--color-fg)] group-hover:text-[color:var(--color-accent)]">${title}</span>
              <span class="shrink-0 text-xs text-[color:var(--color-fg-muted)] tabular-nums">${(e.duration / 1000).toFixed(1)}s</span>
            </div>
            ${desc}
            <div class="mt-1 flex flex-wrap items-center gap-2 text-xs text-[color:var(--color-fg-muted)]">
              <span class="rounded-md border border-[color:var(--color-border)] px-1.5 py-0.5 text-[10px]">${escapeHtml(e.categoryLabel)}</span>
              <span class="font-mono opacity-70">${escapeHtml(e.id)}</span>
            </div>
            <div class="mt-1 flex flex-wrap items-center gap-2 text-[11px] text-[color:var(--color-fg-muted)]">
              <span>${e.elements} elements</span>
              <span>·</span>
              <span>${e.chapters} chapters</span>
            </div>
            ${tagsRow}
          </a>`;
        })
        .join('');
    }

    let debounceId: ReturnType<typeof setTimeout> | null = null;
    searchInput.addEventListener('input', () => {
      if (debounceId !== null) clearTimeout(debounceId);
      debounceId = setTimeout(() => {
        query = searchInput.value;
        render();
      }, 80);
    });

    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && searchInput.value) {
        e.preventDefault();
        searchInput.value = '';
        query = '';
        render();
      }
    });

    for (const btn of catButtons) {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.animCategory ?? '';
        activeCategory = activeCategory === cat ? '' : cat;
        render();
      });
    }

    for (const btn of tagButtons) {
      btn.addEventListener('click', () => {
        const tag = btn.dataset.animTag ?? '';
        activeTag = activeTag === tag ? '' : tag;
        render();
      });
    }

    render();
  }

  if (document.readyState !== 'loading') setupAnimFilter();
  else document.addEventListener('DOMContentLoaded', setupAnimFilter);
  document.addEventListener('astro:page-load', setupAnimFilter);
</script>
