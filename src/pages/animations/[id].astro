---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadAllAnimations } from '../../animations/loader';

export async function getStaticPaths() {
  const all = await loadAllAnimations();
  return all.map((a) => ({
    params: { id: a.id },
    props: { def: a },
  }));
}

const { def } = Astro.props;
---

<BaseLayout title={def.title} description={def.description} ogImage="/og/site.png">
  <section class="mx-auto max-w-4xl px-5">
    <nav class="mb-4 text-sm">
      <a
        href="/animations/"
        class="text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-accent)]"
      >
        ← 애니메이션 카탈로그
      </a>
    </nav>

    <h1 class="mb-2 text-3xl font-bold tracking-tight">{def.title}</h1>
    {def.description && (
      <p class="mb-6 text-[color:var(--color-fg-muted)]">{def.description}</p>
    )}

    <div class="anim-placeholder" data-anim-id={def.id} data-anim-overrides="{}" />

    <section class="mt-10">
      <h2 class="mb-3 text-lg font-semibold">메타데이터</h2>
      <table class="w-full text-sm">
        <tbody>
          <tr class="border-b border-[color:var(--color-border)]">
            <td class="py-2 pr-4 font-medium text-[color:var(--color-fg-muted)]">ID</td>
            <td class="py-2 font-mono">{def.id}</td>
          </tr>
          <tr class="border-b border-[color:var(--color-border)]">
            <td class="py-2 pr-4 font-medium text-[color:var(--color-fg-muted)]">카테고리</td>
            <td class="py-2">{def.category}</td>
          </tr>
          <tr class="border-b border-[color:var(--color-border)]">
            <td class="py-2 pr-4 font-medium text-[color:var(--color-fg-muted)]">버전</td>
            <td class="py-2 font-mono">v{def.version}</td>
          </tr>
          <tr class="border-b border-[color:var(--color-border)]">
            <td class="py-2 pr-4 font-medium text-[color:var(--color-fg-muted)]">요소 / 스텝</td>
            <td class="py-2">{def.elements.length} elements · {def.steps.length} steps</td>
          </tr>
          {def.tags && def.tags.length > 0 && (
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="py-2 pr-4 font-medium text-[color:var(--color-fg-muted)]">태그</td>
              <td class="py-2">
                {def.tags.map((t) => (
                  <span class="mr-1 rounded-md border border-[color:var(--color-border)] px-1.5 py-0.5 font-mono text-xs">
                    #{t}
                  </span>
                ))}
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </section>

    <section class="mt-10">
      <h2 class="mb-3 text-lg font-semibold">본문에 삽입</h2>
      <pre
        class="overflow-x-auto rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-3 text-xs"
      ><code>```anim:{def.id}
{`{}`}
```</code></pre>
    </section>
  </section>
</BaseLayout>
