---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoteCard from '../../components/NoteCard.astro';
import Pagination from '../../components/Pagination.astro';
import { NOTES_PER_PAGE } from '../../consts';
import type { GetStaticPaths, Page } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const notes = (await getCollection('notes')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  return paginate(notes, { pageSize: NOTES_PER_PAGE });
}) satisfies GetStaticPaths;

type Props = { page: Page<CollectionEntry<'notes'>> };
const { page } = Astro.props as Props;
---

<BaseLayout
  title={page.currentPage > 1 ? `노트 (${page.currentPage}페이지)` : '노트'}
  description="짧은 메모와 스쳐가는 생각"
>
  <section class="mx-auto max-w-5xl px-5" data-pagefind-ignore>
    <h1 class="mb-2 text-3xl font-bold tracking-tight">노트</h1>
    <p class="mb-8 text-[color:var(--color-fg-muted)]">
      총 {page.total}개 · {page.currentPage} / {page.lastPage} 페이지
    </p>

    {
      page.data.length === 0 ? (
        <p class="text-sm text-[color:var(--color-fg-muted)]">아직 작성된 노트가 없습니다.</p>
      ) : (
        <div class="notes-bricks">
          {page.data.map((n) => (
            <NoteCard entry={n} showTime />
          ))}
        </div>
      )
    }

    <Pagination currentPage={page.currentPage} lastPage={page.lastPage} baseUrl="/notes/" />
  </section>
</BaseLayout>
