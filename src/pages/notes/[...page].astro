---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoteCard from '../../components/NoteCard.astro';
import NoteCardScript from '../../components/NoteCardScript.astro';
import Pagination from '../../components/Pagination.astro';
import { NOTES_PER_PAGE } from '../../consts';
import type { GetStaticPaths, Page } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const notes = (await getCollection('notes')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  return paginate(notes, { pageSize: NOTES_PER_PAGE });
}) satisfies GetStaticPaths;

type Props = { page: Page<CollectionEntry<'notes'>> };
const { page } = Astro.props as Props;

const hasMore = page.currentPage === 1 && page.lastPage > 1;
---

<BaseLayout
  title={page.currentPage > 1 ? `노트 (${page.currentPage}페이지)` : '노트'}
  description="짧은 메모와 스쳐가는 생각"
>
  <section class="mx-auto max-w-5xl px-5" data-pagefind-ignore>
    <h1 class="mb-2 text-3xl font-bold tracking-tight">노트</h1>
    <p class="mb-8 text-[color:var(--color-fg-muted)]">
      총 {page.total}개 · {page.currentPage} / {page.lastPage} 페이지
    </p>

    {
      page.data.length === 0 ? (
        <p class="text-sm text-[color:var(--color-fg-muted)]">아직 작성된 노트가 없습니다.</p>
      ) : (
        <div class="notes-bricks">
          {page.data.map((n) => (
            <NoteCard entry={n} showTime />
          ))}
        </div>
      )
    }

    {
      hasMore && (
        <div
          id="notes-sentinel"
          class="notes-sentinel"
          data-next-page="2"
          data-last-page={page.lastPage}
          aria-hidden="true"
        />
      )
    }

    <div data-pagination-fallback>
      <Pagination currentPage={page.currentPage} lastPage={page.lastPage} baseUrl="/notes/" />
    </div>
  </section>

  <NoteCardScript />
</BaseLayout>

<script>
  let activeIO: IntersectionObserver | null = null;

  function setupInfiniteScroll() {
    if (activeIO) {
      activeIO.disconnect();
      activeIO = null;
    }

    const sentinel = document.getElementById('notes-sentinel');
    const container = document.querySelector<HTMLElement>('.notes-bricks');
    if (!sentinel || !container) return;

    document.querySelectorAll<HTMLElement>('[data-pagination-fallback]').forEach((el) => {
      el.hidden = true;
    });

    let nextPage = Number(sentinel.dataset.nextPage ?? '0');
    const lastPage = Number(sentinel.dataset.lastPage ?? '0');
    let loading = false;
    let exhausted = false;

    const io = new IntersectionObserver(
      async (entries) => {
        const entry = entries[0];
        if (!entry?.isIntersecting || loading || exhausted) return;
        if (nextPage > lastPage) {
          exhausted = true;
          io.disconnect();
          sentinel.remove();
          return;
        }
        loading = true;
        try {
          const res = await fetch(`/notes/${nextPage}/`);
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          const html = await res.text();
          const doc = new DOMParser().parseFromString(html, 'text/html');
          const cards = doc.querySelectorAll('.notes-bricks > .note-card');
          cards.forEach((card) => container.appendChild(card));
          nextPage += 1;
          if (nextPage > lastPage) {
            exhausted = true;
            io.disconnect();
            sentinel.remove();
          } else {
            io.unobserve(sentinel);
            io.observe(sentinel);
          }
        } catch (err) {
          console.error('[notes] infinite scroll fetch failed', err);
          exhausted = true;
          io.disconnect();
          sentinel.remove();
        } finally {
          loading = false;
        }
      },
      { rootMargin: '300px 0px' },
    );

    io.observe(sentinel);
    activeIO = io;
  }

  document.addEventListener('astro:page-load', setupInfiniteScroll);
</script>
