---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Pagination from '../../components/Pagination.astro';
import { SITE_LOCALE, NOTES_PER_PAGE } from '../../consts';
import type { GetStaticPaths, Page } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const notes = (await getCollection('notes')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  return paginate(notes, { pageSize: NOTES_PER_PAGE });
}) satisfies GetStaticPaths;

type Props = { page: Page<CollectionEntry<'notes'>> };
const { page } = Astro.props as Props;

const fmtDate = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'short',
});
const fmtTime = new Intl.DateTimeFormat(SITE_LOCALE, {
  hour: '2-digit',
  minute: '2-digit',
});

const rendered = await Promise.all(
  page.data.map(async (n) => {
    const { Content } = await render(n);
    return { n, Content };
  }),
);
---

<BaseLayout
  title={page.currentPage > 1 ? `한줄 노트 (${page.currentPage}페이지)` : '한줄 노트'}
  description="한 두 줄짜리 짧은 기록의 타임라인"
>
  <section class="mx-auto max-w-3xl px-5" data-pagefind-body data-pagefind-filter="section:notes">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">한줄 노트</h1>
    <p class="mb-8 text-[color:var(--color-fg-muted)]" data-pagefind-ignore>
      총 {page.total}개의 노트 · {page.currentPage} / {page.lastPage} 페이지
    </p>

    {
      rendered.length === 0 ? (
        <p class="text-sm text-[color:var(--color-fg-muted)]">아직 작성된 노트가 없습니다.</p>
      ) : (
        <ol class="relative space-y-6 border-l border-[color:var(--color-border)] pl-6">
          {rendered.map(({ n, Content }) => (
            <li id={n.id} class="relative" data-pagefind-meta={`note:${n.id}`}>
              <span class="absolute -left-[1.625rem] top-2 h-2.5 w-2.5 rounded-full bg-[color:var(--color-accent)]" />
              <div
                class="flex flex-wrap items-baseline gap-2 text-xs text-[color:var(--color-fg-muted)]"
                data-pagefind-ignore
              >
                <time datetime={n.data.date.toISOString()}>{fmtDate.format(n.data.date)}</time>
                <time datetime={n.data.date.toISOString()}>{fmtTime.format(n.data.date)}</time>
                {n.data.tags.length > 0 && (
                  <span>· {n.data.tags.map((t) => `#${t}`).join(' ')}</span>
                )}
              </div>
              <div class="prose-content mt-1 text-[15px]">
                <Content />
              </div>
            </li>
          ))}
        </ol>
      )
    }

    <Pagination currentPage={page.currentPage} lastPage={page.lastPage} baseUrl="/notes/" />
  </section>
</BaseLayout>
