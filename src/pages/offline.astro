---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="오프라인" description="네트워크 연결이 없어 페이지를 불러올 수 없습니다." noIndex>
  <section class="mx-auto max-w-2xl px-5 py-16 text-center">
    <h1 class="mb-3 text-3xl font-bold tracking-tight">📡 오프라인</h1>
    <p class="mb-6 text-[color:var(--color-fg-muted)]">
      현재 네트워크 연결이 없어 이 페이지를 불러올 수 없습니다.
      이미 방문한 페이지는 캐시되어 계속 볼 수 있습니다.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-1 rounded-full bg-[color:var(--color-accent)] px-4 py-2 text-sm font-medium text-white no-underline hover:bg-[color:var(--color-accent-hover)]"
    >
      홈으로 →
    </a>
  </section>
</BaseLayout>
