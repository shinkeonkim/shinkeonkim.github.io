---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const courses = (await getCollection('courses')).sort((a, b) => {
  const ua = a.data.updated?.valueOf() ?? 0;
  const ub = b.data.updated?.valueOf() ?? 0;
  if (ub !== ua) return ub - ua;
  return a.data.title.localeCompare(b.data.title);
});

const LEVEL_LABEL: Record<string, string> = {
  beginner: '입문',
  intermediate: '중급',
  advanced: '심화',
};

const LEVEL_COLOR: Record<string, string> = {
  beginner: '#16a34a',
  intermediate: '#2563eb',
  advanced: '#a855f7',
};

const totalChapters = courses.reduce((sum, c) => sum + c.data.chapters.length, 0);
---

<BaseLayout
  title="학습 코스"
  description="posts, wiki, notes 를 가로지르는 큐레이션 학습 경로. 진도는 브라우저에 저장됩니다."
>
  <section class="mx-auto max-w-4xl px-5">
    <header class="mb-6">
      <h1 class="mb-1 text-3xl font-bold tracking-tight">🎓 학습 코스</h1>
      <p class="text-sm text-fg-muted">
        {courses.length}개 코스 · 총 {totalChapters}개 챕터. Series (posts 만) 와 달리 wiki·notes 도 한 흐름으로 엮을 수 있습니다.
      </p>
    </header>

    {courses.length === 0 ? (
      <p class="rounded-md border border-border bg-surface-elevated p-4 text-sm text-fg-muted">
        아직 등록된 코스가 없습니다.
      </p>
    ) : (
      <ul class="course-grid">
        {courses.map((c) => (
          <li>
            <a href={`/courses/${c.id}/`} class="course-card">
              <span
                class="course-card-level"
                style={`--level-color: ${LEVEL_COLOR[c.data.level]};`}
              >
                {LEVEL_LABEL[c.data.level]}
              </span>
              <h2 class="course-card-title">{c.data.title}</h2>
              <p class="course-card-description">{c.data.description}</p>
              <footer class="course-card-meta">
                <span>{c.data.chapters.length}개 챕터</span>
                <span class="course-card-sep">·</span>
                <span>{c.data.duration}</span>
                {c.data.tags.length > 0 && (
                  <>
                    <span class="course-card-sep">·</span>
                    <span class="course-card-tags">
                      {c.data.tags.slice(0, 3).map((t) => (
                        <span>#{t}</span>
                      ))}
                    </span>
                  </>
                )}
              </footer>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .course-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 40rem) {
    .course-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .course-card {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 1rem 1.15rem;
    border: 1px solid var(--color-border);
    border-radius: 0.55rem;
    background-color: var(--color-surface-elevated);
    text-decoration: none;
    color: var(--color-fg);
    transition: border-color 0.15s ease, transform 0.15s ease;
    height: 100%;
    position: relative;
  }
  .course-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .course-card-level {
    align-self: flex-start;
    padding: 0.1rem 0.55rem;
    border-radius: 999px;
    background-color: color-mix(in srgb, var(--level-color) 15%, transparent);
    color: var(--level-color);
    font-size: 0.7rem;
    font-family: var(--font-mono);
    font-weight: 600;
    border: 1px solid var(--level-color);
  }
  .course-card-title {
    margin: 0.2rem 0 0;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-fg);
    line-height: 1.35;
  }
  .course-card-description {
    margin: 0;
    font-size: 0.82rem;
    color: var(--color-fg-muted);
    line-height: 1.5;
  }
  .course-card-meta {
    margin-top: auto;
    padding-top: 0.4rem;
    font-size: 0.72rem;
    color: var(--color-fg-muted);
    font-family: var(--font-mono);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem;
  }
  .course-card-sep {
    opacity: 0.5;
  }
  .course-card-tags {
    display: inline-flex;
    gap: 0.3rem;
  }
</style>
