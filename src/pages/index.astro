---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero3D from '../components/Hero3D';
import { SITE_TITLE, SITE_LOCALE } from '../consts';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const notes = (await getCollection('notes'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const wiki = (await getCollection('wiki'))
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .slice(0, 8);

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

function previewNote(body: string | undefined): string {
  if (!body) return '';
  const firstLine = body.split('\n').find((l) => l.trim()) ?? '';
  return firstLine.replace(/\[\[([^\]|#]+)(?:#[^\]|]+)?(?:\|([^\]]+))?\]\]/g, (_m, target, alias) => alias?.trim() ?? target.trim());
}

const heroTitles = posts.map((p) => p.data.title);
---
<BaseLayout>
  <section class="hero3d-section relative mx-auto mb-12 max-w-6xl px-5" data-pagefind-ignore="all">
    <div class="hero3d-stage relative overflow-hidden rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)]">
      <Hero3D titles={heroTitles} prompt="~/koa/log $" client:only="react" transition:animate="none" />
      <div class="hero3d-overlay pointer-events-none absolute inset-0 flex flex-col justify-between p-6 sm:p-10">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-fg-muted)]">SHINKEONKIM · LOG</p>
          <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl">{SITE_TITLE}</h1>
          <p class="mt-2 max-w-md text-sm text-[color:var(--color-fg-muted)] sm:text-base">
            일단 기록을 하자. 흔적을 하나씩 모아보는 곳
          </p>
        </div>
        <div class="pointer-events-auto flex flex-wrap items-center gap-3">
          <a href="/posts/" class="inline-flex items-center gap-1 rounded-full bg-[color:var(--color-accent)] px-4 py-2 text-sm font-medium text-white no-underline hover:bg-[color:var(--color-accent-hover)]">
            최근 글 보기 →
          </a>
          <a href="/graph/" class="inline-flex items-center gap-1 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)]/80 px-4 py-2 text-sm no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)] backdrop-blur">
            그래프 보기 →
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-5" data-pagefind-ignore="all">
    <div class="grid gap-10 md:grid-cols-2">
      <section>
        <div class="mb-4 flex items-baseline justify-between">
          <h2 class="text-xl font-semibold">최근 글</h2>
          <a href="/posts/" class="text-sm">모두 보기 →</a>
        </div>
        {posts.length === 0 ? (
          <p class="text-sm text-[color:var(--color-fg-muted)]">아직 작성된 글이 없습니다.</p>
        ) : (
          <ul class="space-y-3">
            {posts.map((p) => (
              <li class="rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-4">
                <a href={`/posts/${p.id}/`} class="block no-underline">
                  <span class="block text-base font-medium text-[color:var(--color-fg)]">{p.data.title}</span>
                  {p.data.description && (
                    <span class="mt-1 block text-sm text-[color:var(--color-fg-muted)]">{p.data.description}</span>
                  )}
                  <time datetime={p.data.date.toISOString()} class="mt-1 block text-xs text-[color:var(--color-fg-muted)]">
                    {fmt.format(p.data.date)}
                  </time>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>

      <section>
        <div class="mb-4 flex items-baseline justify-between">
          <h2 class="text-xl font-semibold">최근 한줄 노트</h2>
          <a href="/notes/" class="text-sm">모두 보기 →</a>
        </div>
        {notes.length === 0 ? (
          <p class="text-sm text-[color:var(--color-fg-muted)]">아직 작성된 노트가 없습니다.</p>
        ) : (
          <ul class="space-y-3">
            {notes.map((n) => (
              <li class="rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-4 text-sm">
                <time datetime={n.data.date.toISOString()} class="block text-xs text-[color:var(--color-fg-muted)]">
                  {fmt.format(n.data.date)}
                </time>
                <p class="mt-1 leading-relaxed">{previewNote((n as { body?: string }).body)}</p>
              </li>
            ))}
          </ul>
        )}
      </section>
    </div>

    <section class="mt-12">
      <div class="mb-4 flex items-baseline justify-between">
        <h2 class="text-xl font-semibold">위키</h2>
        <a href="/wiki/" class="text-sm">모두 보기 →</a>
      </div>
      {wiki.length === 0 ? (
        <p class="text-sm text-[color:var(--color-fg-muted)]">아직 작성된 위키 페이지가 없습니다.</p>
      ) : (
        <ul class="grid grid-cols-2 gap-2 sm:grid-cols-3 md:grid-cols-4">
          {wiki.map((w) => (
            <li>
              <a href={`/wiki/${w.id}/`} class="block rounded-md border border-[color:var(--color-border)] px-3 py-2 text-sm no-underline hover:border-[color:var(--color-accent)]">
                {w.data.title}
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>
  </section>
</BaseLayout>

<style is:global>
  .hero3d-stage {
    min-height: 460px;
  }
  .hero3d-canvas {
    display: block;
  }
  .hero3d-overlay {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-surface-elevated) 92%, transparent) 0%,
      transparent 32%,
      transparent 70%,
      color-mix(in srgb, var(--color-surface-elevated) 80%, transparent) 100%
    );
  }
  @media (max-width: 640px) {
    .hero3d-stage {
      min-height: 360px;
    }
  }
</style>
