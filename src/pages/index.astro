---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero3D from '@/widgets/hero-3d/Hero3D';
import NoteCard from '@/entities/note/ui/NoteCard.astro';
import NoteCardScript from '@/entities/note/ui/NoteCardScript.astro';
import { SITE_TITLE, SITE_LOCALE } from '@/shared/config';
import {
  getPublishedNotes,
  getPublishedPosts,
  getPublishedWiki,
  sortByDateDesc,
  sortByTitleAsc,
} from '@/shared/lib/content/content-queries';
import { listCategoryInfos, listSeriesInfos } from '@/shared/lib/content/taxonomy';

const TOP_TAXONOMY_PREVIEW = 5;

const posts = sortByDateDesc(await getPublishedPosts()).slice(0, 5);
const notes = sortByDateDesc(await getPublishedNotes()).slice(0, 5);
const wiki = sortByTitleAsc(await getPublishedWiki()).slice(0, 8);
const [categories, seriesList] = await Promise.all([listCategoryInfos(), listSeriesInfos()]);
const topCategories = categories.slice(0, TOP_TAXONOMY_PREVIEW);
const topSeries = seriesList.slice(0, TOP_TAXONOMY_PREVIEW);

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const heroTitles = posts.map((p) => p.data.title);
---

<BaseLayout ogImage="/og/site.png">
  <section class="hero3d-section relative mx-auto mb-12 max-w-6xl px-5" data-pagefind-ignore="all">
    <div
      class="hero3d-stage relative overflow-hidden rounded-2xl border border-border bg-surface-elevated"
    >
      <Hero3D
        titles={heroTitles}
        prompt="~/koa/log $"
        client:only="react"
        transition:animate="none"
      />
      <div
        class="hero3d-overlay pointer-events-none absolute inset-0 flex flex-col justify-between p-6 sm:p-10"
      >
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-fg-muted">
            SHINKEONKIM · LOG
          </p>
          <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl">
            {SITE_TITLE}
          </h1>
          <p class="mt-2 max-w-md text-sm text-fg-muted sm:text-base">
            일단 기록을 하자. 흔적을 하나씩 모아보는 곳
          </p>
        </div>
        <div class="pointer-events-auto flex flex-wrap items-center gap-3">
          <a
            href="/posts/"
            class="inline-flex items-center gap-1 rounded-full bg-accent px-4 py-2 text-sm font-medium text-white no-underline hover:bg-accent-hover"
          >
            최근 글 보기 →
          </a>
          <a
            href="/graph/"
            class="inline-flex items-center gap-1 rounded-full border border-border bg-surface/80 px-4 py-2 text-sm no-underline hover:border-accent hover:text-accent backdrop-blur"
          >
            그래프 보기 →
          </a>
        </div>
      </div>
    </div>
  </section>

  {
    (topCategories.length > 0 || topSeries.length > 0) && (
      <section class="mx-auto mb-10 max-w-5xl px-5" data-pagefind-ignore="all">
        <div class="grid gap-6 md:grid-cols-2">
          {topCategories.length > 0 && (
            <section>
              <div class="mb-3 flex items-baseline justify-between">
                <h2 class="text-sm font-semibold uppercase tracking-wide text-fg-muted">
                  📁 주제별
                </h2>
                <a href="/posts/categories/" class="text-xs text-accent">
                  전체 {categories.length}개 →
                </a>
              </div>
              <ul class="flex flex-wrap gap-1.5">
                {topCategories.map((c) => (
                  <li>
                    <a
                      href={`/posts/category/${encodeURIComponent(c.slug)}/`}
                      class="inline-flex items-center gap-1 rounded-full border border-border px-2.5 py-0.5 text-sm no-underline hover:border-accent hover:text-accent"
                    >
                      {c.label} <span class="opacity-60 text-xs">({c.count})</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
          {topSeries.length > 0 && (
            <section>
              <div class="mb-3 flex items-baseline justify-between">
                <h2 class="text-sm font-semibold uppercase tracking-wide text-fg-muted">
                  📚 시리즈
                </h2>
                <a href="/posts/series/" class="text-xs text-accent">
                  전체 {seriesList.length}개 →
                </a>
              </div>
              <ul class="flex flex-wrap gap-1.5">
                {topSeries.map((s) => (
                  <li>
                    <a
                      href={`/posts/series/${encodeURIComponent(s.slug)}/`}
                      class="inline-flex items-center gap-1 rounded-full border border-border px-2.5 py-0.5 text-sm no-underline hover:border-accent hover:text-accent"
                    >
                      {s.name} <span class="opacity-60 text-xs">({s.count}편)</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </div>
      </section>
    )
  }

  <section class="mx-auto max-w-5xl px-5" data-pagefind-ignore="all">
    <div class="grid gap-10 md:grid-cols-2">
      <section>
        <div class="mb-4 flex items-baseline justify-between">
          <h2 class="text-xl font-semibold">최근 글</h2>
          <a href="/posts/" class="text-sm">모두 보기 →</a>
        </div>
        {
          posts.length === 0 ? (
            <p class="text-sm text-fg-muted">아직 작성된 글이 없습니다.</p>
          ) : (
            <ul class="space-y-3">
              {posts.map((p) => (
                <li class="rounded-md border border-border bg-surface-elevated p-4">
                  <a href={`/posts/${p.id}/`} class="block no-underline">
                    <span class="block text-base font-medium text-fg">
                      {p.data.title}
                    </span>
                    {p.data.description && (
                      <span class="mt-1 block text-sm text-fg-muted">
                        {p.data.description}
                      </span>
                    )}
                    <time
                      datetime={p.data.date.toISOString()}
                      class="mt-1 block text-xs text-fg-muted"
                    >
                      {fmt.format(p.data.date)}
                    </time>
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </section>

      <section>
        <div class="mb-4 flex items-baseline justify-between">
          <h2 class="text-xl font-semibold">최근 노트</h2>
          <a href="/notes/" class="text-sm">모두 보기 →</a>
        </div>
        {
          notes.length === 0 ? (
            <p class="text-sm text-fg-muted">아직 작성된 노트가 없습니다.</p>
          ) : (
            <div class="notes-bricks">
              {notes.map((n) => (
                <NoteCard entry={n} preview />
              ))}
            </div>
          )
        }
      </section>
    </div>

    <section class="mt-12">
      <div class="mb-4 flex items-baseline justify-between">
        <h2 class="text-xl font-semibold">위키</h2>
        <a href="/wiki/" class="text-sm">모두 보기 →</a>
      </div>
      {
        wiki.length === 0 ? (
          <p class="text-sm text-fg-muted">
            아직 작성된 위키 페이지가 없습니다.
          </p>
        ) : (
          <ul class="grid grid-cols-2 gap-2 sm:grid-cols-3 md:grid-cols-4">
            {wiki.map((w) => (
              <li>
                <a
                  href={`/wiki/${w.id}/`}
                  class="block rounded-md border border-border px-3 py-2 text-sm no-underline hover:border-accent"
                >
                  {w.data.title}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </section>
  </section>

  <NoteCardScript />
</BaseLayout>

<style is:global>
  .hero3d-stage {
    min-height: 460px;
  }
  .hero3d-canvas {
    display: block;
  }
  .hero3d-overlay {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-surface-elevated) 92%, transparent) 0%,
      transparent 32%,
      transparent 70%,
      color-mix(in srgb, var(--color-surface-elevated) 80%, transparent) 100%
    );
  }
  @media (max-width: 640px) {
    .hero3d-stage {
      min-height: 360px;
    }
  }
</style>
