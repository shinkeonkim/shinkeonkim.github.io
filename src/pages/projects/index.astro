---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { listProjects, formatPeriod } from '../../lib/projects';

const projects = await listProjects();
const ongoing = projects.filter((p) => p.data.status === 'ongoing');
const completed = projects.filter((p) => p.data.status === 'completed');
const archived = projects.filter((p) => p.data.status === 'archived');
---

<BaseLayout
  title="프로젝트"
  description="개인/팀 프로젝트 모음과 회고. 각 프로젝트에는 GitHub 활동 통계가 포함됩니다."
>
  <section class="mx-auto max-w-5xl px-5" data-pagefind-ignore="all">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">프로젝트</h1>
    <p class="mb-8 text-sm text-[color:var(--color-fg-muted)]">
      총 {projects.length}개 · 진행 중 {ongoing.length} · 완료 {completed.length} · 보관 {
        archived.length
      }
    </p>

    {
      projects.length === 0 ? (
        <p class="text-sm text-[color:var(--color-fg-muted)]">
          아직 등록된 프로젝트가 없습니다. <code>src/content/projects/</code> 에 새 프로젝트를
          추가하세요.
        </p>
      ) : (
        <ul class="grid gap-4 sm:grid-cols-2">
          {projects.map((p) => (
            <li class="project-card">
              <a href={`/projects/${p.id}/`} class="project-card-link">
                {p.data.thumbnail && (
                  <img
                    src={p.data.thumbnail}
                    alt={p.data.title}
                    class="project-card-thumb"
                    width="480"
                    height="270"
                    loading="lazy"
                    decoding="async"
                  />
                )}
                <div class="project-card-body">
                  <div class="project-card-meta">
                    <span class="project-card-status project-card-status-{p.data.status}">
                      {p.data.status === 'ongoing'
                        ? '진행 중'
                        : p.data.status === 'archived'
                          ? '보관'
                          : '완료'}
                    </span>
                    <time class="project-card-period">
                      {formatPeriod(p.data.start, p.data.end)}
                    </time>
                  </div>
                  <h2 class="project-card-title">{p.data.title}</h2>
                  <p class="project-card-summary">{p.data.summary}</p>
                  {p.data.stack.length > 0 && (
                    <div class="project-card-stack">
                      {p.data.stack.slice(0, 5).map((s) => (
                        <span class="project-card-stack-item">{s}</span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>

<style is:global>
  .project-card {
    border: 1px solid var(--color-border);
    border-radius: 0.6rem;
    background-color: var(--color-surface-elevated);
    overflow: hidden;
    transition:
      border-color 120ms,
      transform 120ms;
  }
  .project-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .project-card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .project-card-thumb {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-bottom: 1px solid var(--color-border);
  }
  .project-card-body {
    padding: 0.9rem 1rem 1.1rem;
  }
  .project-card-meta {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
  }
  .project-card-status {
    font-size: 0.7rem;
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    background-color: var(--color-code-bg);
    color: var(--color-fg-muted);
  }
  .project-card-status-ongoing {
    background-color: color-mix(in srgb, var(--color-accent) 18%, transparent);
    color: var(--color-accent);
  }
  .project-card-period {
    font-size: 0.75rem;
    color: var(--color-fg-muted);
  }
  .project-card-title {
    margin: 0 0 0.3rem;
    font-size: 1.05rem;
    font-weight: 600;
  }
  .project-card-summary {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-fg-muted);
  }
  .project-card-stack {
    margin-top: 0.6rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .project-card-stack-item {
    font-size: 0.7rem;
    padding: 0.1rem 0.45rem;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    color: var(--color-fg-muted);
  }
</style>
