---
import BaseLayout from '../layouts/BaseLayout.astro';
import UrlPreview from '../components/UrlPreview.astro';
import { absoluteUrl, breadcrumbSchema } from '../lib/schema';
import { EXTERNAL_PROFILES } from '../lib/external-profiles';

const jsonLd = [breadcrumbSchema([{ name: '소개', url: absoluteUrl('/about/') }])];
---

<BaseLayout
  title="소개"
  description="개발자 김신건(koa) 소개, Python·Django·Astro 로 작업하는 개발자. 알고리즘 문제 풀이, 웹 개발, 데이터베이스 관련 기록을 남깁니다."
  ogType="profile"
  jsonLd={jsonLd}
>
  <article class="container-prose prose-content" data-pagefind-ignore="all">
    <h1>소개</h1>
    <blockquote>일단 기록을 하자.</blockquote>

    <h2>about me</h2>
    <p>
      안녕하세요. 개발자 <strong>김신건</strong> 입니다.
    </p>

    <h2>다른 곳에서</h2>
    <p>
      이력서 / 자기소개서 / 포트폴리오는 별도 사이트에서 관리하고 있습니다.
    </p>
    {EXTERNAL_PROFILES.map((profile) => <UrlPreview url={profile.url} hideImage />)}

    <h2>about this site</h2>
    <p>
      이 블로그는 <a href="https://astro.build/" target="_blank" rel="noreferrer">Astro</a> 로 만들었습니다.
      마크다운으로 글을 쓰면 <code>[[wikilink]]</code> 문법이 자동으로 내부 링크로 변환되고, 백링크와
      그래프가 빌드 시점에 생성됩니다.
    </p>
    <ul>
      <li><a href="/posts/">긴 글</a>, 정리해서 남기고 싶은 내용</li>
      <li><a href="/notes/">노트</a>, 짧은 메모와 스쳐가는 생각</li>
      <li><a href="/wiki/">위키</a>, 자주 참조하는 개념 정리</li>
      <li><a href="/graph/">그래프</a>, 노트 사이의 연결 시각화</li>
    </ul>
  </article>
</BaseLayout>
