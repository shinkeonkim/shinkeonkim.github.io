---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_LOCALE } from '@/shared/config';
import { getPublishedPosts, sortByDateDesc } from '@/shared/lib/content/content-queries';

const recent = sortByDateDesc(await getPublishedPosts()).slice(0, 6);

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title="페이지를 찾을 수 없음"
  description="요청한 페이지가 존재하지 않거나 이동/삭제되었습니다. 검색 또는 최근 글 목록을 이용해보세요."
  noIndex
>
  <section class="mx-auto max-w-2xl px-5">
    <div class="text-center py-6">
      <p class="text-sm font-mono text-fg-muted">404, Not Found</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight md:text-4xl">페이지를 찾을 수 없어요</h1>
      <p class="mt-3 text-fg-muted">
        주소가 잘못되었거나, 글이 이동·삭제되었을 수 있습니다.
      </p>
      <div class="mt-5 flex flex-wrap justify-center gap-2">
        <a
          href="/"
          class="rounded-full bg-accent px-4 py-1.5 text-sm text-white no-underline hover:bg-accent-hover"
          >홈으로</a
        >
        <button
          type="button"
          data-search-modal-open
          class="rounded-full border border-border px-4 py-1.5 text-sm cursor-pointer hover:border-accent hover:text-accent"
          aria-label="검색 모달 열기 (Cmd+K)"
        >🔎 검색 (⌘K)</button>
        <a
          href="/posts/"
          class="rounded-full border border-border px-4 py-1.5 text-sm no-underline hover:border-accent hover:text-accent"
          >글 목록</a
        >
        <a
          href="/graph/"
          class="rounded-full border border-border px-4 py-1.5 text-sm no-underline hover:border-accent hover:text-accent"
          >그래프</a
        >
      </div>
    </div>

    <section
      id="suggest-section"
      class="mt-8 hidden rounded-md border border-border bg-surface-elevated p-4"
    >
      <h2 class="mb-2 text-base font-semibold">
        혹시 이 페이지를 찾으셨나요?
      </h2>
      <p class="mb-3 text-xs text-fg-muted">
        URL의 단어로 검색한 결과입니다.
        <span id="suggest-query" class="font-mono"></span>
      </p>
      <ul id="suggest-list" class="space-y-2 text-sm"></ul>
    </section>

    {
      recent.length > 0 && (
        <section class="mt-10">
          <h2 class="mb-4 text-lg font-semibold">최근 글</h2>
          <ul class="space-y-3">
            {recent.map((p) => (
              <li class="rounded-md border border-border bg-surface-elevated p-3">
                <a href={`/posts/${p.id}/`} class="block no-underline">
                  <span class="block text-base font-medium text-fg">
                    {p.data.title}
                  </span>
                  {p.data.description && (
                    <span class="mt-0.5 block text-sm text-fg-muted">
                      {p.data.description}
                    </span>
                  )}
                  <time
                    datetime={p.data.date.toISOString()}
                    class="mt-0.5 block text-xs text-fg-muted"
                  >
                    {fmt.format(p.data.date)}
                  </time>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </section>
</BaseLayout>

<script>
  function extractQueryFromPath(): string {
    const path = window.location.pathname;
    const segments = path.split('/').filter(Boolean);
    const last = segments[segments.length - 1] ?? '';
    // Decode and turn separators into spaces so 'sql-join' becomes 'sql join'.
    return decodeURIComponent(last)
      .replace(/[-_+]/g, ' ')
      .replace(/\.html?$/, '')
      .trim();
  }

  async function runSuggest() {
    const query = extractQueryFromPath();
    if (!query || query.length < 2) return;
    const section = document.getElementById('suggest-section');
    const queryEl = document.getElementById('suggest-query');
    const list = document.getElementById('suggest-list');
    if (!section || !queryEl || !list) return;
    queryEl.textContent = `"${query}"`;
    try {
      const pagefindUrl = '/pagefind/pagefind.js';
      const mod = (await import(/* @vite-ignore */ pagefindUrl)) as {
        search: (q: string) => Promise<{ results: { data: () => Promise<unknown> }[] }>;
        options: (o: object) => Promise<void>;
        init: () => Promise<void>;
      };
      await mod.options({});
      await mod.init();
      const result = await mod.search(query);
      if (!result || result.results.length === 0) return;
      const hits = (await Promise.all(
        result.results.slice(0, 5).map((r) => r.data()),
      )) as { url: string; meta?: { title?: string }; excerpt?: string; filters?: { section?: string | string[]; category?: string | string[] } }[];
      const pickFirst = (v: string | string[] | undefined) =>
        Array.isArray(v) ? v[0] : (v ?? '');
      const SECTION_LABELS: Record<string, string> = { posts: '글', notes: '노트', wiki: '위키' };
      list.innerHTML = hits
        .map((h) => {
          const section = pickFirst(h.filters?.section);
          const category = pickFirst(h.filters?.category);
          const badge = SECTION_LABELS[section] ?? section;
          const title = h.meta?.title ?? h.url;
          const path = category ? ` <span class="text-xs text-fg-muted">${section} / ${category}</span>` : '';
          return `<li><a href="${h.url}" class="block no-underline hover:text-accent">
            ${badge ? `<span class="mr-1 inline-block rounded-sm border border-border px-1 text-xs">${badge}</span>` : ''}
            <span class="font-medium">${title}</span>
            ${path}
          </a></li>`;
        })
        .join('');
      section.classList.remove('hidden');
    } catch {
      /* pagefind unavailable in dev; silently skip */
    }
  }

  if (document.readyState !== 'loading') runSuggest();
  else document.addEventListener('DOMContentLoaded', runSuggest);
</script>
