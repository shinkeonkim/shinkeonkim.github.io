---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_LOCALE } from '../consts';
import { getPublishedPosts, sortByDateDesc } from '../lib/content-queries';

const recent = sortByDateDesc(await getPublishedPosts()).slice(0, 6);

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title="페이지를 찾을 수 없음"
  description="요청한 페이지가 존재하지 않거나 이동/삭제되었습니다. 검색 또는 최근 글 목록을 이용해보세요."
  noIndex
>
  <section class="mx-auto max-w-2xl px-5">
    <div class="text-center py-6">
      <p class="text-sm font-mono text-[color:var(--color-fg-muted)]">404 — Not Found</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight md:text-4xl">페이지를 찾을 수 없어요</h1>
      <p class="mt-3 text-[color:var(--color-fg-muted)]">
        주소가 잘못되었거나, 글이 이동·삭제되었을 수 있습니다.
      </p>
      <div class="mt-5 flex flex-wrap justify-center gap-2">
        <a
          href="/"
          class="rounded-full bg-[color:var(--color-accent)] px-4 py-1.5 text-sm text-white no-underline hover:bg-[color:var(--color-accent-hover)]"
          >홈으로</a
        >
        <button
          type="button"
          data-search-modal-open
          class="rounded-full border border-[color:var(--color-border)] px-4 py-1.5 text-sm cursor-pointer hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
          aria-label="검색 모달 열기 (Cmd+K)"
        >🔎 검색 (⌘K)</button>
        <a
          href="/posts/"
          class="rounded-full border border-[color:var(--color-border)] px-4 py-1.5 text-sm no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
          >글 목록</a
        >
        <a
          href="/graph/"
          class="rounded-full border border-[color:var(--color-border)] px-4 py-1.5 text-sm no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
          >그래프</a
        >
      </div>
    </div>

    {
      recent.length > 0 && (
        <section class="mt-10">
          <h2 class="mb-4 text-lg font-semibold">최근 글</h2>
          <ul class="space-y-3">
            {recent.map((p) => (
              <li class="rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-3">
                <a href={`/posts/${p.id}/`} class="block no-underline">
                  <span class="block text-base font-medium text-[color:var(--color-fg)]">
                    {p.data.title}
                  </span>
                  {p.data.description && (
                    <span class="mt-0.5 block text-sm text-[color:var(--color-fg-muted)]">
                      {p.data.description}
                    </span>
                  )}
                  <time
                    datetime={p.data.date.toISOString()}
                    class="mt-0.5 block text-xs text-[color:var(--color-fg-muted)]"
                  >
                    {fmt.format(p.data.date)}
                  </time>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </section>
</BaseLayout>
