---
import { type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Pagination from '@/shared/ui/Pagination.astro';
import WikiList from '@/widgets/wiki-list/WikiList.astro';
import WikiFilterUI from '@/features/wiki-filter/ui/WikiFilterUI.astro';
import { SITE_LOCALE, WIKI_PER_PAGE } from '@/shared/config';
import { getWikiTaxonomy, groupCategoryBySubcategory } from '@/shared/lib/content/taxonomy';
import { getWikiCategoryMeta } from '@/shared/lib/content/wiki-category-meta';
import { absoluteUrl, breadcrumbSchema, collectionPageSchema } from '@/shared/lib/seo/schema';
import type { GetStaticPaths, Page } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const taxonomy = await getWikiTaxonomy();
  const all: { params: { category: string }; props: { categoryName: string } }[] = [];
  for (const [category, items] of taxonomy.categories) {
    const paginated = paginate(items, { pageSize: WIKI_PER_PAGE, params: { category } });
    all.push(
      ...(paginated.map((p) => ({
        ...p,
        props: { ...p.props, categoryName: category },
      })) as never[]),
    );
  }
  return all;
}) satisfies GetStaticPaths;

type Props = { page: Page<CollectionEntry<'wiki'>>; categoryName: string };
const { page, categoryName } = Astro.props as Props;

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryBase = `/wiki/category/${encodeURIComponent(categoryName)}/`;
const pageDescription =
  `${categoryName} 카테고리에 속한 위키 ${page.total}개. ${page.data[0]?.data.title ? `최근 갱신: ${page.data[0].data.title}` : ''}`.trim();

const jsonLd = [
  collectionPageSchema({
    name: `${categoryName} 위키`,
    description: pageDescription,
    url: absoluteUrl(page.url.current),
    itemCount: page.total,
  }),
  breadcrumbSchema([
    { name: '위키', url: absoluteUrl('/wiki/') },
    { name: categoryName, url: absoluteUrl(categoryBase) },
  ]),
];

const prevUrl = page.url.prev ? absoluteUrl(page.url.prev) : undefined;
const nextUrl = page.url.next ? absoluteUrl(page.url.next) : undefined;

const subGroups = page.currentPage === 1
  ? await groupCategoryBySubcategory(categoryName)
  : [];
const hasSubGroups = subGroups.length > 1 || (subGroups[0]?.slug !== null && subGroups.length > 0);
const categoryMeta = getWikiCategoryMeta(categoryName);

// Build the category-scoped index for client-side filtering. Includes every
// entry that belongs to the current category (not just the current page slice)
// so search + tag filter operate on the whole category, matching how the
// /wiki/ landing filter behaves against the full wiki set.
interface WikiIndexEntry {
  id: string;
  title: string;
  aliases: string[];
  tags: string[];
  updated: string | null;
  updatedLabel: string | null;
}

const taxonomy = await getWikiTaxonomy();
const allInCategory = (taxonomy.categories.get(categoryName) ?? [])
  .slice()
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const wikiIndex: WikiIndexEntry[] = allInCategory.map((w) => ({
  id: w.id,
  title: w.data.title,
  aliases: w.data.aliases ?? [],
  tags: w.data.tags ?? [],
  updated: w.data.updated ? w.data.updated.toISOString() : null,
  updatedLabel: w.data.updated ? fmt.format(w.data.updated) : null,
}));

const tagCounts = new Map<string, number>();
for (const w of allInCategory) {
  for (const t of w.data.tags ?? []) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
const sortedTags = Array.from(tagCounts.entries())
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([tag, count]) => ({ tag, count }));

// Escape `<` to prevent `</script>` injection from any title/tag string.
const wikiIndexJson = JSON.stringify(wikiIndex).replace(/</g, '\\u003c');
---

<BaseLayout
  title={page.currentPage > 1
    ? `📁 ${categoryName} 위키 (${page.currentPage}페이지)`
    : `📁 ${categoryName} 위키`}
  description={pageDescription}
  jsonLd={jsonLd}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
  keywords={[categoryName, '위키', '카테고리']}
  ogImage={`/og/wiki/category/${encodeURIComponent(categoryName)}.png`}
>
  <section class="mx-auto max-w-3xl px-5" data-pagefind-ignore="all">
    <nav class="mb-3 text-xs text-fg-muted">
      <a href="/" class="hover:text-accent">홈</a>
      <span class="mx-1">/</span>
      <a href="/wiki/" class="hover:text-accent">위키</a>
      <span class="mx-1">/</span>
      <a href="/wiki/categories/" class="hover:text-accent">카테고리</a>
      <span class="mx-1">/</span>
      <span class="text-fg">{categoryName}</span>
    </nav>
    <h1 class="mb-2 flex items-center gap-2 text-3xl font-bold tracking-tight">
      <span
        class="inline-flex h-8 w-8 items-center justify-center rounded-md border-l-4 bg-surface-elevated text-base"
        style={`border-left-color: ${categoryMeta.color}`}
        aria-hidden="true"
        >{categoryMeta.icon}</span
      >
      <span>{categoryName}</span>
    </h1>
    <p class="mb-6 text-fg-muted">
      총 {page.total}개의 위키 · {page.currentPage} / {page.lastPage} 페이지
      <a
        href={`/wiki/category/${encodeURIComponent(categoryName)}/rss.xml`}
        class="ml-2 text-xs hover:text-accent"
        title={`${categoryName} 카테고리 RSS`}
        rel="alternate"
        type="application/rss+xml"
      >
        📡 RSS
      </a>
      <a
        href={`/graph/?category=${encodeURIComponent(categoryName)}`}
        class="ml-2 text-xs hover:text-accent"
        title={`${categoryName} 카테고리 그래프 보기`}
      >
        🕸️ 그래프
      </a>
    </p>

    <WikiFilterUI tags={sortedTags} />

    <div data-wiki-default-list>
      {hasSubGroups ? (
        <div class="space-y-8">
          {subGroups.map((g) => (
            <section>
              <header class="mb-2 flex items-baseline justify-between gap-2">
                <h2 class="text-lg font-semibold">
                  {g.slug ? `📂 ${g.slug}` : '(기타)'}
                </h2>
                <span class="text-xs text-fg-muted tabular-nums">
                  {g.entries.length}개
                </span>
              </header>
              <WikiList entries={g.entries} fmt={fmt} />
            </section>
          ))}
        </div>
      ) : (
        <WikiList entries={page.data} fmt={fmt} />
      )}
    </div>

    <section data-wiki-filtered hidden data-pagefind-ignore="all" aria-label="검색 결과">
      <p
        class="mb-3 text-sm text-fg-muted"
        data-wiki-filtered-count
        aria-live="polite"
      ></p>
      <ul class="wiki-list" data-wiki-filtered-list></ul>
      <p class="mt-3 hidden text-sm text-fg-muted" data-wiki-filtered-empty>
        일치하는 위키 페이지가 없습니다. 다른 검색어나 태그를 시도해보세요.
      </p>
      <nav
        data-wiki-filtered-pagination
        class="mt-10 flex flex-wrap items-center justify-center gap-1.5 text-sm"
        aria-label="검색 결과 페이지 네비게이션"
        hidden
      ></nav>
    </section>

    {!hasSubGroups && (
      <div data-wiki-pagination-wrap>
        <Pagination
          currentPage={page.currentPage}
          lastPage={page.lastPage}
          baseUrl={categoryBase}
        />
      </div>
    )}

    <script
      is:inline
      type="application/json"
      id="wiki-index-data"
      data-pagefind-ignore="all"
      set:html={wikiIndexJson}
    />
  </section>
</BaseLayout>

<script>
  import { setupWikiFilter } from '@/features/wiki-filter/lib/wiki-filter';

  if (document.readyState !== 'loading') setupWikiFilter();
  else document.addEventListener('DOMContentLoaded', setupWikiFilter);
  document.addEventListener('astro:page-load', setupWikiFilter);
</script>
