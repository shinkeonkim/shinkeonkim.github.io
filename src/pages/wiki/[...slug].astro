---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import WikiSidebar from '@/widgets/wiki-sidebar/WikiSidebar.astro';
import { buildWikiTreeForCategory, categoryOf } from '@/shared/lib/content/taxonomy';

export async function getStaticPaths() {
  const entries = await getCollection('wiki');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const body = (entry as { body?: string }).body ?? '';

const cat = categoryOf(entry);
const sidebarTree = cat ? await buildWikiTreeForCategory(cat) : null;
---

<PostLayout
  title={entry.data.title}
  date={entry.data.updated ?? new Date()}
  updated={entry.data.updated}
  tags={entry.data.tags}
  slug={entry.id}
  collection="wiki"
  cover={entry.data.cover}
  coverAlt={entry.data.coverAlt}
  category={entry.data.category}
  references={entry.data.references}
  headings={headings}
  body={body}
>
  {entry.data.aliases && entry.data.aliases.length > 0 && (
    <span class="sr-only" data-pagefind-meta="aliases">
      {entry.data.aliases.join(', ')}
    </span>
  )}
  {sidebarTree && (
    <Fragment slot="sidebar-extra">
      <WikiSidebar tree={sidebarTree} activeId={entry.id} />
    </Fragment>
  )}
  <Content />
</PostLayout>
