---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Pagination from '@/shared/ui/Pagination.astro';
import { SITE_LOCALE, WIKI_PER_PAGE } from '@/shared/config';
import type { GetStaticPaths, Page } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const entries = (await getCollection('wiki')).sort((a, b) =>
    a.data.title.localeCompare(b.data.title),
  );
  return paginate(entries, { pageSize: WIKI_PER_PAGE });
}) satisfies GetStaticPaths;

type Props = { page: Page<CollectionEntry<'wiki'>> };
const { page } = Astro.props as Props;

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const isLanding = page.currentPage === 1;

interface StubInfo {
  entry: CollectionEntry<'wiki'>;
  chars: number;
}

interface WikiIndexEntry {
  id: string;
  title: string;
  aliases: string[];
  tags: string[];
  updated: string | null;
  updatedLabel: string | null;
}

// Build the full index for client-side filtering. Available on every paginated
// page so the filter operates across the complete wiki set, not the current slice.
const allEntries = (await getCollection('wiki')).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);

const wikiIndex: WikiIndexEntry[] = allEntries.map((w) => ({
  id: w.id,
  title: w.data.title,
  aliases: w.data.aliases ?? [],
  tags: w.data.tags ?? [],
  updated: w.data.updated ? w.data.updated.toISOString() : null,
  updatedLabel: w.data.updated ? fmt.format(w.data.updated) : null,
}));

// Tag counts (descending by frequency, then alphabetical).
const tagCounts = new Map<string, number>();
for (const w of allEntries) {
  for (const t of w.data.tags ?? []) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
const sortedTags = Array.from(tagCounts.entries())
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([tag, count]) => ({ tag, count }));

let recentUpdates: CollectionEntry<'wiki'>[] = [];
let stubs: StubInfo[] = [];

if (isLanding) {
  recentUpdates = allEntries
    .filter((e) => e.data.updated)
    .sort((a, b) => (b.data.updated!.valueOf() - a.data.updated!.valueOf()))
    .slice(0, 6);

  const STUB_THRESHOLD = 100;
  for (const entry of allEntries) {
    const body = (entry as { body?: string }).body ?? '';
    const stripped = body.replace(/```[\s\S]*?```/g, '').replace(/<[^>]+>/g, '').trim();
    if (stripped.length < STUB_THRESHOLD) {
      stubs.push({ entry, chars: stripped.length });
    }
  }
  stubs.sort((a, b) => a.chars - b.chars);
}

// Serialize index for inline embedding. Escape `<` to prevent `</script>` injection
// from any title/tag string that might contain HTML-like characters.
const wikiIndexJson = JSON.stringify(wikiIndex).replace(/</g, '\\u003c');
---

<BaseLayout
  title={page.currentPage > 1 ? `위키 (${page.currentPage}페이지)` : '위키'}
  description="개념 정리 노트 모음, 자주 참조하는 주제를 한 페이지로 묶었습니다."
>
  <section class="mx-auto max-w-3xl px-5">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">위키</h1>
    <p class="mb-6 text-[color:var(--color-fg-muted)]" data-pagefind-ignore>
      총 {page.total}개의 페이지 · {page.currentPage} / {page.lastPage}
      {!isLanding && ` · ${page.total}개 중 ${(page.currentPage - 1) * WIKI_PER_PAGE + 1}–${(page.currentPage - 1) * WIKI_PER_PAGE + page.data.length}`}
    </p>

    <div data-wiki-context>
      {isLanding && recentUpdates.length > 0 && (
        <section class="mb-8" data-pagefind-ignore="all">
          <h2 class="mb-3 text-lg font-semibold">최근 업데이트</h2>
          <ul class="grid grid-cols-1 gap-2 sm:grid-cols-2">
            {recentUpdates.map((w) => (
              <li>
                <a
                  href={`/wiki/${w.id}/`}
                  class="block rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] px-3 py-2 no-underline hover:border-[color:var(--color-accent)]"
                >
                  <span class="block text-sm font-medium">{w.data.title}</span>
                  <time
                    datetime={w.data.updated!.toISOString()}
                    class="mt-0.5 block text-xs text-[color:var(--color-fg-muted)]"
                  >
                    {fmt.format(w.data.updated!)}
                  </time>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {isLanding && stubs.length > 0 && (
        <section class="mb-8" data-pagefind-ignore="all">
          <h2 class="mb-3 text-lg font-semibold">📝 내용 보강 필요 ({stubs.length})</h2>
          <p class="mb-2 text-xs text-[color:var(--color-fg-muted)]">
            본문이 100자 미만인 위키 페이지. 한 줄 정의만 있거나 미작성 상태입니다.
          </p>
          <ul class="flex flex-wrap gap-1.5">
            {stubs.slice(0, 24).map(({ entry, chars }) => (
              <li>
                <a
                  href={`/wiki/${entry.id}/`}
                  class="inline-flex items-baseline gap-1 rounded-full border border-dashed border-[color:var(--color-border)] px-2.5 py-0.5 text-sm no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
                  title={`본문 ${chars}자`}
                >
                  {entry.data.title}
                  <span class="text-xs opacity-60">{chars}자</span>
                </a>
              </li>
            ))}
            {stubs.length > 24 && (
              <li class="text-xs text-[color:var(--color-fg-muted)] self-center">
                +{stubs.length - 24}개 더
              </li>
            )}
          </ul>
        </section>
      )}
    </div>

    {isLanding && (
      <header data-wiki-pages-header class="mb-3">
        <h2 class="text-lg font-semibold">전체 페이지</h2>
      </header>
    )}

    <section
      class="wiki-filter mb-4"
      data-wiki-filter-ui
      data-pagefind-ignore="all"
      aria-label="위키 필터"
    >
      <label class="block">
        <span class="sr-only">위키 페이지 검색</span>
        <input
          type="search"
          data-wiki-search
          placeholder="제목, 별칭, 태그로 검색…"
          autocomplete="off"
          class="w-full rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-3 py-2 text-sm placeholder:text-[color:var(--color-fg-muted)] focus:border-[color:var(--color-accent)] focus:outline-none"
        />
      </label>
      {sortedTags.length > 0 && (
        <details class="mt-2 wiki-filter-tags" data-wiki-tag-panel>
          <summary class="cursor-pointer select-none text-xs text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-accent)]">
            태그로 필터 ({sortedTags.length})
            <span data-wiki-active-tag-label class="ml-1 hidden text-[color:var(--color-accent)]"></span>
          </summary>
          <div class="mt-2 flex flex-wrap gap-1.5" data-wiki-tag-chips>
            {sortedTags.map(({ tag, count }) => (
              <button
                type="button"
                data-wiki-tag={tag}
                aria-pressed="false"
                class="wiki-tag-chip inline-flex items-baseline gap-1 rounded-full border border-[color:var(--color-border)] bg-transparent px-2.5 py-0.5 text-xs hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
              >
                #{tag} <span class="opacity-60">{count}</span>
              </button>
            ))}
          </div>
        </details>
      )}
    </section>

    <section
      data-pagefind-body
      data-pagefind-filter="section:wiki"
      data-wiki-default-list
    >
      {page.data.length === 0 ? (
        <p class="text-sm text-[color:var(--color-fg-muted)]">
          아직 작성된 위키 페이지가 없습니다.
        </p>
      ) : (
        <ul class="wiki-list">
          {page.data.map((w) => (
            <li>
              <a href={`/wiki/${w.id}/`} class="wiki-list-item group">
                <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-0.5">
                  <span class="text-base font-medium group-hover:text-[color:var(--color-accent)]">
                    {w.data.title}
                  </span>
                  {w.data.updated && (
                    <time
                      datetime={w.data.updated.toISOString()}
                      class="shrink-0 text-xs text-[color:var(--color-fg-muted)] tabular-nums"
                    >
                      {fmt.format(w.data.updated)}
                    </time>
                  )}
                </div>
                {w.data.tags.length > 0 && (
                  <div class="mt-0.5 text-xs text-[color:var(--color-fg-muted)]">
                    {w.data.tags.map((t) => `#${t}`).join(' ')}
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>

    <section data-wiki-filtered hidden data-pagefind-ignore="all" aria-label="필터 결과">
      <p
        class="mb-3 text-sm text-[color:var(--color-fg-muted)]"
        data-wiki-filtered-count
        aria-live="polite"
      ></p>
      <ul class="wiki-list" data-wiki-filtered-list></ul>
      <p class="mt-3 hidden text-sm text-[color:var(--color-fg-muted)]" data-wiki-filtered-empty>
        일치하는 위키 페이지가 없습니다. 다른 검색어나 태그를 시도해보세요.
      </p>
    </section>

    <div data-wiki-pagination-wrap>
      <Pagination currentPage={page.currentPage} lastPage={page.lastPage} baseUrl="/wiki/" />
    </div>

    <script
      is:inline
      type="application/json"
      id="wiki-index-data"
      data-pagefind-ignore="all"
      set:html={wikiIndexJson}
    />
  </section>
</BaseLayout>

<style>
  /* Active tag chip - styled via attribute selector so it works regardless of
     Tailwind aria variant support. */
  .wiki-tag-chip[aria-pressed='true'] {
    border-color: var(--color-accent);
    background: var(--color-surface-elevated);
    color: var(--color-accent);
  }

  /* Dense list: subtle dividers, no card borders. Suits an index page. */
  .wiki-list {
    border-top: 1px solid var(--color-border);
  }
  .wiki-list > li {
    border-bottom: 1px solid var(--color-border);
  }
  .wiki-list-item {
    display: block;
    padding: 0.6rem 0;
    text-decoration: none;
    color: inherit;
  }
</style>

<script>
  // Wiki listing filter: in-page search (title / aliases / tags) + tag chip filter.
  // State is mirrored to URL query params (?search=, ?tag=) so filtered views are shareable.
  type WikiEntry = {
    id: string;
    title: string;
    aliases: string[];
    tags: string[];
    updated: string | null;
    updatedLabel: string | null;
  };

  function setupWikiFilter(): void {
    const filterUi = document.querySelector<HTMLElement>('[data-wiki-filter-ui]');
    if (!filterUi || filterUi.dataset.wikiFilterReady === '1') return;

    const dataEl = document.getElementById('wiki-index-data');
    const searchInput = document.querySelector<HTMLInputElement>('[data-wiki-search]');
    const contextEl = document.querySelector<HTMLElement>('[data-wiki-context]');
    const pagesHeaderEl = document.querySelector<HTMLElement>('[data-wiki-pages-header]');
    const defaultListEl = document.querySelector<HTMLElement>('[data-wiki-default-list]');
    const paginationWrapEl = document.querySelector<HTMLElement>('[data-wiki-pagination-wrap]');
    const filteredView = document.querySelector<HTMLElement>('[data-wiki-filtered]');
    const filteredCount = document.querySelector<HTMLElement>('[data-wiki-filtered-count]');
    const filteredList = document.querySelector<HTMLUListElement>('[data-wiki-filtered-list]');
    const filteredEmpty = document.querySelector<HTMLElement>('[data-wiki-filtered-empty]');
    const tagButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>('[data-wiki-tag]'),
    );
    const tagLabel = document.querySelector<HTMLElement>('[data-wiki-active-tag-label]');
    const tagPanel = document.querySelector<HTMLDetailsElement>('[data-wiki-tag-panel]');

    if (
      !dataEl ||
      !searchInput ||
      !filteredView ||
      !filteredCount ||
      !filteredList ||
      !filteredEmpty
    ) {
      return;
    }

    let allEntries: WikiEntry[] = [];
    try {
      allEntries = JSON.parse(dataEl.textContent ?? '[]') as WikiEntry[];
    } catch {
      return;
    }

    filterUi.dataset.wikiFilterReady = '1';

    // Use `search` (not `q`) to avoid colliding with the global SearchModal,
    // which auto-opens on `?q=` and strips it from the URL.
    const params = new URLSearchParams(window.location.search);
    let query = params.get('search') ?? '';
    let activeTag = params.get('tag') ?? '';

    if (query) searchInput.value = query;
    if (activeTag && tagPanel) tagPanel.open = true;

    const escapeHtml = (s: string): string =>
      s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');

    const norm = (s: string): string => s.normalize('NFC').toLowerCase();

    function syncUrl(): void {
      const url = new URL(window.location.href);
      if (query) url.searchParams.set('search', query);
      else url.searchParams.delete('search');
      if (activeTag) url.searchParams.set('tag', activeTag);
      else url.searchParams.delete('tag');
      window.history.replaceState({}, '', url.toString());
    }

    function setFilterState(active: boolean): void {
      // Filter UI itself stays visible in both states. Toggle only context,
      // section header, default list, pagination, and the filtered container.
      if (contextEl) contextEl.hidden = active;
      if (pagesHeaderEl) pagesHeaderEl.hidden = active;
      if (defaultListEl) defaultListEl.hidden = active;
      if (paginationWrapEl) paginationWrapEl.hidden = active;
      filteredView!.hidden = !active;
    }

    function render(): void {
      const hasFilter = query.trim().length > 0 || activeTag.length > 0;

      for (const btn of tagButtons) {
        btn.setAttribute(
          'aria-pressed',
          btn.dataset.wikiTag === activeTag && activeTag.length > 0 ? 'true' : 'false',
        );
      }

      if (tagLabel) {
        if (activeTag) {
          tagLabel.textContent = `· #${activeTag}`;
          tagLabel.classList.remove('hidden');
        } else {
          tagLabel.textContent = '';
          tagLabel.classList.add('hidden');
        }
      }

      syncUrl();

      if (!hasFilter) {
        setFilterState(false);
        filteredList!.innerHTML = '';
        return;
      }

      const q = norm(query.trim());
      const filtered = allEntries.filter((e) => {
        if (activeTag && !e.tags.includes(activeTag)) return false;
        if (q) {
          const haystack = norm(
            `${e.title} ${e.aliases.join(' ')} ${e.tags.join(' ')}`,
          );
          return haystack.includes(q);
        }
        return true;
      });

      setFilterState(true);

      if (filtered.length === 0) {
        filteredList!.innerHTML = '';
        filteredCount!.textContent = `검색 결과 없음 · 전체 ${allEntries.length}개`;
        filteredEmpty!.classList.remove('hidden');
        return;
      }

      filteredEmpty!.classList.add('hidden');
      filteredCount!.textContent = `검색 결과 ${filtered.length}개 · 전체 ${allEntries.length}개`;
      filteredList!.innerHTML = filtered
        .map((e) => {
          const title = escapeHtml(e.title);
          const updated =
            e.updated && e.updatedLabel
              ? `<time datetime="${escapeHtml(e.updated)}" class="shrink-0 text-xs text-[color:var(--color-fg-muted)] tabular-nums">${escapeHtml(e.updatedLabel)}</time>`
              : '';
          const tagsRow =
            e.tags.length > 0
              ? `<div class="mt-0.5 text-xs text-[color:var(--color-fg-muted)]">${e.tags.map((t) => `#${escapeHtml(t)}`).join(' ')}</div>`
              : '';
          return `<li><a href="/wiki/${encodeURIComponent(e.id)}/" class="wiki-list-item group"><div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-0.5"><span class="text-base font-medium group-hover:text-[color:var(--color-accent)]">${title}</span>${updated}</div>${tagsRow}</a></li>`;
        })
        .join('');
    }

    let debounceId: ReturnType<typeof setTimeout> | null = null;
    searchInput.addEventListener('input', () => {
      if (debounceId !== null) clearTimeout(debounceId);
      debounceId = setTimeout(() => {
        query = searchInput.value;
        render();
      }, 80);
    });

    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && searchInput.value) {
        e.preventDefault();
        searchInput.value = '';
        query = '';
        render();
      }
    });

    for (const btn of tagButtons) {
      btn.addEventListener('click', () => {
        const tag = btn.dataset.wikiTag ?? '';
        activeTag = activeTag === tag ? '' : tag;
        render();
      });
    }

    render();
  }

  if (document.readyState !== 'loading') setupWikiFilter();
  else document.addEventListener('DOMContentLoaded', setupWikiFilter);
  document.addEventListener('astro:page-load', setupWikiFilter);
</script>
