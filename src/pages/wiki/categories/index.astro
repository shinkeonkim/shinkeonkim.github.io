---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getWikiTaxonomy, listWikiCategoryInfos } from '@/shared/lib/content/taxonomy';
import { absoluteUrl, breadcrumbSchema, collectionPageSchema } from '@/shared/lib/seo/schema';
import { SITE_LOCALE } from '@/shared/config';

const RECENT_COUNT = 3;

const [categories, taxonomy] = await Promise.all([listWikiCategoryInfos(), getWikiTaxonomy()]);

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const cards = categories.map((c) => ({
  slug: c.slug,
  label: c.label,
  count: c.count,
  recent: (taxonomy.categories.get(c.slug) ?? []).slice(0, RECENT_COUNT),
}));

const total = categories.length;
const description = `위키 카테고리 ${total}개. 카테고리별 최근 갱신을 한눈에.`;

const jsonLd = [
  collectionPageSchema({
    name: '위키 카테고리',
    description,
    url: absoluteUrl('/wiki/categories/'),
    itemCount: total,
  }),
  breadcrumbSchema([
    { name: '위키', url: absoluteUrl('/wiki/') },
    { name: '카테고리', url: absoluteUrl('/wiki/categories/') },
  ]),
];
---

<BaseLayout title="위키 카테고리" description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-4xl px-5">
    <nav class="mb-3 text-xs text-fg-muted">
      <a href="/" class="hover:text-accent">홈</a>
      <span class="mx-1">/</span>
      <a href="/wiki/" class="hover:text-accent">위키</a>
      <span class="mx-1">/</span>
      <span class="text-fg">카테고리</span>
    </nav>
    <h1 class="mb-2 text-3xl font-bold tracking-tight">📁 위키 카테고리</h1>
    <p class="mb-8 text-fg-muted">총 {total}개</p>

    {
      total === 0 ? (
        <p class="text-sm text-fg-muted">
          아직 카테고리가 없습니다.
        </p>
      ) : (
        <ul class="grid gap-4 md:grid-cols-2">
          {cards.map((c) => (
            <li class="rounded-lg border border-border bg-surface-elevated p-4">
              <div class="flex items-baseline justify-between gap-2">
                <a
                  href={`/wiki/category/${encodeURIComponent(c.slug)}/`}
                  class="text-lg font-semibold no-underline hover:text-accent"
                >
                  {c.label}
                </a>
                <span class="text-xs text-fg-muted">
                  {c.count}개
                </span>
              </div>
              {c.recent.length > 0 && (
                <ul class="mt-3 space-y-1.5 text-sm">
                  {c.recent.map((w) => (
                    <li class="flex items-baseline justify-between gap-2">
                      <a
                        href={`/wiki/${w.id}/`}
                        class="truncate text-fg no-underline hover:text-accent"
                      >
                        {w.data.title}
                      </a>
                      {w.data.updated && (
                        <time
                          datetime={w.data.updated.toISOString()}
                          class="shrink-0 text-xs text-fg-muted"
                        >
                          {fmt.format(w.data.updated)}
                        </time>
                      )}
                    </li>
                  ))}
                </ul>
              )}
              {c.count > RECENT_COUNT && (
                <p class="mt-3 text-xs">
                  <a
                    href={`/wiki/category/${encodeURIComponent(c.slug)}/`}
                    class="text-accent"
                  >
                    전체 {c.count}개 보기 →
                  </a>
                </p>
              )}
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
