---
import { computeRelated, type RelatedCollection } from '@/shared/lib/content/related';
import { SITE_LOCALE } from '@/shared/config';

interface Props {
  collection: RelatedCollection;
  slug: string;
  tags: string[];
  category?: string;
  series?: string;
  limit?: number;
}

const { collection, slug, tags, category, series, limit = 5 } = Astro.props as Props;
const related = await computeRelated({ collection, slug, tags, category, series, limit });

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const BADGES: Record<RelatedCollection, string> = {
  posts: '글',
  wiki: '위키',
  notes: '노트',
};

function urlFor(c: RelatedCollection, id: string): string {
  if (c === 'posts') return `/posts/${id}/`;
  if (c === 'wiki') return `/wiki/${id}/`;
  return `/notes/${id}/`;
}
---
{related.length > 0 && (
  <aside class="related-posts not-prose" data-pagefind-ignore="all">
    <h3 class="related-posts-title">🔗 관련 글</h3>
    <ul class="related-posts-list">
      {related.map((r) => (
        <li class="related-posts-item">
          <a href={urlFor(r.collection, r.id)} class="related-posts-link">
            <span class="related-posts-badge">{BADGES[r.collection]}</span>
            <span class="related-posts-text">
              <span class="related-posts-name">{r.title}</span>
              <span class="related-posts-meta">
                {r.date && (
                  <time datetime={r.date.toISOString()}>{fmt.format(r.date)}</time>
                )}
                <span class="related-posts-shared">
                  {r.shared.slice(0, 3).map((t) => (
                    <span>#{t}</span>
                  ))}
                </span>
              </span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </aside>
)}

<style is:global>
  .related-posts {
    margin-top: 2.5rem;
    padding: 1rem 1.2rem;
    border: 1px solid var(--color-border);
    border-radius: 0.6rem;
    background-color: var(--color-surface-elevated);
  }
  .related-posts-title {
    margin: 0 0 0.65rem;
    font-size: 0.95rem;
    font-weight: 600;
  }
  .related-posts-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .related-posts-link {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    padding: 0.5rem 0.6rem;
    border-radius: 0.4rem;
    text-decoration: none;
    color: var(--color-fg);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
  }
  .related-posts-link:hover {
    border-color: var(--color-accent);
  }
  .related-posts-badge {
    flex-shrink: 0;
    padding: 0.05rem 0.45rem;
    font-size: 0.7rem;
    font-family: var(--font-mono);
    border-radius: 999px;
    background-color: var(--color-code-bg);
    color: var(--color-fg-muted);
    margin-top: 0.15rem;
  }
  .related-posts-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
    flex: 1;
  }
  .related-posts-name {
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .related-posts-meta {
    margin-top: 0.15rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.72rem;
    color: var(--color-fg-muted);
  }
  .related-posts-shared {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }
</style>
