---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import {
  SITE_TITLE,
  SITE_DESCRIPTION,
  SITE_URL,
  SITE_LOCALE,
  SITE_AUTHOR,
  SITE_KEYWORDS,
} from '@/shared/config';
import { personSchema, websiteSchema } from '@/shared/lib/seo/schema';
import Header from '@/widgets/header/Header.astro';
import Footer from '@/widgets/footer/Footer.astro';
import HeadSeo from '@/widgets/site-head/HeadSeo.astro';
import HeadFeeds from '@/widgets/site-head/HeadFeeds.astro';
import HeadAssets from '@/widgets/site-head/HeadAssets.astro';
import ThemeBootstrap from '@/widgets/site-head/ThemeBootstrap.astro';
import MermaidLoader from '@/features/mermaid/ui/MermaidLoader.astro';
import CodeWithOutputLoader from '@/features/code-with-output/ui/CodeWithOutputLoader.astro';
import CodeCopy from '@/shared/ui/CodeCopy.astro';
import ImageLightbox from '@/shared/ui/ImageLightbox.astro';
import AnimationLoader from '@/entities/animation/ui/AnimationLoader.astro';
import ReactInit from '@/shared/ui/ReactInit';
import KatexCopy from '@/shared/ui/KatexCopy.astro';
import GoogleAnalytics from '@/shared/analytics/GoogleAnalytics.astro';
import GaEvents from '@/shared/analytics/GaEvents.astro';
import ServiceWorkerRegister from '@/shared/analytics/ServiceWorkerRegister.astro';
import SearchModal from '@/features/search/ui/SearchModal.astro';
import TopProgressBar from '@/shared/ui/TopProgressBar.astro';
import WikilinkHoverPreview from '@/features/url-preview/ui/WikilinkHoverPreview.astro';
import BackToTop from '@/shared/ui/BackToTop.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  ogType?: 'website' | 'article' | 'profile';
  publishedTime?: string;
  modifiedTime?: string;
  articleTags?: string[];
  articleAuthor?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  prevUrl?: string;
  nextUrl?: string;
  keywords?: string[];
  /**
   * Override the page's canonical URL. Defaults to `Astro.url.pathname`.
   * Used for alias pages (e.g. `/tags/<alias>/` pointing to `/tags/<canonical>/`)
   * so SEO consolidates duplicate pages to a single canonical source.
   * Accepts either an absolute URL or a path beginning with `/`.
   */
  canonicalUrl?: string;
}

const {
  title,
  description = SITE_DESCRIPTION,
  ogImage,
  noIndex = false,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  articleTags,
  articleAuthor,
  jsonLd,
  prevUrl,
  nextUrl,
  keywords,
  canonicalUrl,
} = Astro.props as Props;

const fullTitle = title ? `${title} | ${SITE_TITLE}` : SITE_TITLE;
const canonical = canonicalUrl
  ? new URL(canonicalUrl, SITE_URL).toString()
  : new URL(Astro.url.pathname, SITE_URL).toString();
const ogImageUrl = ogImage ? new URL(ogImage, SITE_URL).toString() : undefined;
const robotsContent = noIndex
  ? 'noindex,nofollow'
  : 'index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1';

const googleVerify = import.meta.env.PUBLIC_GOOGLE_VERIFY as string | undefined;
const naverVerify = import.meta.env.PUBLIC_NAVER_VERIFY as string | undefined;

const keywordList = keywords && keywords.length > 0 ? keywords : SITE_KEYWORDS;
const keywordsMeta = keywordList.join(', ');

const jsonLdList: Record<string, unknown>[] = Array.isArray(jsonLd)
  ? jsonLd
  : jsonLd
    ? [jsonLd]
    : [];
const allJsonLd = [websiteSchema(), personSchema(), ...jsonLdList];
---

<!doctype html>
<html lang={SITE_LOCALE.split('-')[0]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <HeadSeo
      fullTitle={fullTitle}
      description={description}
      keywordsMeta={keywordsMeta}
      articleAuthor={articleAuthor ?? SITE_AUTHOR}
      robotsContent={robotsContent}
      googleVerify={googleVerify}
      naverVerify={naverVerify}
      canonical={canonical}
      ogType={ogType}
      ogImageUrl={ogImageUrl}
      ogSiteName={SITE_TITLE}
      ogLocale={SITE_LOCALE.replace('-', '_')}
      title={title}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      articleTags={articleTags}
    />
    <HeadFeeds
      siteTitle={SITE_TITLE}
      siteUrl={SITE_URL}
      prevUrl={prevUrl}
      nextUrl={nextUrl}
    />
    <HeadAssets />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(allJsonLd)} />
    <ThemeBootstrap />
    <ClientRouter />
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main" class="skip-to-content">본문으로 건너뛰기</a>
    <TopProgressBar />
    <Header />
    <main id="main" class="flex-1 py-10">
      <slot />
    </main>
    <Footer />
    <SearchModal />
    <MermaidLoader />
    <CodeWithOutputLoader />
    <CodeCopy />
    <ImageLightbox />
    <WikilinkHoverPreview />
    <BackToTop />
    <AnimationLoader />
    <ReactInit client:only="react" />
    <KatexCopy />
    <GoogleAnalytics />
    <GaEvents />
    <ServiceWorkerRegister />
  </body>
</html>
