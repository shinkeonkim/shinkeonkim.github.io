---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import {
  SITE_TITLE,
  SITE_DESCRIPTION,
  SITE_URL,
  SITE_LOCALE,
  SITE_AUTHOR,
  SITE_KEYWORDS,
} from '@/shared/config';
import { personSchema, websiteSchema } from '../lib/schema';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MermaidLoader from '../components/MermaidLoader.astro';
import CodeWithOutputLoader from '../components/CodeWithOutputLoader.astro';
import CodeCopy from '../components/CodeCopy.astro';
import ImageLightbox from '../components/ImageLightbox.astro';
import AnimationLoader from '../components/AnimationLoader.astro';
import ReactInit from '../components/ReactInit';
import KatexCopy from '../components/KatexCopy.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import GaEvents from '../components/GaEvents.astro';
import ServiceWorkerRegister from '../components/ServiceWorkerRegister.astro';
import SearchModal from '../components/SearchModal.astro';
import TopProgressBar from '../components/TopProgressBar.astro';
import WikilinkHoverPreview from '../components/WikilinkHoverPreview.astro';
import BackToTop from '../components/BackToTop.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  ogType?: 'website' | 'article' | 'profile';
  publishedTime?: string;
  modifiedTime?: string;
  articleTags?: string[];
  articleAuthor?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  prevUrl?: string;
  nextUrl?: string;
  keywords?: string[];
  /**
   * Override the page's canonical URL. Defaults to `Astro.url.pathname`.
   * Used for alias pages (e.g. `/tags/<alias>/` pointing to `/tags/<canonical>/`)
   * so SEO consolidates duplicate pages to a single canonical source.
   * Accepts either an absolute URL or a path beginning with `/`.
   */
  canonicalUrl?: string;
}

const {
  title,
  description = SITE_DESCRIPTION,
  ogImage,
  noIndex = false,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  articleTags,
  articleAuthor,
  jsonLd,
  prevUrl,
  nextUrl,
  keywords,
  canonicalUrl,
} = Astro.props as Props;

const fullTitle = title ? `${title} | ${SITE_TITLE}` : SITE_TITLE;
const canonical = canonicalUrl
  ? new URL(canonicalUrl, SITE_URL).toString()
  : new URL(Astro.url.pathname, SITE_URL).toString();
const ogImageUrl = ogImage ? new URL(ogImage, SITE_URL).toString() : undefined;
const robotsContent = noIndex
  ? 'noindex,nofollow'
  : 'index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1';

const googleVerify = import.meta.env.PUBLIC_GOOGLE_VERIFY as string | undefined;
const naverVerify = import.meta.env.PUBLIC_NAVER_VERIFY as string | undefined;

const keywordList = keywords && keywords.length > 0 ? keywords : SITE_KEYWORDS;
const keywordsMeta = keywordList.join(', ');

const jsonLdList: Record<string, unknown>[] = Array.isArray(jsonLd)
  ? jsonLd
  : jsonLd
    ? [jsonLd]
    : [];
const allJsonLd = [websiteSchema(), personSchema(), ...jsonLdList];
---

<!doctype html>
<html lang={SITE_LOCALE.split('-')[0]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline' https://giscus.app https://www.googletagmanager.com https://www.google-analytics.com https://platform.twitter.com https://gist.github.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://giscus.app; img-src 'self' data: https: blob:; font-src 'self' data:; connect-src 'self' https://api.github.com https://www.google-analytics.com https://*.google-analytics.com https://analytics.google.com https://*.giscus.app https://giscus.app; frame-src 'self' https://giscus.app https://www.youtube-nocookie.com https://www.youtube.com https://player.vimeo.com https://www.figma.com https://codepen.io https://platform.twitter.com https://twitter.com https://platform.twitter.com; child-src 'self' https://giscus.app; media-src 'self' https:; object-src 'none'; base-uri 'self'; form-action 'self';"
    />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {keywordsMeta && <meta name="keywords" content={keywordsMeta} />}
    <meta name="author" content={articleAuthor ?? SITE_AUTHOR} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    {googleVerify && <meta name="google-site-verification" content={googleVerify} />}
    {naverVerify && <meta name="naver-site-verification" content={naverVerify} />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ko-KR" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE_TITLE} RSS`}
      href={`${SITE_URL}/rss.xml`}
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE_TITLE} - 노트 RSS`}
      href={`${SITE_URL}/notes/rss.xml`}
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE_TITLE} - 위키 RSS`}
      href={`${SITE_URL}/wiki/rss.xml`}
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE_TITLE} - 전체 최신 RSS`}
      href={`${SITE_URL}/feed/all.xml`}
    />
    <link
      rel="alternate"
      type="application/feed+json"
      title={`${SITE_TITLE} JSON Feed`}
      href={`${SITE_URL}/feed.json`}
    />
    <link rel="sitemap" type="application/xml" href={`${SITE_URL}/sitemap-index.xml`} />
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#4f46e5" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0b0b0f" media="(prefers-color-scheme: dark)" />
    <link rel="preconnect" href="https://giscus.app" crossorigin />
    <link rel="dns-prefetch" href="https://giscus.app" />
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/pretendard/woff2-dynamic-subset/PretendardVariable.subset.91.woff2"
      crossorigin
    />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:locale" content={SITE_LOCALE.replace('-', '_')} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {ogImageUrl && <meta property="og:image:alt" content={title ?? SITE_TITLE} />}
    {
      ogType === 'article' && publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {
      ogType === 'article' && modifiedTime && (
        <meta property="article:modified_time" content={modifiedTime} />
      )
    }
    {
      ogType === 'article' && (articleAuthor ?? SITE_AUTHOR) && (
        <meta property="article:author" content={articleAuthor ?? SITE_AUTHOR} />
      )
    }
    {
      ogType === 'article' &&
        articleTags?.map((tag) => <meta property="article:tag" content={tag} />)
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    {ogImageUrl && <meta name="twitter:image:alt" content={title ?? SITE_TITLE} />}

    <script is:inline type="application/ld+json" set:html={JSON.stringify(allJsonLd)} />

    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = saved || (prefersDark ? 'dark' : 'light');
          if (theme === 'dark') document.documentElement.classList.add('dark');
        } catch {
          /* private mode / storage disabled - ignore */
        }
      })();
    </script>
    <script is:inline>
      document.addEventListener('astro:after-swap', function () {
        try {
          const saved = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = saved || (prefersDark ? 'dark' : 'light');
          if (theme === 'dark') document.documentElement.classList.add('dark');
          else document.documentElement.classList.remove('dark');
        } catch {
          /* ignore */
        }
      });
    </script>
    <ClientRouter />
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main" class="skip-to-content">본문으로 건너뛰기</a>
    <TopProgressBar />
    <Header />
    <main id="main" class="flex-1 py-10">
      <slot />
    </main>
    <Footer />
    <SearchModal />
    <MermaidLoader />
    <CodeWithOutputLoader />
    <CodeCopy />
    <ImageLightbox />
    <WikilinkHoverPreview />
    <BackToTop />
    <AnimationLoader />
    <ReactInit client:only="react" />
    <KatexCopy />
    <GoogleAnalytics />
    <GaEvents />
    <ServiceWorkerRegister />
  </body>
</html>
