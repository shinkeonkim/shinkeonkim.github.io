---
import BaseLayout from './BaseLayout.astro';
import ProjectStats from '../components/ProjectStats.astro';
import { formatPeriod } from '../lib/projects';

interface Props {
  id: string;
  title: string;
  summary: string;
  description?: string;
  start: Date;
  end?: Date;
  teamSize: number;
  role?: string;
  thumbnail?: string;
  cover?: string;
  repos?: { url: string; label?: string; track: boolean }[];
  stack?: string[];
  links?: { url: string; label: string }[];
  status?: 'ongoing' | 'completed' | 'archived';
  tags?: string[];
}

const {
  id,
  title,
  summary,
  description,
  start,
  end,
  teamSize,
  role,
  cover,
  thumbnail,
  repos = [],
  stack = [],
  links = [],
  status = 'completed',
  tags = [],
} = Astro.props as Props;

const period = formatPeriod(start, end);
const trackedRepos = repos.filter((r) => r.track);
const statusLabel = status === 'ongoing' ? '진행 중' : status === 'archived' ? '보관' : '완료';
const ogImage = cover ?? thumbnail;
---

<BaseLayout
  title={title}
  description={description ?? summary}
  ogImage={ogImage}
  ogType="article"
  publishedTime={start.toISOString()}
  modifiedTime={(end ?? start).toISOString()}
  articleTags={tags}
>
  <article
    class="mx-auto max-w-4xl px-5"
    data-pagefind-body
    data-pagefind-filter="section:projects"
  >
    {
      cover && (
        <figure class="project-cover not-prose">
          <img src={cover} alt={title} class="project-cover-img" loading="eager" />
        </figure>
      )
    }
    <header class="mb-6">
      <nav class="mb-3 text-xs text-[color:var(--color-fg-muted)]">
        <a href="/projects/" class="hover:text-[color:var(--color-accent)]">프로젝트</a>
        <span class="mx-1">/</span>
        <span>{title}</span>
      </nav>
      <h1 class="text-3xl font-bold tracking-tight md:text-4xl">{title}</h1>
      <p class="mt-2 text-[color:var(--color-fg-muted)]">{summary}</p>

      <dl class="mt-4 grid grid-cols-2 gap-x-6 gap-y-2 text-sm md:grid-cols-4">
        <div>
          <dt class="text-xs uppercase tracking-[0.08em] text-[color:var(--color-fg-muted)]">
            기간
          </dt>
          <dd>{period}</dd>
        </div>
        <div>
          <dt class="text-xs uppercase tracking-[0.08em] text-[color:var(--color-fg-muted)]">
            상태
          </dt>
          <dd>{statusLabel}</dd>
        </div>
        <div>
          <dt class="text-xs uppercase tracking-[0.08em] text-[color:var(--color-fg-muted)]">팀</dt>
          <dd>{teamSize}명</dd>
        </div>
        {
          role && (
            <div>
              <dt class="text-xs uppercase tracking-[0.08em] text-[color:var(--color-fg-muted)]">
                담당
              </dt>
              <dd>{role}</dd>
            </div>
          )
        }
      </dl>

      {
        stack.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-1.5">
            {stack.map((s) => (
              <span class="rounded-full border border-[color:var(--color-border)] px-2 py-0.5 text-xs text-[color:var(--color-fg-muted)]">
                {s}
              </span>
            ))}
          </div>
        )
      }

      {
        (repos.length > 0 || links.length > 0) && (
          <div class="mt-4 flex flex-wrap gap-2 text-sm">
            {repos.map((r) => (
              <a
                href={r.url}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-1 rounded-full border border-[color:var(--color-border)] px-3 py-1 no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
              >
                <span aria-hidden="true">⌥</span>
                {r.label ?? 'GitHub'}
              </a>
            ))}
            {links.map((l) => (
              <a
                href={l.url}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-1 rounded-full border border-[color:var(--color-border)] px-3 py-1 no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
              >
                <span aria-hidden="true">↗</span>
                {l.label}
              </a>
            ))}
          </div>
        )
      }
    </header>

    <div class="prose-content">
      <slot />
    </div>

    {trackedRepos.length > 0 && <ProjectStats projectId={id} repos={trackedRepos} />}
  </article>
</BaseLayout>

<style is:global>
  .project-cover {
    margin: 0 0 1.5rem;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  .project-cover-img {
    display: block;
    width: 100%;
    max-height: 22rem;
    object-fit: cover;
  }
</style>
