---
import BaseLayout from './BaseLayout.astro';
import Backlinks from '../components/Backlinks.astro';
import { SITE_LOCALE } from '../consts';
import { getPostTaxonomy, slugify } from '../lib/taxonomy';

interface Props {
  title: string;
  description?: string;
  date: Date;
  updated?: Date;
  tags?: string[];
  slug: string;
  collection: 'posts' | 'wiki';
  cover?: string;
  coverAlt?: string;
  coverCredit?: string;
  category?: string;
}

const {
  title,
  description,
  date,
  updated,
  tags = [],
  slug,
  collection,
  cover,
  coverAlt,
  coverCredit,
  category: categoryProp,
} = Astro.props as Props;

const dateFmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const isoDate = date.toISOString();

let category: string | null = null;
let seriesInfo:
  | { slug: string; name: string; order: number; total: number; prev?: { id: string; title: string }; next?: { id: string; title: string }; entries: { id: string; title: string; order: number }[] }
  | null = null;

if (collection === 'posts') {
  const taxonomy = await getPostTaxonomy();
  category = categoryProp ?? taxonomy.postCategory.get(slug) ?? null;

  const seriesMeta = taxonomy.postSeries.get(slug);
  if (seriesMeta) {
    const list = taxonomy.series.get(seriesMeta.slug)?.posts ?? [];
    const idx = list.findIndex((p) => p.id === slug);
    const prevEntry = idx > 0 ? list[idx - 1] : null;
    const nextEntry = idx >= 0 && idx < list.length - 1 ? list[idx + 1] : null;
    seriesInfo = {
      ...seriesMeta,
      entries: list.map((p, i) => ({ id: p.id, title: p.data.title, order: i + 1 })),
      prev: prevEntry ? { id: prevEntry.id, title: prevEntry.data.title } : undefined,
      next: nextEntry ? { id: nextEntry.id, title: nextEntry.data.title } : undefined,
    };
  }
} else {
  category = categoryProp ?? null;
}

const categoryUrl = category ? `/posts/category/${encodeURIComponent(category)}/` : null;
const seriesUrl = seriesInfo ? `/posts/series/${slugify(seriesInfo.name)}/` : null;
---
<BaseLayout title={title} description={description} ogImage={cover}>
  <article
    class="container-prose"
    data-pagefind-body
    data-pagefind-filter={`section:${collection}`}
    data-pagefind-meta={`date:${isoDate}`}
  >
    {cover && (
      <figure class="post-cover not-prose">
        <img
          src={cover}
          alt={coverAlt ?? ''}
          class="post-cover-img"
          loading="eager"
          fetchpriority="high"
        />
        {coverCredit && (
          <figcaption class="post-cover-credit">{coverCredit}</figcaption>
        )}
      </figure>
    )}

    <header class="mb-8">
      {(category || seriesInfo) && (
        <div class="mb-2 flex flex-wrap items-center gap-2 text-xs text-[color:var(--color-fg-muted)]" data-pagefind-ignore>
          {category && categoryUrl && (
            <a href={categoryUrl} class="inline-flex items-center gap-1 rounded-full border border-[color:var(--color-border)] px-2.5 py-0.5 no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]">
              📁 {category}
            </a>
          )}
          {seriesInfo && seriesUrl && (
            <a href={seriesUrl} class="inline-flex items-center gap-1 rounded-full border border-[color:var(--color-border)] px-2.5 py-0.5 no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]">
              📚 {seriesInfo.name}
              <span class="opacity-70">{seriesInfo.order} / {seriesInfo.total}</span>
            </a>
          )}
        </div>
      )}

      <h1 class="text-3xl font-bold tracking-tight md:text-4xl">{title}</h1>
      {description && (
        <p class="mt-2 text-[color:var(--color-fg-muted)]" data-pagefind-meta="description">{description}</p>
      )}
      <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-[color:var(--color-fg-muted)]" data-pagefind-ignore>
        <time datetime={isoDate}>{dateFmt.format(date)}</time>
        {updated && (
          <span>· 수정 <time datetime={updated.toISOString()}>{dateFmt.format(updated)}</time></span>
        )}
        {tags.length > 0 && (
          <span class="flex flex-wrap gap-1">
            {tags.map((t) => (
              <a href={`/tags/${encodeURIComponent(t)}/`} class="rounded-full border border-[color:var(--color-border)] px-2 py-0.5 text-xs no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]">#{t}</a>
            ))}
          </span>
        )}
      </div>
    </header>

    <div class="prose-content">
      <slot />
    </div>

    {seriesInfo && (
      <aside class="series-nav not-prose mt-10 rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-4" data-pagefind-ignore="all">
        <div class="mb-3 flex flex-wrap items-baseline justify-between gap-2">
          <h3 class="text-sm font-semibold">
            📚 시리즈: <a href={seriesUrl ?? '#'} class="text-[color:var(--color-accent)]">{seriesInfo.name}</a>
          </h3>
          <span class="text-xs text-[color:var(--color-fg-muted)]">{seriesInfo.order} / {seriesInfo.total}</span>
        </div>
        <ol class="space-y-1 text-sm">
          {seriesInfo.entries.map((e) => (
            <li class={e.id === slug ? 'font-semibold text-[color:var(--color-accent)]' : ''}>
              <span class="mr-1 inline-block w-6 text-right font-mono text-xs text-[color:var(--color-fg-muted)]">{e.order}.</span>
              {e.id === slug ? (
                <span>{e.title}</span>
              ) : (
                <a href={`/posts/${e.id}/`}>{e.title}</a>
              )}
            </li>
          ))}
        </ol>
        {(seriesInfo.prev || seriesInfo.next) && (
          <nav class="mt-3 flex justify-between gap-2 border-t border-[color:var(--color-border)] pt-3 text-sm">
            {seriesInfo.prev ? (
              <a href={`/posts/${seriesInfo.prev.id}/`} class="flex-1 truncate" rel="prev">← {seriesInfo.prev.title}</a>
            ) : <span />}
            {seriesInfo.next ? (
              <a href={`/posts/${seriesInfo.next.id}/`} class="flex-1 truncate text-right" rel="next">{seriesInfo.next.title} →</a>
            ) : <span />}
          </nav>
        )}
      </aside>
    )}

    <div data-pagefind-ignore="all">
      <Backlinks slug={slug} collection={collection} />
    </div>
  </article>
</BaseLayout>

<style is:global>
  .post-cover {
    margin: 0 0 1.5rem;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background-color: var(--color-surface-elevated);
  }
  .post-cover-img {
    display: block;
    width: 100%;
    max-height: 22rem;
    object-fit: cover;
  }
  .post-cover-credit {
    padding: 0.4rem 0.85rem;
    font-size: 0.75rem;
    color: var(--color-fg-muted);
    background-color: var(--color-surface-elevated);
    border-top: 1px solid var(--color-border);
  }
</style>
