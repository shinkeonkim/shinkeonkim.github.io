---
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import AuthorCard from '../components/AuthorCard.astro';
import Backlinks from '../components/Backlinks.astro';
import Comments from '../components/Comments.astro';
import LocalGraph from '../components/LocalGraph.astro';
import PostToc from '../components/PostToc.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import ReferencesBlock from '../components/ReferencesBlock.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import { SITE_AUTHOR, SITE_LOCALE, SITE_TITLE, SITE_URL } from '../consts';
import { breadcrumbSchema } from '../lib/schema';
import { getPostTaxonomy, slugify } from '../lib/taxonomy';
import { estimateReadingTime } from '../lib/reading-time';

interface Props {
  title: string;
  description?: string;
  date: Date;
  updated?: Date;
  tags?: string[];
  slug: string;
  collection: 'posts' | 'wiki' | 'notes';
  cover?: string;
  coverAlt?: string;
  coverCredit?: string;
  category?: string;
  references?: unknown[];
  headings?: MarkdownHeading[];
  body?: string;
}

const {
  title,
  description,
  date,
  updated,
  tags = [],
  slug,
  collection,
  cover,
  coverAlt,
  coverCredit,
  category: categoryProp,
  references,
  headings = [],
  body,
} = Astro.props as Props;

const readingTime = body ? estimateReadingTime(body) : null;

const dateFmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const isoDate = date.toISOString();

let category: string | null;
let seriesInfo: {
  slug: string;
  name: string;
  order: number;
  total: number;
  prev?: { id: string; title: string };
  next?: { id: string; title: string };
  entries: { id: string; title: string; order: number }[];
} | null = null;

if (collection === 'posts') {
  const taxonomy = await getPostTaxonomy();
  category = categoryProp ?? taxonomy.postCategory.get(slug) ?? null;

  const seriesMeta = taxonomy.postSeries.get(slug);
  if (seriesMeta) {
    const list = taxonomy.series.get(seriesMeta.slug)?.posts ?? [];
    const idx = list.findIndex((p) => p.id === slug);
    const prevEntry = idx > 0 ? list[idx - 1] : null;
    const nextEntry = idx >= 0 && idx < list.length - 1 ? list[idx + 1] : null;
    seriesInfo = {
      ...seriesMeta,
      entries: list.map((p, i) => ({ id: p.id, title: p.data.title, order: i + 1 })),
      prev: prevEntry ? { id: prevEntry.id, title: prevEntry.data.title } : undefined,
      next: nextEntry ? { id: nextEntry.id, title: nextEntry.data.title } : undefined,
    };
  }
} else {
  category = categoryProp ?? null;
}

const categoryUrl = category ? `/posts/category/${encodeURIComponent(category)}/` : null;
const seriesUrl = seriesInfo ? `/posts/series/${slugify(seriesInfo.name)}/` : null;

const SERIES_WINDOW_BEFORE = 3;
const SERIES_WINDOW_AFTER = 4;
const SERIES_INLINE_THRESHOLD = 12;

interface WindowedSeries {
  visible: { id: string; title: string; order: number }[];
  hiddenBefore: number;
  hiddenAfter: number;
}

function windowedSeriesEntries(info: NonNullable<typeof seriesInfo>): WindowedSeries {
  const all = info.entries;
  if (all.length <= SERIES_INLINE_THRESHOLD) {
    return { visible: all, hiddenBefore: 0, hiddenAfter: 0 };
  }
  const currentIdx = info.order - 1;
  const start = Math.max(0, currentIdx - SERIES_WINDOW_BEFORE);
  const end = Math.min(all.length, currentIdx + SERIES_WINDOW_AFTER + 1);
  return {
    visible: all.slice(start, end),
    hiddenBefore: start,
    hiddenAfter: all.length - end,
  };
}

const seriesWindow = seriesInfo ? windowedSeriesEntries(seriesInfo) : null;

const articleUrl = new URL(
  collection === 'posts' ? `/posts/${slug}/` : collection === 'wiki' ? `/wiki/${slug}/` : `/notes/${slug}/`,
  SITE_URL,
).toString();
const articleImage = cover ? new URL(cover, SITE_URL).toString() : undefined;

const postingSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': collection === 'wiki' ? 'TechArticle' : 'BlogPosting',
  '@id': `${articleUrl}#article`,
  headline: title,
  description,
  datePublished: isoDate,
  ...(updated && { dateModified: updated.toISOString() }),
  inLanguage: SITE_LOCALE,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  url: articleUrl,
  author: { '@id': `${SITE_URL}/#person` },
  publisher: { '@id': `${SITE_URL}/#person` },
  isPartOf: { '@id': `${SITE_URL}/#website` },
  ...(articleImage && {
    image: {
      '@type': 'ImageObject',
      url: articleImage,
      ...(coverAlt && { caption: coverAlt }),
    },
  }),
  ...(tags.length > 0 && { keywords: tags.join(', ') }),
  ...(category && { articleSection: category }),
  ...(seriesInfo && {
    isPartOf: {
      '@type': 'CreativeWorkSeries',
      name: seriesInfo.name,
      position: seriesInfo.order,
    },
  }),
};

const breadcrumb = breadcrumbSchema([
  {
    name: collection === 'posts' ? '글' : collection === 'wiki' ? '위키' : '노트',
    url: new URL(collection === 'posts' ? '/posts/' : collection === 'wiki' ? '/wiki/' : '/notes/', SITE_URL).toString(),
  },
  ...(category && collection === 'posts'
    ? [
        {
          name: category,
          url: new URL(`/posts/category/${encodeURIComponent(category)}/`, SITE_URL).toString(),
        },
      ]
    : []),
  { name: title, url: articleUrl },
]);

void SITE_TITLE;
void SITE_AUTHOR;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={cover ?? `/og/${collection}/${slug}.png`}
  ogType="article"
  publishedTime={isoDate}
  modifiedTime={updated?.toISOString()}
  articleTags={tags}
  articleAuthor={SITE_AUTHOR}
  jsonLd={[postingSchema, breadcrumb]}
  keywords={[...tags, ...(category ? [category] : [])]}
>
  <ReadingProgress />
  <div class="post-shell">
    <article
      class="container-prose post-article"
      data-pagefind-body
      data-pagefind-filter={`section:${collection}`}
      data-pagefind-meta={`date:${isoDate}`}
    >
      {
        cover && (
          <figure class="post-cover not-prose">
        <img
          src={cover}
          alt={coverAlt ?? ''}
          class="post-cover-img"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
            {coverCredit && <figcaption class="post-cover-credit">{coverCredit}</figcaption>}
          </figure>
        )
      }

      <header class="mb-8">
        {
          (category || seriesInfo) && (
            <div
              class="mb-2 flex flex-wrap items-center gap-2 text-xs text-[color:var(--color-fg-muted)]"
              data-pagefind-ignore
            >
              {category && categoryUrl && (
                <a
                  href={categoryUrl}
                  class="inline-flex items-center gap-1 rounded-full border border-[color:var(--color-border)] px-2.5 py-0.5 no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
                >
                  📁 {category}
                </a>
              )}
              {seriesInfo && seriesUrl && (
                <a
                  href={seriesUrl}
                  class="inline-flex items-center gap-1 rounded-full border border-[color:var(--color-border)] px-2.5 py-0.5 no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
                >
                  📚 {seriesInfo.name}
                  <span class="opacity-70">
                    {seriesInfo.order} / {seriesInfo.total}
                  </span>
                </a>
              )}
            </div>
          )
        }

        <h1 class="text-3xl font-bold tracking-tight md:text-4xl">{title}</h1>
        {
          description && (
            <p class="mt-2 text-[color:var(--color-fg-muted)]" data-pagefind-meta="description">
              {description}
            </p>
          )
        }
        <div
          class="mt-3 flex flex-wrap items-center gap-3 text-sm text-[color:var(--color-fg-muted)]"
          data-pagefind-ignore
        >
          <time datetime={isoDate}>{dateFmt.format(date)}</time>
          {
            updated && (
              <span>
                · 수정 <time datetime={updated.toISOString()}>{dateFmt.format(updated)}</time>
              </span>
            )
          }
          {readingTime && (
            <span title={`한글 ${readingTime.cjkChars}자 · 영문 ${readingTime.asciiWords}단어`}>
              · 📖 약 {readingTime.minutes}분 · {readingTime.cjkChars + readingTime.asciiWords > 0
                ? `${(readingTime.cjkChars + readingTime.asciiWords).toLocaleString()}자/단어`
                : ''}
            </span>
          )}
          {
            tags.length > 0 && (
              <span class="flex flex-wrap gap-1">
                {tags.map((t) => (
                  <a
                    href={`/tags/${encodeURIComponent(t.toLowerCase())}/`}
                    class="rounded-full border border-[color:var(--color-border)] px-2 py-0.5 text-xs no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
                  >
                    #{t}
                  </a>
                ))}
              </span>
            )
          }
        </div>
      </header>

      <div class="prose-content">
        <slot />
      </div>

      {
        seriesInfo && seriesWindow && (
          <aside
            class="series-nav not-prose mt-10 rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-4"
            data-pagefind-ignore="all"
          >
            <div class="mb-3 flex flex-wrap items-baseline justify-between gap-2">
              <h3 class="text-sm font-semibold">
                📚 시리즈:{' '}
                <a href={seriesUrl ?? '#'} class="text-[color:var(--color-accent)]">
                  {seriesInfo.name}
                </a>
              </h3>
              <span class="text-xs text-[color:var(--color-fg-muted)]">
                {seriesInfo.order} / {seriesInfo.total}
              </span>
            </div>
            <ol class="space-y-1 text-sm">
              {seriesWindow.hiddenBefore > 0 && seriesUrl && (
                <li class="text-xs text-[color:var(--color-fg-muted)]">
                  <a href={seriesUrl} class="hover:text-[color:var(--color-accent)]">
                    ↑ 이전 {seriesWindow.hiddenBefore}편 …
                  </a>
                </li>
              )}
              {seriesWindow.visible.map((e) => (
                <li class={e.id === slug ? 'font-semibold text-[color:var(--color-accent)]' : ''}>
                  <span class="mr-1 inline-block w-6 text-right font-mono text-xs text-[color:var(--color-fg-muted)]">
                    {e.order}.
                  </span>
                  {e.id === slug ? (
                    <span>{e.title}</span>
                  ) : (
                    <a href={`/posts/${e.id}/`}>{e.title}</a>
                  )}
                </li>
              ))}
              {seriesWindow.hiddenAfter > 0 && seriesUrl && (
                <li class="text-xs text-[color:var(--color-fg-muted)]">
                  <a href={seriesUrl} class="hover:text-[color:var(--color-accent)]">
                    ↓ 이후 {seriesWindow.hiddenAfter}편 …
                  </a>
                </li>
              )}
            </ol>
            {(seriesInfo.prev || seriesInfo.next || seriesUrl) && (
              <nav class="mt-3 flex flex-wrap items-center justify-between gap-2 border-t border-[color:var(--color-border)] pt-3 text-sm">
                {seriesInfo.prev ? (
                  <a href={`/posts/${seriesInfo.prev.id}/`} class="flex-1 truncate" rel="prev">
                    ← {seriesInfo.prev.title}
                  </a>
                ) : (
                  <span class="flex-1" />
                )}
                {seriesUrl && (
                  <a
                    href={seriesUrl}
                    class="rounded-full border border-[color:var(--color-border)] px-2.5 py-0.5 text-xs no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
                  >
                    전체 {seriesInfo.total}편 →
                  </a>
                )}
                {seriesInfo.next ? (
                  <a
                    href={`/posts/${seriesInfo.next.id}/`}
                    class="flex-1 truncate text-right"
                    rel="next"
                  >
                    {seriesInfo.next.title} →
                  </a>
                ) : (
                  <span class="flex-1" />
                )}
              </nav>
            )}
          </aside>
        )
      }

    <ReferencesBlock references={references} />

    {collection !== 'notes' && (
      <RelatedPosts
        collection={collection}
        slug={slug}
        tags={tags}
        category={category ?? undefined}
        series={seriesInfo?.name}
      />
    )}

    <LocalGraph collection={collection} slug={slug} />

    <div data-pagefind-ignore="all">
      <Backlinks slug={slug} collection={collection} />
    </div>

    <AuthorCard />

    <Comments slug={`${collection}/${slug}`} />
    </article>
    <aside class="post-sidebar">
      <PostToc headings={headings} />
    </aside>
  </div>
</BaseLayout>

<style is:global>
  .post-cover {
    margin: 0 0 1.5rem;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background-color: var(--color-surface-elevated);
  }
  .post-cover-img {
    display: block;
    width: 100%;
    max-height: 22rem;
    object-fit: cover;
  }
  .post-cover-credit {
    padding: 0.4rem 0.85rem;
    font-size: 0.75rem;
    color: var(--color-fg-muted);
    background-color: var(--color-surface-elevated);
    border-top: 1px solid var(--color-border);
  }
  .post-shell {
    display: block;
  }
  .post-sidebar {
    display: none;
  }
  @media (min-width: 1280px) {
    .post-shell {
      display: grid;
      grid-template-columns: minmax(0, 60rem) 16rem;
      gap: 2rem;
      max-width: 80rem;
      margin: 0 auto;
      padding-right: 1.25rem;
    }
    .post-article {
      margin: 0;
      max-width: none;
    }
    .post-sidebar {
      display: block;
    }
  }
</style>
