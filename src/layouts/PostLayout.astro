---
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import DevEditButton from '@/features/dev-edit/ui/DevEditButton.astro';
import AuthorCard from '@/widgets/author-card/AuthorCard.astro';
import Backlinks from '@/features/backlinks/ui/Backlinks.astro';
import Comments from '@/features/comments/ui/Comments.astro';
import LocalGraph from '@/widgets/graph-view/LocalGraph.astro';
import PostToc from '@/widgets/post-toc/PostToc.astro';
import ReadingProgress from '@/shared/ui/ReadingProgress.astro';
import ReferencesBlock from '@/entities/source/ui/ReferencesBlock.astro';
import RelatedPosts from '@/entities/post/ui/RelatedPosts.astro';
import ShareButtons from '@/features/share/ui/ShareButtons.astro';
import PostBreadcrumbs from '@/widgets/post-article/PostBreadcrumbs.astro';
import PostCover from '@/widgets/post-article/PostCover.astro';
import PostHeader from '@/widgets/post-article/PostHeader.astro';
import PostSeriesNav from '@/widgets/post-article/PostSeriesNav.astro';
import PostAdjacent from '@/widgets/post-article/PostAdjacent.astro';
import '@/widgets/post-article/styles/post-article.css';
import { SITE_AUTHOR, SITE_LOCALE, SITE_TITLE, SITE_URL } from '@/shared/config';
import { breadcrumbSchema } from '@/shared/lib/seo/schema';
import { getAdjacentPosts, getPostTaxonomy, slugify } from '@/shared/lib/content/taxonomy';
import { estimateReadingTime } from '@/shared/lib/content/reading-time';

interface Props {
  title: string;
  description?: string;
  date: Date;
  updated?: Date;
  tags?: string[];
  slug: string;
  collection: 'posts' | 'wiki' | 'notes';
  cover?: string;
  coverAlt?: string;
  coverCredit?: string;
  category?: string;
  references?: unknown[];
  headings?: MarkdownHeading[];
  body?: string;
}

const {
  title,
  description,
  date,
  updated,
  tags = [],
  slug,
  collection,
  cover,
  coverAlt,
  coverCredit,
  category: categoryProp,
  references,
  headings = [],
  body,
} = Astro.props as Props;

const readingTime = body ? estimateReadingTime(body) : null;
const isoDate = date.toISOString();

let category: string | null;
let seriesInfo: {
  slug: string;
  name: string;
  order: number;
  total: number;
  prev?: { id: string; title: string };
  next?: { id: string; title: string };
  entries: { id: string; title: string; order: number }[];
} | null = null;

let adjacent: Awaited<ReturnType<typeof getAdjacentPosts>> = null;

if (collection === 'posts') {
  const taxonomy = await getPostTaxonomy();
  category = categoryProp ?? taxonomy.postCategory.get(slug) ?? null;

  const seriesMeta = taxonomy.postSeries.get(slug);
  if (seriesMeta) {
    const list = taxonomy.series.get(seriesMeta.slug)?.posts ?? [];
    const idx = list.findIndex((p) => p.id === slug);
    const prevEntry = idx > 0 ? list[idx - 1] : null;
    const nextEntry = idx >= 0 && idx < list.length - 1 ? list[idx + 1] : null;
    seriesInfo = {
      ...seriesMeta,
      entries: list.map((p, i) => ({ id: p.id, title: p.data.title, order: i + 1 })),
      prev: prevEntry ? { id: prevEntry.id, title: prevEntry.data.title } : undefined,
      next: nextEntry ? { id: nextEntry.id, title: nextEntry.data.title } : undefined,
    };
  } else {
    adjacent = await getAdjacentPosts(slug);
  }
} else {
  category = categoryProp ?? null;
}

const categoryUrl = category
  ? collection === 'wiki'
    ? `/wiki/category/${encodeURIComponent(category)}/`
    : collection === 'posts'
      ? `/posts/category/${encodeURIComponent(category)}/`
      : null
  : null;
const seriesUrl = seriesInfo ? `/posts/series/${slugify(seriesInfo.name)}/` : null;

const articleUrl = new URL(
  collection === 'posts' ? `/posts/${slug}/` : collection === 'wiki' ? `/wiki/${slug}/` : `/notes/${slug}/`,
  SITE_URL,
).toString();
const articleImage = cover ? new URL(cover, SITE_URL).toString() : undefined;

const postingSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': collection === 'wiki' ? 'TechArticle' : 'BlogPosting',
  '@id': `${articleUrl}#article`,
  headline: title,
  description,
  datePublished: isoDate,
  ...(updated && { dateModified: updated.toISOString() }),
  inLanguage: SITE_LOCALE,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  url: articleUrl,
  author: { '@id': `${SITE_URL}/#person` },
  publisher: { '@id': `${SITE_URL}/#person` },
  isPartOf: { '@id': `${SITE_URL}/#website` },
  ...(articleImage && {
    image: {
      '@type': 'ImageObject',
      url: articleImage,
      ...(coverAlt && { caption: coverAlt }),
    },
  }),
  ...(tags.length > 0 && { keywords: tags.join(', ') }),
  ...(category && { articleSection: category }),
  ...(seriesInfo && {
    isPartOf: {
      '@type': 'CreativeWorkSeries',
      name: seriesInfo.name,
      position: seriesInfo.order,
    },
  }),
};

const collectionLabel = collection === 'posts' ? '글' : collection === 'wiki' ? '위키' : '노트';
const collectionIndexHref =
  collection === 'posts' ? '/posts/' : collection === 'wiki' ? '/wiki/' : '/notes/';

const dateFmtForCrumb = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

interface VisibleCrumb {
  label: string;
  href?: string;
}

const visibleBreadcrumbs: VisibleCrumb[] = [
  { label: '홈', href: '/' },
  { label: collectionLabel, href: collectionIndexHref },
  ...(category && (collection === 'posts' || collection === 'wiki') && categoryUrl
    ? [{ label: category, href: categoryUrl }]
    : []),
  { label: collection === 'notes' ? dateFmtForCrumb.format(date) : title },
];

const breadcrumb = breadcrumbSchema([
  {
    name: collectionLabel,
    url: new URL(collectionIndexHref, SITE_URL).toString(),
  },
  ...(category && (collection === 'posts' || collection === 'wiki') && categoryUrl
    ? [
        {
          name: category,
          url: new URL(categoryUrl, SITE_URL).toString(),
        },
      ]
    : []),
  { name: title, url: articleUrl },
]);

void SITE_TITLE;
void SITE_AUTHOR;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={cover ?? `/og/${collection}/${slug}.png`}
  ogType="article"
  publishedTime={isoDate}
  modifiedTime={updated?.toISOString()}
  articleTags={tags}
  articleAuthor={SITE_AUTHOR}
  jsonLd={[postingSchema, breadcrumb]}
  keywords={[...tags, ...(category ? [category] : [])]}
>
  <ReadingProgress />
  <div class="post-shell">
    <article
      class="container-prose post-article"
      data-pagefind-body
      data-pagefind-filter={[`section:${collection}`, ...(category ? [`category:${category}`] : [])].join(', ')}
      data-pagefind-meta={`date:${isoDate}`}
    >
      <PostBreadcrumbs crumbs={visibleBreadcrumbs} />

      {cover && <PostCover cover={cover} coverAlt={coverAlt} coverCredit={coverCredit} />}

      <PostHeader
        collection={collection}
        title={title}
        description={description}
        date={date}
        updated={updated}
        tags={tags}
        category={category}
        categoryUrl={categoryUrl}
        series={seriesInfo ? { name: seriesInfo.name, order: seriesInfo.order, total: seriesInfo.total } : null}
        seriesUrl={seriesUrl}
        readingTime={readingTime}
      />

      <div class="prose-content">
        <slot />
      </div>

      {
        seriesInfo && seriesUrl && (
          <PostSeriesNav seriesInfo={seriesInfo} seriesUrl={seriesUrl} slug={slug} />
        )
      }

      {
        adjacent && (adjacent.older || adjacent.newer) && (
          <PostAdjacent older={adjacent.older} newer={adjacent.newer} />
        )
      }

      <ReferencesBlock references={references} />

      <RelatedPosts
        collection={collection}
        slug={slug}
        tags={tags}
        category={category ?? undefined}
        series={seriesInfo?.name}
        limit={collection === 'notes' ? 4 : 5}
      />

      <LocalGraph collection={collection} slug={slug} />

      <div data-pagefind-ignore="all">
        <Backlinks slug={slug} collection={collection} />
      </div>

      <ShareButtons title={title} path={`/${collection}/${slug}/`} />

      <AuthorCard />

      <Comments slug={`${collection}/${slug}`} />
    </article>
    <aside class="post-sidebar">
      <slot name="sidebar-extra" />
      <PostToc headings={headings} />
    </aside>
  </div>
  <DevEditButton collection={collection} slug={slug} />
</BaseLayout>
