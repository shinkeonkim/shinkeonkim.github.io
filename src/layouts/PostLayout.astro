---
import BaseLayout from './BaseLayout.astro';
import Backlinks from '../components/Backlinks.astro';
import { SITE_LOCALE } from '../consts';

interface Props {
  title: string;
  description?: string;
  date: Date;
  updated?: Date;
  tags?: string[];
  slug: string;
  collection: 'posts' | 'wiki';
}

const { title, description, date, updated, tags = [], slug, collection } = Astro.props as Props;
const dateFmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const isoDate = date.toISOString();
---
<BaseLayout title={title} description={description}>
  <article
    class="container-prose"
    data-pagefind-body
    data-pagefind-filter={`section:${collection}`}
    data-pagefind-meta={`date:${isoDate}`}
  >
    <header class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight md:text-4xl">{title}</h1>
      {description && (
        <p class="mt-2 text-[color:var(--color-fg-muted)]" data-pagefind-meta="description">{description}</p>
      )}
      <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-[color:var(--color-fg-muted)]" data-pagefind-ignore>
        <time datetime={isoDate}>{dateFmt.format(date)}</time>
        {updated && (
          <span>· 수정 <time datetime={updated.toISOString()}>{dateFmt.format(updated)}</time></span>
        )}
        {tags.length > 0 && (
          <span class="flex flex-wrap gap-1">
            {tags.map((t) => (
              <a href={`/tags/${encodeURIComponent(t)}/`} class="rounded-full border border-[color:var(--color-border)] px-2 py-0.5 text-xs no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]">#{t}</a>
            ))}
          </span>
        )}
      </div>
    </header>
    <div class="prose-content">
      <slot />
    </div>
    <div data-pagefind-ignore="all">
      <Backlinks slug={slug} collection={collection} />
    </div>
  </article>
</BaseLayout>
