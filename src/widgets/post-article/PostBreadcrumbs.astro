---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props as Props;
---
<nav
  class="post-breadcrumbs not-prose"
  aria-label="브레드크럼"
  data-pagefind-ignore="all"
>
  <ol class="post-breadcrumbs-list">
    {
      crumbs.map((c, i) => (
        <>
          {i > 0 && <li class="post-breadcrumbs-sep" aria-hidden="true">/</li>}
          <li
            class={i === crumbs.length - 1 ? 'post-breadcrumbs-current' : ''}
            {...(i === crumbs.length - 1 ? { 'aria-current': 'page' } : {})}
          >
            {c.href ? <a href={c.href}>{c.label}</a> : <span>{c.label}</span>}
          </li>
        </>
      ))
    }
  </ol>
</nav>
