---
import { SITE_LOCALE } from '@/shared/config';
import type { ReadingStats } from '@/shared/lib/content/reading-time';
import type { ComplexityLevel, ComplexityMetrics } from '@/shared/lib/content/complexity';

interface SeriesBadge {
  name: string;
  order: number;
  total: number;
}

interface Props {
  collection: 'posts' | 'wiki' | 'notes';
  slug: string;
  title: string;
  description?: string;
  date: Date;
  updated?: Date;
  tags: string[];
  category: string | null;
  categoryUrl: string | null;
  series: SeriesBadge | null;
  seriesUrl: string | null;
  readingTime: ReadingStats | null;
  hasCheatsheetFence?: boolean;
  complexity?: {
    level: ComplexityLevel;
    metrics: ComplexityMetrics;
    source: 'override' | 'auto';
  } | null;
}

const {
  collection,
  slug,
  title,
  description,
  date,
  updated,
  tags,
  category,
  categoryUrl,
  series,
  seriesUrl,
  readingTime,
  hasCheatsheetFence,
  complexity,
} = Astro.props as Props;

const CHEATSHEET_MIN_MINUTES = 10;
const showCheatsheetLink =
  collection === 'posts' &&
  (hasCheatsheetFence || (readingTime?.minutes ?? 0) >= CHEATSHEET_MIN_MINUTES);
const cheatsheetHref = showCheatsheetLink ? `/posts/${slug}/cheatsheet/` : null;

const LEVEL_LABEL: Record<ComplexityLevel, string> = {
  beginner: '입문',
  intermediate: '중급',
  advanced: '심화',
};

const LEVEL_ICON: Record<ComplexityLevel, string> = {
  beginner: '🌱',
  intermediate: '🌿',
  advanced: '🌳',
};

const complexityTooltip = complexity
  ? `${complexity.source === 'override' ? '수동 지정' : '자동 산정'} · 문장 평균 ${Math.round(complexity.metrics.avgSentenceLength)}어절 · 전문 용어 ${(complexity.metrics.jargonRatio * 100).toFixed(1)}% · 스코어 ${Math.round(complexity.metrics.score)}`
  : '';

void title;

const dateFmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const noteDateFmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'long',
});
const noteTimeFmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  hour: '2-digit',
  minute: '2-digit',
});
const isoDate = date.toISOString();
---
<header class="mb-8">
  {
    (category || series) && (
      <div
        class="mb-2 flex flex-wrap items-center gap-2 text-xs text-fg-muted"
        data-pagefind-ignore
      >
        {category && categoryUrl && (
          <a
            href={categoryUrl}
            class="inline-flex items-center gap-1 rounded-full border border-border px-2.5 py-0.5 no-underline hover:border-accent hover:text-accent"
          >
            📁 {category}
          </a>
        )}
        {series && seriesUrl && (
          <a
            href={seriesUrl}
            class="inline-flex items-center gap-1 rounded-full border border-border px-2.5 py-0.5 no-underline hover:border-accent hover:text-accent"
          >
            📚 {series.name}
            <span class="opacity-70">
              {series.order} / {series.total}
            </span>
          </a>
        )}
      </div>
    )
  }

  {
    collection === 'notes' ? (
      <>
        <h1 class="sr-only">{title}</h1>
        <time
          datetime={isoDate}
          class="block text-xl font-semibold tracking-tight text-fg md:text-2xl"
        >
          {noteDateFmt.format(date)}
        </time>
        <div
          class="mt-2 flex flex-wrap items-center gap-3 text-sm text-fg-muted"
          data-pagefind-ignore
        >
          <time datetime={isoDate}>{noteTimeFmt.format(date)}</time>
          {readingTime && (
            <span title={`한글 ${readingTime.cjkChars}자 · 영문 ${readingTime.asciiWords}단어`}>
              · 📖 약 {readingTime.minutes}분
            </span>
          )}
          {tags.length > 0 && (
            <span class="flex flex-wrap gap-1">
              {tags.map((t) => (
                <a
                  href={`/tags/${encodeURIComponent(t.toLowerCase())}/`}
                  class="rounded-full border border-border px-2 py-0.5 text-xs no-underline hover:border-accent hover:text-accent"
                >
                  #{t}
                </a>
              ))}
            </span>
          )}
        </div>
      </>
    ) : (
      <>
        <h1 class="text-3xl font-bold tracking-tight md:text-4xl">{title}</h1>
        {description && (
          <p
            class="mt-2 text-fg-muted"
            data-pagefind-meta="description"
          >
            {description}
          </p>
        )}
        <div
          class="mt-3 flex flex-wrap items-center gap-3 text-sm text-fg-muted"
          data-pagefind-ignore
        >
          <time datetime={isoDate}>{dateFmt.format(date)}</time>
          {updated && (
            <span>
              · 수정 <time datetime={updated.toISOString()}>{dateFmt.format(updated)}</time>
            </span>
          )}
          {readingTime && (
            <span title={`한글 ${readingTime.cjkChars}자 · 영문 ${readingTime.asciiWords}단어`}>
              · 📖 약 {readingTime.minutes}분 ·{' '}
              {readingTime.cjkChars + readingTime.asciiWords > 0
                ? `${(readingTime.cjkChars + readingTime.asciiWords).toLocaleString()}자/단어`
                : ''}
            </span>
          )}
          {tags.length > 0 && (
            <span class="flex flex-wrap gap-1">
              {tags.map((t) => (
                <a
                  href={`/tags/${encodeURIComponent(t.toLowerCase())}/`}
                  class="rounded-full border border-border px-2 py-0.5 text-xs no-underline hover:border-accent hover:text-accent"
                >
                  #{t}
                </a>
              ))}
            </span>
          )}
          {complexity && (
            <span
              class:list={['complexity-badge', `is-${complexity.level}`]}
              title={complexityTooltip}
              aria-label={`난이도: ${LEVEL_LABEL[complexity.level]}`}
            >
              <span aria-hidden="true">{LEVEL_ICON[complexity.level]}</span>
              {LEVEL_LABEL[complexity.level]}
            </span>
          )}
          {cheatsheetHref && (
            <a
              href={cheatsheetHref}
              class="post-cheatsheet-link inline-flex items-center gap-1 rounded-full border border-accent px-2.5 py-0.5 text-xs text-accent no-underline hover:bg-accent hover:text-white"
              aria-label="이 글의 치트시트 보기"
              title="A4 1페이지 요약"
            >
              🃏 치트시트
            </a>
          )}
        </div>
      </>
    )
  }
</header>

<style is:global>
  .complexity-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.1rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 500;
    background: var(--color-surface);
    color: var(--color-fg-muted);
  }
  .complexity-badge.is-beginner {
    border-color: #16a34a;
    color: #16a34a;
    background-color: color-mix(in srgb, #16a34a 8%, transparent);
  }
  .complexity-badge.is-intermediate {
    border-color: #2563eb;
    color: #2563eb;
    background-color: color-mix(in srgb, #2563eb 8%, transparent);
  }
  .complexity-badge.is-advanced {
    border-color: #a855f7;
    color: #a855f7;
    background-color: color-mix(in srgb, #a855f7 8%, transparent);
  }
</style>
