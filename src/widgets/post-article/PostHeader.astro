---
import { SITE_LOCALE } from '@/shared/config';
import type { ReadingStats } from '@/shared/lib/content/reading-time';

interface SeriesBadge {
  name: string;
  order: number;
  total: number;
}

interface Props {
  collection: 'posts' | 'wiki' | 'notes';
  title: string;
  description?: string;
  date: Date;
  updated?: Date;
  tags: string[];
  category: string | null;
  categoryUrl: string | null;
  series: SeriesBadge | null;
  seriesUrl: string | null;
  readingTime: ReadingStats | null;
}

const {
  collection,
  title,
  description,
  date,
  updated,
  tags,
  category,
  categoryUrl,
  series,
  seriesUrl,
  readingTime,
} = Astro.props as Props;

const dateFmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const noteDateFmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'long',
});
const noteTimeFmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  hour: '2-digit',
  minute: '2-digit',
});
const isoDate = date.toISOString();
---
<header class="mb-8">
  {
    (category || series) && (
      <div
        class="mb-2 flex flex-wrap items-center gap-2 text-xs text-fg-muted"
        data-pagefind-ignore
      >
        {category && categoryUrl && (
          <a
            href={categoryUrl}
            class="inline-flex items-center gap-1 rounded-full border border-border px-2.5 py-0.5 no-underline hover:border-accent hover:text-accent"
          >
            📁 {category}
          </a>
        )}
        {series && seriesUrl && (
          <a
            href={seriesUrl}
            class="inline-flex items-center gap-1 rounded-full border border-border px-2.5 py-0.5 no-underline hover:border-accent hover:text-accent"
          >
            📚 {series.name}
            <span class="opacity-70">
              {series.order} / {series.total}
            </span>
          </a>
        )}
      </div>
    )
  }

  {
    collection === 'notes' ? (
      <>
        <h1 class="sr-only">{title}</h1>
        <time
          datetime={isoDate}
          class="block text-xl font-semibold tracking-tight text-fg md:text-2xl"
        >
          {noteDateFmt.format(date)}
        </time>
        <div
          class="mt-2 flex flex-wrap items-center gap-3 text-sm text-fg-muted"
          data-pagefind-ignore
        >
          <time datetime={isoDate}>{noteTimeFmt.format(date)}</time>
          {readingTime && (
            <span title={`한글 ${readingTime.cjkChars}자 · 영문 ${readingTime.asciiWords}단어`}>
              · 📖 약 {readingTime.minutes}분
            </span>
          )}
          {tags.length > 0 && (
            <span class="flex flex-wrap gap-1">
              {tags.map((t) => (
                <a
                  href={`/tags/${encodeURIComponent(t.toLowerCase())}/`}
                  class="rounded-full border border-border px-2 py-0.5 text-xs no-underline hover:border-accent hover:text-accent"
                >
                  #{t}
                </a>
              ))}
            </span>
          )}
        </div>
      </>
    ) : (
      <>
        <h1 class="text-3xl font-bold tracking-tight md:text-4xl">{title}</h1>
        {description && (
          <p
            class="mt-2 text-fg-muted"
            data-pagefind-meta="description"
          >
            {description}
          </p>
        )}
        <div
          class="mt-3 flex flex-wrap items-center gap-3 text-sm text-fg-muted"
          data-pagefind-ignore
        >
          <time datetime={isoDate}>{dateFmt.format(date)}</time>
          {updated && (
            <span>
              · 수정 <time datetime={updated.toISOString()}>{dateFmt.format(updated)}</time>
            </span>
          )}
          {readingTime && (
            <span title={`한글 ${readingTime.cjkChars}자 · 영문 ${readingTime.asciiWords}단어`}>
              · 📖 약 {readingTime.minutes}분 ·{' '}
              {readingTime.cjkChars + readingTime.asciiWords > 0
                ? `${(readingTime.cjkChars + readingTime.asciiWords).toLocaleString()}자/단어`
                : ''}
            </span>
          )}
          {tags.length > 0 && (
            <span class="flex flex-wrap gap-1">
              {tags.map((t) => (
                <a
                  href={`/tags/${encodeURIComponent(t.toLowerCase())}/`}
                  class="rounded-full border border-border px-2 py-0.5 text-xs no-underline hover:border-accent hover:text-accent"
                >
                  #{t}
                </a>
              ))}
            </span>
          )}
        </div>
      </>
    )
  }
</header>
