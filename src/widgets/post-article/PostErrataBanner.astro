---
import { getErrataFor } from '@/shared/lib/content/errata';
import type { ErrataCollection } from '@/shared/config';

interface Props {
  slug: string;
  collection: ErrataCollection;
}

const { slug, collection } = Astro.props as Props;
const issues = await getErrataFor(collection, slug);
const closed = issues.filter((i) => i.state === 'closed');
const open = issues.filter((i) => i.state === 'open');
const anchor = `#${collection}-${slug.replace(/\//g, '-')}`;
---

{
  (closed.length > 0 || open.length > 0) && (
    <aside class="post-errata-banner not-prose" data-pagefind-ignore="all" role="note">
      <span class="post-errata-banner-icon" aria-hidden="true">📌</span>
      <span class="post-errata-banner-text">
        {closed.length > 0 && (
          <>
            <a href={`/errata/${anchor}`}>{closed.length}개의 정오표</a>가 반영되어 있습니다.
          </>
        )}
        {closed.length > 0 && open.length > 0 && <span aria-hidden="true"> · </span>}
        {open.length > 0 && (
          <>
            <a href={`/errata/${anchor}`}>{open.length}개의 의견</a>이 검토 중입니다.
          </>
        )}
      </span>
    </aside>
  )
}

<style is:global>
  .post-errata-banner {
    margin: 1rem 0 1.5rem;
    padding: 0.55rem 0.85rem;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: 0.4rem;
    background-color: color-mix(in srgb, var(--color-accent) 5%, var(--color-surface-elevated));
    font-size: 0.82rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .post-errata-banner-icon {
    flex-shrink: 0;
  }
  .post-errata-banner-text {
    color: var(--color-fg);
  }
  .post-errata-banner a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }
  .post-errata-banner a:hover {
    text-decoration: underline;
  }
</style>
