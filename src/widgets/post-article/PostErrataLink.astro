---
import { issueUrlFor, type ErrataCollection } from '@/shared/config';

interface Props {
  slug: string;
  collection: ErrataCollection;
  title: string;
}

const { slug, collection, title } = Astro.props as Props;
const href = issueUrlFor({ collection, slug, title });
---

<p class="post-errata-link not-prose" data-pagefind-ignore="all">
  <a href={href} target="_blank" rel="noopener noreferrer">
    <span aria-hidden="true">🔧</span>
    이 글에 오류나 개선할 점이 있나요?
    <span class="post-errata-link-hint">GitHub 이슈로 알려주세요</span>
  </a>
</p>

<style is:global>
  .post-errata-link {
    margin: 1.5rem 0 0;
    padding: 0.55rem 0.85rem;
    border: 1px dashed var(--color-border);
    border-radius: 0.4rem;
    background-color: transparent;
    font-size: 0.82rem;
    color: var(--color-fg-muted);
    text-align: center;
  }
  .post-errata-link a {
    color: var(--color-fg-muted);
    text-decoration: none;
  }
  .post-errata-link a:hover {
    color: var(--color-accent);
  }
  .post-errata-link-hint {
    font-size: 0.72rem;
    opacity: 0.85;
    margin-left: 0.35rem;
  }
  @media (max-width: 640px) {
    .post-errata-link {
      font-size: 0.78rem;
    }
    .post-errata-link-hint {
      display: block;
      margin-left: 0;
      margin-top: 0.15rem;
    }
  }
</style>
