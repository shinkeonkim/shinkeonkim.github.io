---
interface AdjacentEntry {
  id: string;
  data: { title: string };
}

interface Props {
  older?: AdjacentEntry | null;
  newer?: AdjacentEntry | null;
}

const { older, newer } = Astro.props as Props;
---
<nav
  class="post-adjacent not-prose"
  aria-label="이전·다음 글"
  data-pagefind-ignore="all"
>
  {older ? (
    <a class="post-adjacent-link" href={`/posts/${older.id}/`} rel="prev">
      <span class="post-adjacent-label">← 이전 글</span>
      <span class="post-adjacent-title">{older.data.title}</span>
    </a>
  ) : (
    <span class="post-adjacent-empty" aria-hidden="true" />
  )}
  {newer ? (
    <a class="post-adjacent-link post-adjacent-link-right" href={`/posts/${newer.id}/`} rel="next">
      <span class="post-adjacent-label">다음 글 →</span>
      <span class="post-adjacent-title">{newer.data.title}</span>
    </a>
  ) : (
    <span class="post-adjacent-empty" aria-hidden="true" />
  )}
</nav>
