---
interface Props {
  cover: string;
  coverAlt?: string;
  coverCredit?: string;
}

const { cover, coverAlt, coverCredit } = Astro.props as Props;
---
<figure class="post-cover not-prose">
  <img
    src={cover}
    alt={coverAlt ?? ''}
    class="post-cover-img"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  {coverCredit && <figcaption class="post-cover-credit">{coverCredit}</figcaption>}
</figure>
