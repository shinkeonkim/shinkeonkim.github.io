---
import {
  canonicalId,
  getContentGraph,
  type Collection,
  type ContentNode,
} from '@/shared/lib/content/content-graph';

interface Props {
  slug: string;
  collection: Collection;
  title: string;
}

const { slug, collection, title } = Astro.props as Props;

const graph = await getContentGraph();
const id = canonicalId(collection, slug);
const prereqs: ContentNode[] = graph.learningPath.prereqs.get(id) ?? [];
const follows: ContentNode[] = graph.learningPath.follows.get(id) ?? [];

const learningPathHref = collection === 'wiki' ? `/wiki/${slug}/learning-path/` : null;
---

{
  (prereqs.length > 0 || follows.length > 0) && (
    <nav
      class="learning-path not-prose"
      aria-label="학습 경로"
      data-pagefind-ignore="all"
    >
      {prereqs.length > 0 && (
        <div class="learning-path-group learning-path-before">
          <span class="learning-path-label">
            <span aria-hidden="true">↑</span> 선수
          </span>
          <ul class="learning-path-list">
            {prereqs.map((p) => (
              <li>
                <a href={p.url} class="learning-path-chip">
                  {p.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
      <div class="learning-path-self" aria-current="true">
        <span class="learning-path-self-label">지금 읽는 글</span>
        <span class="learning-path-self-title">{title}</span>
      </div>
      {follows.length > 0 && (
        <div class="learning-path-group learning-path-after">
          <span class="learning-path-label">
            <span aria-hidden="true">↓</span> 다음
          </span>
          <ul class="learning-path-list">
            {follows.map((f) => (
              <li>
                <a href={f.url} class="learning-path-chip">
                  {f.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
      {learningPathHref && (
        <a href={learningPathHref} class="learning-path-expand">
          전체 학습 경로 보기 →
        </a>
      )}
    </nav>
  )
}

<style is:global>
  .learning-path {
    margin: 1.25rem 0 1.75rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.6rem;
    background-color: var(--color-surface-elevated);
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .learning-path-group {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .learning-path-label {
    flex-shrink: 0;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-family: var(--font-mono);
  }
  .learning-path-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .learning-path-chip {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background-color: var(--color-surface);
    color: var(--color-fg);
    text-decoration: none;
    font-size: 0.82rem;
    line-height: 1.35;
  }
  .learning-path-chip:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .learning-path-self {
    padding: 0.45rem 0.7rem;
    border-left: 3px solid var(--color-accent);
    background-color: color-mix(in srgb, var(--color-accent) 6%, var(--color-surface));
    border-radius: 0 0.4rem 0.4rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }
  .learning-path-self-label {
    font-size: 0.65rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: var(--font-mono);
    font-weight: 600;
  }
  .learning-path-self-title {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-fg);
  }
  .learning-path-expand {
    align-self: flex-end;
    font-size: 0.75rem;
    color: var(--color-fg-muted);
    text-decoration: none;
    padding: 0.15rem 0.35rem;
    border-radius: 0.25rem;
  }
  .learning-path-expand:hover {
    color: var(--color-accent);
    background-color: var(--color-surface);
  }
  @media (max-width: 640px) {
    .learning-path {
      padding: 0.75rem 0.85rem;
    }
    .learning-path-chip {
      font-size: 0.78rem;
    }
    .learning-path-self-title {
      font-size: 0.85rem;
    }
  }
</style>
