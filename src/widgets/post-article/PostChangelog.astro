---
import { getChangelogFor } from '@/shared/lib/content/changelog';
import { SITE_LOCALE } from '@/shared/config';

interface Props {
  slug: string;
  collection: 'posts' | 'wiki' | 'notes';
}

const { slug, collection } = Astro.props as Props;
const entries = await getChangelogFor(collection, slug);
const MIN_ENTRIES = 2;

const fmt = new Intl.DateTimeFormat(SITE_LOCALE, {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const latestLabel = entries.length > 0 ? fmt.format(new Date(entries[0].date)) : null;
---

{entries.length >= MIN_ENTRIES && (
  <details class="post-changelog not-prose" data-pagefind-ignore="all">
    <summary class="post-changelog-summary">
      <span class="post-changelog-icon" aria-hidden="true">📝</span>
      <span>
        이 글의 편집 이력 <span class="post-changelog-count">({entries.length}회{latestLabel && `, 최신 ${latestLabel}`})</span>
      </span>
      <span class="post-changelog-chevron" aria-hidden="true">▾</span>
    </summary>
    <ol class="post-changelog-list">
      {entries.map((e) => (
        <li class:list={['post-changelog-item', { 'is-major': e.major }]}>
          <time class="post-changelog-date" datetime={e.date}>{fmt.format(new Date(e.date))}</time>
          <a class="post-changelog-subject" href={e.url} target="_blank" rel="noopener noreferrer">
            {e.major && (
              <span class="post-changelog-major-badge" title="주요 개정 (50줄 이상 or refactor/rewrite/overhaul)">
                ✨ 주요
              </span>
            )}
            {e.subject}
          </a>
          <span class="post-changelog-meta">
            <span class="post-changelog-delta" title={`+${e.insertions} -${e.deletions} 줄`}>
              <span class="post-changelog-ins">+{e.insertions}</span>
              <span class="post-changelog-del">-{e.deletions}</span>
            </span>
            <code class="post-changelog-sha">{e.shortSha}</code>
          </span>
        </li>
      ))}
    </ol>
  </details>
)}

<style is:global>
  .post-changelog {
    margin-top: 2rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.6rem;
    background-color: var(--color-surface-elevated);
  }
  .post-changelog[open] {
    padding-bottom: 1.1rem;
  }
  .post-changelog-summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-fg);
    list-style: none;
    user-select: none;
  }
  .post-changelog-summary::-webkit-details-marker {
    display: none;
  }
  .post-changelog-count {
    color: var(--color-fg-muted);
    font-weight: 500;
    font-size: 0.85rem;
  }
  .post-changelog-chevron {
    margin-left: auto;
    color: var(--color-fg-muted);
    transition: transform 0.15s ease;
    font-size: 0.8rem;
  }
  .post-changelog[open] .post-changelog-chevron {
    transform: rotate(180deg);
  }
  .post-changelog-list {
    list-style: none;
    margin: 0.9rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .post-changelog-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.5rem 0.75rem;
    padding: 0.5rem 0.65rem;
    border: 1px solid var(--color-border);
    border-left-width: 3px;
    border-radius: 0.4rem;
    background-color: var(--color-surface);
    align-items: baseline;
  }
  .post-changelog-item.is-major {
    border-left-color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-accent) 5%, var(--color-surface));
  }
  .post-changelog-major-badge {
    display: inline-block;
    margin-right: 0.4rem;
    padding: 0.05rem 0.4rem;
    font-size: 0.65rem;
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    vertical-align: baseline;
  }
  .post-changelog-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-fg-muted);
    white-space: nowrap;
    tabular-nums: 1;
  }
  .post-changelog-subject {
    color: var(--color-fg);
    text-decoration: none;
    font-size: 0.85rem;
    line-height: 1.45;
    overflow-wrap: anywhere;
  }
  .post-changelog-subject:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }
  .post-changelog-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
    font-size: 0.72rem;
    font-family: var(--font-mono);
  }
  .post-changelog-delta {
    display: inline-flex;
    gap: 0.25rem;
  }
  .post-changelog-ins {
    color: #16a34a;
  }
  .post-changelog-del {
    color: #dc2626;
  }
  .post-changelog-sha {
    padding: 0.05rem 0.35rem;
    border-radius: 0.25rem;
    background-color: var(--color-code-bg);
    color: var(--color-fg-muted);
    font-size: 0.7rem;
  }
  @media (max-width: 640px) {
    .post-changelog {
      padding: 0.75rem 0.85rem;
    }
    .post-changelog-item {
      grid-template-columns: 1fr;
      gap: 0.25rem;
      padding: 0.55rem 0.65rem;
    }
    .post-changelog-date {
      order: -1;
    }
    .post-changelog-meta {
      order: 3;
      justify-content: flex-start;
    }
    .post-changelog-summary {
      font-size: 0.9rem;
    }
  }
</style>
