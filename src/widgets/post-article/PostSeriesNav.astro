---
interface SeriesEntry {
  id: string;
  title: string;
  order: number;
}

interface SeriesInfo {
  slug: string;
  name: string;
  order: number;
  total: number;
  prev?: { id: string; title: string };
  next?: { id: string; title: string };
  entries: SeriesEntry[];
}

interface Props {
  seriesInfo: SeriesInfo;
  seriesUrl: string;
  slug: string;
}

const SERIES_WINDOW_BEFORE = 3;
const SERIES_WINDOW_AFTER = 4;
const SERIES_INLINE_THRESHOLD = 12;

interface WindowedSeries {
  visible: SeriesEntry[];
  hiddenBefore: number;
  hiddenAfter: number;
}

function windowedSeriesEntries(info: SeriesInfo): WindowedSeries {
  const all = info.entries;
  if (all.length <= SERIES_INLINE_THRESHOLD) {
    return { visible: all, hiddenBefore: 0, hiddenAfter: 0 };
  }
  const currentIdx = info.order - 1;
  const start = Math.max(0, currentIdx - SERIES_WINDOW_BEFORE);
  const end = Math.min(all.length, currentIdx + SERIES_WINDOW_AFTER + 1);
  return {
    visible: all.slice(start, end),
    hiddenBefore: start,
    hiddenAfter: all.length - end,
  };
}

const { seriesInfo, seriesUrl, slug } = Astro.props as Props;
const seriesWindow = windowedSeriesEntries(seriesInfo);
---
<aside
  class="series-nav not-prose mt-10 rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-4"
  data-pagefind-ignore="all"
>
  <div class="mb-3 flex flex-wrap items-baseline justify-between gap-2">
    <h3 class="text-sm font-semibold">
      📚 시리즈:{' '}
      <a href={seriesUrl} class="text-[color:var(--color-accent)]">
        {seriesInfo.name}
      </a>
    </h3>
    <span class="text-xs text-[color:var(--color-fg-muted)]">
      {seriesInfo.order} / {seriesInfo.total}
    </span>
  </div>
  <ol class="space-y-1 text-sm">
    {seriesWindow.hiddenBefore > 0 && (
      <li class="text-xs text-[color:var(--color-fg-muted)]">
        <a href={seriesUrl} class="hover:text-[color:var(--color-accent)]">
          ↑ 이전 {seriesWindow.hiddenBefore}편 …
        </a>
      </li>
    )}
    {seriesWindow.visible.map((e) => (
      <li class={e.id === slug ? 'font-semibold text-[color:var(--color-accent)]' : ''}>
        <span class="mr-1 inline-block w-6 text-right font-mono text-xs text-[color:var(--color-fg-muted)]">
          {e.order}.
        </span>
        {e.id === slug ? (
          <span>{e.title}</span>
        ) : (
          <a href={`/posts/${e.id}/`}>{e.title}</a>
        )}
      </li>
    ))}
    {seriesWindow.hiddenAfter > 0 && (
      <li class="text-xs text-[color:var(--color-fg-muted)]">
        <a href={seriesUrl} class="hover:text-[color:var(--color-accent)]">
          ↓ 이후 {seriesWindow.hiddenAfter}편 …
        </a>
      </li>
    )}
  </ol>
  {(seriesInfo.prev || seriesInfo.next || seriesUrl) && (
    <nav class="mt-3 flex flex-wrap items-center justify-between gap-2 border-t border-[color:var(--color-border)] pt-3 text-sm">
      {seriesInfo.prev ? (
        <a href={`/posts/${seriesInfo.prev.id}/`} class="flex-1 truncate" rel="prev">
          ← {seriesInfo.prev.title}
        </a>
      ) : (
        <span class="flex-1" />
      )}
      {seriesUrl && (
        <a
          href={seriesUrl}
          class="rounded-full border border-[color:var(--color-border)] px-2.5 py-0.5 text-xs no-underline hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
        >
          전체 {seriesInfo.total}편 →
        </a>
      )}
      {seriesInfo.next ? (
        <a
          href={`/posts/${seriesInfo.next.id}/`}
          class="flex-1 truncate text-right"
          rel="next"
        >
          {seriesInfo.next.title} →
        </a>
      ) : (
        <span class="flex-1" />
      )}
    </nav>
  )}
</aside>
