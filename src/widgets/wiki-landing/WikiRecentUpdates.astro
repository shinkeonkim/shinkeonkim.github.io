---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entries: CollectionEntry<'wiki'>[];
  fmt: Intl.DateTimeFormat;
}

const { entries, fmt } = Astro.props as Props;
---
<section class="mb-8" data-pagefind-ignore="all">
  <h2 class="mb-3 text-lg font-semibold">최근 업데이트</h2>
  <ul class="grid grid-cols-1 gap-2 sm:grid-cols-2">
    {entries.map((w) => (
      <li>
        <a
          href={`/wiki/${w.id}/`}
          class="block rounded-md border border-border bg-surface-elevated px-3 py-2 no-underline hover:border-accent"
        >
          <span class="block text-sm font-medium">{w.data.title}</span>
          <time
            datetime={w.data.updated!.toISOString()}
            class="mt-0.5 block text-xs text-fg-muted"
          >
            {fmt.format(w.data.updated!)}
          </time>
        </a>
      </li>
    ))}
  </ul>
</section>
