---
import type { CollectionEntry } from 'astro:content';

export interface WikiStub {
  entry: CollectionEntry<'wiki'>;
  chars: number;
}

interface Props {
  stubs: WikiStub[];
  maxVisible?: number;
}

const { stubs, maxVisible = 24 } = Astro.props as Props;
const visible = stubs.slice(0, maxVisible);
const hidden = Math.max(0, stubs.length - maxVisible);
---
<section class="mb-8" data-pagefind-ignore="all">
  <h2 class="mb-3 text-lg font-semibold">📝 내용 보강 필요 ({stubs.length})</h2>
  <p class="mb-2 text-xs text-fg-muted">
    본문이 100자 미만인 위키 페이지. 한 줄 정의만 있거나 미작성 상태입니다.
  </p>
  <ul class="flex flex-wrap gap-1.5">
    {visible.map(({ entry, chars }) => (
      <li>
        <a
          href={`/wiki/${entry.id}/`}
          class="inline-flex items-baseline gap-1 rounded-full border border-dashed border-border px-2.5 py-0.5 text-sm no-underline hover:border-accent hover:text-accent"
          title={`본문 ${chars}자`}
        >
          {entry.data.title}
          <span class="text-xs opacity-60">{chars}자</span>
        </a>
      </li>
    ))}
    {hidden > 0 && (
      <li class="text-xs text-fg-muted self-center">
        +{hidden}개 더
      </li>
    )}
  </ul>
</section>
