---
import type { CategoryInfo } from '@/shared/lib/content/taxonomy';
import { getWikiCategoryMeta } from '@/shared/lib/content/wiki-category-meta';

interface Props {
  categories: CategoryInfo[];
}

const { categories } = Astro.props as Props;
---
{categories.length > 0 && (
  <section class="wiki-category-grid mb-10" data-pagefind-ignore="all">
    <header class="mb-3 flex items-baseline justify-between gap-2">
      <h2 class="text-lg font-semibold">📁 카테고리</h2>
      <a
        href="/wiki/categories/"
        class="text-xs text-fg-muted hover:text-accent"
      >
        전체 보기 →
      </a>
    </header>
    <ul class="grid grid-cols-2 gap-2 sm:grid-cols-3 md:grid-cols-4">
      {categories.map((c) => {
        const meta = getWikiCategoryMeta(c.slug);
        return (
          <li>
            <a
              href={`/wiki/category/${encodeURIComponent(c.slug)}/`}
              class="wiki-category-card group block rounded-lg border border-border border-l-4 bg-surface-elevated px-3 py-2.5 no-underline transition-colors hover:border-accent"
              style={`border-left-color: ${meta.color}`}
            >
              <div class="flex items-center justify-between gap-2">
                <span class="truncate text-sm font-medium group-hover:text-accent inline-flex items-center gap-1.5">
                  <span
                    class="inline-flex items-center justify-center shrink-0"
                    style={`color: ${meta.color}`}
                    aria-hidden="true"
                    set:html={meta.icon}
                  />
                  {c.label}
                </span>
                <span class="shrink-0 text-xs text-fg-muted tabular-nums">
                  {c.count}
                </span>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
)}
