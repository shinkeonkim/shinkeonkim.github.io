---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entries: CollectionEntry<'wiki'>[];
  fmt: Intl.DateTimeFormat;
  emptyMessage?: string;
}

const { entries, fmt, emptyMessage = '아직 작성된 위키 페이지가 없습니다.' } = Astro.props as Props;
---
{entries.length === 0 ? (
  <p class="text-sm text-fg-muted">
    {emptyMessage}
  </p>
) : (
  <ul class="wiki-list">
    {entries.map((w) => (
      <li>
        <a href={`/wiki/${w.id}/`} class="wiki-list-item group">
          <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-0.5">
            <span class="text-base font-medium group-hover:text-accent">
              {w.data.title}
            </span>
            {w.data.updated && (
              <time
                datetime={w.data.updated.toISOString()}
                class="shrink-0 text-xs text-fg-muted tabular-nums"
              >
                {fmt.format(w.data.updated)}
              </time>
            )}
          </div>
          {w.data.tags.length > 0 && (
            <div class="mt-0.5 text-xs text-fg-muted">
              {w.data.tags.map((t) => `#${t}`).join(' ')}
            </div>
          )}
        </a>
      </li>
    ))}
  </ul>
)}

<style>
  .wiki-list {
    border-top: 1px solid var(--color-border);
  }
  .wiki-list > li {
    border-bottom: 1px solid var(--color-border);
  }
  .wiki-list-item {
    display: block;
    padding: 0.6rem 0;
    text-decoration: none;
    color: inherit;
  }
</style>
