---
import type { AnimationDef } from '@/entities/animation/engine/schema';
import { categoryLabel } from '@/features/animation-filter/lib/categories';

interface Props {
  animation: AnimationDef;
}

const { animation: a } = Astro.props as Props;
const catLabel = categoryLabel(a.category);
---
<a
  href={`/animations/${a.id}/`}
  class="anim-card group block rounded-lg border border-border bg-surface-elevated p-4 no-underline transition-colors hover:border-accent"
  data-anim-category={a.category ?? 'general'}
>
  <div class="mb-1 flex items-start justify-between gap-2">
    <span class="text-base font-semibold text-fg group-hover:text-accent">
      {a.title}
    </span>
    <span class="shrink-0 text-xs text-fg-muted tabular-nums">
      {(a.duration / 1000).toFixed(1)}s
    </span>
  </div>
  {a.description && (
    <p class="mb-2 line-clamp-2 text-sm text-fg-muted">
      {a.description}
    </p>
  )}
  <div class="mt-1 flex flex-wrap items-center gap-2 text-xs text-fg-muted">
    <span class="rounded-md border border-border px-1.5 py-0.5 text-[10px]">
      {catLabel}
    </span>
    <span class="font-mono opacity-70">{a.id}</span>
  </div>
  <div class="mt-1 flex flex-wrap items-center gap-2 text-[11px] text-fg-muted">
    <span>{a.elements.length} elements</span>
    <span>·</span>
    <span>{a.chapters.length} chapters</span>
  </div>
  {a.tags && a.tags.length > 0 && (
    <div class="mt-2 flex flex-wrap gap-1 text-[11px] text-fg-muted">
      {a.tags.slice(0, 4).map((t) => (
        <span class="rounded-md border border-border px-1.5 py-0.5">
          #{t}
        </span>
      ))}
      {a.tags.length > 4 && <span class="opacity-60">+{a.tags.length - 4}</span>}
    </div>
  )}
</a>

<style>
  .anim-card {
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .anim-card:hover {
    transform: translateY(-1px);
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
