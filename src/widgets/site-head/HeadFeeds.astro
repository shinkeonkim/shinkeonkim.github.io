---
interface Props {
  siteTitle: string;
  siteUrl: string;
  prevUrl?: string;
  nextUrl?: string;
}

const { siteTitle, siteUrl, prevUrl, nextUrl } = Astro.props as Props;
---
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${siteTitle} RSS`}
  href={`${siteUrl}/rss.xml`}
/>
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${siteTitle} - 노트 RSS`}
  href={`${siteUrl}/notes/rss.xml`}
/>
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${siteTitle} - 위키 RSS`}
  href={`${siteUrl}/wiki/rss.xml`}
/>
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${siteTitle} - 전체 최신 RSS`}
  href={`${siteUrl}/feed/all.xml`}
/>
<link
  rel="alternate"
  type="application/feed+json"
  title={`${siteTitle} JSON Feed`}
  href={`${siteUrl}/feed.json`}
/>
<link rel="sitemap" type="application/xml" href={`${siteUrl}/sitemap-index.xml`} />
{prevUrl && <link rel="prev" href={prevUrl} />}
{nextUrl && <link rel="next" href={nextUrl} />}
