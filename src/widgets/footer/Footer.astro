---
import { SITE_AUTHOR, SITE_SOCIAL } from '@/shared/config';
import { FOOTER_NAV_GROUPS } from '@/shared/config/nav';
import { EXTERNAL_PROFILES } from '@/shared/lib/external/external-profiles';
const year = new Date().getFullYear();

function labelFor(href: string): string {
  if (href.includes('github.com')) return 'GitHub';
  if (href.includes('acmicpc.net')) return 'Baekjoon';
  if (href.includes('linkedin.com')) return 'LinkedIn';
  if (href.includes('mastodon')) return 'Mastodon';
  if (href.includes('bsky.app') || href.includes('bluesky')) return 'Bluesky';
  try {
    return new URL(href).hostname;
  } catch {
    return href;
  }
}
---

<footer
  class="mt-20 border-t border-border bg-surface-subtle"
  data-pagefind-ignore="all"
  transition:persist
  transition:name="site-footer"
>
  <div class="mx-auto max-w-6xl px-5 py-10 text-sm text-fg-muted">
    <div class="grid grid-cols-2 gap-6 md:grid-cols-4 md:gap-8 pb-8 border-b border-border">
      {FOOTER_NAV_GROUPS.map((group) => (
        <div class="flex flex-col gap-2.5">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-fg mb-1">
            {group.title}
          </h3>
          <ul class="flex flex-col gap-1.5">
            {group.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  {...(('external' in link && link.external) ? {
                    target: '_blank',
                    rel: 'noopener noreferrer'
                  } : {})}
                  class="text-fg-muted hover:text-accent no-underline transition-colors inline-flex items-center gap-1"
                >
                  <span>{link.label}</span>
                  {('external' in link && link.external) && (
                    <span class="text-[0.65rem] opacity-60" aria-hidden="true">↗</span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    {EXTERNAL_PROFILES.length > 0 && (
      <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1.5 py-4 border-b border-border md:justify-start">
        <span class="text-xs uppercase tracking-wider opacity-70">소개 자료</span>
        {EXTERNAL_PROFILES.map((p) => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1 rounded-full border border-border bg-surface-elevated px-2.5 py-0.5 text-xs no-underline hover:border-accent hover:text-accent"
            title={p.description ?? p.label}
          >
            <span aria-hidden="true">{p.icon}</span>
            <span>{p.label}</span>
          </a>
        ))}
      </div>
    )}

    <div class="flex flex-col items-center justify-between gap-2 pt-4 md:flex-row">
      <span>&copy; {year} {SITE_AUTHOR}</span>
      {SITE_SOCIAL.length > 0 && (
        <span class="flex flex-wrap items-center gap-2">
          {SITE_SOCIAL.map((href) => (
            <a
              href={href}
              target="_blank"
              rel="noopener me"
              class="hover:text-accent"
            >
              {labelFor(href)}
            </a>
          ))}
        </span>
      )}
      <span>dev.shinkeonkim@gmail.com</span>
    </div>
  </div>
</footer>
