---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
  minHeadings?: number;
}

const { headings, minHeadings = 2 } = Astro.props as Props;
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const showToc = filtered.length >= minHeadings;
---

{
  showToc && (
    <nav class="post-toc" aria-label="목차" data-pagefind-ignore="all">
      <details class="post-toc-details" open>
        <summary class="post-toc-summary">
          <p class="post-toc-title">목차</p>
        </summary>
        <ol class="post-toc-list">
          {filtered.map((h) => (
            <li class={`post-toc-item post-toc-depth-${h.depth}`}>
              <a href={`#${h.slug}`} class="post-toc-link" data-toc-target={h.slug}>
                {h.text}
              </a>
            </li>
          ))}
        </ol>
      </details>
    </nav>
  )
}

<script>
  function initScrollspy() {
    const toc = document.querySelector<HTMLElement>('.post-toc');
    if (!toc) return;
    const links = Array.from(toc.querySelectorAll<HTMLAnchorElement>('.post-toc-link'));
    if (links.length === 0) return;
    const linkMap = new Map<string, HTMLAnchorElement>();
    const targets: HTMLElement[] = [];
    for (const link of links) {
      const slug = link.dataset.tocTarget;
      if (!slug) continue;
      const el = document.getElementById(slug);
      if (!el) continue;
      linkMap.set(slug, link);
      targets.push(el);
    }
    if (targets.length === 0) return;
    let active: HTMLAnchorElement | null = null;
    const setActive = (slug: string) => {
      const link = linkMap.get(slug);
      if (!link || link === active) return;
      active?.classList.remove('is-active');
      link.classList.add('is-active');
      active = link;
    };
    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort(
            (a, b) => (a.target as HTMLElement).offsetTop - (b.target as HTMLElement).offsetTop,
          );
        if (visible.length > 0) {
          setActive((visible[0].target as HTMLElement).id);
        }
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: [0, 1] },
    );
    targets.forEach((t) => observer.observe(t));
    document.addEventListener('astro:before-swap', () => observer.disconnect(), { once: true });
  }
  initScrollspy();
  document.addEventListener('astro:page-load', initScrollspy);
</script>

<style is:global>
  .post-toc {
    position: sticky;
    top: 5rem;
    margin: 0;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.55rem;
    background-color: var(--color-surface-elevated);
    max-height: calc(100vh - 7rem);
    overflow-y: auto;
    font-size: 0.82rem;
  }
  .post-toc-details {
    margin: 0;
  }
  .post-toc-summary {
    cursor: pointer;
    list-style: none;
    margin-bottom: 0.5rem;
  }
  .post-toc-summary::-webkit-details-marker {
    display: none;
  }
  .post-toc-summary::before {
    content: '▾';
    display: inline-block;
    margin-right: 0.3rem;
    color: var(--color-fg-muted);
    font-size: 0.7rem;
    transition: transform 100ms;
  }
  .post-toc-details:not([open]) .post-toc-summary::before {
    transform: rotate(-90deg);
  }
  .post-toc-title {
    display: inline;
    margin: 0;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .post-toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .post-toc-item.post-toc-depth-3 {
    padding-left: 0.85rem;
  }
  .post-toc-link {
    display: block;
    padding: 0.2rem 0.4rem;
    border-radius: 0.3rem;
    color: var(--color-fg-muted);
    text-decoration: none;
    line-height: 1.35;
    border-left: 2px solid transparent;
    transition:
      color 80ms,
      background-color 80ms,
      border-color 80ms;
  }
  .post-toc-link:hover {
    color: var(--color-fg);
    background-color: var(--color-code-bg);
  }
  .post-toc-link.is-active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-accent) 8%, transparent);
  }
  @media (max-width: 1023px) {
    .post-toc {
      position: static;
      max-height: none;
      margin-bottom: 1.5rem;
    }
  }
</style>
