---
import type { WikiTreeCategory, WikiTreeLeaf } from '@/shared/lib/content/taxonomy';

interface Props {
  tree: WikiTreeCategory;
  activeId: string;
}

const { tree, activeId } = Astro.props as Props;
const categoryUrl = `/wiki/category/${encodeURIComponent(tree.slug)}/`;

const subGroups = new Map<string | null, WikiTreeLeaf[]>();
for (const leaf of tree.entries) {
  if (!subGroups.has(leaf.subcategory)) subGroups.set(leaf.subcategory, []);
  subGroups.get(leaf.subcategory)!.push(leaf);
}
const sortedGroups = Array.from(subGroups.entries()).sort((a, b) => {
  if (a[0] === null && b[0] !== null) return 1;
  if (a[0] !== null && b[0] === null) return -1;
  if (a[0] === null && b[0] === null) return 0;
  return b[1].length - a[1].length || (a[0] ?? '').localeCompare(b[0] ?? '');
});
const hasNamedGroups = sortedGroups.some(([slug]) => slug !== null);
---
<aside
  class="wiki-sidebar hidden md:block"
  data-wiki-sidebar
  data-pagefind-ignore="all"
  aria-label="카테고리 사이드바"
>
  <button
    type="button"
    class="wiki-sidebar-toggle"
    data-wiki-sidebar-toggle
    aria-expanded="false"
    aria-controls="wiki-sidebar-tree"
    title="사이드바 토글 (S)"
  >
    <span class="wiki-sidebar-toggle-icon" aria-hidden="true">☰</span>
    <span class="wiki-sidebar-toggle-label">목차</span>
  </button>
  <nav
    id="wiki-sidebar-tree"
    class="wiki-sidebar-tree"
    hidden
  >
    <header class="wiki-sidebar-header">
      <a href={categoryUrl} class="wiki-sidebar-title">
        📁 {tree.slug}
      </a>
      <span class="wiki-sidebar-count">{tree.count}</span>
    </header>
    {hasNamedGroups ? (
      sortedGroups.map(([sub, leaves]) => (
        <div class="wiki-sidebar-group">
          <p class="wiki-sidebar-group-label">
            {sub ?? '(기타)'} <span class="wiki-sidebar-group-count">{leaves.length}</span>
          </p>
          <ul class="wiki-sidebar-list">
            {leaves.map((leaf) => (
              <li>
                <a
                  href={`/wiki/${leaf.id}/`}
                  class={`wiki-sidebar-leaf${leaf.id === activeId ? ' is-active' : ''}`}
                  aria-current={leaf.id === activeId ? 'page' : undefined}
                >
                  {leaf.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    ) : (
      <ul class="wiki-sidebar-list">
        {tree.entries.map((leaf) => (
          <li>
            <a
              href={`/wiki/${leaf.id}/`}
              class={`wiki-sidebar-leaf${leaf.id === activeId ? ' is-active' : ''}`}
              aria-current={leaf.id === activeId ? 'page' : undefined}
            >
              {leaf.title}
            </a>
          </li>
        ))}
      </ul>
    )}
  </nav>
</aside>

<style is:global>
  .wiki-sidebar {
    position: sticky;
    top: 5rem;
    align-self: flex-start;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    font-size: 0.85rem;
  }
  .wiki-sidebar-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
    background: var(--color-surface-elevated);
    color: var(--color-fg-muted);
    font-size: 0.78rem;
    cursor: pointer;
  }
  .wiki-sidebar-toggle:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .wiki-sidebar-toggle[aria-expanded='true'] {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .wiki-sidebar-tree {
    margin-top: 0.6rem;
    padding: 0.7rem 0.8rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-surface);
  }
  .wiki-sidebar-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    padding-bottom: 0.5rem;
    margin-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
  }
  .wiki-sidebar-title {
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    color: inherit;
  }
  .wiki-sidebar-title:hover {
    color: var(--color-accent);
  }
  .wiki-sidebar-count {
    font-size: 0.7rem;
    color: var(--color-fg-muted);
    font-variant-numeric: tabular-nums;
  }
  .wiki-sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }
  .wiki-sidebar-group + .wiki-sidebar-group {
    margin-top: 0.6rem;
  }
  .wiki-sidebar-group-label {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin: 0 0 0.2rem 0;
    padding: 0 0.5rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-fg-muted);
    text-transform: lowercase;
  }
  .wiki-sidebar-group-count {
    font-weight: 400;
    font-variant-numeric: tabular-nums;
    opacity: 0.7;
  }
  .wiki-sidebar-leaf {
    display: block;
    padding: 0.25rem 0.5rem;
    border-radius: 0.3rem;
    text-decoration: none;
    color: var(--color-fg-muted);
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .wiki-sidebar-leaf:hover {
    color: var(--color-fg);
    background: var(--color-surface-elevated);
  }
  .wiki-sidebar-leaf.is-active {
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    font-weight: 500;
  }
</style>

<script>
  function setupWikiSidebar() {
    const sidebar = document.querySelector<HTMLElement>('[data-wiki-sidebar]');
    if (!sidebar) return;
    const toggle = sidebar.querySelector<HTMLButtonElement>('[data-wiki-sidebar-toggle]');
    const tree = sidebar.querySelector<HTMLElement>('#wiki-sidebar-tree');
    if (!toggle || !tree) return;

    const KEY = 'wiki-sidebar-open';
    const stored = localStorage.getItem(KEY);
    const isOpen = stored === '1';
    if (isOpen) {
      toggle.setAttribute('aria-expanded', 'true');
      tree.hidden = false;
      const active = tree.querySelector<HTMLAnchorElement>('.is-active');
      if (active) active.scrollIntoView({ block: 'nearest' });
    }

    toggle.addEventListener('click', () => {
      const next = toggle.getAttribute('aria-expanded') !== 'true';
      toggle.setAttribute('aria-expanded', String(next));
      tree.hidden = !next;
      localStorage.setItem(KEY, next ? '1' : '0');
      if (next) {
        const active = tree.querySelector<HTMLAnchorElement>('.is-active');
        if (active) active.scrollIntoView({ block: 'nearest' });
      }
    });
  }

  if (document.readyState !== 'loading') setupWikiSidebar();
  else document.addEventListener('DOMContentLoaded', setupWikiSidebar);
  document.addEventListener('astro:page-load', setupWikiSidebar);
</script>
