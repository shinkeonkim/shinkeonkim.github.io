---
// Chart Editor — dev-only page for visually building Chart.js configs
// Access at: http://localhost:4321/_chart-editor
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Chart.js Editor (dev)" description="차트 편집기" noIndex>
  <section class="chart-editor-shell" data-pagefind-ignore="all">
    <div class="chart-editor-layout">
      <div class="panel panel-left">
        <h1>📊 Chart.js Editor</h1>
        <p class="chart-editor-desc">
          차트를 시각적으로 편집하고, MDX에 붙여넣을 수 있는 코드를 생성합니다.
        </p>

        <h2>템플릿</h2>
        <div class="templates" id="templates"></div>

        <h2>차트 타입</h2>
        <select id="chart-type">
          <option value="bar">Bar</option>
          <option value="line" selected>Line</option>
          <option value="pie">Pie</option>
          <option value="doughnut">Doughnut</option>
          <option value="radar">Radar</option>
          <option value="scatter">Scatter</option>
        </select>

        <h2>제목 / 캡션</h2>
        <label for="chart-title">title</label>
        <input id="chart-title" placeholder="차트 위에 표시할 제목" />
        <label for="chart-caption">caption</label>
        <input id="chart-caption" placeholder="차트 아래 설명 (선택)" />
        <label for="chart-height">height</label>
        <input id="chart-height" value="280px" placeholder="280px" />

        <h2>data (JSON)</h2>
        <textarea id="data-input" placeholder='{"labels":["A","B"],"datasets":[...]}'></textarea>
        <div class="error" id="data-error"></div>

        <h2>options (JSON, 선택)</h2>
        <textarea id="options-input" class="options-textarea" placeholder="{}"></textarea>
        <div class="error" id="options-error"></div>

        <div class="btn-group">
          <button onclick="renderChart()">🔄 렌더</button>
          <button class="btn-secondary" onclick="copySnippet()">📋 MDX 복사</button>
        </div>
      </div>

      <div class="panel panel-right">
        <div class="chart-container">
          <canvas id="chart-canvas"></canvas>
        </div>
        <div class="output-section">
          <h2>MDX 코드</h2>
          <pre class="snippet-code" id="snippet-output">차트를 렌더한 뒤 여기에 코드가 표시됩니다.</pre>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.8/dist/chart.umd.min.js"></script>
<script is:inline>
  const TEMPLATES = {
    'Line (기본)': {
      type: 'line',
      data: { labels: ['A','B','C','D','E'], datasets: [{ label: '시리즈1', data: [10,20,15,30,25], borderColor: '#3b82f6', backgroundColor: 'transparent', borderWidth: 2, tension: 0.3, pointRadius: 4 }] },
      options: { scales: { y: { beginAtZero: true } } }
    },
    'Bar (비교)': {
      type: 'bar',
      data: { labels: ['PostgreSQL','MySQL'], datasets: [{ label: '실행 시간 (ms)', data: [0.07, 148], backgroundColor: ['#3b82f6','#ef4444'], borderRadius: 6 }] },
      options: { plugins: { legend: { display: false } } }
    },
    'Line (Log Scale)': {
      type: 'line',
      data: { labels: ['n=1','n=3','n=5','n=10','n=20','n=50'], datasets: [
        { label: 'UNION ALL', data: [0.002, 0.006, 0.013, 0.028, 0.055, 0.158], borderColor: '#f97316', backgroundColor: 'transparent', borderWidth: 2, tension: 0.3 },
        { label: 'OR', data: [0.002, 40.35, 44.55, 56.15, 80.5, 147.0], borderColor: '#22c55e', backgroundColor: 'transparent', borderWidth: 2, tension: 0.3 }
      ] },
      options: { scales: { y: { type: 'logarithmic', title: { display: true, text: 'ms (log)' } } } }
    },
    'Horizontal Bar': {
      type: 'bar',
      data: { labels: ['MySQL 5.7','MySQL 8.0','MySQL 8.4'], datasets: [{ label: 'ms', data: [619, 52, 56], backgroundColor: ['#fca5a5','#fb923c','#f59e0b'], borderRadius: 6 }] },
      options: { indexAxis: 'y', plugins: { legend: { display: false } } }
    },
    'Pie': {
      type: 'pie',
      data: { labels: ['Index Scan','Full Scan'], datasets: [{ data: [3, 97], backgroundColor: ['#3b82f6','#ef4444'] }] },
      options: {}
    }
  };

  let chartInstance = null;

  // Render templates buttons
  const tplContainer = document.getElementById('templates');
  Object.keys(TEMPLATES).forEach(name => {
    const btn = document.createElement('button');
    btn.className = 'btn-secondary';
    btn.textContent = name;
    btn.onclick = () => loadTemplate(name);
    tplContainer.appendChild(btn);
  });

  function loadTemplate(name) {
    const t = TEMPLATES[name];
    document.getElementById('chart-type').value = t.type;
    document.getElementById('data-input').value = JSON.stringify(t.data, null, 2);
    document.getElementById('options-input').value = JSON.stringify(t.options, null, 2);
    renderChart();
  }

  function renderChart() {
    const type = document.getElementById('chart-type').value;
    const dataStr = document.getElementById('data-input').value;
    const optStr = document.getElementById('options-input').value || '{}';

    document.getElementById('data-error').textContent = '';
    document.getElementById('options-error').textContent = '';

    let data, options;
    try { data = JSON.parse(dataStr); }
    catch(e) { document.getElementById('data-error').textContent = 'JSON 파싱 에러: ' + e.message; return; }
    try { options = JSON.parse(optStr); }
    catch(e) { document.getElementById('options-error').textContent = 'JSON 파싱 에러: ' + e.message; return; }

    if (chartInstance) chartInstance.destroy();

    const merged = {
      responsive: true,
      maintainAspectRatio: false,
      ...options
    };

    chartInstance = new Chart(document.getElementById('chart-canvas'), {
      type, data, options: merged
    });

    generateSnippet(type, data, options);
  }

  function generateSnippet(type, data, options) {
    const title = document.getElementById('chart-title').value;
    const caption = document.getElementById('chart-caption').value;
    const height = document.getElementById('chart-height').value || '280px';

    const dataStr = JSON.stringify(data);
    const optStr = Object.keys(options).length ? `\n  options={${JSON.stringify(options)}}` : '';
    const titleStr = title ? `\n  title="${title}"` : '';
    const captionStr = caption ? `\n  caption="${caption}"` : '';
    const heightStr = height !== '280px' ? `\n  height="${height}"` : '';

    const snippet = `<ChartJs
  client:visible
  type="${type}"${titleStr}${captionStr}${heightStr}
  data={${dataStr}}${optStr}
/>`;

    document.getElementById('snippet-output').textContent = snippet;
  }

  // exported to global for onclick handler
  // eslint-disable-next-line @typescript-eslint/no-unused-vars
  function copySnippet() {
    const text = document.getElementById('snippet-output').textContent;
    navigator.clipboard.writeText(text).then(() => {
      const btn = event.target;
      const orig = btn.textContent;
      btn.textContent = '✓ 복사됨!';
      setTimeout(() => btn.textContent = orig, 1500);
    });
  }

  // Load first template on init
  loadTemplate('Line (기본)');
</script>

<style>
  .chart-editor-shell {
    height: calc(100vh - var(--navbar-height, 56px));
    overflow: hidden;
  }

  .chart-editor-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    height: 100%;
  }

  .panel {
    padding: 1.5rem;
    overflow-y: auto;
  }

  .panel-left {
    border-right: 1px solid var(--color-border, #e2e8f0);
    background: var(--color-surface, #f8fafc);
  }

  .panel-right {
    display: flex;
    flex-direction: column;
  }

  h1 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  h2 {
    font-size: 0.9rem;
    font-weight: 600;
    margin: 1rem 0 0.5rem;
  }

  label {
    display: block;
    font-size: 0.78rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  select,
  input {
    width: 100%;
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 6px;
    background: var(--color-bg, #fff);
    color: var(--color-fg, #1e293b);
    font-size: 0.82rem;
    margin-bottom: 0.75rem;
  }

  textarea {
    width: 100%;
    min-height: 200px;
    padding: 0.6rem;
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 6px;
    background: var(--color-bg, #fff);
    color: var(--color-fg, #1e293b);
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    line-height: 1.5;
    resize: vertical;
    margin-bottom: 0.75rem;
  }

  .options-textarea {
    min-height: 120px;
  }

  button {
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 6px;
    background: var(--color-accent, #2563eb);
    color: #fff;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
  }

  button:hover {
    opacity: 0.9;
  }

  .btn-group {
    display: flex;
    gap: 0.5rem;
    margin: 0.75rem 0;
    flex-wrap: wrap;
  }

  .btn-secondary {
    background: var(--color-border, #e2e8f0);
    color: var(--color-fg, #1e293b);
  }

  .chart-container {
    flex: 1;
    position: relative;
    min-height: 300px;
    padding: 1rem;
  }

  .output-section {
    border-top: 1px solid var(--color-border, #e2e8f0);
    padding: 1rem;
  }

  .output-section pre {
    font-size: 0.72rem;
    background: var(--color-surface, #f8fafc);
    padding: 0.6rem;
    border-radius: 6px;
    overflow-x: auto;
    max-height: 200px;
    overflow-y: auto;
    white-space: pre-wrap;
    word-break: break-all;
  }

  .snippet-code {
    font-size: 0.72rem;
    background: #1e293b;
    color: #e2e8f0;
    padding: 0.8rem;
    border-radius: 8px;
    overflow-x: auto;
    white-space: pre;
    line-height: 1.4;
  }

  .error {
    color: #dc2626;
    font-size: 0.78rem;
    margin: 0.5rem 0;
  }

  .templates {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .templates button {
    padding: 0.3rem 0.6rem;
    font-size: 0.72rem;
  }

  .chart-editor-desc {
    font-size: 0.78rem;
    opacity: 0.7;
    margin-bottom: 1rem;
  }
</style>
