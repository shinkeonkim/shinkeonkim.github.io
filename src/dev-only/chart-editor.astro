---
import BaseLayout from '../layouts/BaseLayout.astro';

const TEMPLATES = {
  'Line (기본)': {
    type: 'line',
    data: {
      labels: ['A', 'B', 'C', 'D', 'E'],
      datasets: [
        {
          label: '시리즈1',
          data: [10, 20, 15, 30, 25],
          borderColor: '#3b82f6',
          backgroundColor: 'transparent',
          borderWidth: 2,
          tension: 0.3,
          pointRadius: 4,
        },
      ],
    },
    options: { scales: { y: { beginAtZero: true } } },
  },
  'Bar (비교)': {
    type: 'bar',
    data: {
      labels: ['PostgreSQL', 'MySQL'],
      datasets: [
        {
          label: '실행 시간 (ms)',
          data: [0.07, 148],
          backgroundColor: ['#3b82f6', '#ef4444'],
          borderRadius: 6,
        },
      ],
    },
    options: { plugins: { legend: { display: false } } },
  },
  'Line (Log Scale)': {
    type: 'line',
    data: {
      labels: ['n=1', 'n=3', 'n=5', 'n=10', 'n=20', 'n=50'],
      datasets: [
        {
          label: 'UNION ALL',
          data: [0.002, 0.006, 0.013, 0.028, 0.055, 0.158],
          borderColor: '#f97316',
          backgroundColor: 'transparent',
          borderWidth: 2,
          tension: 0.3,
        },
        {
          label: 'OR',
          data: [0.002, 40.35, 44.55, 56.15, 80.5, 147.0],
          borderColor: '#22c55e',
          backgroundColor: 'transparent',
          borderWidth: 2,
          tension: 0.3,
        },
      ],
    },
    options: {
      scales: { y: { type: 'logarithmic', title: { display: true, text: 'ms (log)' } } },
    },
  },
  'Horizontal Bar': {
    type: 'bar',
    data: {
      labels: ['MySQL 5.7', 'MySQL 8.0', 'MySQL 8.4'],
      datasets: [
        {
          label: 'ms',
          data: [619, 52, 56],
          backgroundColor: ['#fca5a5', '#fb923c', '#f59e0b'],
          borderRadius: 6,
        },
      ],
    },
    options: { indexAxis: 'y', plugins: { legend: { display: false } } },
  },
  Pie: {
    type: 'pie',
    data: {
      labels: ['Index Scan', 'Full Scan'],
      datasets: [{ data: [3, 97], backgroundColor: ['#3b82f6', '#ef4444'] }],
    },
    options: {},
  },
};

const templateNames = Object.keys(TEMPLATES);
---

<BaseLayout title="Chart.js Editor (dev)" description="차트 편집기" noIndex>
  <section class="chart-editor-shell" data-pagefind-ignore="all">
    <div class="chart-editor-layout">
      <div class="panel panel-left">
        <h1>📊 Chart.js Editor</h1>
        <p class="chart-editor-desc">
          왼쪽 필드를 수정하면 오른쪽 미리보기에 자동 반영됩니다. 완성한 차트는 <strong>📋 MDX 복사</strong>로
          가져갈 수 있습니다.
        </p>

        <h2>템플릿</h2>
        <div class="templates">
          {
            templateNames.map((name) => (
              <button class="btn-secondary tpl-btn" data-template={name} type="button">
                {name}
              </button>
            ))
          }
        </div>

        <h2>차트 타입</h2>
        <select id="chart-type">
          <option value="bar">Bar</option>
          <option value="line" selected>Line</option>
          <option value="pie">Pie</option>
          <option value="doughnut">Doughnut</option>
          <option value="radar">Radar</option>
          <option value="scatter">Scatter</option>
        </select>

        <h2>제목 / 캡션</h2>
        <label for="chart-title">title</label>
        <input id="chart-title" placeholder="차트 위에 표시할 제목" />
        <label for="chart-caption">caption</label>
        <input id="chart-caption" placeholder="차트 아래 설명 (선택)" />
        <label for="chart-height">height</label>
        <input id="chart-height" value="280px" placeholder="280px" />

        <h2>data (JSON)</h2>
        <textarea id="data-input" placeholder='{"labels":["A","B"],"datasets":[...]}'></textarea>
        <div class="error" id="data-error"></div>

        <h2>options (JSON, 선택)</h2>
        <textarea id="options-input" class="options-textarea" placeholder="{}"></textarea>
        <div class="error" id="options-error"></div>

        <div class="btn-group">
          <button id="btn-copy" class="btn-secondary" type="button">📋 MDX 복사</button>
        </div>
      </div>

      <div class="panel panel-right">
        <div class="preview-section">
          <div class="chart-preview-card" id="chart-preview-card">
            <div class="chart-preview-title" id="chart-preview-title" hidden></div>
            <div class="chart-canvas-container">
              <canvas id="chart-canvas"></canvas>
            </div>
            <div class="chart-preview-caption" id="chart-preview-caption" hidden></div>
          </div>
        </div>
        <div class="output-section">
          <h2>MDX 코드</h2>
          <div class="snippet-code" id="snippet-output">템플릿을 선택하거나 data 를 입력하면 코드가 표시됩니다.</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.8/dist/chart.umd.min.js"></script>
<script
  is:inline
  define:vars={{ TEMPLATES }}
>
  let chartInstance = null;
  let renderTimer = null;

  const $ = (id) => document.getElementById(id);
  const typeSel = $('chart-type');
  const titleInput = $('chart-title');
  const captionInput = $('chart-caption');
  const heightInput = $('chart-height');
  const dataInput = $('data-input');
  const optionsInput = $('options-input');
  const dataError = $('data-error');
  const optionsError = $('options-error');
  const canvas = $('chart-canvas');
  const canvasContainer = canvas.parentElement;
  const previewTitle = $('chart-preview-title');
  const previewCaption = $('chart-preview-caption');
  const snippetOutput = $('snippet-output');

  function readThemeColors() {
    const isDark = document.documentElement.classList.contains('dark');
    return {
      text: isDark ? '#e2e8f0' : '#1e293b',
      grid: isDark ? '#334155' : '#f1f5f9',
    };
  }

  const RADIAL = new Set(['pie', 'doughnut', 'radar', 'polarArea']);

  function buildOptions(type, userOptions, colors) {
    const user = userOptions || {};
    const userPlugins = user.plugins || {};
    const userLegend = userPlugins.legend || {};
    const userLegendLabels = userLegend.labels || {};
    const userTooltip = userPlugins.tooltip || {};
    const merged = {
      responsive: true,
      maintainAspectRatio: false,
      ...user,
      plugins: {
        ...userPlugins,
        legend: {
          position: 'bottom',
          ...userLegend,
          labels: {
            usePointStyle: true,
            font: { size: 11 },
            ...userLegendLabels,
            color: colors.text,
          },
        },
        tooltip: { enabled: true, ...userTooltip },
      },
    };
    if (!RADIAL.has(type)) {
      const userScales = user.scales || {};
      const userX = userScales.x || {};
      const userY = userScales.y || {};
      merged.scales = {
        ...userScales,
        x: {
          ...userX,
          grid: { ...(userX.grid || {}), color: colors.grid },
          ticks: { ...(userX.ticks || {}), color: colors.text },
        },
        y: {
          ...userY,
          grid: { ...(userY.grid || {}), color: colors.grid },
          ticks: { ...(userY.ticks || {}), color: colors.text },
        },
      };
    }
    return merged;
  }

  function loadTemplate(name) {
    const t = TEMPLATES[name];
    if (!t) return;
    typeSel.value = t.type;
    dataInput.value = JSON.stringify(t.data, null, 2);
    optionsInput.value = JSON.stringify(t.options, null, 2);
    renderChart();
  }

  function applyHeight() {
    const h = (heightInput.value || '280px').trim();
    canvasContainer.style.height = h;
  }

  function applyTitleCaption() {
    const t = titleInput.value.trim();
    const c = captionInput.value.trim();
    if (t) {
      previewTitle.textContent = t;
      previewTitle.hidden = false;
    } else {
      previewTitle.textContent = '';
      previewTitle.hidden = true;
    }
    if (c) {
      previewCaption.textContent = c;
      previewCaption.hidden = false;
    } else {
      previewCaption.textContent = '';
      previewCaption.hidden = true;
    }
  }

  function renderChart() {
    applyHeight();
    applyTitleCaption();

    const type = typeSel.value;
    const dataStr = dataInput.value;
    const optStr = optionsInput.value || '{}';

    dataError.textContent = '';
    optionsError.textContent = '';

    let data, options;
    try {
      data = JSON.parse(dataStr);
    } catch (e) {
      dataError.textContent = 'JSON 파싱 에러: ' + e.message;
      return;
    }
    try {
      options = JSON.parse(optStr);
    } catch (e) {
      optionsError.textContent = 'JSON 파싱 에러: ' + e.message;
      return;
    }

    const colors = readThemeColors();
    const merged = buildOptions(type, options, colors);

    if (chartInstance && chartInstance.config.type === type) {
      chartInstance.data = data;
      chartInstance.options = merged;
      chartInstance.update();
    } else {
      if (chartInstance) chartInstance.destroy();
      chartInstance = new window.Chart(canvas, { type, data, options: merged });
    }

    generateSnippet(type, data, options);
  }

  function scheduleRender() {
    if (renderTimer) clearTimeout(renderTimer);
    renderTimer = setTimeout(renderChart, 200);
  }

  function generateSnippet(type, data, options) {
    const title = titleInput.value.trim();
    const caption = captionInput.value.trim();
    const height = (heightInput.value || '280px').trim();
    const dataStr = JSON.stringify(data);
    const optStr = options && Object.keys(options).length ? `\n  options={${JSON.stringify(options)}}` : '';
    const titleStr = title ? `\n  title=${JSON.stringify(title)}` : '';
    const captionStr = caption ? `\n  caption=${JSON.stringify(caption)}` : '';
    const heightStr = height && height !== '280px' ? `\n  height="${height}"` : '';
    snippetOutput.textContent = `<ChartJs
  client:visible
  type="${type}"${titleStr}${captionStr}${heightStr}
  data={${dataStr}}${optStr}
/>`;
  }

  function copySnippet(btn) {
    const text = snippetOutput.textContent;
    navigator.clipboard.writeText(text).then(() => {
      const orig = btn.textContent;
      btn.textContent = '✓ 복사됨!';
      setTimeout(() => {
        btn.textContent = orig;
      }, 1500);
    });
  }

  document.querySelectorAll('.tpl-btn').forEach((btn) => {
    btn.addEventListener('click', () => loadTemplate(btn.dataset.template));
  });
  typeSel.addEventListener('change', renderChart);
  [titleInput, captionInput, heightInput, dataInput, optionsInput].forEach((el) => {
    el.addEventListener('input', scheduleRender);
  });
  $('btn-copy').addEventListener('click', (e) => copySnippet(e.currentTarget));

  const themeObserver = new MutationObserver(() => {
    if (chartInstance) renderChart();
  });
  themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

  loadTemplate('Line (기본)');
</script>

<style is:global>
  .chart-editor-shell {
    height: calc(100vh - var(--navbar-height, 56px));
    overflow: hidden;
  }

  .chart-editor-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    height: 100%;
  }

  .chart-editor-shell .panel {
    padding: 1.5rem;
    overflow-y: auto;
  }

  .chart-editor-shell .panel-left {
    border-right: 1px solid var(--color-border);
    background: var(--color-surface-elevated);
    color: var(--color-fg);
  }

  .chart-editor-shell .panel-right {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    color: var(--color-fg);
  }

  .chart-editor-shell h1 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-fg);
  }

  .chart-editor-shell h2 {
    font-size: 0.9rem;
    font-weight: 600;
    margin: 1rem 0 0.5rem;
    color: var(--color-fg);
  }

  .chart-editor-shell label {
    display: block;
    font-size: 0.78rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
    color: var(--color-fg-muted);
  }

  .chart-editor-shell select,
  .chart-editor-shell input,
  .chart-editor-shell textarea {
    width: 100%;
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-surface);
    color: var(--color-fg);
    font-size: 0.82rem;
    margin-bottom: 0.75rem;
  }

  .chart-editor-shell textarea {
    min-height: 200px;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    line-height: 1.5;
    resize: vertical;
  }

  .chart-editor-shell .options-textarea {
    min-height: 120px;
  }

  .chart-editor-shell button {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s ease;
  }

  .chart-editor-shell button:hover {
    opacity: 0.88;
  }

  .chart-editor-shell .btn-secondary {
    background: var(--color-surface);
    color: var(--color-fg);
    border: 1px solid var(--color-border);
  }

  .chart-editor-shell .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    opacity: 1;
  }

  .chart-editor-shell .btn-group {
    display: flex;
    gap: 0.5rem;
    margin: 0.75rem 0;
    flex-wrap: wrap;
  }

  .chart-editor-shell .templates {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .chart-editor-shell .templates button {
    padding: 0.3rem 0.6rem;
    font-size: 0.72rem;
  }

  .chart-editor-shell .chart-editor-desc {
    font-size: 0.78rem;
    color: var(--color-fg-muted);
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .chart-editor-shell .preview-section {
    padding: 1.5rem;
    overflow-y: auto;
    min-height: 0;
  }

  .chart-editor-shell .chart-preview-card {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-surface-elevated);
    padding: 1rem;
  }

  .chart-editor-shell .chart-preview-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-fg);
    margin-bottom: 0.25rem;
  }

  .chart-editor-shell .chart-canvas-container {
    position: relative;
    width: 100%;
    height: 280px;
  }

  .chart-editor-shell .chart-preview-caption {
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.75rem;
    font-style: italic;
    color: var(--color-fg-muted);
  }

  .chart-editor-shell .output-section {
    margin-top: auto;
    border-top: 1px solid var(--color-border);
    padding: 1rem 1.5rem 1.5rem;
    background: var(--color-surface);
  }

  .chart-editor-shell .snippet-code {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.72rem;
    background: #1e293b;
    color: #e2e8f0;
    padding: 0.8rem;
    border: 1px solid #334155;
    border-radius: 8px;
    overflow-x: auto;
    white-space: pre;
    line-height: 1.4;
    margin: 0;
  }

  .chart-editor-shell .error {
    color: #dc2626;
    font-size: 0.78rem;
    margin: 0.5rem 0;
    min-height: 1.1em;
  }

  :root.dark .chart-editor-shell .error {
    color: #f87171;
  }
</style>
