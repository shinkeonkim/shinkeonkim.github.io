---
import BaseLayout from '../layouts/BaseLayout.astro';
import './editor.css';

const isDev = import.meta.env.DEV;
---

<BaseLayout title="콘텐츠 에디터 (dev)" description="개발 환경 전용 마크다운 에디터" noIndex>
  <section class="editor-shell w-full px-3" data-pagefind-ignore="all">
    {
      !isDev ? (
        <div class="rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-6 text-sm">
          <h1 class="mb-2 text-xl font-semibold">에디터는 dev 모드에서만 사용할 수 있습니다.</h1>
          <p class="text-[color:var(--color-fg-muted)]">
            로컬에서 <code>bun dev</code> 로 실행한 뒤 이 페이지를 다시 여세요.
          </p>
        </div>
      ) : (
        <div id="editor-app" class="editor-app">
          <header class="editor-toolbar">
            <h1 class="editor-title">
              콘텐츠 에디터 <span class="editor-tag">dev</span>
            </h1>
            <div class="editor-actions">
              <span
                id="editor-autosave-indicator"
                class="editor-autosave-indicator"
                aria-live="polite"
              />
              <span id="editor-status" class="editor-status" aria-live="polite">
                대기 중
              </span>
              <button
                type="button"
                id="editor-ext-toggle"
                class="editor-btn"
                style="display:none"
                title="확장자 변환"
              >
                .md → .mdx
              </button>
              <button
                type="button"
                id="editor-git-toggle"
                class="editor-btn"
                title="Git 패널 열기/닫기"
              >
                🌿 Git
              </button>
              <button type="button" id="editor-save" class="editor-btn editor-btn-primary" disabled>
                저장 (⌘S)
              </button>
              <button
                type="button"
                id="editor-preview-link"
                class="editor-btn"
                style="display:none"
              >
                미리보기 →
              </button>
            </div>
          </header>

          <div class="editor-layout">
            <aside class="editor-sidebar" aria-label="파일 목록">
              <div class="editor-sidebar-header">
                <strong>탐색기</strong>
              </div>
              <div class="editor-tree-filter">
                <input
                  type="search"
                  id="editor-tree-search"
                  class="editor-tree-filter-input"
                  placeholder="파일 찾기 (ESC 로 초기화)"
                  autocomplete="off"
                  aria-label="파일 트리 검색"
                />
              </div>
              <div id="editor-tree-root" class="editor-tree" />
            </aside>

            <main class="editor-main">
              <div class="editor-pane">
                <div class="editor-pane-header">
                  <span id="editor-current-path">파일을 선택하거나 "새 파일" 을 누르세요</span>
                  <label class="editor-preview-toggle">
                    <input type="checkbox" id="editor-preview-toggle" />
                    <span>미리보기 분할</span>
                  </label>
                </div>
                <div class="editor-md-toolbar" role="toolbar" aria-label="마크다운 툴바">
                  <div class="editor-md-group">
                    <button type="button" data-md="bold" title="굵게 (⌘B)" aria-label="굵게">
                      <strong>B</strong>
                    </button>
                    <button type="button" data-md="italic" title="기울임 (⌘I)" aria-label="기울임">
                      <em>I</em>
                    </button>
                    <button type="button" data-md="strike" title="취소선" aria-label="취소선">
                      <s>S</s>
                    </button>
                    <button
                      type="button"
                      data-md="code"
                      title="인라인 코드"
                      aria-label="인라인 코드"
                    >
                      <code>&lt;/&gt;</code>
                    </button>
                  </div>
                  <div class="editor-md-group">
                    <button type="button" data-md="link" title="링크 (⌘K)" aria-label="링크">
                      🔗
                    </button>
                    <button
                      type="button"
                      data-md="image"
                      title="이미지 업로드/삽입"
                      aria-label="이미지"
                    >
                      🖼️
                    </button>
                    <button
                      type="button"
                      data-md="url-preview"
                      title="URL 미리보기 카드 삽입"
                      aria-label="URL 미리보기"
                    >
                      🔖
                    </button>
                    <button
                      type="button"
                      data-md="url-preview-toggle"
                      title="커서 위의 URL ↔ 미리보기 카드 토글"
                      aria-label="URL 토글"
                    >
                      ↔
                    </button>
                  </div>
                  <div class="editor-md-group">
                    <button type="button" data-md="h1" title="제목 1" aria-label="H1">
                      H1
                    </button>
                    <button type="button" data-md="h2" title="제목 2" aria-label="H2">
                      H2
                    </button>
                    <button type="button" data-md="h3" title="제목 3" aria-label="H3">
                      H3
                    </button>
                  </div>
                  <div class="editor-md-group">
                    <button type="button" data-md="ul" title="목록" aria-label="목록">
                      •
                    </button>
                    <button type="button" data-md="ol" title="번호 목록" aria-label="번호 목록">
                      1.
                    </button>
                    <button type="button" data-md="task" title="할 일" aria-label="할 일">
                      ☐
                    </button>
                    <button type="button" data-md="quote" title="인용" aria-label="인용">
                      ❝
                    </button>
                  </div>
                  <div class="editor-md-group">
                    <button
                      type="button"
                      data-md="codeblock"
                      title="코드 블록"
                      aria-label="코드 블록"
                    >
                      {}
                    </button>
                    <button type="button" data-md="table" title="표" aria-label="표">
                      ⊞
                    </button>
                    <button type="button" data-md="hr" title="구분선" aria-label="구분선">
                      —
                    </button>
                  </div>
                  <div class="editor-md-group">
                    <div class="editor-md-dropdown">
                      <button
                        type="button"
                        data-md-menu="callout"
                        aria-haspopup="true"
                        aria-expanded="false"
                      >
                        콜아웃 ▾
                      </button>
                      <div class="editor-md-menu" data-menu="callout" hidden>
                        <button type="button" data-md="callout-note">
                          Note (정보)
                        </button>
                        <button type="button" data-md="callout-tip">
                          Tip (팁)
                        </button>
                        <button type="button" data-md="callout-important">
                          Important (중요)
                        </button>
                        <button type="button" data-md="callout-warning">
                          Warning (경고)
                        </button>
                        <button type="button" data-md="callout-caution">
                          Caution (주의)
                        </button>
                      </div>
                    </div>
                    <div class="editor-md-dropdown">
                      <button
                        type="button"
                        data-md-menu="cwo"
                        aria-haspopup="true"
                        aria-expanded="false"
                      >
                        CodeWithOutput ▾
                      </button>
                      <div class="editor-md-menu" data-menu="cwo" hidden>
                        <button type="button" data-md="cwo-single">
                          단일 언어
                        </button>
                        <button type="button" data-md="cwo-multi">
                          멀티 언어 (variants)
                        </button>
                      </div>
                    </div>
                    <div class="editor-md-dropdown">
                      <button
                        type="button"
                        data-md-menu="mermaid"
                        aria-haspopup="true"
                        aria-expanded="false"
                      >
                        Mermaid ▾
                      </button>
                      <div class="editor-md-menu" data-menu="mermaid" hidden>
                        <button type="button" data-md="mermaid-flowchart">
                          Flowchart
                        </button>
                        <button type="button" data-md="mermaid-sequence">
                          Sequence
                        </button>
                        <button type="button" data-md="mermaid-state">
                          State
                        </button>
                        <button type="button" data-md="mermaid-class">
                          Class
                        </button>
                        <button type="button" data-md="mermaid-er">
                          ER Diagram
                        </button>
                      </div>
                    </div>
                    <div class="editor-md-dropdown">
                      <button
                        type="button"
                        data-md-menu="fm"
                        aria-haspopup="true"
                        aria-expanded="false"
                      >
                        Frontmatter ▾
                      </button>
                      <div class="editor-md-menu" data-menu="fm" hidden>
                        <button type="button" data-md="fm-cover">
                          🖼️ 커버 이미지 설정
                        </button>
                        <button type="button" data-md="fm-thumbnail">
                          🃏 썸네일 이미지 설정
                        </button>
                        <button type="button" data-md="fm-series">
                          📚 시리즈 설정
                        </button>
                        <button type="button" data-md="fm-category">
                          📁 카테고리 설정
                        </button>
                        <button type="button" data-md="fm-tags">
                          🏷️ 태그 추가
                        </button>
                        <button type="button" data-md="fm-references">
                          📚 출처 관리…
                        </button>
                      </div>
                    </div>
                    <button
                      type="button"
                      data-md="wikilink"
                      title="위키링크 (자동완성: [[ 입력)"
                      aria-label="위키링크"
                    >
                      [[…]]
                    </button>
                  </div>
                </div>
                <div class="editor-split" id="editor-split">
                  <textarea
                    id="editor-textarea"
                    class="editor-textarea"
                    spellcheck="false"
                    placeholder="여기에 마크다운을 작성하세요. ⌘S 로 저장됩니다. [[ 입력으로 위키링크 자동완성, 이미지는 드래그/붙여넣기."
                  />
                  <div id="editor-preview" class="editor-preview" hidden>
                    <article class="prose-content" id="editor-preview-content" />
                  </div>
                </div>
                <dialog id="editor-image-dialog" class="editor-image-dialog">
                  <form method="dialog" class="editor-image-form">
                    <h3 class="editor-image-title" id="editor-image-title">
                      이미지 삽입 옵션
                    </h3>
                    <fieldset class="editor-image-row" data-image-section="purpose">
                      <legend>용도</legend>
                      <label>
                        <input type="radio" name="img-purpose" value="body" checked /> 본문에 삽입
                      </label>
                      <label>
                        <input type="radio" name="img-purpose" value="cover" /> 커버 이미지
                        (frontmatter)
                      </label>
                      <label>
                        <input type="radio" name="img-purpose" value="thumbnail" /> 썸네일
                        (frontmatter)
                      </label>
                    </fieldset>
                    <fieldset class="editor-image-row" data-image-section="source">
                      <legend>이미지 소스</legend>
                      <label>
                        <input type="radio" name="img-source" value="upload" checked /> 파일 업로드
                        / 클립보드
                      </label>
                      <label>
                        <input type="radio" name="img-source" value="url-fetch" /> 외부 URL
                        (다운로드해서 저장)
                      </label>
                      <label>
                        <input type="radio" name="img-source" value="url-direct" /> 외부 URL (그대로
                        사용)
                      </label>
                    </fieldset>
                    <div class="editor-image-row" data-image-source-upload>
                      <button type="button" class="editor-btn" data-image-pick>
                        📁 파일 선택…
                      </button>
                      <span class="editor-image-source-status" id="editor-image-source-status" />
                    </div>
                    <div class="editor-image-row" data-image-source-url hidden>
                      <label>
                        <span>외부 URL</span>
                        <input
                          type="url"
                          id="editor-image-url"
                          placeholder="https://example.com/image.png"
                          style="width:100%"
                        />
                      </label>
                      <button type="button" class="editor-btn" data-image-url-fetch>
                        🌐 가져오기
                      </button>
                    </div>
                    <div class="editor-image-preview">
                      <img id="editor-image-preview-img" alt="" />
                    </div>
                    <label class="editor-image-row">
                      <span>대체 텍스트 (alt)</span>
                      <input type="text" id="editor-image-alt" placeholder="이미지 설명" />
                    </label>
                    <fieldset class="editor-image-row" data-image-section="body-only">
                      <legend>너비 (본문 삽입 시)</legend>
                      <label>
                        <input type="radio" name="img-width" value="" checked /> 원본
                      </label>
                      <label>
                        <input type="radio" name="img-width" value="img-quarter" /> 작게 (25%)
                      </label>
                      <label>
                        <input type="radio" name="img-width" value="img-half" /> 절반 (50%)
                      </label>
                      <label>
                        <input type="radio" name="img-width" value="img-three-quarter" /> 크게 (75%)
                      </label>
                      <label>
                        <input type="radio" name="img-width" value="img-full" /> 가득 (100%)
                      </label>
                      <label>
                        <input type="radio" name="img-width" value="custom" /> 직접:
                        <input
                          type="text"
                          id="editor-image-width-custom"
                          placeholder="예: 40%, 320px"
                          style="width: 9rem; margin-left: 0.3rem"
                        />
                      </label>
                    </fieldset>
                    <fieldset class="editor-image-row" data-image-section="body-only">
                      <legend>정렬 (본문 삽입 시)</legend>
                      <label>
                        <input type="radio" name="img-align" value="" checked /> 기본 (인라인)
                      </label>
                      <label>
                        <input type="radio" name="img-align" value="img-left" /> 왼쪽
                      </label>
                      <label>
                        <input type="radio" name="img-align" value="img-center" /> 가운데
                      </label>
                      <label>
                        <input type="radio" name="img-align" value="img-right" /> 오른쪽
                      </label>
                    </fieldset>
                    <div class="editor-image-actions">
                      <button type="button" value="cancel" data-image-cancel>
                        취소
                      </button>
                      <button
                        type="submit"
                        value="insert"
                        class="editor-btn-primary"
                        data-image-confirm
                      >
                        삽입
                      </button>
                    </div>
                  </form>
                </dialog>
                <input
                  type="file"
                  id="editor-image-input"
                  accept="image/*,application/pdf"
                  hidden
                />
              </div>
              <aside id="editor-git-panel" class="editor-git-panel" hidden />
            </main>
          </div>
        </div>
      )
    }
  </section>
</BaseLayout>

{isDev && <script>import {initEditor} from './editor/main'; initEditor();</script>}

