---
import BaseLayout from '../layouts/BaseLayout.astro';

const isDev = import.meta.env.DEV;
---
<BaseLayout title="콘텐츠 에디터 (dev)" description="개발 환경 전용 마크다운 에디터" noIndex>
  <section class="mx-auto max-w-7xl px-4" data-pagefind-ignore="all">
    {!isDev ? (
      <div class="rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-6 text-sm">
        <h1 class="mb-2 text-xl font-semibold">에디터는 dev 모드에서만 사용할 수 있습니다.</h1>
        <p class="text-[color:var(--color-fg-muted)]">로컬에서 <code>bun dev</code> 로 실행한 뒤 이 페이지를 다시 여세요.</p>
      </div>
    ) : (
      <div id="editor-app" class="editor-app">
        <header class="editor-toolbar">
          <h1 class="editor-title">콘텐츠 에디터 <span class="editor-tag">dev</span></h1>
          <div class="editor-actions">
            <span id="editor-status" class="editor-status" aria-live="polite">대기 중</span>
            <button type="button" id="editor-new" class="editor-btn">새 파일</button>
            <button type="button" id="editor-save" class="editor-btn editor-btn-primary" disabled>저장 (⌘S)</button>
            <button type="button" id="editor-preview-link" class="editor-btn" style="display:none">미리보기 →</button>
          </div>
        </header>

        <div class="editor-layout">
          <aside class="editor-sidebar" aria-label="파일 목록">
            {(['posts', 'notes', 'wiki'] as const).map((c) => (
              <details open class="editor-collection">
                <summary>{c}</summary>
                <ul class="editor-file-list" data-collection={c}></ul>
              </details>
            ))}
          </aside>

          <main class="editor-main">
            <div class="editor-pane">
              <div class="editor-pane-header">
                <span id="editor-current-path">파일을 선택하거나 "새 파일" 을 누르세요</span>
                <label class="editor-preview-toggle">
                  <input type="checkbox" id="editor-preview-toggle" />
                  <span>미리보기 분할</span>
                </label>
              </div>
              <div class="editor-md-toolbar" role="toolbar" aria-label="마크다운 툴바">
                <div class="editor-md-group">
                  <button type="button" data-md="bold" title="굵게 (⌘B)" aria-label="굵게"><strong>B</strong></button>
                  <button type="button" data-md="italic" title="기울임 (⌘I)" aria-label="기울임"><em>I</em></button>
                  <button type="button" data-md="strike" title="취소선" aria-label="취소선"><s>S</s></button>
                  <button type="button" data-md="code" title="인라인 코드" aria-label="인라인 코드"><code>&lt;/&gt;</code></button>
                </div>
                <div class="editor-md-group">
                  <button type="button" data-md="link" title="링크 (⌘K)" aria-label="링크">🔗</button>
                  <button type="button" data-md="image" title="이미지 업로드/삽입" aria-label="이미지">🖼️</button>
                </div>
                <div class="editor-md-group">
                  <button type="button" data-md="h1" title="제목 1" aria-label="H1">H1</button>
                  <button type="button" data-md="h2" title="제목 2" aria-label="H2">H2</button>
                  <button type="button" data-md="h3" title="제목 3" aria-label="H3">H3</button>
                </div>
                <div class="editor-md-group">
                  <button type="button" data-md="ul" title="목록" aria-label="목록">•</button>
                  <button type="button" data-md="ol" title="번호 목록" aria-label="번호 목록">1.</button>
                  <button type="button" data-md="task" title="할 일" aria-label="할 일">☐</button>
                  <button type="button" data-md="quote" title="인용" aria-label="인용">❝</button>
                </div>
                <div class="editor-md-group">
                  <button type="button" data-md="codeblock" title="코드 블록" aria-label="코드 블록">{ }</button>
                  <button type="button" data-md="table" title="표" aria-label="표">⊞</button>
                  <button type="button" data-md="hr" title="구분선" aria-label="구분선">—</button>
                </div>
                <div class="editor-md-group">
                  <div class="editor-md-dropdown">
                    <button type="button" data-md-menu="callout" aria-haspopup="true" aria-expanded="false">콜아웃 ▾</button>
                    <div class="editor-md-menu" data-menu="callout" hidden>
                      <button type="button" data-md="callout-note">Note (정보)</button>
                      <button type="button" data-md="callout-tip">Tip (팁)</button>
                      <button type="button" data-md="callout-important">Important (중요)</button>
                      <button type="button" data-md="callout-warning">Warning (경고)</button>
                      <button type="button" data-md="callout-caution">Caution (주의)</button>
                    </div>
                  </div>
                  <div class="editor-md-dropdown">
                    <button type="button" data-md-menu="cwo" aria-haspopup="true" aria-expanded="false">CodeWithOutput ▾</button>
                    <div class="editor-md-menu" data-menu="cwo" hidden>
                      <button type="button" data-md="cwo-single">단일 언어</button>
                      <button type="button" data-md="cwo-multi">멀티 언어 (variants)</button>
                    </div>
                  </div>
                  <div class="editor-md-dropdown">
                    <button type="button" data-md-menu="mermaid" aria-haspopup="true" aria-expanded="false">Mermaid ▾</button>
                    <div class="editor-md-menu" data-menu="mermaid" hidden>
                      <button type="button" data-md="mermaid-flowchart">Flowchart</button>
                      <button type="button" data-md="mermaid-sequence">Sequence</button>
                      <button type="button" data-md="mermaid-state">State</button>
                      <button type="button" data-md="mermaid-class">Class</button>
                      <button type="button" data-md="mermaid-er">ER Diagram</button>
                    </div>
                  </div>
                  <button type="button" data-md="wikilink" title="위키링크" aria-label="위키링크">[[…]]</button>
                </div>
              </div>
              <div class="editor-split" id="editor-split">
                <textarea
                  id="editor-textarea"
                  class="editor-textarea"
                  spellcheck="false"
                  placeholder="여기에 마크다운을 작성하세요. ⌘S 로 저장됩니다. 이미지는 끌어다 놓거나 붙여넣으세요."
                ></textarea>
                <div id="editor-preview" class="editor-preview" hidden>
                  <article class="prose-content" id="editor-preview-content"></article>
                </div>
              </div>
              <dialog id="editor-image-dialog" class="editor-image-dialog">
                <form method="dialog" class="editor-image-form">
                  <h3 class="editor-image-title">이미지 삽입 옵션</h3>
                  <div class="editor-image-preview">
                    <img id="editor-image-preview-img" alt="" />
                  </div>
                  <label class="editor-image-row">
                    <span>대체 텍스트 (alt)</span>
                    <input type="text" id="editor-image-alt" placeholder="이미지 설명" />
                  </label>
                  <fieldset class="editor-image-row">
                    <legend>너비</legend>
                    <label><input type="radio" name="img-width" value="" checked /> 원본</label>
                    <label><input type="radio" name="img-width" value="img-quarter" /> 작게 (25%)</label>
                    <label><input type="radio" name="img-width" value="img-half" /> 절반 (50%)</label>
                    <label><input type="radio" name="img-width" value="img-three-quarter" /> 크게 (75%)</label>
                    <label><input type="radio" name="img-width" value="img-full" /> 가득 (100%)</label>
                  </fieldset>
                  <fieldset class="editor-image-row">
                    <legend>정렬</legend>
                    <label><input type="radio" name="img-align" value="" checked /> 기본 (인라인)</label>
                    <label><input type="radio" name="img-align" value="img-left" /> 왼쪽 (텍스트 흐름)</label>
                    <label><input type="radio" name="img-align" value="img-center" /> 가운데 (블록)</label>
                    <label><input type="radio" name="img-align" value="img-right" /> 오른쪽 (텍스트 흐름)</label>
                  </fieldset>
                  <div class="editor-image-actions">
                    <button type="button" value="cancel" data-image-cancel>취소</button>
                    <button type="submit" value="insert" class="editor-btn-primary" data-image-confirm>삽입</button>
                  </div>
                </form>
              </dialog>
              <input type="file" id="editor-image-input" accept="image/*,application/pdf" hidden />
            </div>
          </main>
        </div>
      </div>
    )}
  </section>
</BaseLayout>

<style is:global>
  .editor-app {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      height: calc(100vh - 8rem);
      min-height: 600px;
    }
    .editor-toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.75rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--color-border);
    }
    .editor-title {
      font-size: 1.25rem;
      font-weight: 600;
      margin: 0;
    }
    .editor-tag {
      display: inline-block;
      margin-left: 0.4rem;
      padding: 0.1rem 0.5rem;
      font-size: 0.7rem;
      font-weight: 600;
      border-radius: 0.375rem;
      background-color: #f59e0b;
      color: #fff;
      vertical-align: middle;
    }
    .editor-actions {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .editor-status {
      font-size: 0.8rem;
      color: var(--color-fg-muted);
      font-family: var(--font-mono);
    }
    .editor-btn {
      display: inline-flex;
      align-items: center;
      padding: 0.4rem 0.85rem;
      border: 1px solid var(--color-border);
      border-radius: 0.375rem;
      background-color: var(--color-surface);
      color: var(--color-fg);
      font-size: 0.85rem;
      cursor: pointer;
      transition: border-color 120ms, color 120ms, background-color 120ms;
      text-decoration: none;
    }
    .editor-btn:hover:not([disabled]) {
      border-color: var(--color-accent);
      color: var(--color-accent);
    }
    .editor-btn[disabled] {
      opacity: 0.4;
      cursor: not-allowed;
    }
    .editor-btn-primary {
      background-color: var(--color-accent);
      color: #fff;
      border-color: var(--color-accent);
    }
    .editor-btn-primary:hover:not([disabled]) {
      background-color: var(--color-accent-hover);
      border-color: var(--color-accent-hover);
      color: #fff;
    }
    .editor-layout {
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 0.75rem;
      flex: 1;
      min-height: 0;
    }
    @media (max-width: 768px) {
      .editor-layout {
        grid-template-columns: 1fr;
        grid-template-rows: auto 1fr;
      }
    }
    .editor-sidebar {
      border: 1px solid var(--color-border);
      border-radius: 0.5rem;
      padding: 0.5rem;
      overflow-y: auto;
      background-color: var(--color-surface-elevated);
    }
    .editor-collection summary {
      cursor: pointer;
      font-family: var(--font-mono);
      font-size: 0.78rem;
      text-transform: uppercase;
      padding: 0.3rem 0.4rem;
      color: var(--color-fg-muted);
      letter-spacing: 0.04em;
    }
    .editor-file-list {
      list-style: none;
      margin: 0 0 0.5rem;
      padding: 0;
    }
    .editor-file-list li button {
      display: block;
      width: 100%;
      text-align: left;
      padding: 0.35rem 0.5rem;
      border: 0;
      border-radius: 0.25rem;
      background: transparent;
      color: var(--color-fg);
      font-size: 0.82rem;
      cursor: pointer;
      word-break: break-all;
    }
    .editor-file-list li button:hover {
      background-color: var(--color-code-bg);
    }
    .editor-file-list li button.is-active {
      background-color: var(--color-code-bg);
      color: var(--color-accent);
    }
    .editor-main {
      display: flex;
      flex-direction: column;
      min-width: 0;
    }
    .editor-pane {
      display: flex;
      flex-direction: column;
      flex: 1;
      min-height: 0;
      border: 1px solid var(--color-border);
      border-radius: 0.5rem;
      overflow: hidden;
      background-color: var(--color-code-bg);
    }
    .editor-pane-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
      padding: 0.45rem 0.75rem;
      border-bottom: 1px solid var(--color-border);
      background-color: var(--color-code-header-bg);
      font-size: 0.8rem;
      color: var(--color-code-header-fg);
      font-family: var(--font-mono);
    }
    .editor-preview-toggle {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.78rem;
      cursor: pointer;
    }
    .editor-split {
      flex: 1;
      display: grid;
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .editor-split.has-preview {
      grid-template-columns: 1fr 1fr;
    }
    @media (max-width: 768px) {
      .editor-split.has-preview {
        grid-template-columns: 1fr;
        grid-template-rows: 1fr 1fr;
      }
    }
    .editor-textarea {
      width: 100%;
      height: 100%;
      border: 0;
      outline: none;
      resize: none;
      padding: 1rem;
      font-family: var(--font-mono);
      font-size: 0.9rem;
      line-height: 1.6;
      background-color: var(--color-code-bg);
      color: var(--color-fg);
    }
  .editor-preview {
    overflow-y: auto;
    padding: 1rem 1.25rem;
    border-left: 1px solid var(--color-border);
    background-color: var(--color-surface);
  }
  @media (max-width: 768px) {
    .editor-preview {
      border-left: 0;
      border-top: 1px solid var(--color-border);
    }
  }
  .mdx-component-placeholder {
    margin: 1rem 0;
    border: 1px dashed var(--color-accent);
    border-radius: 0.5rem;
    background-color: color-mix(in srgb, var(--color-accent) 8%, transparent);
    overflow: hidden;
  }
  .mdx-component-placeholder__header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.45rem 0.75rem;
    border-bottom: 1px dashed var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
  }
  .mdx-component-placeholder__name {
    font-weight: 600;
  }
  .mdx-component-placeholder__attrs {
    color: var(--color-fg-muted);
    word-break: break-all;
  }
  .mdx-component-placeholder__body {
    padding: 0.5rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-fg-muted);
    white-space: pre-wrap;
    max-height: 12rem;
    overflow-y: auto;
  }

  .editor-md-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-code-header-bg);
  }
  .editor-md-group {
    display: flex;
    align-items: center;
    gap: 0.15rem;
    padding-right: 0.4rem;
    border-right: 1px solid var(--color-border);
  }
  .editor-md-group:last-child {
    border-right: 0;
  }
  .editor-md-toolbar button {
    background: transparent;
    border: 1px solid transparent;
    border-radius: 0.3rem;
    padding: 0.3rem 0.55rem;
    color: var(--color-fg);
    font-size: 0.8rem;
    cursor: pointer;
    line-height: 1;
    min-width: 2rem;
    height: 1.85rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .editor-md-toolbar button:hover {
    background-color: var(--color-surface-elevated);
    border-color: var(--color-border);
  }
  .editor-md-toolbar button:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }
  .editor-md-dropdown {
    position: relative;
  }
  .editor-md-menu {
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 30;
    min-width: 12rem;
    margin-top: 0.25rem;
    padding: 0.25rem;
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
    background-color: var(--color-surface);
    box-shadow: 0 8px 24px -8px rgba(0, 0, 0, 0.4);
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .editor-md-menu button {
    width: 100%;
    justify-content: flex-start;
    text-align: left;
    height: auto;
    padding: 0.4rem 0.6rem;
  }
  .editor-md-menu button:hover {
    background-color: var(--color-code-bg);
  }

  .editor-image-dialog {
    width: min(520px, 92vw);
    max-height: 90vh;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 0.6rem;
    background-color: var(--color-surface);
    color: var(--color-fg);
    overflow: hidden;
  }
  .editor-image-dialog::backdrop {
    background-color: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }
  .editor-image-form {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1rem 1.1rem;
  }
  .editor-image-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
  }
  .editor-image-preview {
    display: grid;
    place-items: center;
    padding: 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
    background-color: var(--color-surface-elevated);
    min-height: 8rem;
  }
  .editor-image-preview img {
    max-width: 100%;
    max-height: 14rem;
    object-fit: contain;
  }
  .editor-image-row {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-size: 0.85rem;
    border: 0;
    padding: 0;
    margin: 0;
  }
  .editor-image-row > span,
  .editor-image-row > legend {
    font-weight: 500;
    color: var(--color-fg-muted);
    padding: 0;
    margin-bottom: 0.25rem;
  }
  .editor-image-row label {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-right: 0.75rem;
    cursor: pointer;
  }
  .editor-image-row input[type='text'] {
    padding: 0.45rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: 0.35rem;
    background-color: var(--color-surface-elevated);
    color: var(--color-fg);
  }
  .editor-image-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
  }
  .editor-image-actions button {
    padding: 0.45rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 0.35rem;
    background-color: var(--color-surface);
    color: var(--color-fg);
    cursor: pointer;
    font-size: 0.85rem;
  }
  .editor-image-actions .editor-btn-primary {
    background-color: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }
  .editor-image-actions .editor-btn-primary:hover {
    background-color: var(--color-accent-hover);
  }
  .editor-uploading {
    pointer-events: none;
    opacity: 0.6;
  }
  .editor-drag-hover {
    box-shadow: inset 0 0 0 3px var(--color-accent);
  }
</style>

<script is:inline define:vars={{ isDev }}>
  (function () {
    if (!isDev) return;
      const statusEl = document.getElementById('editor-status');
      const textarea = document.getElementById('editor-textarea');
      const saveBtn = document.getElementById('editor-save');
      const newBtn = document.getElementById('editor-new');
      const pathEl = document.getElementById('editor-current-path');
      const previewToggle = document.getElementById('editor-preview-toggle');
      const previewEl = document.getElementById('editor-preview');
      const previewContent = document.getElementById('editor-preview-content');
      const previewLink = document.getElementById('editor-preview-link');
      const splitEl = document.getElementById('editor-split');
      if (!textarea || !saveBtn) return;

      let current = null;
      let isDirty = false;

      function setStatus(text, kind) {
        statusEl.textContent = text;
        statusEl.style.color = kind === 'error' ? '#ef4444' : kind === 'ok' ? '#10b981' : 'var(--color-fg-muted)';
      }

      function urlFor(collection, slug) {
        if (collection === 'notes') return '/notes/#' + slug;
        return '/' + collection + '/' + slug + '/';
      }

      function selectFile(collection, slug, ext) {
        current = { collection, slug, ext };
        pathEl.textContent = collection + '/' + slug + ext;
        textarea.disabled = false;
        saveBtn.disabled = false;
        previewLink.style.display = '';
        previewLink.dataset.href = urlFor(collection, slug);
        document.querySelectorAll('.editor-file-list button').forEach((b) => {
          b.classList.toggle('is-active', b.dataset.collection === collection && b.dataset.slug === slug);
        });
        textarea.focus();
        renderPreview();
      }

      async function loadFiles() {
        setStatus('파일 목록 로딩…');
        try {
          const res = await fetch('/_editor/api/files');
          const data = await res.json();
          for (const c of Object.keys(data)) {
            const list = document.querySelector(`[data-collection="${c}"]`);
            if (!list) continue;
            list.innerHTML = '';
            for (const f of data[c]) {
              const li = document.createElement('li');
              const btn = document.createElement('button');
              btn.type = 'button';
              btn.textContent = f.slug + f.ext;
              btn.dataset.collection = c;
              btn.dataset.slug = f.slug;
              btn.dataset.ext = f.ext;
              btn.addEventListener('click', () => loadFile(c, f.slug));
              li.appendChild(btn);
              list.appendChild(li);
            }
          }
          setStatus('준비됨', 'ok');
        } catch (e) {
          setStatus('파일 목록 로드 실패', 'error');
          console.error(e);
        }
      }

      async function loadFile(collection, slug) {
        setStatus('파일 로딩…');
        try {
          const res = await fetch(`/_editor/api/file?collection=${encodeURIComponent(collection)}&slug=${encodeURIComponent(slug)}`);
          if (!res.ok) {
            const err = await res.json().catch(() => ({}));
            setStatus('로드 실패: ' + (err.error || res.status), 'error');
            return;
          }
          const data = await res.json();
          textarea.value = data.content;
          isDirty = false;
          selectFile(collection, slug, data.ext);
          setStatus('로드 완료', 'ok');
          refreshPreviewAfterLoad();
        } catch (e) {
          setStatus('로드 실패', 'error');
          console.error(e);
        }
      }

      async function save() {
        if (!current) return;
        setStatus('저장 중…');
        try {
          const res = await fetch('/_editor/api/file', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              collection: current.collection,
              slug: current.slug,
              ext: current.ext,
              content: textarea.value,
            }),
          });
          const data = await res.json();
          if (!res.ok) {
            setStatus('저장 실패: ' + (data.error || res.status), 'error');
            return;
          }
          isDirty = false;
          setStatus(`저장됨 → ${data.path} (${data.bytes}B)`, 'ok');
          loadFiles();
        } catch (e) {
          setStatus('저장 실패', 'error');
          console.error(e);
        }
      }

      function todayIsoDate() {
        const d = new Date();
        return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
      }
      function todayIsoTime() {
        const d = new Date();
        const tz = -d.getTimezoneOffset();
        const sign = tz >= 0 ? '+' : '-';
        const hh = String(Math.floor(Math.abs(tz) / 60)).padStart(2, '0');
        const mm = String(Math.abs(tz) % 60).padStart(2, '0');
        return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0') + 'T' + String(d.getHours()).padStart(2, '0') + ':' + String(d.getMinutes()).padStart(2, '0') + ':00' + sign + hh + ':' + mm;
      }
      function templateFor(collection, slug) {
        if (collection === 'posts') {
          return `---\ntitle: "${slug}"\ndescription: ""\ndate: ${todayIsoDate()}\ntags: []\ndraft: true\n---\n\n`;
        }
        if (collection === 'notes') {
          return `---\ndate: ${todayIsoTime()}\ntags: []\n---\n\n`;
        }
        return `---\ntitle: "${slug}"\naliases: []\ntags: []\nupdated: ${todayIsoDate()}\n---\n\n## 개요\n\n`;
      }

      newBtn.addEventListener('click', () => {
        const collection = prompt('컬렉션 (posts / notes / wiki):', 'posts');
        if (!collection || !['posts', 'notes', 'wiki'].includes(collection)) return;
        const slug = prompt('파일 슬러그 (예: my-new-post, 또는 sub/folder/name):');
        if (!slug) return;
        const ext = collection === 'notes' ? '.md' : (confirm('MDX 컴포넌트가 필요한가요? (확인=.mdx / 취소=.md)') ? '.mdx' : '.md');
        textarea.value = templateFor(collection, slug);
        selectFile(collection, slug, ext);
        isDirty = true;
        setStatus('새 파일 (저장 안 됨)', 'ok');
      });

      saveBtn.addEventListener('click', save);

      textarea.addEventListener('input', () => {
        isDirty = true;
        schedulePreview();
      });

      function getSel() {
        return {
          start: textarea.selectionStart,
          end: textarea.selectionEnd,
          before: textarea.value.slice(0, textarea.selectionStart),
          selected: textarea.value.slice(textarea.selectionStart, textarea.selectionEnd),
          after: textarea.value.slice(textarea.selectionEnd),
        };
      }

      function setValue(newValue, selStart, selEnd) {
        textarea.value = newValue;
        if (selStart !== undefined) {
          textarea.selectionStart = selStart;
          textarea.selectionEnd = selEnd !== undefined ? selEnd : selStart;
        }
        textarea.focus();
        textarea.dispatchEvent(new Event('input', { bubbles: true }));
      }

      function wrapSel(prefix, suffix, placeholderText) {
        const s = getSel();
        const text = s.selected || (placeholderText || '');
        const newValue = s.before + prefix + text + suffix + s.after;
        const startAt = s.start + prefix.length;
        const endAt = startAt + text.length;
        setValue(newValue, startAt, endAt);
      }

      function prefixLines(prefix) {
        const s = getSel();
        const lineStart = textarea.value.lastIndexOf('\n', s.start - 1) + 1;
        let lineEnd = textarea.value.indexOf('\n', s.end);
        if (lineEnd < 0) lineEnd = textarea.value.length;
        const block = textarea.value.slice(lineStart, lineEnd);
        const transformed = block
          .split('\n')
          .map((l) => (l.startsWith(prefix) ? l : prefix + l))
          .join('\n');
        const newValue = textarea.value.slice(0, lineStart) + transformed + textarea.value.slice(lineEnd);
        setValue(newValue, lineStart + transformed.length, lineStart + transformed.length);
      }

      function insertBlock(text) {
        const s = getSel();
        const needLead = s.before && !s.before.endsWith('\n\n') ? (s.before.endsWith('\n') ? '\n' : '\n\n') : '';
        const needTrail = s.after && !s.after.startsWith('\n') ? '\n\n' : '\n';
        const block = needLead + text + needTrail;
        const newValue = s.before + block + s.after;
        const cursorAt = s.before.length + needLead.length + text.length;
        setValue(newValue, cursorAt, cursorAt);
      }

      const CWO_SINGLE = `<CodeWithOutput
  language="bash"
  label="$ bash"
  outputLanguage="text"
  outputLabel="stdout"
  title="제목"
  code={\`echo "Hello"\`}
  output={\`Hello\`}
/>`;

      const CWO_MULTI = `<CodeWithOutput
  outputLanguage="text"
  outputLabel="stdout"
  title="멀티 언어 데모"
  output={\`결과\`}
  variants={[
    { label: 'python', language: 'python', code: \`print("hi")\` },
    { label: 'typescript', language: 'ts', code: \`console.log("hi")\` },
  ]}
/>`;

      const MERMAID_TEMPLATES = {
        flowchart: '```mermaid\nflowchart LR\n  A[시작] --> B{판단}\n  B -->|예| C[처리]\n  B -->|아니오| D[종료]\n```',
        sequence: '```mermaid\nsequenceDiagram\n  participant A as 클라이언트\n  participant B as 서버\n  A->>B: 요청\n  B-->>A: 응답\n```',
        state: '```mermaid\nstateDiagram-v2\n  [*] --> Idle\n  Idle --> Running: start\n  Running --> Idle: stop\n  Running --> [*]: done\n```',
        class: '```mermaid\nclassDiagram\n  class Animal {\n    +String name\n    +eat()\n  }\n  class Dog\n  Animal <|-- Dog\n```',
        er: '```mermaid\nerDiagram\n  POST ||--o{ TAG_LINK : has\n  TAG ||--o{ TAG_LINK : tagged\n  POST {\n    string slug PK\n    string title\n  }\n```',
      };

      const MD_HANDLERS = {
        bold: () => wrapSel('**', '**', '굵게'),
        italic: () => wrapSel('*', '*', '기울임'),
        strike: () => wrapSel('~~', '~~', '취소선'),
        code: () => wrapSel('`', '`', 'code'),
        link: () => {
          const url = prompt('링크 URL:', 'https://');
          if (!url) return;
          const s = getSel();
          const text = s.selected || prompt('링크 텍스트:', '') || url;
          const newValue = s.before + '[' + text + '](' + url + ')' + s.after;
          const cursor = s.before.length + text.length + url.length + 4;
          setValue(newValue, cursor, cursor);
        },
        image: () => openImagePicker(),
        h1: () => prefixLines('# '),
        h2: () => prefixLines('## '),
        h3: () => prefixLines('### '),
        ul: () => prefixLines('- '),
        ol: () => prefixLines('1. '),
        task: () => prefixLines('- [ ] '),
        quote: () => prefixLines('> '),
        codeblock: () => {
          const lang = prompt('언어 (예: ts, python, bash, json):', '') || '';
          const s = getSel();
          const fenceOpen = '```' + lang;
          const fenceClose = '```';
          const text = s.selected || '코드';
          insertBlock(fenceOpen + '\n' + text + '\n' + fenceClose);
        },
        table: () =>
          insertBlock('| 컬럼1 | 컬럼2 | 컬럼3 |\n|---|---|---|\n| 셀1 | 셀2 | 셀3 |\n| 셀4 | 셀5 | 셀6 |'),
        hr: () => insertBlock('---'),
        'callout-note': () => insertBlock('> [!NOTE]\n> 정보 내용'),
        'callout-tip': () => insertBlock('> [!TIP]\n> 팁 내용'),
        'callout-important': () => insertBlock('> [!IMPORTANT]\n> 중요한 내용'),
        'callout-warning': () => insertBlock('> [!WARNING]\n> 경고 내용'),
        'callout-caution': () => insertBlock('> [!CAUTION]\n> 주의 내용'),
        'cwo-single': () => insertBlock(CWO_SINGLE),
        'cwo-multi': () => insertBlock(CWO_MULTI),
        'mermaid-flowchart': () => insertBlock(MERMAID_TEMPLATES.flowchart),
        'mermaid-sequence': () => insertBlock(MERMAID_TEMPLATES.sequence),
        'mermaid-state': () => insertBlock(MERMAID_TEMPLATES.state),
        'mermaid-class': () => insertBlock(MERMAID_TEMPLATES.class),
        'mermaid-er': () => insertBlock(MERMAID_TEMPLATES.er),
        wikilink: () => wrapSel('[[', ']]', '페이지명'),
      };

      document.querySelectorAll('.editor-md-toolbar [data-md]').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const key = btn.dataset.md;
          const handler = MD_HANDLERS[key];
          if (handler) handler();
          closeAllMenus();
        });
      });

      document.querySelectorAll('[data-md-menu]').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const key = btn.dataset.mdMenu;
          const menu = document.querySelector(`[data-menu="${key}"]`);
          const willOpen = menu && menu.hidden;
          closeAllMenus();
          if (willOpen) {
            menu.hidden = false;
            btn.setAttribute('aria-expanded', 'true');
          }
        });
      });

      function closeAllMenus() {
        document.querySelectorAll('.editor-md-menu').forEach((m) => {
          m.hidden = true;
        });
        document.querySelectorAll('[data-md-menu]').forEach((b) => b.setAttribute('aria-expanded', 'false'));
      }

      document.addEventListener('click', (e) => {
        if (!e.target.closest('.editor-md-dropdown')) closeAllMenus();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeAllMenus();
      });

      textarea.addEventListener('keydown', (e) => {
        if (!(e.metaKey || e.ctrlKey)) return;
        const key = e.key.toLowerCase();
        if (key === 'b') { e.preventDefault(); MD_HANDLERS.bold(); }
        else if (key === 'i') { e.preventDefault(); MD_HANDLERS.italic(); }
        else if (key === 'k') { e.preventDefault(); MD_HANDLERS.link(); }
      });

      const imageInput = document.getElementById('editor-image-input');
      const imageDialog = document.getElementById('editor-image-dialog');
      const imagePreviewImg = document.getElementById('editor-image-preview-img');
      const imageAltInput = document.getElementById('editor-image-alt');
      const imageForm = imageDialog.querySelector('.editor-image-form');

      let pendingImage = null;

      function openImagePicker() {
        imageInput.value = '';
        imageInput.click();
      }

      imageInput.addEventListener('change', async () => {
        const file = imageInput.files?.[0];
        if (file) await uploadAndOpenDialog(file);
      });

      async function uploadAndOpenDialog(file) {
        setStatus('업로드 중…');
        document.body.classList.add('editor-uploading');
        try {
          const fd = new FormData();
          fd.append('file', file);
          const res = await fetch('/_editor/api/upload', { method: 'POST', body: fd });
          const data = await res.json();
          if (!res.ok) {
            setStatus('업로드 실패: ' + (data.error || res.status), 'error');
            return;
          }
          pendingImage = { ...data, originalName: file.name };
          imagePreviewImg.src = data.path;
          imagePreviewImg.alt = file.name;
          imageAltInput.value = file.name.replace(/\.[^.]+$/, '');
          imageForm.querySelectorAll('input[name="img-width"]').forEach((r) => (r.checked = r.value === ''));
          imageForm.querySelectorAll('input[name="img-align"]').forEach((r) => (r.checked = r.value === ''));
          if (typeof imageDialog.showModal === 'function') imageDialog.showModal();
          else imageDialog.setAttribute('open', '');
          setStatus(`업로드됨 (${formatBytes(data.size)})`, 'ok');
        } catch (err) {
          setStatus('업로드 실패', 'error');
          console.error(err);
        } finally {
          document.body.classList.remove('editor-uploading');
        }
      }

      function formatBytes(n) {
        if (n < 1024) return n + ' B';
        if (n < 1024 * 1024) return (n / 1024).toFixed(1) + ' KB';
        return (n / (1024 * 1024)).toFixed(2) + ' MB';
      }

      imageDialog.addEventListener('click', (e) => {
        if (e.target.dataset.imageCancel !== undefined) {
          imageDialog.close('cancel');
        }
      });

      imageForm.addEventListener('submit', (e) => {
        e.preventDefault();
        if (!pendingImage) {
          imageDialog.close();
          return;
        }
        const alt = imageAltInput.value.trim();
        const width = imageForm.querySelector('input[name="img-width"]:checked')?.value ?? '';
        const align = imageForm.querySelector('input[name="img-align"]:checked')?.value ?? '';
        const classes = [width, align].filter(Boolean).join(' ');
        const md = classes
          ? `<img src="${pendingImage.path}" alt="${alt.replace(/"/g, '&quot;')}" class="${classes}" />`
          : `![${alt}](${pendingImage.path})`;
        insertBlock(md);
        pendingImage = null;
        imageDialog.close();
      });

      textarea.addEventListener('dragover', (e) => {
        e.preventDefault();
        textarea.classList.add('editor-drag-hover');
      });
      textarea.addEventListener('dragleave', () => {
        textarea.classList.remove('editor-drag-hover');
      });
      textarea.addEventListener('drop', async (e) => {
        e.preventDefault();
        textarea.classList.remove('editor-drag-hover');
        const file = e.dataTransfer?.files?.[0];
        if (file) await uploadAndOpenDialog(file);
      });

      textarea.addEventListener('paste', async (e) => {
        const items = e.clipboardData?.items;
        if (!items) return;
        for (const item of items) {
          if (item.kind === 'file' && item.type.startsWith('image/')) {
            e.preventDefault();
            const file = item.getAsFile();
            if (file) await uploadAndOpenDialog(file);
            return;
          }
        }
      });

      document.addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 's') {
          e.preventDefault();
          if (current) save();
        }
      });

      window.addEventListener('beforeunload', (e) => {
        if (isDirty) {
          e.preventDefault();
          e.returnValue = '';
        }
      });

      previewLink.addEventListener('click', () => {
        if (previewLink.dataset.href) window.open(previewLink.dataset.href, '_blank', 'noopener');
      });

      previewToggle.addEventListener('change', () => {
        previewEl.hidden = !previewToggle.checked;
        splitEl.classList.toggle('has-preview', previewToggle.checked);
        if (previewToggle.checked) renderPreview();
      });

      function refreshPreviewAfterLoad() {
        if (previewEl && !previewEl.hidden) renderPreview();
      }

      let previewToken = 0;
      let previewTimer = null;

      function schedulePreview() {
        if (!previewEl || previewEl.hidden) return;
        clearTimeout(previewTimer);
        previewTimer = setTimeout(renderPreview, 250);
      }

      async function renderPreview() {
        if (!previewEl || previewEl.hidden) return;
        const token = ++previewToken;
        const content = textarea.value;
        const ext = current?.ext ?? '.md';
        try {
          const res = await fetch('/_editor/api/render', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ content, ext }),
          });
          if (token !== previewToken) return;
          const data = await res.json();
          if (!res.ok) {
            previewContent.innerHTML = `<pre class="cwo-error" style="color:#ef4444;white-space:pre-wrap">렌더링 실패: ${(data.error || res.status)}\n\n${data.stack || ''}</pre>`;
            return;
          }
          previewContent.innerHTML = data.html;
          document.dispatchEvent(new CustomEvent('preview-updated', { detail: { container: previewContent } }));
        } catch (err) {
          if (token !== previewToken) return;
          previewContent.innerHTML = `<pre style="color:#ef4444">미리보기 요청 실패: ${err && err.message ? err.message : err}</pre>`;
        }
      }

      textarea.disabled = true;
      saveBtn.disabled = true;
      loadFiles();
  })();
</script>

