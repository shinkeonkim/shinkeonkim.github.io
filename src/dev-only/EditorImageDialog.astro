---
---
<dialog id="editor-image-dialog" class="editor-image-dialog">
  <form method="dialog" class="editor-image-form">
    <h3 class="editor-image-title" id="editor-image-title">이미지 삽입 옵션</h3>
    <fieldset class="editor-image-row" data-image-section="purpose">
      <legend>용도</legend>
      <label>
        <input type="radio" name="img-purpose" value="body" checked /> 본문에 삽입
      </label>
      <label>
        <input type="radio" name="img-purpose" value="cover" /> 커버 이미지 (frontmatter)
      </label>
      <label>
        <input type="radio" name="img-purpose" value="thumbnail" /> 썸네일 (frontmatter)
      </label>
    </fieldset>
    <fieldset class="editor-image-row" data-image-section="source">
      <legend>이미지 소스</legend>
      <label>
        <input type="radio" name="img-source" value="upload" checked /> 파일 업로드 / 클립보드
      </label>
      <label>
        <input type="radio" name="img-source" value="url-fetch" /> 외부 URL (다운로드해서 저장)
      </label>
      <label>
        <input type="radio" name="img-source" value="url-direct" /> 외부 URL (그대로 사용)
      </label>
    </fieldset>
    <div class="editor-image-row" data-image-source-upload>
      <button type="button" class="editor-btn" data-image-pick>📁 파일 선택…</button>
      <span class="editor-image-source-status" id="editor-image-source-status" />
    </div>
    <div class="editor-image-row" data-image-source-url hidden>
      <label>
        <span>외부 URL</span>
        <input
          type="url"
          id="editor-image-url"
          placeholder="https://example.com/image.png"
          style="width:100%"
        />
      </label>
      <button type="button" class="editor-btn" data-image-url-fetch>🌐 가져오기</button>
    </div>
    <div class="editor-image-preview">
      <img id="editor-image-preview-img" alt="" />
    </div>
    <label class="editor-image-row">
      <span>대체 텍스트 (alt)</span>
      <input type="text" id="editor-image-alt" placeholder="이미지 설명" />
    </label>
    <fieldset class="editor-image-row" data-image-section="body-only">
      <legend>너비 (본문 삽입 시)</legend>
      <label><input type="radio" name="img-width" value="" checked /> 원본</label>
      <label><input type="radio" name="img-width" value="img-quarter" /> 작게 (25%)</label>
      <label><input type="radio" name="img-width" value="img-half" /> 절반 (50%)</label>
      <label><input type="radio" name="img-width" value="img-three-quarter" /> 크게 (75%)</label>
      <label><input type="radio" name="img-width" value="img-full" /> 가득 (100%)</label>
      <label>
        <input type="radio" name="img-width" value="custom" /> 직접:
        <input
          type="text"
          id="editor-image-width-custom"
          placeholder="예: 40%, 320px"
          style="width: 9rem; margin-left: 0.3rem"
        />
      </label>
    </fieldset>
    <fieldset class="editor-image-row" data-image-section="body-only">
      <legend>정렬 (본문 삽입 시)</legend>
      <label><input type="radio" name="img-align" value="" checked /> 기본 (인라인)</label>
      <label><input type="radio" name="img-align" value="img-left" /> 왼쪽</label>
      <label><input type="radio" name="img-align" value="img-center" /> 가운데</label>
      <label><input type="radio" name="img-align" value="img-right" /> 오른쪽</label>
    </fieldset>
    <div class="editor-image-actions">
      <button type="button" value="cancel" data-image-cancel>취소</button>
      <button type="submit" value="insert" class="editor-btn-primary" data-image-confirm>삽입</button>
    </div>
  </form>
</dialog>
