    { "type": "text", "id": "step", "x": 450, "y": 58, "content": "각 동전을 다항식으로, 곱셈으로 모든 조합 자동 계산", "fontSize": 13, "fontWeight": 500, "color": "#6366f1", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 14000 }], "tracks": [
      { "property": "content", "keyframes": [
        { "time": 0, "value": "각 동전을 다항식으로, 곱셈으로 모든 조합 자동 계산" },
        { "time": 2000, "value": "1원: 1 + x + x² + x³ + ... = 1/(1-x)" },
        { "time": 4000, "value": "2원: 1 + x² + x⁴ + x⁶ + ... = 1/(1-x²)" },
        { "time": 6000, "value": "5원: 1 + x⁵ + x¹⁰ + ... = 1/(1-x⁵)" },
        { "time": 9000, "value": "곱셈: [1/(1-x)] × [1/(1-x²)] × [1/(1-x⁵)]" },
        { "time": 11500, "value": "계수 [x^k] = k원 만드는 방법 수" }
      ]}
