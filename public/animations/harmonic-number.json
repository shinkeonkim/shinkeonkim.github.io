    {
      "id": "bar-2-text", "type": "text", "x": 160, "y": 153, "text": "1/2", "fontSize": 12, "fill": "#1e3a8a", "textAlign": "center"
    },
    {
      "id": "bar-3", "type": "rect", "x": 190, "y": 145, "width": 27, "height": 20,
      "fill": "#dbeafe", "stroke": "#2563eb", "strokeWidth": 1, "rx": 2
    },
    {
      "id": "bar-3-text", "type": "text", "x": 203, "y": 158, "text": "1/3", "fontSize": 12, "fill": "#1e3a8a", "textAlign": "center"
    },
    {
      "id": "bar-4", "type": "rect", "x": 227, "y": 148, "width": 20, "height": 20,
      "fill": "#dbeafe", "stroke": "#2563eb", "strokeWidth": 1, "rx": 2
    },
    {
      "id": "bar-4-text", "type": "text", "x": 237, "y": 161, "text": "1/4", "fontSize": 12, "fill": "#1e3a8a", "textAlign": "center"
    },
    {
      "id": "bar-5to10", "type": "rect", "x": 257, "y": 152, "width": 60, "height": 20,
      "fill": "#dbeafe", "stroke": "#2563eb", "strokeWidth": 1, "rx": 2
    },
    {
      "id": "bar-5to10-text", "type": "text", "x": 287, "y": 165, "text": "1/5..1/10", "fontSize": 11, "fill": "#1e3a8a", "textAlign": "center"
    },
    {
      "id": "result-bar", "type": "rect", "x": 50, "y": 190, "width": 267, "height": 30,
      "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "rx": 4
    },
    {
      "id": "result-text", "type": "text", "x": 183, "y": 210, "text": "H_10 = 2.9289", "fontSize": 16, "fontWeight": "bold", "fill": "#14532d", "textAlign": "center"
    },
    {
      "id": "floor-label", "type": "text", "x": 50, "y": 260,
      "text": "Floor sum S(n) = Σ⌊n/i⌋ (i=1..n)", "fontSize": 16, "fill": "#713f12", "fontWeight": "bold"
    },
    {
      "id": "segment-example", "type": "text", "x": 50, "y": 290,
      "text": "n=10: ⌊10/1⌋=10, ⌊10/2⌋=5, ⌊10/3⌋=3, ⌊10/4⌋=2, ⌊10/5..10⌋=1", "fontSize": 14, "fill": "#0b0b0f"
    },
    {
      "id": "segment-group", "type": "rect", "x": 50, "y": 320, "width": 600, "height": 60,
      "fill": "#fef9c3", "stroke": "#eab308", "strokeWidth": 2, "rx": 4
    },
    {
      "id": "segment-group-text", "type": "text", "x": 350, "y": 345,
      "text": "같은 몫 구간 [l, r] 묶음: q = n//l, r = n//q", "fontSize": 15, "fill": "#713f12", "textAlign": "center", "fontWeight": "bold"
    },
    {
      "id": "complexity", "type": "text", "x": 350, "y": 400,
      "text": "O(sqrt(n)) 구간 = O(sqrt(n)) 시간", "fontSize": 18, "fontWeight": "bold", "fill": "#7c3aed", "textAlign": "center"
    },
    {
      "id": "note", "type": "text", "x": 450, "y": 450,
      "text": "S(10^6) = 13970034, H(10^6) = 14.3927", "fontSize": 14, "fill": "#475569", "textAlign": "center"
    }
  ],
  "chapters": [
    {
      "id": "intro", "title": "정의", "startTime": 0, "endTime": 2000,
      "caption": "H_n = Σ 1/i = 1 + 1/2 + ... + 1/n"
    },
    {
      "id": "bars", "title": "항별 막대", "startTime": 2000, "endTime": 4500,
      "caption": "n=10 일 때 각 항의 크기"
    },
    {
      "id": "result", "title": "H_10", "startTime": 4500, "endTime": 6500,
      "caption": "H_10 = 2.9289 ≈ ln(10) + 0.5772"
    },
    {
      "id": "floor", "title": "Floor sum", "startTime": 6500, "endTime": 9500,
      "caption": "Σ⌊n/i⌋, n=10: 10+5+3+2+1+1+1+1+1+1 = 27"
    },
    {
      "id": "grouping", "title": "구간 묶음", "startTime": 9500, "endTime": 11500,
      "caption": "같은 몫 구간 [l, r] 을 O(1) 에 처리"
    },
    {
      "id": "done", "title": "완료", "startTime": 11500, "endTime": 13000,
      "caption": "O(√n) 시간에 모든 floor sum 계산"
    }
  ],
  "effects": [
    {
      "id": "fade-bar-1", "elementId": "bar-1", "type": "fade", "startTime": 2200, "duration": 300, "from": 0, "to": 1
