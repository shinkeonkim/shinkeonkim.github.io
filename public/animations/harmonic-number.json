{
  "version": 4,
  "id": "harmonic-number",
  "title": "조화수 (Harmonic Number)",
  "description": "H_n = 1 + 1/2 + 1/3 + ... + 1/n ≈ ln n + γ. Floor sum Σ⌊n/i⌋ 구간 나누기.",
  "category": "algorithm",
  "tags": ["harmonic-number", "number-theory", "math"],
  "duration": 13000,
  "canvas": { "width": 900, "height": 500, "background": "transparent" },
  "elements": [
    {
      "id": "title", "type": "text", "x": 450, "y": 30,
      "text": "Harmonic Number: H_n", "fontSize": 20, "fontWeight": "bold",
      "fill": "#0b0b0f", "textAlign": "center"
    },
    {
      "id": "defn", "type": "text", "x": 450, "y": 55,
      "text": "H_n = 1 + 1/2 + 1/3 + ... + 1/n ≈ ln n + 0.5772", "fontSize": 15, "fill": "#475569", "textAlign": "center"
    },
    {
      "id": "segment-label", "type": "text", "x": 50, "y": 100,
      "text": "H_10 = 1 + 1/2 + 1/3 + ... + 1/10", "fontSize": 16, "fill": "#1e3a8a", "fontWeight": "bold"
    },
    {
      "id": "bar-1", "type": "rect", "x": 50, "y": 130, "width": 80, "height": 20,
