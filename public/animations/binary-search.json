{
  "version": 2,
  "id": "binary-search",
  "title": "이진 탐색 (Binary Search)",
  "description": "정렬된 배열에서 중간값과 비교하여 탐색 범위를 반으로 줄여가는 알고리즘",
  "category": "algorithm",
  "tags": ["array", "search", "binary-search", "algorithm", "divide-and-conquer"],
  "canvas": { "width": 800, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "step-label", "rotation": 0, "x": 400, "y": 60, "content": "초기 상태: 정렬된 배열에서 Target(14) 찾기", "fontSize": 18, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle" },
    { "type": "text", "id": "target-label", "rotation": 0, "x": 650, "y": 100, "content": "Target: 14", "fontSize": 20, "fontWeight": 800, "color": "#ef4444", "textAnchor": "middle" },

    { "type": "rect", "id": "r0", "x": 105, "y": 200, "width": 50, "height": 50, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 4, "label": "1", "labelSize": 18, "labelColor": "#312e81" },
    { "type": "rect", "id": "r1", "x": 165, "y": 200, "width": 50, "height": 50, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 4, "label": "3", "labelSize": 18, "labelColor": "#312e81" },
    { "type": "rect", "id": "r2", "x": 225, "y": 200, "width": 50, "height": 50, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 4, "label": "5", "labelSize": 18, "labelColor": "#312e81" },
    { "type": "rect", "id": "r3", "x": 285, "y": 200, "width": 50, "height": 50, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 4, "label": "7", "labelSize": 18, "labelColor": "#312e81" },
    { "type": "rect", "id": "r4", "x": 345, "y": 200, "width": 50, "height": 50, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 4, "label": "11", "labelSize": 18, "labelColor": "#312e81" },
    { "type": "rect", "id": "r5", "x": 405, "y": 200, "width": 50, "height": 50, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 4, "label": "14", "labelSize": 18, "labelColor": "#312e81" },
    { "type": "rect", "id": "r6", "x": 465, "y": 200, "width": 50, "height": 50, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 4, "label": "18", "labelSize": 18, "labelColor": "#312e81" },
    { "type": "rect", "id": "r7", "x": 525, "y": 200, "width": 50, "height": 50, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 4, "label": "22", "labelSize": 18, "labelColor": "#312e81" },
    { "type": "rect", "id": "r8", "x": 585, "y": 200, "width": 50, "height": 50, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 4, "label": "25", "labelSize": 18, "labelColor": "#312e81" },
    { "type": "rect", "id": "r9", "x": 645, "y": 200, "width": 50, "height": 50, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 4, "label": "30", "labelSize": 18, "labelColor": "#312e81" },

    { "type": "text", "id": "idx0", "x": 130, "y": 180, "content": "0", "fontSize": 12, "color": "#94a3b8", "textAnchor": "middle" },
    { "type": "text", "id": "idx1", "x": 190, "y": 180, "content": "1", "fontSize": 12, "color": "#94a3b8", "textAnchor": "middle" },
    { "type": "text", "id": "idx2", "x": 250, "y": 180, "content": "2", "fontSize": 12, "color": "#94a3b8", "textAnchor": "middle" },
    { "type": "text", "id": "idx3", "x": 310, "y": 180, "content": "3", "fontSize": 12, "color": "#94a3b8", "textAnchor": "middle" },
    { "type": "text", "id": "idx4", "x": 370, "y": 180, "content": "4", "fontSize": 12, "color": "#94a3b8", "textAnchor": "middle" },
    { "type": "text", "id": "idx5", "x": 430, "y": 180, "content": "5", "fontSize": 12, "color": "#94a3b8", "textAnchor": "middle" },
    { "type": "text", "id": "idx6", "x": 490, "y": 180, "content": "6", "fontSize": 12, "color": "#94a3b8", "textAnchor": "middle" },
    { "type": "text", "id": "idx7", "x": 550, "y": 180, "content": "7", "fontSize": 12, "color": "#94a3b8", "textAnchor": "middle" },
    { "type": "text", "id": "idx8", "x": 610, "y": 180, "content": "8", "fontSize": 12, "color": "#94a3b8", "textAnchor": "middle" },
    { "type": "text", "id": "idx9", "x": 670, "y": 180, "content": "9", "fontSize": 12, "color": "#94a3b8", "textAnchor": "middle" },

    { "type": "arrow", "id": "ptr-lo", "x1": 130, "y1": 290, "x2": 130, "y2": 260, "stroke": "#2563eb", "strokeWidth": 3, "headEnd": "arrow", "label": "lo", "labelColor": "#1e40af" },
    { "type": "arrow", "id": "ptr-hi", "x1": 670, "y1": 290, "x2": 670, "y2": 260, "stroke": "#2563eb", "strokeWidth": 3, "headEnd": "arrow", "label": "hi", "labelColor": "#1e40af" },
    { "type": "arrow", "id": "ptr-mid", "x1": 370, "y1": 110, "x2": 370, "y2": 140, "stroke": "#ea580c", "strokeWidth": 3, "headEnd": "arrow", "label": "mid", "labelColor": "#c2410c" }
  ],
  "initiallyHidden": ["ptr-mid"],
  "steps": [
    { "id": "s1", "label": "Step 1: mid 계산", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "ptr-mid": { "visible": true },
        "r4": { "fill": "#fbbf24", "stroke": "#d97706" },
        "step-label": { "content": "lo(0) ~ hi(9) → mid(4) = 11. 11 < 14" }
      },
      "effects": [{ "type": "pulse", "elementId": "r4", "scale": 1.1, "duration": 400 }] },
      
    { "id": "s2", "label": "Step 1: 범위 축소", "duration": 800, "ease": "easeInOut",
      "keyframes": {
        "ptr-lo": { "x1": 430, "x2": 430 },
        "r0": { "fill": "#fecaca", "stroke": "#dc2626" },
        "r1": { "fill": "#fecaca", "stroke": "#dc2626" },
        "r2": { "fill": "#fecaca", "stroke": "#dc2626" },
        "r3": { "fill": "#fecaca", "stroke": "#dc2626" },
        "r4": { "fill": "#fecaca", "stroke": "#dc2626" },
        "ptr-mid": { "visible": false },
        "step-label": { "content": "mid < Target 이므로, lo = mid + 1 (5) 로 변경" }
      },
      "effects": [] },

    { "id": "s3", "label": "Step 2: mid 계산", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "ptr-mid": { "visible": true, "x1": 550, "x2": 550 },
        "r7": { "fill": "#fbbf24", "stroke": "#d97706" },
        "step-label": { "content": "lo(5) ~ hi(9) → mid(7) = 22. 22 > 14" }
      },
      "effects": [{ "type": "pulse", "elementId": "r7", "scale": 1.1, "duration": 400 }] },

    { "id": "s4", "label": "Step 2: 범위 축소", "duration": 800, "ease": "easeInOut",
      "keyframes": {
        "ptr-hi": { "x1": 490, "x2": 490 },
        "r7": { "fill": "#fecaca", "stroke": "#dc2626" },
        "r8": { "fill": "#fecaca", "stroke": "#dc2626" },
        "r9": { "fill": "#fecaca", "stroke": "#dc2626" },
        "ptr-mid": { "visible": false },
        "step-label": { "content": "mid > Target 이므로, hi = mid - 1 (6) 로 변경" }
      },
      "effects": [] },

    { "id": "s5", "label": "Step 3: mid 계산 및 탐색 성공", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "ptr-mid": { "visible": true, "x1": 430, "x2": 430 },
        "r5": { "fill": "#34d399", "stroke": "#059669", "labelColor": "#064e3b" },
        "step-label": { "content": "lo(5) ~ hi(6) → mid(5) = 14. Target 발견! 탐색 성공" }
      },
      "effects": [{ "type": "pulse", "elementId": "r5", "scale": 1.2, "duration": 600 }, { "type": "highlight", "elementId": "r5", "color": "#10b981", "duration": 800 }] },

    { "id": "s6", "label": "재시작", "duration": 600, "ease": "linear",
      "keyframes": {
        "r0": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "r1": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "r2": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "r3": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "r4": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "r5": { "fill": "#e0e7ff", "stroke": "#6366f1", "labelColor": "#312e81" },
        "r6": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "r7": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "r8": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "r9": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "ptr-lo": { "x1": 130, "x2": 130 },
        "ptr-hi": { "x1": 670, "x2": 670 },
        "ptr-mid": { "visible": false, "x1": 370, "x2": 370 },
        "step-label": { "content": "초기 상태: 정렬된 배열에서 Target(14) 찾기" }
      },
      "effects": [] }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 400 }
}