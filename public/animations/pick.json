    { "type": "text", "id": "step", "rotation": 0, "x": 450, "y": 58, "content": "격자점 삼각형: (0,0),(6,0),(0,8)", "fontSize": 14, "fontWeight": 600, "color": "#6366f1", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [
      { "property": "content", "keyframes": [
        { "time": 0, "value": "격자점 삼각형: (0,0),(6,0),(0,8)" },
        { "time": 3500, "value": "경계 격자점 B = gcd(6,0)+gcd(0,8)+gcd(6,8) = 6+8+2 = 12" },
        { "time": 6500, "value": "내부 격자점 I (녹색) = 19" },
        { "time": 9500, "value": "A = I + B/2 - 1 = 19 + 6 - 1 = 24" },
        { "time": 11500, "value": "Shoelace 검증: (0*0+6*8+0*0 - 0*6-0*0-8*0)/2 = 48/2 = 24" },
        { "time": 12500, "value": "작은 격자점 수로 큰 넓이를 구하는 강력한 정리" }
      ]}
    ]},
