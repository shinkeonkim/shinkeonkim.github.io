{
  "version": 2,
  "id": "load-balancer",
  "title": "Load Balancer Round-Robin",
  "description": "Load Balancer 가 요청을 서버 풀에 라운드 로빈으로 분산",
  "category": "architecture",
  "tags": ["load-balancer", "round-robin", "distribution"],
  "canvas": { "width": 800, "height": 460, "background": "transparent" },
  "elements": [
    { "type": "rect", "id": "client", "rotation": 0, "x": 60, "y": 200, "width": 120, "height": 70, "fill": "#dbeafe", "stroke": "#3b82f6", "strokeWidth": 2, "cornerRadius": 10, "label": "Client", "labelColor": "#1e3a8a", "labelSize": 15 },
    { "type": "rect", "id": "lb", "rotation": 0, "x": 290, "y": 200, "width": 140, "height": 70, "fill": "#fed7aa", "stroke": "#ea580c", "strokeWidth": 2.5, "cornerRadius": 10, "label": "LB", "labelColor": "#7c2d12", "labelSize": 16, "subtitle": "round-robin" },
    { "type": "rect", "id": "srv1", "rotation": 0, "x": 560, "y": 60, "width": 130, "height": 60, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 10, "label": "Server 1", "labelColor": "#14532d", "labelSize": 14 },
    { "type": "rect", "id": "srv2", "rotation": 0, "x": 560, "y": 200, "width": 130, "height": 60, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 10, "label": "Server 2", "labelColor": "#14532d", "labelSize": 14 },
    { "type": "rect", "id": "srv3", "rotation": 0, "x": 560, "y": 340, "width": 130, "height": 60, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 10, "label": "Server 3", "labelColor": "#14532d", "labelSize": 14 },
    { "type": "circle", "id": "req", "rotation": 0, "cx": 120, "cy": 235, "r": 9, "fill": "#facc15", "stroke": "#a16207", "strokeWidth": 2 },
    { "type": "text", "id": "step-label", "rotation": 0, "x": 400, "y": 40, "content": "요청 #1 → Server 1", "fontSize": 18, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle" }
  ],
  "initiallyHidden": [],
  "steps": [
    { "id": "s1", "label": "→ LB", "duration": 700, "ease": "easeInOut",
      "keyframes": { "req": { "cx": 360 } },
      "effects": [] },
    { "id": "s2", "label": "→ Server 1", "duration": 700, "ease": "easeInOut",
      "keyframes": { "req": { "cx": 625, "cy": 90 } },
      "effects": [{ "type": "highlight", "elementId": "srv1", "color": "#86efac", "duration": 500, "delay": 0 }] },
    { "id": "s3", "label": "복귀", "duration": 600, "ease": "easeInOut",
      "keyframes": { "req": { "cx": 120, "cy": 235 }, "step-label": { "content": "요청 #2 → Server 2" } },
      "effects": [] },
    { "id": "s4", "label": "→ LB", "duration": 700, "ease": "easeInOut",
      "keyframes": { "req": { "cx": 360 } },
      "effects": [] },
    { "id": "s5", "label": "→ Server 2", "duration": 700, "ease": "easeInOut",
      "keyframes": { "req": { "cx": 625, "cy": 230 } },
      "effects": [{ "type": "highlight", "elementId": "srv2", "color": "#86efac", "duration": 500, "delay": 0 }] },
    { "id": "s6", "label": "복귀", "duration": 600, "ease": "easeInOut",
      "keyframes": { "req": { "cx": 120, "cy": 235 }, "step-label": { "content": "요청 #3 → Server 3" } },
      "effects": [] },
    { "id": "s7", "label": "→ LB", "duration": 700, "ease": "easeInOut",
      "keyframes": { "req": { "cx": 360 } },
      "effects": [] },
    { "id": "s8", "label": "→ Server 3", "duration": 700, "ease": "easeInOut",
      "keyframes": { "req": { "cx": 625, "cy": 370 } },
      "effects": [{ "type": "highlight", "elementId": "srv3", "color": "#86efac", "duration": 500, "delay": 0 }] },
    { "id": "s9", "label": "복귀", "duration": 600, "ease": "easeInOut",
      "keyframes": { "req": { "cx": 120, "cy": 235 }, "step-label": { "content": "요청 #1 → Server 1" } },
      "effects": [] }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 100 }
}
