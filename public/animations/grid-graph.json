      "id": "code-title",
      "type": "text",
      "x": 580,
      "y": 210,
      "content": "BFS Pseudocode",
      "fontSize": 14,
      "fill": "#e2e8f0",
      "fontWeight": "bold",
      "textAnchor": "middle"
    },
    {
      "id": "code-content",
      "type": "text",
      "x": 340,
      "y": 250,
      "content": "dx = [-1, 1, 0, 0]\ndy = [0, 0, -1, 1]\n\nqueue q\nq.push((sx, sy))\ndist[sx][sy] = 0\n\nwhile q not empty:\n  (x, y) = q.pop()\n  for i in 0..3:\n    nx = x + dx[i]\n    ny = y + dy[i]\n    if valid(nx, ny):\n      dist[nx][ny] = dist[x][y] + 1\n      q.push((nx, ny))",
      "fontSize": 13,
      "fill": "#e2e8f0",
      "fontFamily": "monospace",
      "textAnchor": "start"
    },
    {
      "id": "dist-label",
      "type": "text",
      "x": 150,
      "y": 260,
      "content": "Distance: 0",
      "fontSize": 14,
      "fill": "#5b21b6",
      "fontWeight": "bold",
      "textAnchor": "middle"
    }
  ],
