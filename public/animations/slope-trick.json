    { "type": "rect", "id": "l-heap-box", "rotation": 0, "x": 100, "y": 380, "width": 220, "height": 80, "fill": "#fee2e2", "stroke": "#dc2626", "strokeWidth": 2, "cornerRadius": 6, "label": "L (max-heap)", "labelColor": "#7f1d1d", "labelSize": 14, "subtitle": "breakpoints", "appearances": [{ "start": 0, "end": 12000 }], "tracks": [] },
    { "type": "text", "id": "l-heap-content", "rotation": 0, "x": 210, "y": 430, "content": "[]", "fontSize": 13, "color": "#7f1d1d", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 12000 }], "tracks": [{ "property": "content", "keyframes": [{ "time": 0, "value": "[]" }, { "time": 3000, "value": "[3]" }, { "time": 6000, "value": "[3, 1]" }, { "time": 9000, "value": "[3, 1, 1]" }] }] },
    { "type": "rect", "id": "r-heap-box", "rotation": 0, "x": 360, "y": 380, "width": 220, "height": 80, "fill": "#dbeafe", "stroke": "#2563eb", "strokeWidth": 2, "cornerRadius": 6, "label": "R (min-heap)", "labelColor": "#1e3a8a", "labelSize": 14, "subtitle": "breakpoints", "appearances": [{ "start": 0, "end": 12000 }], "tracks": [] },
    { "type": "text", "id": "r-heap-content", "rotation": 0, "x": 470, "y": 430, "content": "[]", "fontSize": 13, "color": "#1e3a8a", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 12000 }], "tracks": [{ "property": "content", "keyframes": [{ "time": 0, "value": "[]" }, { "time": 3000, "value": "[3]" }, { "time": 6000, "value": "[3]" }, { "time": 9000, "value": "[3, 5]" }] }] },
    { "type": "rect", "id": "min-box", "rotation": 0, "x": 620, "y": 380, "width": 160, "height": 80, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 6, "label": "min_f", "labelColor": "#14532d", "labelSize": 14, "subtitle": "최솟값", "appearances": [{ "start": 0, "end": 12000 }], "tracks": [] },
    { "type": "text", "id": "min-value", "rotation": 0, "x": 700, "y": 430, "content": "0", "fontSize": 16, "fontWeight": 600, "color": "#14532d", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 12000 }], "tracks": [{ "property": "content", "keyframes": [{ "time": 0, "value": "0" }, { "time": 3000, "value": "0" }, { "time": 6000, "value": "2" }, { "time": 9000, "value": "4" }] }] }
  ],
  "chapters": [
    { "id": "init", "time": 0, "label": "초기 상태", "subtitle": "f(x) = 0" },
    { "id": "add1", "time": 3000, "label": "|x-3| 추가", "subtitle": "L=[3], R=[3]" },
    { "id": "add2", "time": 6000, "label": "|x-1| 추가", "subtitle": "min_f = 2" },
    { "id": "add3", "time": 9000, "label": "|x-5| 추가", "subtitle": "min_f = 4" }
  ],
  "effects": [
    { "type": "highlight", "id": "e1", "elementId": "l-marker", "time": 3000, "color": "#facc15", "duration": 600 },
    { "type": "highlight", "id": "e2", "elementId": "r-marker", "time": 3000, "color": "#facc15", "duration": 600 },
    { "type": "pulse", "id": "e3", "elementId": "min-box", "time": 6000, "scale": 1.12, "duration": 500 },
    { "type": "highlight", "id": "e4", "elementId": "l-heap-box", "time": 6000, "color": "#fde68a", "duration": 700 },
    { "type": "highlight", "id": "e5", "elementId": "r-heap-box", "time": 9000, "color": "#bfdbfe", "duration": 700 }
  ],
  "settings": { "loop": true, "autoplay": true, "showCaption": false, "showChapterList": true }
}
