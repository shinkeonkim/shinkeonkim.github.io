{
  "version": 4,
  "id": "slope-trick",
  "title": "Slope Trick",
  "description": "볼록 piecewise-linear 함수를 두 개 priority queue로 유지. |x-a| 추가 연산을 O(log N)에 처리, 최솟값 구간 [L.top, R.top]을 추적.",
  "category": "algorithm",
  "tags": ["algorithm", "dp", "priority-queue"],
  "duration": 12000,
  "canvas": { "width": 900, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "title", "rotation": 0, "x": 450, "y": 28, "content": "Slope Trick: f(x) += |x-a| 연산", "fontSize": 20, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 12000 }], "tracks": [] },
    { "type": "text", "id": "step-label", "rotation": 0, "x": 450, "y": 58, "content": "초기: f(x) = 0", "fontSize": 13, "color": "#6366f1", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 12000 }], "tracks": [{ "property": "content", "keyframes": [{ "time": 0, "value": "초기: f(x) = 0" }, { "time": 3000, "value": "f(x) += |x-3|" }, { "time": 6000, "value": "f(x) += |x-1|" }, { "time": 9000, "value": "f(x) += |x-5|" }] }] },
    { "type": "line", "id": "x-axis", "rotation": 0, "x1": 100, "y1": 320, "x2": 800, "y2": 320, "stroke": "#cbd5e1", "strokeWidth": 1, "appearances": [{ "start": 0, "end": 12000 }], "tracks": [] },
    { "type": "line", "id": "y-axis", "rotation": 0, "x1": 100, "y1": 120, "x2": 100, "y2": 320, "stroke": "#cbd5e1", "strokeWidth": 1, "appearances": [{ "start": 0, "end": 12000 }], "tracks": [] },
    { "type": "line", "id": "func-left-1", "rotation": 0, "x1": 100, "y1": 200, "x2": 300, "y2": 280, "stroke": "#2563eb", "strokeWidth": 3, "appearances": [{ "start": 3000, "end": 12000, "entryMode": "fade", "entryDuration": 400 }], "tracks": [{ "property": "x2", "keyframes": [{ "time": 3000, "value": 300 }, { "time": 6000, "value": 200 }, { "time": 9000, "value": 200 }] }, { "property": "y2", "keyframes": [{ "time": 3000, "value": 280 }, { "time": 6000, "value": 300 }, { "time": 9000, "value": 280 }] }] },
    { "type": "line", "id": "func-flat", "rotation": 0, "x1": 300, "y1": 280, "x2": 300, "y2": 280, "stroke": "#2563eb", "strokeWidth": 3, "appearances": [{ "start": 3000, "end": 12000, "entryMode": "fade", "entryDuration": 400 }], "tracks": [{ "property": "x1", "keyframes": [{ "time": 3000, "value": 300 }, { "time": 6000, "value": 200 }, { "time": 9000, "value": 200 }] }, { "property": "x2", "keyframes": [{ "time": 3000, "value": 300 }, { "time": 6000, "value": 300 }, { "time": 9000, "value": 500 }] }, { "property": "y1", "keyframes": [{ "time": 3000, "value": 280 }, { "time": 6000, "value": 300 }, { "time": 9000, "value": 280 }] }, { "property": "y2", "keyframes": [{ "time": 3000, "value": 280 }, { "time": 6000, "value": 300 }, { "time": 9000, "value": 280 }] }] },
    { "type": "line", "id": "func-right-1", "rotation": 0, "x1": 300, "y1": 280, "x2": 500, "y2": 200, "stroke": "#2563eb", "strokeWidth": 3, "appearances": [{ "start": 3000, "end": 12000, "entryMode": "fade", "entryDuration": 400 }], "tracks": [{ "property": "x1", "keyframes": [{ "time": 3000, "value": 300 }, { "time": 6000, "value": 300 }, { "time": 9000, "value": 500 }] }, { "property": "y1", "keyframes": [{ "time": 3000, "value": 280 }, { "time": 6000, "value": 300 }, { "time": 9000, "value": 280 }] }, { "property": "x2", "keyframes": [{ "time": 3000, "value": 500 }, { "time": 6000, "value": 500 }, { "time": 9000, "value": 700 }] }, { "property": "y2", "keyframes": [{ "time": 3000, "value": 200 }, { "time": 6000, "value": 180 }, { "time": 9000, "value": 200 }] }] },
    { "type": "circle", "id": "l-marker", "rotation": 0, "cx": 300, "cy": 280, "r": 8, "fill": "#dc2626", "stroke": "#7f1d1d", "strokeWidth": 2, "label": "", "appearances": [{ "start": 3000, "end": 12000, "entryMode": "pop", "entryDuration": 400 }], "tracks": [{ "property": "cx", "keyframes": [{ "time": 3000, "value": 300 }, { "time": 6000, "value": 200 }, { "time": 9000, "value": 200 }] }, { "property": "cy", "keyframes": [{ "time": 3000, "value": 280 }, { "time": 6000, "value": 300 }, { "time": 9000, "value": 280 }] }] },
