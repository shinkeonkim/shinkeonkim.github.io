{
  "version": 2,
  "id": "oauth-flow",
  "title": "OAuth 2.0 Authorization Code Flow",
  "description": "사용자 인증 → 인가 코드 → 액세스 토큰 교환",
  "category": "protocol",
  "tags": ["oauth", "auth", "security", "protocol"],
  "canvas": { "width": 900, "height": 460, "background": "transparent" },
  "elements": [
    { "type": "rect", "id": "user", "rotation": 0, "x": 60, "y": 200, "width": 130, "height": 70, "fill": "#dbeafe", "stroke": "#3b82f6", "strokeWidth": 2, "cornerRadius": 10, "label": "User", "labelColor": "#1e3a8a", "labelSize": 15 },
    { "type": "rect", "id": "app", "rotation": 0, "x": 270, "y": 200, "width": 130, "height": 70, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 10, "label": "App", "labelColor": "#312e81", "labelSize": 15, "subtitle": "client" },
    { "type": "rect", "id": "auth", "rotation": 0, "x": 480, "y": 60, "width": 150, "height": 70, "fill": "#fed7aa", "stroke": "#ea580c", "strokeWidth": 2, "cornerRadius": 10, "label": "Auth Server", "labelColor": "#7c2d12", "labelSize": 14, "subtitle": "Google/GitHub" },
    { "type": "rect", "id": "api", "rotation": 0, "x": 720, "y": 200, "width": 130, "height": 70, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 10, "label": "Resource API", "labelColor": "#14532d", "labelSize": 13 },
    { "type": "circle", "id": "msg", "rotation": 0, "cx": 125, "cy": 235, "r": 9, "fill": "#facc15", "stroke": "#a16207", "strokeWidth": 2 },
    { "type": "text", "id": "msg-text", "rotation": 0, "x": 200, "y": 175, "content": "login", "fontSize": 12, "fontWeight": 600, "color": "#71717a", "textAnchor": "middle" },
    { "type": "text", "id": "step-label", "rotation": 0, "x": 450, "y": 40, "content": "1. User → App 로그인 시도", "fontSize": 18, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle" }
  ],
  "initiallyHidden": [],
  "steps": [
    { "id": "s1", "label": "User → App", "duration": 800, "ease": "easeInOut",
      "keyframes": { "msg": { "cx": 335 }, "msg-text": { "content": "redirect", "x": 440, "y": 175 }, "step-label": { "content": "2. App 이 Auth Server 로 redirect" } },
      "effects": [] },
    { "id": "s2", "label": "App → Auth", "duration": 800, "ease": "easeInOut",
      "keyframes": { "msg": { "cx": 555, "cy": 95 }, "msg-text": { "content": "login UI", "x": 555, "y": 165 }, "step-label": { "content": "3. User 가 Auth Server 에서 로그인" } },
      "effects": [{ "type": "highlight", "elementId": "auth", "color": "#fdba74", "duration": 500, "delay": 0 }] },
    { "id": "s3", "label": "Auth UI", "duration": 1000, "ease": "easeInOut",
      "keyframes": { "msg": { "cx": 125, "cy": 235 }, "msg-text": { "content": "credentials", "x": 200, "y": 175 }, "step-label": { "content": "4. User 가 자격증명 입력 + 권한 승인" } },
      "effects": [{ "type": "pulse", "elementId": "user", "scale": 1.05, "duration": 500, "delay": 0 }] },
    { "id": "s4", "label": "Auth code", "duration": 1000, "ease": "easeInOut",
      "keyframes": { "msg": { "cx": 555, "cy": 95, "fill": "#a78bfa" }, "msg-text": { "content": "auth code", "x": 480, "y": 165 }, "step-label": { "content": "5. Auth code 를 App 에 반환" } },
      "effects": [] },
    { "id": "s5", "label": "code → App", "duration": 800, "ease": "easeInOut",
      "keyframes": { "msg": { "cx": 335, "cy": 235 }, "msg-text": { "content": "code+secret", "x": 400, "y": 175 }, "step-label": { "content": "6. App 이 code+secret 으로 token 요청" } },
      "effects": [] },
    { "id": "s6", "label": "App → Auth token exchange", "duration": 800, "ease": "easeInOut",
      "keyframes": { "msg": { "cx": 555, "cy": 95, "fill": "#34d399" }, "msg-text": { "content": "access_token", "x": 470, "y": 165 }, "step-label": { "content": "7. Access token 발급" } },
      "effects": [{ "type": "highlight", "elementId": "auth", "color": "#86efac", "duration": 500, "delay": 0 }] },
    { "id": "s7", "label": "token → App", "duration": 800, "ease": "easeInOut",
      "keyframes": { "msg": { "cx": 335, "cy": 235 }, "msg-text": { "content": "GET /me", "x": 565, "y": 175 }, "step-label": { "content": "8. App 이 token 으로 API 호출" } },
      "effects": [] },
    { "id": "s8", "label": "App → API", "duration": 800, "ease": "easeInOut",
      "keyframes": { "msg": { "cx": 785 }, "msg-text": { "content": "user data", "x": 565, "y": 280 }, "step-label": { "content": "✓ Resource 응답" } },
      "effects": [{ "type": "highlight", "elementId": "api", "color": "#86efac", "duration": 500, "delay": 0 }] },
    { "id": "s9", "label": "API → App", "duration": 800, "ease": "easeInOut",
      "keyframes": { "msg": { "cx": 125, "cy": 235, "fill": "#34d399" }, "msg-text": { "content": "user info", "x": 200, "y": 175 }, "step-label": { "content": "✓ User 에게 로그인 완료" } },
      "effects": [{ "type": "pulse", "elementId": "user", "scale": 1.1, "duration": 600, "delay": 0 }] },
    { "id": "s10", "label": "재시작", "duration": 600, "ease": "linear",
      "keyframes": { "msg": { "cx": 125, "cy": 235, "fill": "#facc15" }, "msg-text": { "content": "login", "x": 200, "y": 175 }, "step-label": { "content": "1. User → App 로그인 시도" } },
      "effects": [] }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 150 }
}
