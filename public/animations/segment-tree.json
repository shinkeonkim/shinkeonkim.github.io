  "chapters": [
    {
      "id": "s1",
      "time": 0,
      "label": "트리와 쿼리",
      "subtitle": "배열 [3, 1, 4, 1] 의 합 세그먼트 트리. 쿼리: 구간 [1..2] 합?"
    },
    {
      "id": "s2",
      "time": 1500,
      "label": "root 방문",
      "subtitle": "쿼리 [1..2] 가 [0..3] 의 부분 → 양쪽 자식 모두 탐색"
    },
    {
      "id": "s3",
      "time": 3000,
      "label": "[0..1] 방문",
      "subtitle": "[1..2] ∩ [0..1] = [1..1] → 좌측 자식 제외, 우측만 탐색"
    },
    {
      "id": "s4",
      "time": 4600,
      "label": "[1] 사용 (값 1)",
      "subtitle": "[1..1] 은 [1..2] 에 완전 포함 → 값 1 을 합에 더함"
    },
    {
      "id": "s5",
      "time": 6100,
      "label": "[2..3] 방문",
      "subtitle": "[1..2] ∩ [2..3] = [2..2] → 우측 자식 제외, 좌측만 탐색"
    },
    {
      "id": "s6",
      "time": 7700,
      "label": "[2] 사용 (값 4)",
      "subtitle": "[2..2] 는 [1..2] 에 완전 포함 → 값 4 를 합에 더함"
    },
    {
      "id": "s7",
      "time": 9200,
      "label": "결과",
      "subtitle": "구간 [1..2] 합 = 5 (단 O(log n) 노드만 방문)"
    },
    {
      "id": "s8",
      "time": 11000,
      "label": "재시작",
      "subtitle": ""
    }
  ],
