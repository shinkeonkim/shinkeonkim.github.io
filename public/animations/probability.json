{
  "version": 4,
  "id": "probability",
  "title": "확률 (Probability)",
  "description": "조건부 확률, 베이즈 정리, 기댓값 선형성 시각화",
  "category": "algorithm",
  "tags": ["probability", "math", "bayes", "expectation"],
  "duration": 13000,
  "canvas": {
    "width": 900,
    "height": 500,
    "background": "transparent"
  },
  "elements": [
    {
      "id": "omega",
      "type": "rect",
      "x": 50,
      "y": 50,
      "width": 300,
      "height": 200,
      "rx": 8,
      "fill": "#e2e8f0",
      "stroke": "#475569",
      "strokeWidth": 2
    },
    {
      "id": "omega_label",
      "type": "text",
      "x": 200,
      "y": 30,
      "text": "Ω (표본 공간)",
      "fontSize": 16,
      "fontWeight": "bold",
      "fill": "#0b0b0f",
      "textAnchor": "middle"
    },
    {
      "id": "event_a",
      "type": "circle",
      "cx": 150,
      "cy": 130,
      "r": 60,
      "fill": "#dbeafe",
      "fillOpacity": 0.7,
      "stroke": "#2563eb",
      "strokeWidth": 2
    },
    {
      "id": "event_b",
      "type": "circle",
      "cx": 230,
      "cy": 130,
      "r": 60,
      "fill": "#dcfce7",
      "fillOpacity": 0.7,
      "stroke": "#16a34a",
      "strokeWidth": 2
    },
    {
      "id": "label_a",
      "type": "text",
      "x": 120,
      "y": 100,
      "text": "A",
      "fontSize": 18,
      "fontWeight": "bold",
      "fill": "#1e3a8a"
    },
    {
      "id": "label_b",
      "type": "text",
      "x": 260,
      "y": 100,
      "text": "B",
      "fontSize": 18,
      "fontWeight": "bold",
      "fill": "#14532d"
    },
    {
      "id": "formula",
      "type": "text",
      "x": 450,
      "y": 100,
      "text": "P(A ∪ B) = P(A) + P(B) - P(A ∩ B)",
      "fontSize": 14,
      "fill": "#0b0b0f",
      "fontFamily": "monospace"
    },
    {
      "id": "conditional",
      "type": "text",
      "x": 450,
      "y": 150,
      "text": "P(A | B) = P(A ∩ B) / P(B)",
      "fontSize": 14,
      "fill": "#7c3aed",
      "fontFamily": "monospace"
    },
    {
      "id": "bayes_title",
      "type": "text",
      "x": 450,
      "y": 220,
      "text": "베이즈 정리",
      "fontSize": 16,
      "fontWeight": "bold",
      "fill": "#0b0b0f"
    },
    {
      "id": "bayes_formula",
      "type": "text",
      "x": 450,
      "y": 250,
      "text": "P(A | B) = P(B | A) · P(A) / P(B)",
      "fontSize": 13,
      "fill": "#dc2626",
      "fontFamily": "monospace"
    },
    {
      "id": "expectation_title",
      "type": "text",
      "x": 50,
      "y": 320,
      "text": "기댓값 선형성: E[X + Y] = E[X] + E[Y]",
      "fontSize": 15,
      "fontWeight": "bold",
      "fill": "#0b0b0f"
    },
    {
      "id": "dice",
      "type": "rect",
      "x": 50,
      "y": 350,
      "width": 40,
      "height": 40,
      "rx": 4,
      "fill": "#fef9c3",
      "stroke": "#eab308",
      "strokeWidth": 2
    },
    {
      "id": "dice_dot",
      "type": "circle",
      "cx": 70,
      "cy": 370,
      "r": 4,
      "fill": "#713f12"
    },
    {
      "id": "dice_label",
      "type": "text",
      "x": 110,
      "y": 375,
      "text": "주사위 기댓값 = 3.5",
      "fontSize": 13,
      "fill": "#0b0b0f"
    },
    {
      "id": "coin",
      "type": "circle",
      "cx": 350,
      "cy": 370,
      "r": 20,
      "fill": "#ede9fe",
      "stroke": "#7c3aed",
      "strokeWidth": 2
    },
    {
      "id": "coin_label",
      "type": "text",
      "x": 385,
      "y": 375,
      "text": "동전 앞면 확률 = 0.5",
      "fontSize": 13,
      "fill": "#0b0b0f"
    }
  ],
  "chapters": [
    {
      "id": "intro",
      "title": "확률 기본",
      "startTime": 0,
      "endTime": 3000,
      "caption": "사건 A, B 와 표본 공간 Ω"
    },
    {
      "id": "conditional",
      "title": "조건부 확률",
      "startTime": 3000,
      "endTime": 6500,
      "caption": "P(A | B) = B 가 일어났을 때 A 확률"
    },
    {
      "id": "bayes",
      "title": "베이즈 정리",
      "startTime": 6500,
      "endTime": 10000,
      "caption": "원인-결과 역전 공식"
    },
    {
      "id": "expectation",
      "title": "기댓값",
      "startTime": 10000,
      "endTime": 13000,
      "caption": "선형성으로 복잡한 변수 분해"
    }
  ],
  "effects": [
    {
      "target": "event_a",
      "type": "opacity",
      "startTime": 0,
      "endTime": 1500,
      "from": 0,
      "to": 0.7
    },
    {
      "target": "event_b",
      "type": "opacity",
      "startTime": 1500,
      "endTime": 3000,
      "from": 0,
      "to": 0.7
    },
    {
      "target": "event_b",
      "type": "fill",
      "startTime": 3000,
      "endTime": 4500,
      "from": "#dcfce7",
      "to": "#fef9c3"
    },
    {
      "target": "conditional",
      "type": "opacity",
      "startTime": 3000,
      "endTime": 4500,
      "from": 0,
      "to": 1
    },
    {
      "target": "bayes_formula",
      "type": "opacity",
      "startTime": 6500,
      "endTime": 8000,
      "from": 0,
      "to": 1
    },
    {
      "target": "dice",
      "type": "opacity",
      "startTime": 10000,
      "endTime": 11000,
      "from": 0,
      "to": 1
    },
    {
      "target": "coin",
      "type": "opacity",
      "startTime": 11000,
      "endTime": 12000,
      "from": 0,
      "to": 1
    }
  ],
  "settings": {
    "loop": true,
    "autoplay": true,
    "showCaption": false,
    "showChapterList": true
  }
}
