{
  "version": 4,
  "id": "number-theory",
  "title": "Number Theory: GCD & Modular Inverse",
  "description": "유클리드 호제법으로 GCD 구하고, 확장 유클리드로 모듈러 역원 계산.",
  "category": "algorithm",
  "tags": ["math", "number-theory", "gcd", "modular"],
  "duration": 12500,
  "canvas": {
    "width": 900,
    "height": 500,
    "background": "transparent"
  },
  "elements": [
    {
      "id": "title-gcd",
      "type": "text",
      "x": 50,
      "y": 50,
      "text": "GCD(48, 18)",
      "fontSize": 20,
      "fill": "#0b0b0f",
      "fontWeight": "bold"
    },
    {
      "id": "step0",
      "type": "text",
      "x": 50,
      "y": 90,
      "text": "48 = 18 × 2 + 12",
      "fontSize": 16,
      "fill": "#475569",
      "opacity": 0
    },
    {
      "id": "step1",
      "type": "text",
      "x": 50,
      "y": 120,
      "text": "18 = 12 × 1 + 6",
      "fontSize": 16,
      "fill": "#475569",
      "opacity": 0
    },
    {
      "id": "step2",
      "type": "text",
      "x": 50,
      "y": 150,
      "text": "12 = 6 × 2 + 0",
      "fontSize": 16,
      "fill": "#475569",
      "opacity": 0
    },
    {
      "id": "result-gcd",
      "type": "text",
      "x": 50,
      "y": 190,
      "text": "→ GCD = 6",
      "fontSize": 18,
      "fill": "#16a34a",
      "fontWeight": "bold",
      "opacity": 0
    },
    {
      "id": "title-ext",
      "type": "text",
      "x": 400,
      "y": 50,
      "text": "Extended Euclidean",
      "fontSize": 20,
      "fill": "#0b0b0f",
      "fontWeight": "bold"
    },
    {
      "id": "ext0",
      "type": "text",
      "x": 400,
      "y": 90,
      "text": "6 = 18 - 12 × 1",
      "fontSize": 16,
      "fill": "#7c3aed",
      "opacity": 0
    },
    {
      "id": "ext1",
      "type": "text",
      "x": 400,
      "y": 120,
      "text": "6 = 18 - (48 - 18×2) × 1",
      "fontSize": 16,
      "fill": "#7c3aed",
      "opacity": 0
    },
    {
      "id": "ext2",
      "type": "text",
      "x": 400,
      "y": 150,
      "text": "6 = 48 × (-1) + 18 × 3",
      "fontSize": 16,
      "fill": "#7c3aed",
      "opacity": 0
    },
    {
      "id": "title-inv",
      "type": "text",
      "x": 50,
      "y": 280,
      "text": "Modular Inverse: 35^(-1) mod 1000000007",
      "fontSize": 18,
      "fill": "#0b0b0f",
      "fontWeight": "bold"
    },
    {
      "id": "inv-step",
      "type": "text",
      "x": 50,
      "y": 320,
      "text": "35 × x ≡ 1 (mod 10^9+7)",
      "fontSize": 16,
      "fill": "#2563eb",
      "opacity": 0
    },
    {
      "id": "inv-result",
      "type": "text",
      "x": 50,
      "y": 350,
      "text": "x = 142857145",
      "fontSize": 16,
      "fill": "#16a34a",
      "fontWeight": "bold",
      "opacity": 0
    },
    {
      "id": "box-gcd",
      "type": "rect",
