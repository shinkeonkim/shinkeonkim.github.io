{
  "version": 4,
  "id": "barrett-reduction",
  "title": "Barrett Reduction으로 나머지 연산 가속",
  "description": "느린 나눗셈 명령 대신 사전 계산된 상수와 곱셈, 시프트 연산으로 모듈러 연산을 빠르게 수행하는 방법을 시각화합니다.",
  "category": "algorithm",
  "tags": ["algorithm", "optimization"],
  "duration": 14000,
  "canvas": { "width": 900, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "title", "rotation": 0, "x": 450, "y": 28, "content": "Barrett Reduction: 나눗셈 없는 모듈러", "fontSize": 20, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 14000 }], "tracks": [] },
    { "type": "text", "id": "step", "rotation": 0, "x": 450, "y": 58, "content": "초기 상태", "fontSize": 13, "color": "#6366f1", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 14000 }], "tracks": [{ "property": "content", "keyframes": [{ "time": 0, "value": "초기 상태: x mod m" }, { "time": 3000, "value": "Naive: 나눗셈 명령" }, { "time": 6000, "value": "Barrett: 사전 계산" }, { "time": 9000, "value": "Barrett: 곱셈 + 시프트" }, { "time": 12000, "value": "성능 비교" }] }] },
    { "type": "text", "id": "equation", "rotation": 0, "x": 450, "y": 100, "content": "x mod m = ?", "fontSize": 18, "fontWeight": 600, "color": "#1e3a8a", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 14000 }], "tracks": [] },
    { "type": "rect", "id": "naive-box", "rotation": 0, "x": 100, "y": 150, "width": 250, "height": 60, "fill": "#fee2e2", "stroke": "#dc2626", "strokeWidth": 2, "cornerRadius": 8, "label": "div 명령", "subtitle": "~25 cycles", "labelColor": "#7f1d1d", "labelSize": 16, "appearances": [{ "start": 3000, "end": 14000, "entryMode": "fade", "entryDuration": 400 }], "tracks": [] },
    { "type": "rect", "id": "naive-timing", "rotation": 0, "x": 100, "y": 230, "width": 250, "height": 30, "fill": "#fee2e2", "stroke": "#dc2626", "strokeWidth": 2, "cornerRadius": 4, "label": "25 cycles", "labelColor": "#7f1d1d", "labelSize": 12, "appearances": [{ "start": 3000, "end": 14000, "entryMode": "slide-left", "entryDuration": 600 }], "tracks": [] },
    { "type": "text", "id": "barrett-title", "rotation": 0, "x": 600, "y": 140, "content": "Barrett 방식", "fontSize": 16, "fontWeight": 700, "color": "#5b21b6", "textAnchor": "middle", "appearances": [{ "start": 6000, "end": 14000, "entryMode": "fade", "entryDuration": 400 }], "tracks": [] },
    { "type": "rect", "id": "precompute", "rotation": 0, "x": 450, "y": 170, "width": 300, "height": 50, "fill": "#ede9fe", "stroke": "#7c3aed", "strokeWidth": 2, "cornerRadius": 6, "label": "M = floor(2^k / m)", "subtitle": "사전 계산 (1회)", "labelColor": "#5b21b6", "labelSize": 14, "appearances": [{ "start": 6000, "end": 14000, "entryMode": "slide-down", "entryDuration": 500 }], "tracks": [] },
    { "type": "rect", "id": "step1-mul", "rotation": 0, "x": 450, "y": 240, "width": 140, "height": 40, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 6, "label": "q = (x*M)>>k", "labelColor": "#14532d", "labelSize": 12, "appearances": [{ "start": 9000, "end": 14000, "entryMode": "slide-down", "entryDuration": 500 }], "tracks": [] },
    { "type": "rect", "id": "step2-sub", "rotation": 0, "x": 610, "y": 240, "width": 140, "height": 40, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 6, "label": "r = x - q*m", "labelColor": "#14532d", "labelSize": 12, "appearances": [{ "start": 9000, "end": 14000, "entryMode": "slide-down", "entryDuration": 500 }], "tracks": [] },
    { "type": "rect", "id": "step3-cond", "rotation": 0, "x": 530, "y": 295, "width": 140, "height": 40, "fill": "#fef9c3", "stroke": "#eab308", "strokeWidth": 2, "cornerRadius": 6, "label": "if r>=m: r-=m", "labelColor": "#713f12", "labelSize": 12, "appearances": [{ "start": 9000, "end": 14000, "entryMode": "slide-down", "entryDuration": 500 }], "tracks": [] },
    { "type": "rect", "id": "barrett-timing", "rotation": 0, "x": 450, "y": 360, "width": 50, "height": 30, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 4, "label": "~5", "labelColor": "#14532d", "labelSize": 12, "appearances": [{ "start": 9000, "end": 14000, "entryMode": "slide-left", "entryDuration": 600 }], "tracks": [] },
    { "type": "text", "id": "timing-label-naive", "rotation": 0, "x": 225, "y": 215, "content": "Naive 타이밍", "fontSize": 12, "fontWeight": 600, "color": "#0b0b0f", "textAnchor": "middle", "appearances": [{ "start": 3000, "end": 14000, "entryMode": "fade", "entryDuration": 400 }], "tracks": [] },
    { "type": "text", "id": "timing-label-barrett", "rotation": 0, "x": 475, "y": 345, "content": "Barrett 타이밍", "fontSize": 12, "fontWeight": 600, "color": "#0b0b0f", "textAnchor": "middle", "appearances": [{ "start": 9000, "end": 14000, "entryMode": "fade", "entryDuration": 400 }], "tracks": [] },
    { "type": "text", "id": "speedup", "rotation": 0, "x": 450, "y": 450, "content": "5배 가속", "fontSize": 18, "fontWeight": 700, "color": "#16a34a", "textAnchor": "middle", "appearances": [{ "start": 12000, "end": 14000, "entryMode": "zoom", "entryDuration": 500 }], "tracks": [] },
    { "type": "line", "id": "sep", "rotation": 0, "x1": 400, "y1": 150, "x2": 400, "y2": 400, "stroke": "#cbd5e1", "strokeWidth": 2, "appearances": [{ "start": 6000, "end": 14000, "entryMode": "fade", "entryDuration": 400 }], "tracks": [] }
  ],
  "chapters": [
    { "id": "init", "time": 0, "label": "초기 상태", "subtitle": "" },
    { "id": "naive", "time": 3000, "label": "Naive 나눗셈", "subtitle": "" },
    { "id": "precomp", "time": 6000, "label": "사전 계산", "subtitle": "" },
    { "id": "barrett", "time": 9000, "label": "Barrett 연산", "subtitle": "" },
    { "id": "compare", "time": 12000, "label": "성능 비교", "subtitle": "" }
  ],
  "effects": [
    { "type": "pulse", "id": "p1", "elementId": "naive-box", "time": 3500, "scale": 1.05, "duration": 500 },
    { "type": "highlight", "id": "h1", "elementId": "precompute", "time": 6500, "color": "#facc15", "duration": 700 },
    { "type": "pulse", "id": "p2", "elementId": "step1-mul", "time": 9500, "scale": 1.1, "duration": 400 },
    { "type": "pulse", "id": "p3", "elementId": "speedup", "time": 12500, "scale": 1.15, "duration": 600 }
  ],
  "settings": { "loop": true, "autoplay": true, "showCaption": false, "showChapterList": true }
}
