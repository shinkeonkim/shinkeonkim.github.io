{
  "version": 4,
  "id": "discrete-log",
  "title": "이산 로그 - Baby-step Giant-step",
  "description": "2^x ≡ 3 (mod 5), m=⌈√5⌉=3. baby step: 2^0..2^2, giant step: 3·(2^{-3})^i",
  "category": "algorithm",
  "tags": ["discrete-log", "number-theory", "math"],
  "duration": 13000,
  "canvas": { "width": 900, "height": 500, "background": "transparent" },
  "elements": [
    {
      "id": "title", "type": "text", "x": 450, "y": 30,
      "text": "BSGS: 2^x ≡ 3 (mod 5)", "fontSize": 20, "fontWeight": "bold",
      "fill": "#0b0b0f", "textAlign": "center"
    },
    {
      "id": "formula", "type": "text", "x": 450, "y": 60,
      "text": "x = i·m + j, m = ⌈√5⌉ = 3", "fontSize": 16, "fill": "#475569", "textAlign": "center"
    },
    {
      "id": "baby-label", "type": "text", "x": 50, "y": 100,
      "text": "Baby step (a^j mod m)", "fontSize": 16, "fill": "#1e3a8a", "fontWeight": "bold"
    },
    {
      "id": "baby-j0", "type": "rect", "x": 50, "y": 125, "width": 120, "height": 40,
      "fill": "#dbeafe", "stroke": "#2563eb", "strokeWidth": 2, "rx": 4
    },
    {
      "id": "baby-j0-text", "type": "text", "x": 110, "y": 150,
      "text": "j=0: 2^0=1", "fontSize": 14, "fill": "#1e3a8a", "textAlign": "center"
    },
    {
      "id": "baby-j1", "type": "rect", "x": 190, "y": 125, "width": 120, "height": 40,
      "fill": "#dbeafe", "stroke": "#2563eb", "strokeWidth": 2, "rx": 4
    },
    {
      "id": "baby-j1-text", "type": "text", "x": 250, "y": 150,
      "text": "j=1: 2^1=2", "fontSize": 14, "fill": "#1e3a8a", "textAlign": "center"
    },
    {
      "id": "baby-j2", "type": "rect", "x": 330, "y": 125, "width": 120, "height": 40,
      "fill": "#dbeafe", "stroke": "#2563eb", "strokeWidth": 2, "rx": 4
    },
    {
      "id": "baby-j2-text", "type": "text", "x": 390, "y": 150,
      "text": "j=2: 2^2=4", "fontSize": 14, "fill": "#1e3a8a", "textAlign": "center"
    },
    {
      "id": "table-box", "type": "rect", "x": 50, "y": 190, "width": 400, "height": 80,
      "fill": "#fef9c3", "stroke": "#eab308", "strokeWidth": 2, "rx": 4
    },
    {
      "id": "table-text", "type": "text", "x": 250, "y": 215,
      "text": "hash: {1→0, 2→1, 4→2}", "fontSize": 16, "fill": "#713f12", "textAlign": "center", "fontWeight": "bold"
    },
    {
      "id": "giant-label", "type": "text", "x": 500, "y": 100,
      "text": "Giant step (b·f^i mod m)", "fontSize": 16, "fill": "#14532d", "fontWeight": "bold"
    },
    {
      "id": "giant-i0", "type": "rect", "x": 500, "y": 125, "width": 140, "height": 40,
      "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "rx": 4
    },
    {
      "id": "giant-i0-text", "type": "text", "x": 570, "y": 150,
      "text": "i=0: 3", "fontSize": 14, "fill": "#14532d", "textAlign": "center"
    },
    {
      "id": "giant-i1", "type": "rect", "x": 660, "y": 125, "width": 140, "height": 40,
      "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "rx": 4
    },
    {
      "id": "giant-i1-text", "type": "text", "x": 730, "y": 150,
      "text": "i=1: 1", "fontSize": 14, "fill": "#14532d", "textAlign": "center"
    },
    {
      "id": "match-arrow", "type": "line", "x1": 730, "y1": 125, "x2": 110, "y2": 125,
      "stroke": "#dc2626", "strokeWidth": 3, "markerEnd": "arrow", "opacity": 0
    },
    {
      "id": "result-box", "type": "rect", "x": 200, "y": 310, "width": 500, "height": 80,
      "fill": "#ede9fe", "stroke": "#7c3aed", "strokeWidth": 3, "rx": 6, "opacity": 0
    },
    {
      "id": "result-text", "type": "text", "x": 450, "y": 355,
      "text": "match: i=1, j=0 → x = 1·3 + 0 = 3", "fontSize": 18, "fontWeight": "bold", "fill": "#5b21b6", "textAlign": "center", "opacity": 0
    }
  ],
  "chapters": [
    {
      "id": "intro", "title": "문제", "startTime": 0, "endTime": 2000,
      "caption": "2^x ≡ 3 (mod 5), m=⌈√5⌉=3"
    },
    {
      "id": "baby", "title": "Baby step", "startTime": 2000, "endTime": 5500,
      "caption": "2^0, 2^1, 2^2 mod 5 저장"
    },
    {
      "id": "giant", "title": "Giant step", "startTime": 5500, "endTime": 9000,
      "caption": "3·2^(-3)^i mod 5 확인"
    },
    {
      "id": "match", "title": "매칭", "startTime": 9000, "endTime": 11500,
      "caption": "i=1 일때 1 매칭 → j=0"
    },
    {
      "id": "conclude", "title": "결과", "startTime": 11500, "endTime": 13000,
      "caption": "x = 3. 2^3 mod 5 = 8 mod 5 = 3. O(√m) 시간."
    }
  ],
  "effects": [
    {
      "id": "highlight-baby", "elementId": "baby-label",
      "type": "highlight", "startTime": 2000, "duration": 1000, "color": "#2563eb"
    },
    {
      "id": "fade-baby-j0", "elementId": "baby-j0", "type": "fade", "startTime": 2200, "duration": 300, "from": 0, "to": 1
    },
    {
      "id": "fade-baby-j1", "elementId": "baby-j1", "type": "fade", "startTime": 3000, "duration": 300, "from": 0, "to": 1
    },
    {
      "id": "fade-baby-j2", "elementId": "baby-j2", "type": "fade", "startTime": 3800, "duration": 300, "from": 0, "to": 1
    },
    {
      "id": "highlight-giant", "elementId": "giant-label",
      "type": "highlight", "startTime": 5500, "duration": 1000, "color": "#16a34a"
    },
    {
      "id": "fade-giant-i0", "elementId": "giant-i0", "type": "fade", "startTime": 5700, "duration": 300, "from": 0, "to": 1
    },
    {
      "id": "fade-giant-i1", "elementId": "giant-i1", "type": "fade", "startTime": 6500, "duration": 300, "from": 0, "to": 1
    },
    {
      "id": "show-match", "elementId": "match-arrow", "type": "fade", "startTime": 9000, "duration": 500, "from": 0, "to": 1
    },
    {
      "id": "show-result", "elementId": "result-box", "type": "scale", "startTime": 11500, "duration": 600, "from": 0.8, "to": 1
    },
    {
      "id": "show-result-text", "elementId": "result-text", "type": "fade", "startTime": 11500, "duration": 600, "from": 0, "to": 1
    }
  ],
  "settings": { "loop": true, "autoplay": true, "showCaption": false, "showChapterList": true }
}
