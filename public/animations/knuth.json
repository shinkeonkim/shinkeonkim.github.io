{
  "version": 4,
  "id": "knuth",
  "title": "Knuth Optimization",
  "description": "크누스 최적화로 구간 DP O(N^3) -> O(N^2). DP 테이블을 구간 길이 순으로 채우며, 각 dp[i][j]의 k 탐색 범위를 opt[i][j-1] <= k <= opt[i+1][j] 로 제한한다.",
  "category": "algorithm",
  "tags": ["algorithm", "dp", "optimization", "divide-and-conquer"],
  "duration": 13000,
  "canvas": { "width": 900, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "title", "rotation": 0, "x": 450, "y": 25, "content": "Knuth Optimization: O(N^3) -> O(N^2)", "fontSize": 18, "fontWeight": 700, "color": "#0b0b0f", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "text", "id": "dp-label", "rotation": 0, "x": 450, "y": 52, "content": "dp[i][j] = min(dp[i][k] + dp[k+1][j]) + C[i][j]", "fontSize": 13, "color": "#475569", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "line", "id": "table-grid", "rotation": 0, "x1": 80, "y1": 80, "x2": 520, "y2": 80, "stroke": "#cbd5e1", "strokeWidth": 1, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "rect", "id": "dp-cell-11", "rotation": 0, "x": 100, "y": 80, "width": 60, "height": 40, "fill": "#e2e8f0", "stroke": "#94a3b8", "strokeWidth": 1, "cornerRadius": 0, "label": "1,1", "labelColor": "#0b0b0f", "labelSize": 14, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "rect", "id": "dp-cell-12", "rotation": 0, "x": 160, "y": 80, "width": 60, "height": 40, "fill": "#e2e8f0", "stroke": "#94a3b8", "strokeWidth": 1, "cornerRadius": 0, "label": "1,2", "labelColor": "#0b0b0f", "labelSize": 14, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "rect", "id": "dp-cell-13", "rotation": 0, "x": 220, "y": 80, "width": 60, "height": 40, "fill": "#e2e8f0", "stroke": "#94a3b8", "strokeWidth": 1, "cornerRadius": 0, "label": "1,3", "labelColor": "#0b0b0f", "labelSize": 14, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "rect", "id": "dp-cell-14", "rotation": 0, "x": 280, "y": 80, "width": 60, "height": 40, "fill": "#e2e8f0", "stroke": "#94a3b8", "strokeWidth": 1, "cornerRadius": 0, "label": "1,4", "labelColor": "#0b0b0f", "labelSize": 14, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "rect", "id": "dp-cell-22", "rotation": 0, "x": 160, "y": 120, "width": 60, "height": 40, "fill": "#e2e8f0", "stroke": "#94a3b8", "strokeWidth": 1, "cornerRadius": 0, "label": "2,2", "labelColor": "#0b0b0f", "labelSize": 14, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "rect", "id": "dp-cell-23", "rotation": 0, "x": 220, "y": 120, "width": 60, "height": 40, "fill": "#e2e8f0", "stroke": "#94a3b8", "strokeWidth": 1, "cornerRadius": 0, "label": "2,3", "labelColor": "#0b0b0f", "labelSize": 14, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "rect", "id": "dp-cell-24", "rotation": 0, "x": 280, "y": 120, "width": 60, "height": 40, "fill": "#e2e8f0", "stroke": "#94a3b8", "strokeWidth": 1, "cornerRadius": 0, "label": "2,4", "labelColor": "#0b0b0f", "labelSize": 14, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "rect", "id": "dp-cell-33", "rotation": 0, "x": 220, "y": 160, "width": 60, "height": 40, "fill": "#e2e8f0", "stroke": "#94a3b8", "strokeWidth": 1, "cornerRadius": 0, "label": "3,3", "labelColor": "#0b0b0f", "labelSize": 14, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "rect", "id": "dp-cell-34", "rotation": 0, "x": 280, "y": 160, "width": 60, "height": 40, "fill": "#e2e8f0", "stroke": "#94a3b8", "strokeWidth": 1, "cornerRadius": 0, "label": "3,4", "labelColor": "#0b0b0f", "labelSize": 14, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "rect", "id": "dp-cell-44", "rotation": 0, "x": 280, "y": 200, "width": 60, "height": 40, "fill": "#e2e8f0", "stroke": "#94a3b8", "strokeWidth": 1, "cornerRadius": 0, "label": "4,4", "labelColor": "#0b0b0f", "labelSize": 14, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "rect", "id": "opt-range-box", "rotation": 0, "x": 160, "y": 80, "width": 60, "height": 40, "fill": "#fef9c3", "stroke": "#eab308", "strokeWidth": 2, "cornerRadius": 0, "label": "", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [{ "property": "x", "keyframes": [{ "time": 500, "value": 160 }, { "time": 3500, "value": 220 }, { "time": 6500, "value": 160 }, { "time": 9500, "value": 160 }] }, { "property": "width", "keyframes": [{ "time": 500, "value": 60 }, { "time": 3500, "value": 120 }, { "time": 6500, "value": 60 }, { "time": 9500, "value": 180 }] }] },
    { "type": "text", "id": "k-range-label", "rotation": 0, "x": 650, "y": 90, "content": "k in [opt[i][j-1], opt[i+1][j]]", "fontSize": 14, "fontWeight": 600, "color": "#713f12", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [{ "property": "content", "keyframes": [{ "time": 500, "value": "len=2: dp[1][2], k in [1,2]" }, { "time": 3500, "value": "len=3: dp[1][3], k in [1, min(2, opt[2][3])]" }, { "time": 6500, "value": "len=3: dp[2][4], k in [opt[2][3]=2, min(3, opt[3][4]=3)]" }, { "time": 9500, "value": "len=4: dp[1][4], k in [opt[1][3]=1, opt[2][4]=3]" }] }] },
    { "type": "text", "id": "opt-explanation", "rotation": 0, "x": 650, "y": 130, "content": "opt[i][j-1] <= opt[i][j] <= opt[i+1][j]", "fontSize": 13, "color": "#7c3aed", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "text", "id": "fill-status", "rotation": 0, "x": 450, "y": 270, "content": "Now filling: len=2", "fontSize": 14, "fontWeight": 600, "color": "#2563eb", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [{ "property": "content", "keyframes": [{ "time": 0, "value": "Fill base: dp[i][i]=0, opt[i][i]=i" }, { "time": 500, "value": "Now filling: len=2" }, { "time": 3500, "value": "Now filling: len=3" }, { "time": 6500, "value": "Now filling: len=3 (next i)" }, { "time": 9500, "value": "Now filling: len=4" }] }] },
    { "type": "rect", "id": "inequality-box", "rotation": 0, "x": 100, "y": 320, "width": 700, "height": 70, "fill": "#ede9fe", "stroke": "#7c3aed", "strokeWidth": 2, "cornerRadius": 6, "label": "Quadrangle Inequality: C[a][c] + C[b][d] <= C[a][d] + C[b][c] for a <= b <= c <= d", "labelColor": "#5b21b6", "labelSize": 14, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "rect", "id": "result-box", "rotation": 0, "x": 100, "y": 420, "width": 300, "height": 50, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 6, "label": "dp[1][4] = 300", "labelColor": "#14532d", "labelSize": 16, "appearances": [{ "start": 9500, "end": 13000 }], "tracks": [] },
    { "type": "text", "id": "arrow-left", "rotation": 0, "x": 155, "y": 240, "content": "opt[i][j-1]", "fontSize": 11, "color": "#7c3aed", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [{ "property": "opacity", "keyframes": [{ "time": 0, "value": 0 }, { "time": 9500, "value": 1 }] }] },
    { "type": "text", "id": "arrow-right", "rotation": 0, "x": 285, "y": 240, "content": "opt[i+1][j]", "fontSize": 11, "color": "#7c3aed", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [{ "property": "opacity", "keyframes": [{ "time": 0, "value": 0 }, { "time": 9500, "value": 1 }] }] }
  ],
  "chapters": [
    { "id": "base", "time": 0, "label": "Base", "subtitle": "dp[i][i] = 0, opt[i][i] = i" },
    { "id": "len2", "time": 500, "label": "Length 2", "subtitle": "dp[1][2], dp[2][3], dp[3][4]" },
    { "id": "len3", "time": 3500, "label": "Length 3", "subtitle": "dp[1][3], dp[2][4]" },
    { "id": "len4", "time": 9500, "label": "Length 4", "subtitle": "dp[1][4] 완성" }
  ],
  "effects": [
    { "type": "highlight", "id": "e1", "elementId": "opt-range-box", "time": 500, "color": "#fef08a", "duration": 600 },
    { "type": "pulse", "id": "e2", "elementId": "inequality-box", "time": 2000, "scale": 1.05, "duration": 400 },
    { "type": "highlight", "id": "e3", "elementId": "dp-cell-14", "time": 9500, "color": "#bbf7d0", "duration": 800 },
    { "type": "pulse", "id": "e4", "elementId": "result-box", "time": 10000, "scale": 1.1, "duration": 500 }
  ],
  "settings": { "loop": true, "autoplay": true, "showCaption": false, "showChapterList": true }
}
