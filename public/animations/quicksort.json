{
  "version": 2,
  "id": "quicksort",
  "title": "퀵 정렬 (Quicksort) — Partition",
  "description": "첫 원소를 pivot 으로 잡고 좌(작은) / 우(큰) 으로 분할하는 한 단계 시각화",
  "category": "algorithm",
  "tags": ["quicksort", "sorting", "algorithm", "divide-and-conquer"],
  "canvas": { "width": 800, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "step-label", "rotation": 0, "x": 400, "y": 32, "content": "Quicksort partition — pivot = 첫 원소", "fontSize": 18, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle" },

    { "type": "text", "id": "input-label", "rotation": 0, "x": 70, "y": 130, "content": "입력", "fontSize": 13, "fontWeight": 700, "color": "#64748b", "textAnchor": "start" },
    { "type": "rect", "id": "n0", "rotation": 0, "x": 180, "y": 100, "width": 60, "height": 60, "fill": "#a78bfa", "stroke": "#7c3aed", "strokeWidth": 2, "cornerRadius": 8, "label": "5", "labelColor": "#1e1b4b", "labelSize": 22 },
    { "type": "rect", "id": "n1", "rotation": 0, "x": 245, "y": 100, "width": 60, "height": 60, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 8, "label": "2", "labelColor": "#312e81", "labelSize": 22 },
    { "type": "rect", "id": "n2", "rotation": 0, "x": 310, "y": 100, "width": 60, "height": 60, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 8, "label": "8", "labelColor": "#312e81", "labelSize": 22 },
    { "type": "rect", "id": "n3", "rotation": 0, "x": 375, "y": 100, "width": 60, "height": 60, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 8, "label": "1", "labelColor": "#312e81", "labelSize": 22 },
    { "type": "rect", "id": "n4", "rotation": 0, "x": 440, "y": 100, "width": 60, "height": 60, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 8, "label": "9", "labelColor": "#312e81", "labelSize": 22 },
    { "type": "rect", "id": "n5", "rotation": 0, "x": 505, "y": 100, "width": 60, "height": 60, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 8, "label": "3", "labelColor": "#312e81", "labelSize": 22 },
    { "type": "rect", "id": "n6", "rotation": 0, "x": 570, "y": 100, "width": 60, "height": 60, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 8, "label": "7", "labelColor": "#312e81", "labelSize": 22 },

    { "type": "text", "id": "pivot-label", "rotation": 0, "x": 70, "y": 250, "content": "pivot", "fontSize": 13, "fontWeight": 700, "color": "#7c3aed", "textAnchor": "start" },
    { "type": "text", "id": "less-label", "rotation": 0, "x": 70, "y": 350, "content": "< pivot", "fontSize": 13, "fontWeight": 700, "color": "#0284c7", "textAnchor": "start" },
    { "type": "text", "id": "greater-label", "rotation": 0, "x": 70, "y": 440, "content": "> pivot", "fontSize": 13, "fontWeight": 700, "color": "#ea580c", "textAnchor": "start" },
    { "type": "rect", "id": "pivot-zone", "rotation": 0, "x": 380, "y": 220, "width": 60, "height": 60, "fill": "#f5f3ff", "stroke": "#c4b5fd", "strokeWidth": 1.5, "strokeDasharray": "4 4", "cornerRadius": 8, "label": "", "labelColor": "#64748b", "labelSize": 12 },
    { "type": "rect", "id": "less-zone", "rotation": 0, "x": 180, "y": 320, "width": 200, "height": 60, "fill": "#f0f9ff", "stroke": "#bae6fd", "strokeWidth": 1.5, "strokeDasharray": "4 4", "cornerRadius": 8, "label": "", "labelColor": "#64748b", "labelSize": 12 },
    { "type": "rect", "id": "greater-zone", "rotation": 0, "x": 440, "y": 410, "width": 200, "height": 60, "fill": "#fff7ed", "stroke": "#fed7aa", "strokeWidth": 1.5, "strokeDasharray": "4 4", "cornerRadius": 8, "label": "", "labelColor": "#64748b", "labelSize": 12 }
  ],
  "initiallyHidden": [],
  "steps": [
    { "id": "s1", "label": "pivot 분리", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "n0": { "x": 380, "y": 220 },
        "step-label": { "content": "pivot = 5 — 별도 위치로" }
      },
      "effects": [{ "type": "pulse", "elementId": "n0", "scale": 1.2, "duration": 500, "delay": 0 }] },
    { "id": "s2", "label": "2 < 5", "duration": 700, "ease": "easeOut",
      "keyframes": {
        "n1": { "x": 190, "y": 330, "fill": "#7dd3fc", "stroke": "#0284c7" },
        "step-label": { "content": "2 < 5 → 왼쪽 (< pivot)" }
      },
      "effects": [{ "type": "pulse", "elementId": "n1", "scale": 1.15, "duration": 400, "delay": 0 }] },
    { "id": "s3", "label": "8 > 5", "duration": 700, "ease": "easeOut",
      "keyframes": {
        "n2": { "x": 450, "y": 420, "fill": "#fdba74", "stroke": "#ea580c" },
        "step-label": { "content": "8 > 5 → 오른쪽 (> pivot)" }
      },
      "effects": [{ "type": "pulse", "elementId": "n2", "scale": 1.15, "duration": 400, "delay": 0 }] },
    { "id": "s4", "label": "1 < 5", "duration": 700, "ease": "easeOut",
      "keyframes": {
        "n3": { "x": 255, "y": 330, "fill": "#7dd3fc", "stroke": "#0284c7" },
        "step-label": { "content": "1 < 5 → 왼쪽" }
      },
      "effects": [{ "type": "pulse", "elementId": "n3", "scale": 1.15, "duration": 400, "delay": 0 }] },
    { "id": "s5", "label": "9 > 5", "duration": 700, "ease": "easeOut",
      "keyframes": {
        "n4": { "x": 515, "y": 420, "fill": "#fdba74", "stroke": "#ea580c" },
        "step-label": { "content": "9 > 5 → 오른쪽" }
      },
      "effects": [{ "type": "pulse", "elementId": "n4", "scale": 1.15, "duration": 400, "delay": 0 }] },
    { "id": "s6", "label": "3 < 5", "duration": 700, "ease": "easeOut",
      "keyframes": {
        "n5": { "x": 320, "y": 330, "fill": "#7dd3fc", "stroke": "#0284c7" },
        "step-label": { "content": "3 < 5 → 왼쪽" }
      },
      "effects": [{ "type": "pulse", "elementId": "n5", "scale": 1.15, "duration": 400, "delay": 0 }] },
    { "id": "s7", "label": "7 > 5", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "n6": { "x": 580, "y": 420, "fill": "#fdba74", "stroke": "#ea580c" },
        "step-label": { "content": "✓ partition 완료 — 좌:[2,1,3] | 5 | 우:[8,9,7]" }
      },
      "effects": [
        { "type": "pulse", "elementId": "n6", "scale": 1.15, "duration": 400, "delay": 0 },
        { "type": "highlight", "elementId": "step-label", "color": "#34d399", "duration": 700, "delay": 300 }
      ] },
    { "id": "s8", "label": "재시작", "duration": 600, "ease": "linear",
      "keyframes": {
        "n0": { "x": 180, "y": 100 },
        "n1": { "x": 245, "y": 100, "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n2": { "x": 310, "y": 100, "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n3": { "x": 375, "y": 100, "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n4": { "x": 440, "y": 100, "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n5": { "x": 505, "y": 100, "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n6": { "x": 570, "y": 100, "fill": "#e0e7ff", "stroke": "#6366f1" },
        "step-label": { "content": "Quicksort partition — pivot = 첫 원소" }
      },
      "effects": [] }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 200 }
}
