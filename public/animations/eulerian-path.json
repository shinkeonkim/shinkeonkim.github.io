    },
    {
      "id": "v2",
      "type": "circle",
      "x": 300,
      "y": 250,
      "radius": 25,
      "fill": "#e2e8f0",
      "stroke": "#475569",
      "strokeWidth": 2
    },
    {
      "id": "v2-label",
      "type": "text",
      "content": "3",
      "x": 300,
      "y": 250,
      "fontSize": 16,
      "fill": "#0b0b0f",
      "textAnchor": "middle",
      "dominantBaseline": "middle"
    },
    {
      "id": "v3",
      "type": "circle",
      "x": 150,
      "y": 250,
      "radius": 25,
      "fill": "#e2e8f0",
      "stroke": "#475569",
      "strokeWidth": 2
