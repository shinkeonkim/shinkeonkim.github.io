{
  "version": 4,
  "id": "eulerian-path",
  "title": "오일러 경로/회로",
  "description": "Hierholzer 알고리즘으로 모든 간선을 한 번씩 방문 (O(V+E))",
  "category": "algorithm",
  "tags": ["graph", "traversal", "eulerian"],
  "duration": 14000,
  "canvas": {
    "width": 900,
    "height": 500,
    "background": "transparent"
  },
  "elements": [
