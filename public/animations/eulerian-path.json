      "id": "graph-label",
      "type": "text",
      "content": "Graph (모든 차수 짝수)",
      "x": 200,
      "y": 30,
      "fontSize": 18,
      "fontWeight": "bold",
      "fill": "#0b0b0f"
    },
    {
      "id": "v0",
      "type": "circle",
      "x": 150,
      "y": 120,
      "radius": 25,
      "fill": "#e2e8f0",
      "stroke": "#475569",
      "strokeWidth": 2
    },
    {
      "id": "v0-label",
      "type": "text",
      "content": "1",
      "x": 150,
      "y": 120,
      "fontSize": 16,
      "fill": "#0b0b0f",
      "textAnchor": "middle",
      "dominantBaseline": "middle"
    },
    {
      "id": "v1",
