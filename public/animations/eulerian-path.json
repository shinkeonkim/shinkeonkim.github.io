  "chapters": [
    {
      "id": "init",
      "title": "초기 상태",
      "startTime": 0,
      "endTime": 2000,
      "caption": "스택에 시작 정점 push"
    },
    {
      "id": "step1",
      "title": "간선 1-2",
      "startTime": 2000,
      "endTime": 4000,
      "caption": "간선 방문 후 스택 push"
    },
    {
      "id": "step2",
      "title": "간선 2-3",
      "startTime": 4000,
      "endTime": 6000,
      "caption": "간선 방문 계속"
    },
    {
      "id": "step3",
      "title": "간선 3-4",
      "startTime": 6000,
      "endTime": 8000,
      "caption": "간선 방문 계속"
    },
    {
      "id": "backtrack",
      "title": "역추적",
      "startTime": 8000,
      "endTime": 12000,
      "caption": "미방문 간선 없으면 path에 추가"
    },
    {
      "id": "result",
      "title": "완료",
      "startTime": 12000,
      "endTime": 14000,
      "caption": "오일러 회로: 1 → 2 → 3 → 4 → 1"
    }
