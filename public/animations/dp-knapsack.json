{
  "version": 2,
  "id": "dp-knapsack",
  "title": "0/1 Knapsack (DP)",
  "description": "Dynamic Programming approach to 0/1 Knapsack using a 1D array.",
  "category": "algorithm",
  "tags": ["dp", "knapsack", "optimization"],
  "canvas": { "width": 800, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "cap-labels", "x": 100, "y": 170, "content": "Cap: 0     1     2     3     4     5", "fontSize": 18, "textAnchor": "start" },
    { "type": "rect", "id": "dp-0", "x": 100, "y": 200, "width": 50, "height": 50, "label": "0", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "dp-1", "x": 160, "y": 200, "width": 50, "height": 50, "label": "0", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "dp-2", "x": 220, "y": 200, "width": 50, "height": 50, "label": "0", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "dp-3", "x": 280, "y": 200, "width": 50, "height": 50, "label": "0", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "dp-4", "x": 340, "y": 200, "width": 50, "height": 50, "label": "0", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "dp-5", "x": 400, "y": 200, "width": 50, "height": 50, "label": "0", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "text", "id": "info", "x": 400, "y": 100, "content": "Initial DP Array", "fontSize": 24, "textAnchor": "middle" },
    { "type": "rect", "id": "item-1", "x": 600, "y": 150, "width": 120, "height": 40, "label": "Item 1 (w:2, v:3)", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "item-2", "x": 600, "y": 210, "width": 120, "height": 40, "label": "Item 2 (w:3, v:4)", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "item-3", "x": 600, "y": 270, "width": 120, "height": 40, "label": "Item 3 (w:4, v:5)", "fill": "#e0e7ff", "stroke": "#6366f1" }
  ],
  "initiallyHidden": [],
  "steps": [
    {
      "id": "step-0",
      "label": "Process Item 1",
      "duration": 800,
      "ease": "easeInOut",
      "keyframes": {
        "info": { "content": "Item 1 (w:2, v:3) => update capacities >= 2" },
        "item-1": { "fill": "#fbbf24", "stroke": "#d97706" }
      },
      "effects": []
    },
    {
      "id": "step-1",
      "label": "Update DP for Item 1",
      "duration": 800,
      "ease": "easeInOut",
      "keyframes": {
        "dp-2": { "label": "3", "fill": "#34d399", "stroke": "#059669" },
        "dp-3": { "label": "3", "fill": "#34d399", "stroke": "#059669" },
        "dp-4": { "label": "3", "fill": "#34d399", "stroke": "#059669" },
        "dp-5": { "label": "3", "fill": "#34d399", "stroke": "#059669" }
      },
      "effects": []
    },
    {
      "id": "step-2",
      "label": "Process Item 2",
      "duration": 800,
      "ease": "easeInOut",
      "keyframes": {
        "info": { "content": "Item 2 (w:3, v:4) => update capacities >= 3" },
        "item-1": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "item-2": { "fill": "#fbbf24", "stroke": "#d97706" },
        "dp-2": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "dp-3": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "dp-4": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "dp-5": { "fill": "#e0e7ff", "stroke": "#6366f1" }
      },
      "effects": []
    },
    {
      "id": "step-3",
      "label": "Update DP for Item 2",
      "duration": 800,
      "ease": "easeInOut",
      "keyframes": {
        "info": { "content": "dp[5]=max(3, dp[2]+4=7), dp[4]=4, dp[3]=4" },
        "dp-3": { "label": "4", "fill": "#34d399", "stroke": "#059669" },
        "dp-4": { "label": "4", "fill": "#34d399", "stroke": "#059669" },
        "dp-5": { "label": "7", "fill": "#34d399", "stroke": "#059669" }
      },
      "effects": []
    },
    {
      "id": "step-4",
      "label": "Process Item 3",
      "duration": 800,
      "ease": "easeInOut",
      "keyframes": {
        "info": { "content": "Item 3 (w:4, v:5) => dp[4]=max(4, dp[0]+5=5)" },
        "item-2": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "item-3": { "fill": "#fbbf24", "stroke": "#d97706" },
        "dp-3": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "dp-4": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "dp-5": { "fill": "#e0e7ff", "stroke": "#6366f1" }
      },
      "effects": []
    },
    {
      "id": "step-5",
      "label": "Update DP for Item 3",
      "duration": 800,
      "ease": "easeInOut",
      "keyframes": {
        "dp-4": { "label": "5", "fill": "#34d399", "stroke": "#059669" }
      },
      "effects": []
    },
    {
      "id": "step-6",
      "label": "Reset",
      "duration": 800,
      "ease": "easeInOut",
      "keyframes": {
        "info": { "content": "Initial DP Array" },
        "item-3": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "dp-2": { "label": "0", "fill": "#e0e7ff", "stroke": "#6366f1" },
        "dp-3": { "label": "0", "fill": "#e0e7ff", "stroke": "#6366f1" },
        "dp-4": { "label": "0", "fill": "#e0e7ff", "stroke": "#6366f1" },
        "dp-5": { "label": "0", "fill": "#e0e7ff", "stroke": "#6366f1" }
      },
      "effects": []
    }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 200 }
}
