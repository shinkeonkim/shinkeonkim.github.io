{
  "version": 2,
  "id": "db-replication",
  "title": "DB Primary-Replica 복제",
  "description": "Primary 에 쓰기 → Replica 들에 WAL 스트림 복제",
  "category": "architecture",
  "tags": ["database", "replication", "primary", "replica"],
  "canvas": { "width": 800, "height": 460, "background": "transparent" },
  "elements": [
    { "type": "rect", "id": "app", "rotation": 0, "x": 60, "y": 200, "width": 130, "height": 70, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 10, "label": "App", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "rect", "id": "primary", "rotation": 0, "x": 320, "y": 200, "width": 140, "height": 80, "fill": "#fef3c7", "stroke": "#d97706", "strokeWidth": 2.5, "cornerRadius": 10, "label": "Primary", "labelColor": "#78350f", "labelSize": 16, "subtitle": "read+write" },
    { "type": "rect", "id": "replica1", "rotation": 0, "x": 580, "y": 70, "width": 140, "height": 70, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 10, "label": "Replica 1", "labelColor": "#14532d", "labelSize": 15, "subtitle": "read-only" },
    { "type": "rect", "id": "replica2", "rotation": 0, "x": 580, "y": 340, "width": 140, "height": 70, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 10, "label": "Replica 2", "labelColor": "#14532d", "labelSize": 15, "subtitle": "read-only" },
    { "type": "circle", "id": "write", "rotation": 0, "cx": 125, "cy": 235, "r": 10, "fill": "#dc2626", "stroke": "#7f1d1d", "strokeWidth": 2 },
    { "type": "circle", "id": "wal1", "rotation": 0, "cx": 390, "cy": 240, "r": 8, "fill": "#16a34a", "stroke": "#14532d", "strokeWidth": 2 },
    { "type": "circle", "id": "wal2", "rotation": 0, "cx": 390, "cy": 240, "r": 8, "fill": "#16a34a", "stroke": "#14532d", "strokeWidth": 2 },
    { "type": "text", "id": "step-label", "rotation": 0, "x": 400, "y": 45, "content": "1. App 이 쓰기 요청", "fontSize": 20, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle" }
  ],
  "initiallyHidden": ["wal1", "wal2"],
  "steps": [
    { "id": "s1", "label": "App → Primary INSERT", "duration": 900, "ease": "easeInOut",
      "keyframes": { "write": { "cx": 390 }, "step-label": { "content": "2. Primary 에 INSERT" } },
      "effects": [{ "type": "highlight", "elementId": "primary", "color": "#fbbf24", "duration": 600, "delay": 0 }] },
    { "id": "s2", "label": "Primary → App ACK", "duration": 700, "ease": "easeInOut",
      "keyframes": { "write": { "cx": 125, "fill": "#34d399" }, "wal1": { "visible": true }, "wal2": { "visible": true }, "step-label": { "content": "3. ACK + WAL 스트림 시작" } },
      "effects": [] },
    { "id": "s3", "label": "WAL → Replicas", "duration": 1200, "ease": "easeInOut",
      "keyframes": { "wal1": { "cx": 650, "cy": 105 }, "wal2": { "cx": 650, "cy": 375 }, "step-label": { "content": "4. 변경 사항을 Replica 들에 복제" } },
      "effects": [
        { "type": "highlight", "elementId": "replica1", "color": "#86efac", "duration": 600, "delay": 200 },
        { "type": "highlight", "elementId": "replica2", "color": "#86efac", "duration": 600, "delay": 400 }
      ] },
    { "id": "s4", "label": "complete", "duration": 600, "ease": "easeOut",
      "keyframes": { "wal1": { "visible": false }, "wal2": { "visible": false }, "step-label": { "content": "✓ 복제 완료" } },
      "effects": [] },
    { "id": "s5", "label": "재시작", "duration": 500, "ease": "linear",
      "keyframes": { "write": { "cx": 125, "fill": "#dc2626" }, "wal1": { "cx": 390, "cy": 240, "visible": false }, "wal2": { "cx": 390, "cy": 240, "visible": false }, "step-label": { "content": "1. App 이 쓰기 요청" } },
      "effects": [] }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 200 }
}
