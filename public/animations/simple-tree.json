{
  "version": 2,
  "id": "simple-tree",
  "title": "이진 트리 BFS 순회",
  "description": "루트에서 시작해 너비 우선 (level order)으로 노드 방문",
  "category": "algorithm",
  "tags": ["tree", "bfs", "algorithm", "traversal"],
  "canvas": { "width": 800, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "step-label", "rotation": 0, "x": 400, "y": 32, "content": "BFS: 큐에 루트 삽입", "fontSize": 18, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle" },

    { "type": "line", "id": "e12", "rotation": 0, "fromId": "n1", "toId": "n2", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e13", "rotation": 0, "fromId": "n1", "toId": "n3", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e24", "rotation": 0, "fromId": "n2", "toId": "n4", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e25", "rotation": 0, "fromId": "n2", "toId": "n5", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e36", "rotation": 0, "fromId": "n3", "toId": "n6", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e37", "rotation": 0, "fromId": "n3", "toId": "n7", "stroke": "#cbd5e1", "strokeWidth": 2 },

    { "type": "circle", "id": "n1", "rotation": 0, "cx": 400, "cy": 95, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "1", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n2", "rotation": 0, "cx": 240, "cy": 200, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "2", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n3", "rotation": 0, "cx": 560, "cy": 200, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "3", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n4", "rotation": 0, "cx": 140, "cy": 305, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "4", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n5", "rotation": 0, "cx": 340, "cy": 305, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "5", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n6", "rotation": 0, "cx": 460, "cy": 305, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "6", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n7", "rotation": 0, "cx": 660, "cy": 305, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "7", "labelColor": "#312e81", "labelSize": 16 },

    { "type": "rect", "id": "queue-box", "rotation": 0, "x": 130, "y": 405, "width": 540, "height": 56, "fill": "#f8fafc", "stroke": "#94a3b8", "strokeWidth": 1.5, "cornerRadius": 8, "label": "", "labelColor": "#475569", "labelSize": 14 },
    { "type": "text", "id": "queue-title", "rotation": 0, "x": 150, "y": 432, "content": "Queue", "fontSize": 13, "fontWeight": 700, "color": "#64748b", "textAnchor": "start" },
    { "type": "text", "id": "queue-content", "rotation": 0, "x": 215, "y": 432, "content": "[1]", "fontSize": 16, "fontWeight": 600, "color": "#0f172a", "textAnchor": "start" },
    { "type": "text", "id": "visited-title", "rotation": 0, "x": 150, "y": 454, "content": "Visited", "fontSize": 13, "fontWeight": 700, "color": "#64748b", "textAnchor": "start" },
    { "type": "text", "id": "visited-content", "rotation": 0, "x": 215, "y": 454, "content": "", "fontSize": 16, "fontWeight": 600, "color": "#16a34a", "textAnchor": "start" }
  ],
  "initiallyHidden": [],
  "steps": [
    { "id": "s1", "label": "방문 1", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "n1": { "fill": "#34d399", "stroke": "#059669" },
        "queue-content": { "content": "[2, 3]" },
        "visited-content": { "content": "1" },
        "step-label": { "content": "1 방문, 자식 2, 3 큐에 추가" }
      },
      "effects": [{ "type": "pulse", "elementId": "n1", "scale": 1.2, "duration": 500, "delay": 0 }] },

    { "id": "s2", "label": "방문 2", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "n2": { "fill": "#34d399", "stroke": "#059669" },
        "e12": { "stroke": "#10b981", "strokeWidth": 3 },
        "queue-content": { "content": "[3, 4, 5]" },
        "visited-content": { "content": "1, 2" },
        "step-label": { "content": "2 방문, 자식 4, 5 큐에 추가" }
      },
      "effects": [{ "type": "pulse", "elementId": "n2", "scale": 1.2, "duration": 500, "delay": 0 }] },

    { "id": "s3", "label": "방문 3", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "n3": { "fill": "#34d399", "stroke": "#059669" },
        "e13": { "stroke": "#10b981", "strokeWidth": 3 },
        "queue-content": { "content": "[4, 5, 6, 7]" },
        "visited-content": { "content": "1, 2, 3" },
        "step-label": { "content": "3 방문, 자식 6, 7 큐에 추가" }
      },
      "effects": [{ "type": "pulse", "elementId": "n3", "scale": 1.2, "duration": 500, "delay": 0 }] },

    { "id": "s4", "label": "방문 4", "duration": 700, "ease": "easeOut",
      "keyframes": {
        "n4": { "fill": "#34d399", "stroke": "#059669" },
        "e24": { "stroke": "#10b981", "strokeWidth": 3 },
        "queue-content": { "content": "[5, 6, 7]" },
        "visited-content": { "content": "1, 2, 3, 4" },
        "step-label": { "content": "4 방문 (리프)" }
      },
      "effects": [{ "type": "pulse", "elementId": "n4", "scale": 1.2, "duration": 500, "delay": 0 }] },

    { "id": "s5", "label": "방문 5", "duration": 700, "ease": "easeOut",
      "keyframes": {
        "n5": { "fill": "#34d399", "stroke": "#059669" },
        "e25": { "stroke": "#10b981", "strokeWidth": 3 },
        "queue-content": { "content": "[6, 7]" },
        "visited-content": { "content": "1, 2, 3, 4, 5" },
        "step-label": { "content": "5 방문 (리프)" }
      },
      "effects": [{ "type": "pulse", "elementId": "n5", "scale": 1.2, "duration": 500, "delay": 0 }] },

    { "id": "s6", "label": "방문 6", "duration": 700, "ease": "easeOut",
      "keyframes": {
        "n6": { "fill": "#34d399", "stroke": "#059669" },
        "e36": { "stroke": "#10b981", "strokeWidth": 3 },
        "queue-content": { "content": "[7]" },
        "visited-content": { "content": "1, 2, 3, 4, 5, 6" },
        "step-label": { "content": "6 방문 (리프)" }
      },
      "effects": [{ "type": "pulse", "elementId": "n6", "scale": 1.2, "duration": 500, "delay": 0 }] },

    { "id": "s7", "label": "방문 7", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "n7": { "fill": "#34d399", "stroke": "#059669" },
        "e37": { "stroke": "#10b981", "strokeWidth": 3 },
        "queue-content": { "content": "[]" },
        "visited-content": { "content": "1, 2, 3, 4, 5, 6, 7" },
        "step-label": { "content": "✓ BFS 완료 — 큐 비었음" }
      },
      "effects": [
        { "type": "pulse", "elementId": "n7", "scale": 1.2, "duration": 500, "delay": 0 },
        { "type": "highlight", "elementId": "queue-box", "color": "#34d399", "duration": 800, "delay": 200 }
      ] },

    { "id": "s8", "label": "재시작", "duration": 600, "ease": "linear",
      "keyframes": {
        "n1": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n2": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n3": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n4": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n5": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n6": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n7": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "e12": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e13": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e24": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e25": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e36": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e37": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "queue-content": { "content": "[1]" },
        "visited-content": { "content": "" },
        "step-label": { "content": "BFS: 큐에 루트 삽입" }
      },
      "effects": [] }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 200 }
}
