  "chapters": [
    { "id": "s1", "time": 0, "label": "URL 입력", "subtitle": "" },
    { "id": "s2", "time": 800, "label": "DNS 쿼리", "subtitle": "" },
    { "id": "s3", "time": 1600, "label": "IP 반환", "subtitle": "" },
    { "id": "s4", "time": 2400, "label": "TCP Handshake", "subtitle": "" },
    { "id": "s5", "time": 3400, "label": "TLS Handshake", "subtitle": "" },
    { "id": "s6", "time": 4600, "label": "HTTP GET", "subtitle": "" },
    { "id": "s7", "time": 5600, "label": "HTTP 응답", "subtitle": "" },
    { "id": "s8", "time": 6400, "label": "렌더링", "subtitle": "" }
