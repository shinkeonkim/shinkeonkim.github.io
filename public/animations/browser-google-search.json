{
  "version": 4,
  "id": "browser-google-search",
  "title": "Google 검색의 네트워크 과정",
  "description": "브라우저에서 서버까지의 통신 단계 시각화",
  "category": "network",
  "tags": ["dns", "tcp", "tls", "http", "browser"],
  "duration": 8000,
  "canvas": { "width": 900, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "step-label", "x": 450, "y": 30, "content": "사용자가 브라우저에 google.com 을 입력합니다.", "fontSize": 18, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 8000 }], "tracks": [
      { "property": "content", "keyframes": [
        { "time": 0, "value": "사용자가 브라우저에 google.com 을 입력합니다." },
        { "time": 800, "value": "1. 브라우저 주소창에 google.com 입력" },
        { "time": 1600, "value": "2. DNS 서버에 google.com 의 IP 주소 쿼리" },
        { "time": 2400, "value": "3. DNS 서버가 IP 주소 반환" },
        { "time": 3400, "value": "4. 서버와 TCP Handshake (SYN → SYN/ACK → ACK)" },
        { "time": 4600, "value": "5. HTTPS 보안 연결을 위한 TLS Handshake" },
        { "time": 5600, "value": "6. 암호화된 HTTP GET 요청 전송" },
        { "time": 6400, "value": "7. 서버가 HTML 문서 응답" },
        { "time": 7200, "value": "8. 브라우저가 화면 렌더링 완료!" }
      ]}
    ]},
    { "type": "rect", "id": "browser", "x": 50, "y": 200, "width": 140, "height": 100, "label": "Browser", "labelColor": "#475569", "labelSize": 16, "fill": "#f1f5f9", "stroke": "#94a3b8", "strokeWidth": 2, "cornerRadius": 8, "appearances": [{ "start": 0, "end": 8000 }], "tracks": [
      { "property": "fill", "keyframes": [
        { "time": 0, "value": "#f1f5f9" },
        { "time": 7200, "value": "#fef08a" },
        { "time": 8000, "value": "#f1f5f9" }
      ]}
    ]},
    { "type": "rect", "id": "url-bar", "x": 60, "y": 215, "width": 120, "height": 25, "fill": "#ffffff", "stroke": "#cbd5e1", "strokeWidth": 1, "cornerRadius": 4, "label": "...", "labelColor": "#64748b", "labelSize": 12, "appearances": [{ "start": 0, "end": 8000 }], "tracks": [
      { "property": "label", "keyframes": [
        { "time": 0, "value": "..." },
        { "time": 800, "value": "google.com" },
        { "time": 2400, "value": "142.250.x.x" },
        { "time": 7200, "value": "Google 홈" }
      ]}
    ]},
    { "type": "rect", "id": "dns-server", "x": 370, "y": 80, "width": 160, "height": 80, "label": "DNS Server", "labelColor": "#1e3a8a", "labelSize": 16, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 8, "appearances": [{ "start": 0, "end": 8000 }], "tracks": [] },
    { "type": "rect", "id": "google-server", "x": 670, "y": 200, "width": 160, "height": 100, "label": "Google Server", "labelColor": "#14532d", "labelSize": 16, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 8, "appearances": [{ "start": 0, "end": 8000 }], "tracks": [] },
