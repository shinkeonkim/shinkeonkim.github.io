      { "property": "cx", "keyframes": [
        { "time": 4600, "value": 190 },
        { "time": 4900, "value": 670 }
      ]}
    ]},
    { "type": "circle", "id": "tls-serverhello", "cx": 670, "cy": 250, "r": 12, "fill": "#a3e635", "stroke": "#84cc16", "strokeWidth": 2, "label": "SH", "labelColor": "#3f6212", "labelSize": 9, "appearances": [{ "start": 5000, "end": 5300, "entryDuration": 100, "exitDuration": 100 }], "tracks": [
      { "property": "cx", "keyframes": [
        { "time": 5000, "value": 670 },
        { "time": 5300, "value": 190 }
      ]}
    ]},
    { "type": "circle", "id": "http-get", "cx": 190, "cy": 250, "r": 12, "fill": "#60a5fa", "stroke": "#2563eb", "strokeWidth": 2, "label": "GET", "labelColor": "#1e3a8a", "labelSize": 9, "appearances": [{ "start": 5600, "end": 5900, "entryDuration": 100, "exitDuration": 100 }], "tracks": [
      { "property": "cx", "keyframes": [
        { "time": 5600, "value": 190 },
        { "time": 5900, "value": 670 }
