  "effects": [
    { "type": "pulse", "id": "eff-browser-pulse", "elementId": "browser", "time": 800, "scale": 1.05, "duration": 500 },
    { "type": "highlight", "id": "eff-dns-highlight", "elementId": "dns-server", "time": 1600, "color": "#c7d2fe", "duration": 600 },
    { "type": "pulse", "id": "eff-server-pulse", "elementId": "google-server", "time": 5600, "scale": 1.06, "duration": 600 }
  ],
  "settings": { "loop": true, "autoplay": true, "showCaption": false, "showChapterList": true }
