    { "type": "line", "id": "l-server", "x1": 190, "y1": 250, "x2": 670, "y2": 250, "stroke": "#cbd5e1", "strokeWidth": 2, "strokeDasharray": "4 4", "appearances": [{ "start": 0, "end": 8000 }], "tracks": [] },
