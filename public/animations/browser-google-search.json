    ]},
    { "type": "circle", "id": "http-response", "cx": 670, "cy": 250, "r": 12, "fill": "#34d399", "stroke": "#059669", "strokeWidth": 2, "label": "HTML", "labelColor": "#064e3b", "labelSize": 9, "appearances": [{ "start": 6400, "end": 6700, "entryDuration": 100, "exitDuration": 100 }], "tracks": [
      { "property": "cx", "keyframes": [
        { "time": 6400, "value": 670 },
        { "time": 6700, "value": 190 }
      ]}
    ]},
    { "type": "arrow", "id": "flow-indicator", "x1": 190, "y1": 280, "x2": 320, "y2": 280, "stroke": "#f59e0b", "strokeWidth": 3, "arrowhead": "end", "appearances": [{ "start": 3400, "end": 6700, "entryDuration": 300, "exitDuration": 300 }], "tracks": [
      { "property": "x2", "keyframes": [
        { "time": 3400, "value": 320 },
        { "time": 4000, "value": 440 },
        { "time": 5000, "value": 550 },
        { "time": 6700, "value": 670 }
