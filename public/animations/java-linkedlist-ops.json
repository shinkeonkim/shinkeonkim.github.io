        {
          "property": "content",
          "keyframes": [
            { "time": 0, "value": "초기, head 와 tail 이 같은 3-노드 리스트 A↔B↔C" },
            { "time": 2500, "value": "addFirst(X) → 새 노드 X, X.next = A, A.prev = X, head 이동" },
            { "time": 6000, "value": "addLast(Y) → 새 노드 Y, Y.prev = C, C.next = Y, tail 이동" },
            { "time": 9500, "value": "get(2) → head 부터 walk, 2 회 next 따라가 B 반환 (O(n))" },
            { "time": 14000, "value": "remove(B) → B.prev.next = B.next, B.next.prev = B.prev, B unlink" }
          ]
        }
      ]
    },
