      "content": "초기, head 와 tail 이 같은 3-노드 리스트 A↔B↔C",
      "fontSize": 14,
      "fontWeight": 500,
      "color": "#6366f1",
      "textAnchor": "middle",
      "appearances": [{ "start": 0, "end": 18000 }],
