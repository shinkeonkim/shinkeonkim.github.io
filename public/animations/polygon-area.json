{
  "version": 4,
  "id": "polygon-area",
  "title": "Polygon Area (Shoelace Formula)",
  "description": "오각형 (0,0)-(4,0)-(5,2)-(2,5)-(-1,2) 의 넓이를 신발끈 공식 O(N) 으로 계산. sum(x_i y_{i+1}) - sum(y_i x_{i+1}) / 2 = 19.",
  "category": "algorithm",
  "tags": ["polygon-area", "geometry", "algorithm"],
  "duration": 13000,
  "canvas": { "width": 900, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "title", "rotation": 0, "x": 450, "y": 28, "content": "Polygon Area - Shoelace Formula", "fontSize": 20, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "text", "id": "step", "rotation": 0, "x": 450, "y": 58, "content": "오각형 N=5, 각 변의 기여도 합산", "fontSize": 14, "fontWeight": 600, "color": "#6366f1", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [
      { "property": "content", "keyframes": [
        { "time": 0, "value": "오각형 N=5, 각 변의 기여도 합산" },
