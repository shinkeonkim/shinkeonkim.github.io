{
  "version": 2,
  "id": "redis-cache-hit",
  "title": "Redis 캐시 적중 (HIT)",
  "description": "캐시에 데이터가 있을 때의 빠른 응답 흐름",
  "category": "cache",
  "tags": ["redis", "cache", "hit"],
  "canvas": { "width": 800, "height": 360, "background": "transparent" },
  "elements": [
    { "type": "rect", "id": "client", "rotation": 0, "x": 60, "y": 140, "width": 140, "height": 80, "fill": "#dbeafe", "stroke": "#3b82f6", "strokeWidth": 2, "cornerRadius": 10, "label": "Client", "labelColor": "#1e3a8a", "labelSize": 16, "subtitle": "browser" },
    { "type": "rect", "id": "app", "rotation": 0, "x": 330, "y": 140, "width": 140, "height": 80, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 10, "label": "App", "labelColor": "#312e81", "labelSize": 16, "subtitle": "API server" },
    { "type": "rect", "id": "redis", "rotation": 0, "x": 600, "y": 140, "width": 140, "height": 80, "fill": "#fee2e2", "stroke": "#dc2626", "strokeWidth": 2, "cornerRadius": 10, "label": "Redis", "labelColor": "#7f1d1d", "labelSize": 16, "subtitle": "cache" },
    { "type": "circle", "id": "req", "rotation": 0, "cx": 130, "cy": 180, "r": 10, "fill": "#facc15", "stroke": "#a16207", "strokeWidth": 2 },
    { "type": "text", "id": "step-label", "rotation": 0, "x": 400, "y": 50, "content": "1. 요청 전송", "fontSize": 22, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle" },
    { "type": "text", "id": "latency", "rotation": 0, "x": 400, "y": 320, "content": "총 6ms (캐시만 조회)", "fontSize": 14, "fontWeight": 400, "color": "#71717a", "textAnchor": "middle" }
  ],
  "initiallyHidden": [],
  "steps": [
    {
      "id": "s1",
      "label": "Client → App 요청",
      "duration": 1000,
      "ease": "easeInOut",
      "keyframes": {
        "req": { "cx": 400 },
        "step-label": { "content": "2. App 이 캐시 조회" }
      },
      "effects": [{ "type": "highlight", "elementId": "app", "color": "#a5b4fc", "duration": 600, "delay": 0 }]
    },
    {
      "id": "s2",
      "label": "App → Redis 조회",
      "duration": 800,
      "ease": "easeInOut",
      "keyframes": {
        "req": { "cx": 670 },
        "step-label": { "content": "3. ✓ HIT - 캐시에서 발견" }
      },
      "effects": [
        { "type": "highlight", "elementId": "redis", "color": "#34d399", "duration": 500, "delay": 0 },
        { "type": "pulse", "elementId": "redis", "scale": 1.15, "duration": 500, "delay": 0 }
      ]
    },
    {
      "id": "s3",
      "label": "Redis → App 데이터",
      "duration": 800,
      "ease": "easeInOut",
      "keyframes": {
        "req": { "cx": 400, "fill": "#34d399" },
        "step-label": { "content": "4. 캐시 데이터를 클라이언트로" }
      },
      "effects": []
    },
    {
      "id": "s4",
      "label": "App → Client 응답",
      "duration": 1000,
      "ease": "easeInOut",
      "keyframes": {
        "req": { "cx": 130 },
        "step-label": { "content": "✓ 완료 (DB 조회 없음)" }
      },
      "effects": []
    },
    {
      "id": "s5",
      "label": "재시작",
      "duration": 500,
      "ease": "linear",
      "keyframes": {
        "req": { "cx": 130, "fill": "#facc15" },
        "step-label": { "content": "1. 요청 전송" }
      },
      "effects": []
    }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 200 }
}
