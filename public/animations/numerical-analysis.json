    { "type": "text", "id": "step", "rotation": 0, "x": 450, "y": 58, "content": "초기값 x₀ = 1.0", "fontSize": 14, "fontWeight": 600, "color": "#6366f1", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 14000 }], "tracks": [
