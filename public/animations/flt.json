    { "type": "text", "id": "step", "rotation": 0, "x": 450, "y": 58, "content": "정리: a^(p-1) ≡ 1 (mod p) if gcd(a,p)=1", "fontSize": 14, "fontWeight": 600, "color": "#6366f1", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [
