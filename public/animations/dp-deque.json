    { "type": "rect", "id": "dp-box", "rotation": 0, "x": 80, "y": 200, "width": 740, "height": 50, "fill": "#ede9fe", "stroke": "#7c3aed", "strokeWidth": 2, "cornerRadius": 8, "label": "dp[0]=1 | dp[1]=-3 | dp[2]=6 | dp[3]=4 | dp[4]=14 | dp[5]=5 | dp[6]=12 | dp[7]=6", "labelColor": "#5b21b6", "labelSize": 13, "subtitle": "dp[i] = best dp[j] + a[i] for j in [i-K, i-1]", "subtitleSize": 10, "appearances": [{ "start": 500, "end": 14000, "entryMode": "fade", "entryDuration": 300 }], "tracks": [] },
    { "type": "rect", "id": "deque-box", "rotation": 0, "x": 100, "y": 300, "width": 700, "height": 70, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 8, "label": "Deque: [0] -> [0,1] -> [2] -> [2,3] -> [4] -> [4,5] -> [4,6] -> [6,7]", "labelColor": "#14532d", "labelSize": 14, "subtitle": "deque contents after each step (indices)", "subtitleSize": 10, "appearances": [{ "start": 1000, "end": 14000, "entryMode": "fade", "entryDuration": 200 }], "tracks": [] },
    { "type": "text", "id": "explain", "rotation": 0, "x": 450, "y": 420, "content": "", "fontSize": 13, "fontWeight": 600, "color": "#7c3aed", "textAnchor": "middle", "appearances": [{ "start": 2000, "end": 14000, "entryMode": "fade", "entryDuration": 300 }], "tracks": [
      { "property": "content", "keyframes": [
        { "time": 2000, "value": "i=0: dq=[0], dp[0]=1" },
        { "time": 3000, "value": "i=1: dq=[0,1], dp[1]=-3" },
        { "time": 4000, "value": "i=2: dq=[2], dp[2]=dp[0]+5=6 (1 > -3 -> 0 stays, 2 beats both)" },
        { "time": 5000, "value": "i=3: dq=[2,3], dp[3]=dp[2]+(-2)=4" },
        { "time": 6000, "value": "i=4: dq=[4], dp[4]=dp[2]+8=14 (front=2 still in range)" },
        { "time": 7000, "value": "i=5: dq=[4,5], dp[5]=dp[4]+(-1)=13" },
        { "time": 8000, "value": "i=6: dq=[4,6], dp[6]=dp[4]+4=12 (5 popped by 6)" },
        { "time": 9000, "value": "i=7: dq=[6,7], dp[7]=dp[6]+(-6)=6" },
        { "time": 11000, "value": "ans = max(dp) = 14 (i=4)" }
      ]}
    ]}
  ],
  "chapters": [
    { "id": "s1", "time": 0, "label": "배열과 K", "subtitle": "" },
