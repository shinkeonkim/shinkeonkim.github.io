{
  "version": 4,
  "id": "dp-deque",
  "title": "덱 DP: 슬라이딩 윈도우 최댓값 + DP 최적화",
  "description": "배열 [1,-3,5,-2,8,-1,4,-6] 에서 K=3 윈도우 내 최대 dp 값 유지. monotonic deque 가 후보를 관리.",
  "category": "algorithm",
  "tags": ["dp-deque", "dp", "deque", "monotonic", "algorithm"],
  "duration": 14000,
  "canvas": { "width": 900, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "title", "rotation": 0, "x": 450, "y": 25, "content": "Deque DP: Monotonic Deque 로 슬라이딩 윈도우 최적화", "fontSize": 18, "fontWeight": 700, "color": "#0b0b0f", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 14000 }], "tracks": [] },
    { "type": "text", "id": "step", "rotation": 0, "x": 450, "y": 52, "content": "A = [1, -3, 5, -2, 8, -1, 4, -6], K = 3", "fontSize": 13, "fontWeight": 600, "color": "#2563eb", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 14000 }], "tracks": [
      { "property": "content", "keyframes": [
        { "time": 0, "value": "A = [1, -3, 5, -2, 8, -1, 4, -6], K = 3" },
        { "time": 2500, "value": "i=2: dp[2]=max(dp[0],dp[1])+a[2] = 1+5=6" },
        { "time": 5500, "value": "i=4: dp[4]=6+8=14 (deque: [2,4])" },
        { "time": 8500, "value": "i=6: dp[6]=8+4=12 (deque: [4,6])" },
        { "time": 11500, "value": "최종 ans=14, dp[4]=14" }
      ]}
    ]},
    { "type": "rect", "id": "a0", "rotation": 0, "x": 70, "y": 100, "width": 70, "height": 50, "fill": "#dbeafe", "stroke": "#2563eb", "strokeWidth": 2, "cornerRadius": 6, "label": "1", "labelColor": "#1e3a8a", "labelSize": 16, "subtitle": "i=0", "subtitleSize": 10, "appearances": [{ "start": 0, "end": 14000 }], "tracks": [] },
