{
  "version": 2,
  "id": "graph-bfs",
  "title": "그래프 BFS (너비 우선 탐색)",
  "description": "큐(Queue)를 사용하여 가까운 노드부터 탐색합니다.",
  "category": "algorithm",
  "tags": ["graph", "bfs", "queue", "search"],
  "canvas": { "width": 800, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "step-label", "x": 400, "y": 32, "content": "BFS 탐색 시작", "fontSize": 18, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle" },
    { "type": "line", "id": "e12", "fromId": "n1", "toId": "n2", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e13", "fromId": "n1", "toId": "n3", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e24", "fromId": "n2", "toId": "n4", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e25", "fromId": "n2", "toId": "n5", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e36", "fromId": "n3", "toId": "n6", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "circle", "id": "n1", "cx": 400, "cy": 100, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "1", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n2", "cx": 250, "cy": 200, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "2", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n3", "cx": 550, "cy": 200, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "3", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n4", "cx": 150, "cy": 300, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "4", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n5", "cx": 350, "cy": 300, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "5", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n6", "cx": 650, "cy": 300, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "6", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "rect", "id": "queue-box", "x": 130, "y": 405, "width": 540, "height": 56, "fill": "#f8fafc", "stroke": "#94a3b8", "strokeWidth": 1.5, "cornerRadius": 8, "label": "", "labelColor": "#475569", "labelSize": 14 },
    { "type": "text", "id": "queue-title", "x": 150, "y": 432, "content": "Queue", "fontSize": 13, "fontWeight": 700, "color": "#64748b", "textAnchor": "start" },
    { "type": "text", "id": "queue-content", "x": 215, "y": 432, "content": "[1]", "fontSize": 16, "fontWeight": 600, "color": "#0f172a", "textAnchor": "start" },
    { "type": "text", "id": "visited-title", "x": 150, "y": 454, "content": "Visited", "fontSize": 13, "fontWeight": 700, "color": "#64748b", "textAnchor": "start" },
    { "type": "text", "id": "visited-content", "x": 215, "y": 454, "content": "", "fontSize": 16, "fontWeight": 600, "color": "#16a34a", "textAnchor": "start" }
  ],
  "initiallyHidden": [],
  "steps": [
    {
      "id": "s1",
      "label": "노드 1 방문",
      "duration": 800,
      "ease": "easeOut",
      "keyframes": {
        "n1": { "fill": "#34d399", "stroke": "#059669" },
        "queue-content": { "content": "[2, 3]" },
        "visited-content": { "content": "1" },
        "step-label": { "content": "1 방문, 인접 노드 2, 3 큐에 추가" }
      },
      "effects": [{ "type": "pulse", "elementId": "n1", "scale": 1.2, "duration": 500 }]
    },
    {
      "id": "s2",
      "label": "노드 2 방문",
      "duration": 800,
      "ease": "easeOut",
      "keyframes": {
        "n2": { "fill": "#34d399", "stroke": "#059669" },
        "e12": { "stroke": "#10b981", "strokeWidth": 3 },
        "queue-content": { "content": "[3, 4, 5]" },
        "visited-content": { "content": "1, 2" },
        "step-label": { "content": "2 방문, 인접 노드 4, 5 큐에 추가" }
      },
      "effects": [{ "type": "pulse", "elementId": "n2", "scale": 1.2, "duration": 500 }]
    },
    {
      "id": "s3",
      "label": "노드 3 방문",
      "duration": 800,
      "ease": "easeOut",
      "keyframes": {
        "n3": { "fill": "#34d399", "stroke": "#059669" },
        "e13": { "stroke": "#10b981", "strokeWidth": 3 },
        "queue-content": { "content": "[4, 5, 6]" },
        "visited-content": { "content": "1, 2, 3" },
        "step-label": { "content": "3 방문, 인접 노드 6 큐에 추가" }
      },
      "effects": [{ "type": "pulse", "elementId": "n3", "scale": 1.2, "duration": 500 }]
    },
    {
      "id": "s4",
      "label": "노드 4 방문",
      "duration": 700,
      "ease": "easeOut",
      "keyframes": {
        "n4": { "fill": "#34d399", "stroke": "#059669" },
        "e24": { "stroke": "#10b981", "strokeWidth": 3 },
        "queue-content": { "content": "[5, 6]" },
        "visited-content": { "content": "1, 2, 3, 4" },
        "step-label": { "content": "4 방문" }
      },
      "effects": [{ "type": "pulse", "elementId": "n4", "scale": 1.2, "duration": 500 }]
    },
    {
      "id": "s5",
      "label": "노드 5 방문",
      "duration": 700,
      "ease": "easeOut",
      "keyframes": {
        "n5": { "fill": "#34d399", "stroke": "#059669" },
        "e25": { "stroke": "#10b981", "strokeWidth": 3 },
        "queue-content": { "content": "[6]" },
        "visited-content": { "content": "1, 2, 3, 4, 5" },
        "step-label": { "content": "5 방문" }
      },
      "effects": [{ "type": "pulse", "elementId": "n5", "scale": 1.2, "duration": 500 }]
    },
    {
      "id": "s6",
      "label": "노드 6 방문",
      "duration": 700,
      "ease": "easeOut",
      "keyframes": {
        "n6": { "fill": "#34d399", "stroke": "#059669" },
        "e36": { "stroke": "#10b981", "strokeWidth": 3 },
        "queue-content": { "content": "[]" },
        "visited-content": { "content": "1, 2, 3, 4, 5, 6" },
        "step-label": { "content": "6 방문, 큐가 비어 탐색 종료" }
      },
      "effects": [
        { "type": "pulse", "elementId": "n6", "scale": 1.2, "duration": 500 },
        { "type": "highlight", "elementId": "queue-box", "color": "#34d399", "duration": 800, "delay": 200 }
      ]
    },
    {
      "id": "s7",
      "label": "초기화",
      "duration": 600,
      "ease": "linear",
      "keyframes": {
        "n1": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n2": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n3": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n4": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n5": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n6": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "e12": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e13": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e24": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e25": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e36": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "queue-content": { "content": "[1]" },
        "visited-content": { "content": "" },
        "step-label": { "content": "BFS 탐색 시작" }
      },
      "effects": []
    }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 200 }
}