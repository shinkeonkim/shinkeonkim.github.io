{
  "version": 2,
  "id": "bridge-edge",
  "title": "단절선 (Bridge)",
  "description": "제거했을 때 그래프가 두 개 이상으로 나누어지는 간선 찾기",
  "category": "algorithm",
  "tags": ["graph", "dfs", "bridge", "algorithm"],
  "canvas": { "width": 800, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "step-label", "rotation": 0, "x": 400, "y": 32, "content": "DFS 진행: 각 노드의 tin(방문순서), low(도달가능 최소순서) 기록", "fontSize": 18, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle" },
    
    { "type": "line", "id": "e12", "fromId": "n1", "toId": "n2", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e23", "fromId": "n2", "toId": "n3", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e31", "fromId": "n3", "toId": "n1", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e34", "fromId": "n3", "toId": "n4", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e45", "fromId": "n4", "toId": "n5", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e56", "fromId": "n5", "toId": "n6", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e64", "fromId": "n6", "toId": "n4", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e57", "fromId": "n5", "toId": "n7", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e67", "fromId": "n6", "toId": "n7", "stroke": "#cbd5e1", "strokeWidth": 2 },

    { "type": "circle", "id": "n1", "cx": 200, "cy": 150, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "1", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n2", "cx": 200, "cy": 350, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "2", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n3", "cx": 300, "cy": 250, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "3", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n4", "cx": 500, "cy": 250, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "4", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n5", "cx": 600, "cy": 150, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "5", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n6", "cx": 600, "cy": 350, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "6", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n7", "cx": 700, "cy": 250, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "7", "labelColor": "#312e81", "labelSize": 16 },

    { "type": "text", "id": "tin-n3", "x": 300, "y": 210, "content": "tin: 3", "fontSize": 12, "fontWeight": 600, "color": "#16a34a", "textAnchor": "middle" },
    { "type": "text", "id": "tin-n4", "x": 500, "y": 210, "content": "low: 4", "fontSize": 12, "fontWeight": 600, "color": "#16a34a", "textAnchor": "middle" }
  ],
  "initiallyHidden": ["tin-n3", "tin-n4"],
  "steps": [
    { "id": "s1", "label": "DFS 1~3", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "n1": { "fill": "#34d399", "stroke": "#059669" },
        "n2": { "fill": "#34d399", "stroke": "#059669" },
        "n3": { "fill": "#fbbf24", "stroke": "#d97706" },
        "e12": { "stroke": "#10b981", "strokeWidth": 3 },
        "e23": { "stroke": "#10b981", "strokeWidth": 3 },
        "step-label": { "content": "DFS 1 -> 2 -> 3 진행. 역방향 간선 발견으로 1~3 사이클 형성" }
      },
      "effects": [{ "type": "pulse", "elementId": "n3", "scale": 1.2, "duration": 400 }] },
      
    { "id": "s2", "label": "DFS 3~4", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "n3": { "fill": "#34d399", "stroke": "#059669" },
        "n4": { "fill": "#fbbf24", "stroke": "#d97706" },
        "e34": { "stroke": "#10b981", "strokeWidth": 3 },
        "tin-n3": { "visible": true },
        "step-label": { "content": "3에서 4로 진행. 4에서 5, 7, 6 탐색" }
      },
      "effects": [{ "type": "pulse", "elementId": "n4", "scale": 1.2, "duration": 400 }] },

    { "id": "s3", "label": "DFS 4~7", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "n4": { "fill": "#34d399", "stroke": "#059669" },
        "n5": { "fill": "#34d399", "stroke": "#059669" },
        "n7": { "fill": "#34d399", "stroke": "#059669" },
        "n6": { "fill": "#fbbf24", "stroke": "#d97706" },
        "e45": { "stroke": "#10b981", "strokeWidth": 3 },
        "e57": { "stroke": "#10b981", "strokeWidth": 3 },
        "e67": { "stroke": "#10b981", "strokeWidth": 3 },
        "step-label": { "content": "4 -> 5 -> 7 -> 6 진행. 역방향 간선으로 4~7 사이클 형성" }
      },
      "effects": [{ "type": "pulse", "elementId": "n6", "scale": 1.2, "duration": 400 }] },

    { "id": "s4", "label": "단절선 판별", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "n6": { "fill": "#34d399", "stroke": "#059669" },
        "tin-n4": { "visible": true },
        "step-label": { "content": "노드 4의 자식들은 3이나 3 이전(1,2)으로 가는 역방향 간선이 없음 (low[4] > tin[3])" }
      },
      "effects": [{ "type": "pulse", "elementId": "n4", "scale": 1.2, "duration": 400 }, { "type": "pulse", "elementId": "n3", "scale": 1.2, "duration": 400 }] },

    { "id": "s5", "label": "단절선 강조", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "e34": { "stroke": "#ef4444", "strokeWidth": 6 },
        "step-label": { "content": "간선 3-4는 단절선(Bridge)! 제거 시 그래프 분리" }
      },
      "effects": [{ "type": "highlight", "elementId": "e34", "color": "#ef4444", "duration": 800 }] },

    { "id": "s6", "label": "재시작", "duration": 600, "ease": "linear",
      "keyframes": {
        "n1": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n2": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n3": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n4": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n5": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n6": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n7": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "e12": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e23": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e34": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e45": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e57": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e67": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "tin-n3": { "visible": false },
        "tin-n4": { "visible": false },
        "step-label": { "content": "DFS 진행: 각 노드의 tin(방문순서), low(도달가능 최소순서) 기록" }
      },
      "effects": [] }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 300 }
}