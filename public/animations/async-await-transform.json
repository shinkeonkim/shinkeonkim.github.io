          { "time": 6000, "value": "await 는 .then 의 문법 설탕, 엔진이 같은 동작을 한다" },
          { "time": 8500, "value": "에러: .catch ↔ try/catch, 두 패턴 모두 동등" },
          { "time": 10500, "value": "선택은 가독성, 평탄한 흐름엔 await, 분기엔 .then 도 OK" }
        ]}
      ]
    },
