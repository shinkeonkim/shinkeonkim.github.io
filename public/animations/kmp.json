{
  "version": 2,
  "id": "kmp",
  "title": "KMP 문자열 매칭",
  "description": "text = ABABABC, pattern = ABABC. failure function 으로 mismatch 시 점프",
  "category": "algorithm",
  "tags": ["kmp", "string-matching", "algorithm"],
  "canvas": { "width": 800, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "step-label", "rotation": 0, "x": 400, "y": 32, "content": "KMP — 시작", "fontSize": 18, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle" },

    { "type": "text", "id": "text-label", "rotation": 0, "x": 80, "y": 100, "content": "text", "fontSize": 13, "fontWeight": 700, "color": "#64748b", "textAnchor": "start" },
    { "type": "rect", "id": "t0", "rotation": 0, "x": 140, "y": 80, "width": 55, "height": 55, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 6, "label": "A", "labelColor": "#312e81", "labelSize": 22 },
    { "type": "rect", "id": "t1", "rotation": 0, "x": 200, "y": 80, "width": 55, "height": 55, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 6, "label": "B", "labelColor": "#312e81", "labelSize": 22 },
    { "type": "rect", "id": "t2", "rotation": 0, "x": 260, "y": 80, "width": 55, "height": 55, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 6, "label": "A", "labelColor": "#312e81", "labelSize": 22 },
    { "type": "rect", "id": "t3", "rotation": 0, "x": 320, "y": 80, "width": 55, "height": 55, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 6, "label": "B", "labelColor": "#312e81", "labelSize": 22 },
    { "type": "rect", "id": "t4", "rotation": 0, "x": 380, "y": 80, "width": 55, "height": 55, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 6, "label": "A", "labelColor": "#312e81", "labelSize": 22 },
    { "type": "rect", "id": "t5", "rotation": 0, "x": 440, "y": 80, "width": 55, "height": 55, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 6, "label": "B", "labelColor": "#312e81", "labelSize": 22 },
    { "type": "rect", "id": "t6", "rotation": 0, "x": 500, "y": 80, "width": 55, "height": 55, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 6, "label": "C", "labelColor": "#312e81", "labelSize": 22 },

    { "type": "text", "id": "pattern-label", "rotation": 0, "x": 80, "y": 200, "content": "pattern", "fontSize": 13, "fontWeight": 700, "color": "#64748b", "textAnchor": "start" },
    { "type": "rect", "id": "p0", "rotation": 0, "x": 140, "y": 180, "width": 55, "height": 55, "fill": "#fef3c7", "stroke": "#d97706", "strokeWidth": 2, "cornerRadius": 6, "label": "A", "labelColor": "#78350f", "labelSize": 22 },
    { "type": "rect", "id": "p1", "rotation": 0, "x": 200, "y": 180, "width": 55, "height": 55, "fill": "#fef3c7", "stroke": "#d97706", "strokeWidth": 2, "cornerRadius": 6, "label": "B", "labelColor": "#78350f", "labelSize": 22 },
    { "type": "rect", "id": "p2", "rotation": 0, "x": 260, "y": 180, "width": 55, "height": 55, "fill": "#fef3c7", "stroke": "#d97706", "strokeWidth": 2, "cornerRadius": 6, "label": "A", "labelColor": "#78350f", "labelSize": 22 },
    { "type": "rect", "id": "p3", "rotation": 0, "x": 320, "y": 180, "width": 55, "height": 55, "fill": "#fef3c7", "stroke": "#d97706", "strokeWidth": 2, "cornerRadius": 6, "label": "B", "labelColor": "#78350f", "labelSize": 22 },
    { "type": "rect", "id": "p4", "rotation": 0, "x": 380, "y": 180, "width": 55, "height": 55, "fill": "#fef3c7", "stroke": "#d97706", "strokeWidth": 2, "cornerRadius": 6, "label": "C", "labelColor": "#78350f", "labelSize": 22 },

    { "type": "text", "id": "fail-label", "rotation": 0, "x": 80, "y": 310, "content": "failure", "fontSize": 13, "fontWeight": 700, "color": "#64748b", "textAnchor": "start" },
    { "type": "text", "id": "f0", "rotation": 0, "x": 167, "y": 310, "content": "0", "fontSize": 18, "fontWeight": 600, "color": "#64748b", "textAnchor": "middle" },
    { "type": "text", "id": "f1", "rotation": 0, "x": 227, "y": 310, "content": "0", "fontSize": 18, "fontWeight": 600, "color": "#64748b", "textAnchor": "middle" },
    { "type": "text", "id": "f2", "rotation": 0, "x": 287, "y": 310, "content": "1", "fontSize": 18, "fontWeight": 600, "color": "#64748b", "textAnchor": "middle" },
    { "type": "text", "id": "f3", "rotation": 0, "x": 347, "y": 310, "content": "2", "fontSize": 18, "fontWeight": 600, "color": "#64748b", "textAnchor": "middle" },
    { "type": "text", "id": "f4", "rotation": 0, "x": 407, "y": 310, "content": "0", "fontSize": 18, "fontWeight": 600, "color": "#64748b", "textAnchor": "middle" },

    { "type": "text", "id": "info", "rotation": 0, "x": 400, "y": 380, "content": "failure = [0, 0, 1, 2, 0]", "fontSize": 15, "fontWeight": 600, "color": "#475569", "textAnchor": "middle" },
    { "type": "text", "id": "action", "rotation": 0, "x": 400, "y": 430, "content": "", "fontSize": 16, "fontWeight": 700, "color": "#16a34a", "textAnchor": "middle" }
  ],
  "initiallyHidden": [],
  "steps": [
    { "id": "s1", "label": "ABAB 매치", "duration": 900, "ease": "easeOut",
      "keyframes": {
        "t0": { "fill": "#34d399", "stroke": "#059669" },
        "t1": { "fill": "#34d399", "stroke": "#059669" },
        "t2": { "fill": "#34d399", "stroke": "#059669" },
        "t3": { "fill": "#34d399", "stroke": "#059669" },
        "p0": { "fill": "#34d399", "stroke": "#059669" },
        "p1": { "fill": "#34d399", "stroke": "#059669" },
        "p2": { "fill": "#34d399", "stroke": "#059669" },
        "p3": { "fill": "#34d399", "stroke": "#059669" },
        "action": { "content": "ABAB 매치 (i=0..3, j=0..3)" },
        "step-label": { "content": "처음 4글자 ABAB 매치" }
      },
      "effects": [] },
    { "id": "s2", "label": "t[4]=A vs p[4]=C", "duration": 1000, "ease": "easeOut",
      "keyframes": {
        "t4": { "fill": "#fca5a5", "stroke": "#dc2626" },
        "p4": { "fill": "#fca5a5", "stroke": "#dc2626" },
        "action": { "content": "mismatch: A ≠ C  (i=4, j=4)" },
        "step-label": { "content": "mismatch — failure[3]=2 로 점프" }
      },
      "effects": [
        { "type": "highlight", "elementId": "p4", "color": "#ef4444", "duration": 600, "delay": 0 },
        { "type": "pulse", "elementId": "f3", "scale": 1.4, "duration": 500, "delay": 300 }
      ] },
    { "id": "s3", "label": "pattern shift", "duration": 900, "ease": "easeInOut",
      "keyframes": {
        "p0": { "x": 260, "fill": "#fef3c7", "stroke": "#d97706" },
        "p1": { "x": 320, "fill": "#fef3c7", "stroke": "#d97706" },
        "p2": { "x": 380, "fill": "#34d399", "stroke": "#059669" },
        "p3": { "x": 440, "fill": "#34d399", "stroke": "#059669" },
        "p4": { "x": 500, "fill": "#fef3c7", "stroke": "#d97706" },
        "t0": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "t1": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "t4": { "fill": "#34d399", "stroke": "#059669" },
        "action": { "content": "pattern 2칸 점프 (j ← failure[3]=2)" },
        "step-label": { "content": "점프 후 p[2..3]=AB 가 이미 t[2..3]=AB 와 일치" }
      },
      "effects": [] },
    { "id": "s4", "label": "p[2]=A vs t[4]=A", "duration": 900, "ease": "easeOut",
      "keyframes": {
        "action": { "content": "이어서 비교: p[2]=A vs t[4]=A ✓" },
        "step-label": { "content": "이미 매치된 AB 활용 — 재비교 불필요" }
      },
      "effects": [{ "type": "pulse", "elementId": "p2", "scale": 1.15, "duration": 500, "delay": 0 }] },
    { "id": "s5", "label": "p[3]=B vs t[5]=B", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "t5": { "fill": "#34d399", "stroke": "#059669" },
        "action": { "content": "p[3]=B vs t[5]=B ✓" },
        "step-label": { "content": "계속 매치" }
      },
      "effects": [{ "type": "pulse", "elementId": "p3", "scale": 1.15, "duration": 500, "delay": 0 }] },
    { "id": "s6", "label": "p[4]=C vs t[6]=C", "duration": 1000, "ease": "easeOut",
      "keyframes": {
        "t6": { "fill": "#34d399", "stroke": "#059669" },
        "p4": { "fill": "#34d399", "stroke": "#059669" },
        "action": { "content": "✓ 전체 매치! position = 2" },
        "step-label": { "content": "✓ 매치 완료 — text[2..6] = ABABC" }
      },
      "effects": [
        { "type": "pulse", "elementId": "p4", "scale": 1.2, "duration": 500, "delay": 0 },
        { "type": "highlight", "elementId": "action", "color": "#34d399", "duration": 800, "delay": 200 }
      ] },
    { "id": "s7", "label": "재시작", "duration": 700, "ease": "linear",
      "keyframes": {
        "t0": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "t1": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "t2": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "t3": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "t4": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "t5": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "t6": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "p0": { "x": 140, "fill": "#fef3c7", "stroke": "#d97706" },
        "p1": { "x": 200, "fill": "#fef3c7", "stroke": "#d97706" },
        "p2": { "x": 260, "fill": "#fef3c7", "stroke": "#d97706" },
        "p3": { "x": 320, "fill": "#fef3c7", "stroke": "#d97706" },
        "p4": { "x": 380, "fill": "#fef3c7", "stroke": "#d97706" },
        "action": { "content": "" },
        "step-label": { "content": "KMP — 시작" }
      },
      "effects": [] }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 300 }
}
