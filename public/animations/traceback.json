  "elements": [
    { "type": "text", "id": "title", "rotation": 0, "x": 450, "y": 28, "content": "DP Traceback, LCS 역추적: parent 를 따라 거꾸로", "fontSize": 20, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "text", "id": "step", "rotation": 0, "x": 450, "y": 58, "content": "DP table: dp[i][j] = LCS length for A[0..i-1] x B[0..j-1]", "fontSize": 13, "fontWeight": 600, "color": "#6366f1", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [
      { "property": "content", "keyframes": [
        { "time": 0, "value": "초기: dp[0][*] = dp[*][0] = 0 (empty prefix)" },
        { "time": 2500, "value": "Fill dp[1][1..3]: A[0]=A vs B[0..2] = A,C,B" },
        { "time": 4500, "value": "Fill dp[2][1..3]: A[1]=B vs B[0..2]" },
        { "time": 6500, "value": "Fill dp[3][1..3]: A[2]=C vs B[0..2], table complete" },
        { "time": 8500, "value": "Traceback: start at dp[3][3]=2, follow parent" },
        { "time": 11000, "value": "Reverse: path = A,B -> LCS = AB (or AC)" }
      ]}
    ]},
    { "type": "text", "id": "col-header", "rotation": 0, "x": 175, "y": 90, "content": "  A C B", "fontSize": 14, "fontWeight": 700, "color": "#475569", "textAnchor": "start", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
