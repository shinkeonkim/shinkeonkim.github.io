{
  "version": 2,
  "id": "union-find",
  "title": "유니온 파인드 (Union-Find)와 경로 압축",
  "description": "서로소 집합을 트리 형태로 표현하며, Find 연산 시 경로 압축(Path Compression)을 수행합니다.",
  "category": "algorithm",
  "tags": ["tree", "union-find", "disjoint-set", "path-compression"],
  "canvas": { "width": 800, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "step-label", "x": 400, "y": 50, "content": "초기 상태: 6개의 독립된 집합", "fontSize": 18, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle" },
    
    { "type": "arrow", "id": "e21", "fromId": "n2", "toId": "n1", "stroke": "transparent", "strokeWidth": 2, "curvature": -0.4, "headEnd": "arrow" },
    { "type": "arrow", "id": "e43", "fromId": "n4", "toId": "n3", "stroke": "transparent", "strokeWidth": 2, "curvature": -0.4, "headEnd": "arrow" },
    { "type": "arrow", "id": "e31", "fromId": "n3", "toId": "n1", "stroke": "transparent", "strokeWidth": 2, "curvature": -0.5, "headEnd": "arrow" },
    { "type": "arrow", "id": "e41", "fromId": "n4", "toId": "n1", "stroke": "transparent", "strokeWidth": 2, "curvature": -0.7, "headEnd": "arrow" },

    { "type": "circle", "id": "n1", "cx": 100, "cy": 250, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "1", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n2", "cx": 220, "cy": 250, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "2", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n3", "cx": 340, "cy": 250, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "3", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n4", "cx": 460, "cy": 250, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "4", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n5", "cx": 580, "cy": 250, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "5", "labelColor": "#312e81", "labelSize": 16 },
    { "type": "circle", "id": "n6", "cx": 700, "cy": 250, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "6", "labelColor": "#312e81", "labelSize": 16 }
  ],
  "initiallyHidden": [],
  "steps": [
    {
      "id": "s1",
      "label": "Union(1, 2)",
      "duration": 800,
      "ease": "easeOut",
      "keyframes": {
        "e21": { "stroke": "#cbd5e1", "strokeWidth": 3 },
        "n2": { "fill": "#fbbf24", "stroke": "#d97706" },
        "n1": { "fill": "#34d399", "stroke": "#059669" },
        "step-label": { "content": "Union(1, 2): 2의 부모를 1로 설정" }
      },
      "effects": [{ "type": "pulse", "elementId": "n2", "scale": 1.2, "duration": 500 }]
    },
    {
      "id": "s2",
      "label": "Union(3, 4)",
      "duration": 800,
      "ease": "easeOut",
      "keyframes": {
        "n1": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n2": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "e21": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e43": { "stroke": "#cbd5e1", "strokeWidth": 3 },
        "n4": { "fill": "#fbbf24", "stroke": "#d97706" },
        "n3": { "fill": "#34d399", "stroke": "#059669" },
        "step-label": { "content": "Union(3, 4): 4의 부모를 3으로 설정" }
      },
      "effects": [{ "type": "pulse", "elementId": "n4", "scale": 1.2, "duration": 500 }]
    },
    {
      "id": "s3",
      "label": "Union(2, 3)",
      "duration": 900,
      "ease": "easeOut",
      "keyframes": {
        "n4": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n3": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "e43": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "n2": { "fill": "#fbbf24", "stroke": "#d97706" },
        "n3": { "fill": "#fbbf24", "stroke": "#d97706" },
        "step-label": { "content": "Union(2, 3): 2의 루트(1)와 3의 루트(3)를 찾아 연결" }
      },
      "effects": [
        { "type": "pulse", "elementId": "n2", "scale": 1.2, "duration": 500 },
        { "type": "pulse", "elementId": "n3", "scale": 1.2, "duration": 500 }
      ]
    },
    {
      "id": "s4",
      "label": "루트 연결",
      "duration": 800,
      "ease": "easeOut",
      "keyframes": {
        "n2": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n3": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "e31": { "stroke": "#cbd5e1", "strokeWidth": 3 },
        "n1": { "fill": "#34d399", "stroke": "#059669" },
        "step-label": { "content": "3의 부모를 1(2의 루트)로 설정" }
      },
      "effects": [{ "type": "pulse", "elementId": "n1", "scale": 1.2, "duration": 500 }]
    },
    {
      "id": "s5",
      "label": "Find(4) 탐색",
      "duration": 800,
      "ease": "easeOut",
      "keyframes": {
        "n1": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "e31": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "n4": { "fill": "#fbbf24", "stroke": "#d97706" },
        "e43": { "stroke": "#fbbf24", "strokeWidth": 3 },
        "n3": { "fill": "#fbbf24", "stroke": "#d97706" },
        "e31": { "stroke": "#fbbf24", "strokeWidth": 3 },
        "n1": { "fill": "#fbbf24", "stroke": "#d97706" },
        "step-label": { "content": "Find(4): 4 → 3 → 1 경로를 따라 루트 탐색" }
      },
      "effects": [{ "type": "pulse", "elementId": "n4", "scale": 1.2, "duration": 500 }]
    },
    {
      "id": "s6",
      "label": "경로 압축",
      "duration": 900,
      "ease": "easeOut",
      "keyframes": {
        "e43": { "stroke": "transparent" },
        "e41": { "stroke": "#10b981", "strokeWidth": 3 },
        "n4": { "fill": "#34d399", "stroke": "#059669" },
        "n3": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "e31": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "n1": { "fill": "#34d399", "stroke": "#059669" },
        "step-label": { "content": "경로 압축(Path Compression): 4의 부모를 루트인 1로 직접 연결!" }
      },
      "effects": [{ "type": "pulse", "elementId": "n4", "scale": 1.2, "duration": 500 }]
    },
    {
      "id": "s7",
      "label": "초기화",
      "duration": 600,
      "ease": "linear",
      "keyframes": {
        "n1": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n2": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n3": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n4": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "e21": { "stroke": "transparent", "strokeWidth": 2 },
        "e43": { "stroke": "transparent", "strokeWidth": 2 },
        "e31": { "stroke": "transparent", "strokeWidth": 2 },
        "e41": { "stroke": "transparent", "strokeWidth": 2 },
        "step-label": { "content": "초기 상태: 6개의 독립된 집합" }
      },
      "effects": []
    }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 200 }
}