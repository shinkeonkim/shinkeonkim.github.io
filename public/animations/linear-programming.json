{
  "version": 4,
  "id": "linear-programming",
  "title": "선형 계획법: Simplex Method",
  "description": "LP feasible region (convex polygon) + 목적 함수 c^T x 최적화, simplex pivot 시각화",
  "category": "algorithm",
  "tags": ["linear-programming", "simplex", "optimization", "math"],
  "duration": 14000,
  "canvas": { "width": 900, "height": 500, "background": "transparent" },
  "elements": [
    { "id": "title", "type": "text", "x": 450, "y": 25, "text": "LP: max x + y", "fontSize": 20, "fontWeight": "bold", "fill": "#0b0b0f", "textAnchor": "middle" },
    { "id": "polygon", "type": "polygon", "points": "150,380 300,380 420,260 380,140 220,140 100,260", "fill": "#dbeafe", "stroke": "#2563eb", "strokeWidth": 3, "opacity": 0.4 },
    { "id": "vtx", "type": "circle", "cx": 100, "cy": 260, "r": 8, "fill": "#e2e8f0", "stroke": "#475569", "strokeWidth": 2 },
    { "id": "vtx-1", "type": "circle", "cx": 300, "cy": 380, "r": 6, "fill": "#e2e8f0", "stroke": "#475569", "strokeWidth": 1.5 },
    { "id": "vtx-2", "type": "circle", "cx": 420, "cy": 260, "r": 6, "fill": "#e2e8f0", "stroke": "#475569", "strokeWidth": 1.5 },
    { "id": "vtx-3", "type": "circle", "cx": 380, "cy": 140, "r": 6, "fill": "#e2e8f0", "stroke": "#475569", "strokeWidth": 1.5 },
    { "id": "vtx-4", "type": "circle", "cx": 220, "cy": 140, "r": 6, "fill": "#e2e8f0", "stroke": "#475569", "strokeWidth": 1.5 },
    { "id": "vtx-5", "type": "circle", "cx": 150, "cy": 380, "r": 6, "fill": "#e2e8f0", "stroke": "#475569", "strokeWidth": 1.5 },
    { "id": "obj-line", "type": "line", "x1": 100, "y1": 420, "x2": 400, "y2": 120, "stroke": "#dc2626", "strokeWidth": 3, "opacity": 0.6 },
    { "id": "obj-arrow", "type": "line", "x1": 400, "y1": 120, "x2": 440, "y2": 80, "stroke": "#dc2626", "strokeWidth": 3 },
    { "id": "obj-lbl", "type": "text", "x": 445, "y": 75, "text": "c^T x", "fontSize": 16, "fontWeight": "bold", "fill": "#dc2626" },
    { "id": "axes-x", "type": "line", "x1": 50, "y1": 420, "x2": 500, "y2": 420, "stroke": "#475569", "strokeWidth": 2 },
