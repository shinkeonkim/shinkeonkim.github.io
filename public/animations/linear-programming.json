    { "id": "c1", "type": "text", "x": 580, "y": 135, "text": "x + 2y <= 4", "fontSize": 14, "fill": "#e2e8f0" },
    { "id": "c2", "type": "text", "x": 580, "y": 160, "text": "2x + y <= 5", "fontSize": 14, "fill": "#e2e8f0" },
    { "id": "c3", "type": "text", "x": 580, "y": 185, "text": "x, y >= 0", "fontSize": 14, "fill": "#e2e8f0" },
    { "id": "opt-val", "type": "text", "x": 580, "y": 220, "text": "max = 3 (x=2, y=1)", "fontSize": 16, "fontWeight": "bold", "fill": "#fef9c3" },
    { "id": "result-box", "type": "rect", "x": 560, "y": 280, "width": 300, "height": 70, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "rx": 6 },
    { "id": "result-title", "type": "text", "x": 710, "y": 305, "text": "Simplex: O(poly) avg", "fontSize": 16, "fontWeight": "bold", "fill": "#14532d", "textAnchor": "middle" },
    { "id": "result-detail", "type": "text", "x": 710, "y": 335, "text": "Worst-case: exponential", "fontSize": 13, "fill": "#14532d", "textAnchor": "middle" },
    { "id": "x-lbl", "type": "text", "x": 500, "y": 440, "text": "x", "fontSize": 16, "fill": "#475569", "fontWeight": "bold" },
    { "id": "y-lbl", "type": "text", "x": 65, "y": 50, "text": "y", "fontSize": 16, "fill": "#475569", "fontWeight": "bold" }
  ],
  "chapters": [
    { "id": "intro", "title": "문제 설정", "startTime": 0, "endTime": 2500, "description": "6각형 convex feasible region" },
    { "id": "obj", "title": "목적 함수", "startTime": 2500, "endTime": 5500, "description": "c^T x 방향 polytope 접점" },
    { "id": "pivot", "title": "Simplex Pivot", "startTime": 5500, "endTime": 10000, "description": "꼭짓점 이동: (0,0)->(2.5,0)->(2,1)" },
    { "id": "end", "title": "완료", "startTime": 10000, "endTime": 14000, "description": "x=2, y=1, c^T x=3" }
  ],
  "effects": [
    { "target": "polygon", "type": "opacity", "from": 0, "to": 0.4, "startTime": 0, "duration": 800, "easing": "ease-in-out" },
    { "target": "obj-line", "type": "opacity", "from": 0, "to": 0.6, "startTime": 2500, "duration": 1000, "easing": "ease-in-out" },
    { "target": "vtx", "type": "fill", "from": "#e2e8f0", "to": "#16a34a", "startTime": 5500, "duration": 1000, "easing": "ease-in-out" },
    { "target": "result-box", "type": "scale", "from": 0.5, "to": 1, "startTime": 10000, "duration": 800, "easing": "ease-out" },
    { "target": "info-box", "type": "opacity", "from": 0, "to": 1, "startTime": 0, "duration": 600, "easing": "ease-in-out" }
  ],
  "settings": { "loop": true, "autoplay": true, "showCaption": false, "showChapterList": true }
}
