      "y": 55,
      "content": "VM은 hypervisor 위에서 각자 게스트 커널을 실행합니다",
      "fontSize": 13,
      "color": "#475569",
      "textAnchor": "middle",
      "appearances": [{"start": 0, "end": 15000, "entryDuration": 300, "exitDuration": 300}],
