    { "id": "mfmc-detail", "type": "text", "x": 450, "y": 440, "text": "Primal: max flow | Dual: min cut capacity", "fontSize": 14, "fill": "#5b21b6", "textAnchor": "middle" },
    { "id": "cs-text", "type": "text", "x": 450, "y": 470, "text": "Complementary Slackness: tight constraints == 0 slack", "fontSize": 13, "fill": "#475569", "textAnchor": "middle" },
