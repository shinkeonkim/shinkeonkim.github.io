    { "id": "p-c2", "type": "text", "x": 70, "y": 170, "text": "2x + y <= 5, x, y >= 0", "fontSize": 14, "fill": "#1e3a8a" },
    { "id": "p-val", "type": "text", "x": 70, "y": 210, "text": "opt = 3", "fontSize": 18, "fontWeight": "bold", "fill": "#16a34a" },
