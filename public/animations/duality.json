    { "id": "weak", "type": "text", "x": 450, "y": 295, "text": "Weak: c^T x <= b^T y", "fontSize": 16, "fontWeight": "bold", "fill": "#e2e8f0", "textAnchor": "middle" },
    { "id": "strong", "type": "text", "x": 450, "y": 325, "text": "Strong: c^T x* = b^T y*", "fontSize": 16, "fontWeight": "bold", "fill": "#fef9c3", "textAnchor": "middle" },
    { "id": "mfmc-box", "type": "rect", "x": 100, "y": 390, "width": 700, "height": 75, "fill": "#ede9fe", "stroke": "#7c3aed", "strokeWidth": 2, "rx": 6 },
