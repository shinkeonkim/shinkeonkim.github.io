{
  "version": 2,
  "id": "http-request",
  "title": "HTTP 요청 / 응답",
  "description": "Client → Server 의 기본 HTTP 요청-응답 흐름과 상태 코드",
  "category": "network",
  "tags": ["http", "request", "response", "network"],
  "canvas": { "width": 800, "height": 400, "background": "transparent" },
  "elements": [
    { "type": "rect", "id": "client", "rotation": 0, "x": 80, "y": 160, "width": 160, "height": 90, "fill": "#dbeafe", "stroke": "#3b82f6", "strokeWidth": 2, "cornerRadius": 12, "label": "Client", "labelColor": "#1e3a8a", "labelSize": 18, "subtitle": "browser" },
    { "type": "rect", "id": "server", "rotation": 0, "x": 560, "y": 160, "width": 160, "height": 90, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 12, "label": "Server", "labelColor": "#14532d", "labelSize": 18, "subtitle": "API" },
    { "type": "text", "id": "req-text", "rotation": 0, "x": 400, "y": 130, "content": "GET /api/users", "fontSize": 16, "fontWeight": 600, "color": "#3b82f6", "textAnchor": "middle" },
    { "type": "text", "id": "resp-text", "rotation": 0, "x": 400, "y": 290, "content": "200 OK { ... }", "fontSize": 16, "fontWeight": 600, "color": "#16a34a", "textAnchor": "middle" },
    { "type": "circle", "id": "req-dot", "rotation": 0, "cx": 240, "cy": 180, "r": 9, "fill": "#3b82f6", "stroke": "#1e40af", "strokeWidth": 2 },
    { "type": "circle", "id": "resp-dot", "rotation": 0, "cx": 560, "cy": 230, "r": 9, "fill": "#16a34a", "stroke": "#14532d", "strokeWidth": 2 },
    { "type": "text", "id": "step-label", "rotation": 0, "x": 400, "y": 50, "content": "요청", "fontSize": 22, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle" }
  ],
  "initiallyHidden": ["resp-text", "resp-dot"],
  "steps": [
    { "id": "s1", "label": "요청 전송", "duration": 1200, "ease": "easeInOut",
      "keyframes": { "req-dot": { "cx": 560 }, "step-label": { "content": "서버가 요청을 받음" } },
      "effects": [] },
    { "id": "s2", "label": "서버 처리", "duration": 800, "ease": "easeInOut",
      "keyframes": { "req-dot": { "visible": false }, "resp-dot": { "visible": true }, "resp-text": { "visible": true }, "step-label": { "content": "서버가 응답 준비" } },
      "effects": [
        { "type": "highlight", "elementId": "server", "color": "#86efac", "duration": 600, "delay": 0 },
        { "type": "pulse", "elementId": "server", "scale": 1.08, "duration": 600, "delay": 0 }
      ] },
    { "id": "s3", "label": "응답 반환", "duration": 1200, "ease": "easeInOut",
      "keyframes": { "resp-dot": { "cx": 240 }, "step-label": { "content": "클라이언트가 응답을 받음" } },
      "effects": [] },
    { "id": "s4", "label": "재시작", "duration": 600, "ease": "linear",
      "keyframes": { "req-dot": { "cx": 240, "visible": true }, "resp-dot": { "cx": 560, "visible": false }, "resp-text": { "visible": false }, "step-label": { "content": "요청" } },
      "effects": [] }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 200 }
}
