    { "id": "step1", "time": 2000, "label": "Step 1", "subtitle": "s_1=1, d=0 통과" },
    { "id": "step2", "time": 4000, "label": "Step 2", "subtitle": "s_2=2, d=1 → L=2" },
    { "id": "step3", "time": 7000, "label": "Step 3~5", "subtitle": "s_3,4,5 모두 통과" },
