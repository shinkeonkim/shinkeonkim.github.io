{
  "version": 2,
  "id": "sqrt-decomposition",
  "title": "Square Root Decomposition",
  "description": "Divides array into blocks of size sqrt(N) to optimize range queries.",
  "category": "algorithm",
  "tags": ["array", "range-query", "data-structure"],
  "canvas": { "width": 800, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "rect", "id": "arr-0", "x": 100, "y": 200, "width": 50, "height": 50, "label": "3", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "arr-1", "x": 160, "y": 200, "width": 50, "height": 50, "label": "1", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "arr-2", "x": 220, "y": 200, "width": 50, "height": 50, "label": "4", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "arr-3", "x": 300, "y": 200, "width": 50, "height": 50, "label": "1", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "arr-4", "x": 360, "y": 200, "width": 50, "height": 50, "label": "5", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "arr-5", "x": 420, "y": 200, "width": 50, "height": 50, "label": "9", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "arr-6", "x": 500, "y": 200, "width": 50, "height": 50, "label": "2", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "arr-7", "x": 560, "y": 200, "width": 50, "height": 50, "label": "6", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "arr-8", "x": 620, "y": 200, "width": 50, "height": 50, "label": "5", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "blk-0", "x": 100, "y": 280, "width": 170, "height": 40, "label": "Sum: 8", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "blk-1", "x": 300, "y": 280, "width": 170, "height": 40, "label": "Sum: 15", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "rect", "id": "blk-2", "x": 500, "y": 280, "width": 170, "height": 40, "label": "Sum: 13", "fill": "#e0e7ff", "stroke": "#6366f1" },
    { "type": "text", "id": "info", "x": 400, "y": 100, "content": "Initial Array & Blocks", "fontSize": 24, "textAnchor": "middle" }
  ],
  "initiallyHidden": [],
  "steps": [
    {
      "id": "step-0",
      "label": "Query [2..6]",
      "duration": 800,
      "ease": "easeInOut",
      "keyframes": {
        "info": { "content": "Query Range: [2..6]" }
      },
      "effects": []
    },
    {
      "id": "step-1",
      "label": "Partial block 0",
      "duration": 800,
      "ease": "easeInOut",
      "keyframes": {
        "info": { "content": "Partial block (idx 2): Add 4" },
        "arr-2": { "fill": "#fbbf24", "stroke": "#d97706" }
      },
      "effects": []
    },
    {
      "id": "step-2",
      "label": "Full block 1",
      "duration": 800,
      "ease": "easeInOut",
      "keyframes": {
        "info": { "content": "Full block (idx 3-5): Add block sum 15" },
        "blk-1": { "fill": "#34d399", "stroke": "#059669" },
        "arr-3": { "fill": "#34d399", "stroke": "#059669" },
        "arr-4": { "fill": "#34d399", "stroke": "#059669" },
        "arr-5": { "fill": "#34d399", "stroke": "#059669" }
      },
      "effects": []
    },
    {
      "id": "step-3",
      "label": "Partial block 2",
      "duration": 800,
      "ease": "easeInOut",
      "keyframes": {
        "info": { "content": "Partial block (idx 6): Add 2" },
        "arr-6": { "fill": "#fbbf24", "stroke": "#d97706" }
      },
      "effects": []
    },
    {
      "id": "step-4",
      "label": "Result",
      "duration": 800,
      "ease": "easeInOut",
      "keyframes": {
        "info": { "content": "Total Sum = 4 + 15 + 2 = 21" }
      },
      "effects": []
    },
    {
      "id": "step-5",
      "label": "Reset",
      "duration": 800,
      "ease": "easeInOut",
      "keyframes": {
        "info": { "content": "Initial Array & Blocks" },
        "arr-2": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "blk-1": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "arr-3": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "arr-4": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "arr-5": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "arr-6": { "fill": "#e0e7ff", "stroke": "#6366f1" }
      },
      "effects": []
    }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 200 }
}
