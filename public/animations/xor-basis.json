{
  "version": 4,
  "id": "xor-basis",
  "title": "XOR 기저 (XOR Basis)",
  "description": "XOR 기저 삽입 과정: [3, 5, 9, 11] 의 기저를 구하고 최대 XOR = 15",
  "category": "algorithm",
  "tags": ["xor-basis", "bitmask", "linear-algebra", "math"],
  "duration": 13000,
  "canvas": { "width": 900, "height": 500, "background": "transparent" },
  "elements": [
    { "id": "title", "type": "text", "x": 450, "y": 25, "text": "XOR Basis Insertion", "fontSize": 20, "fontWeight": "bold", "fill": "#0b0b0f", "textAlign": "center" },
    { "id": "basis-label", "type": "text", "x": 50, "y": 60, "text": "Basis (initial: empty)", "fontSize": 14, "fill": "#475569" },
    { "id": "slot-msb", "type": "text", "x": 120, "y": 90, "text": "bit 3: [  ]", "fontSize": 16, "fill": "#475569" },
    { "id": "slot-b2", "type": "text", "x": 120, "y": 115, "text": "bit 2: [  ]", "fontSize": 16, "fill": "#475569" },
    { "id": "slot-b1", "type": "text", "x": 120, "y": 140, "text": "bit 1: [  ]", "fontSize": 16, "fill": "#475569" },
    { "id": "slot-b0", "type": "text", "x": 120, "y": 165, "text": "bit 0: [  ]", "fontSize": 16, "fill": "#475569" },
    { "id": "val-3", "type": "rect", "x": 450, "y": 80, "width": 120, "height": 40, "fill": "#ede9fe", "stroke": "#7c3aed", "strokeWidth": 2, "rx": 4 },
    { "id": "val-3-text", "type": "text", "x": 510, "y": 105, "text": "3 (0011)", "fontSize": 16, "fontWeight": "bold", "fill": "#5b21b6", "textAlign": "center" },
    { "id": "val-5", "type": "rect", "x": 450, "y": 130, "width": 120, "height": 40, "fill": "#dbeafe", "stroke": "#2563eb", "strokeWidth": 2, "rx": 4 },
    { "id": "val-5-text", "type": "text", "x": 510, "y": 155, "text": "5 (0101)", "fontSize": 16, "fontWeight": "bold", "fill": "#1e3a8a", "textAlign": "center" },
    { "id": "val-9", "type": "rect", "x": 450, "y": 180, "width": 120, "height": 40, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "rx": 4 },
    { "id": "val-9-text", "type": "text", "x": 510, "y": 205, "text": "9 (1001)", "fontSize": 16, "fontWeight": "bold", "fill": "#14532d", "textAlign": "center" },
    { "id": "val-11", "type": "rect", "x": 450, "y": 230, "width": 120, "height": 40, "fill": "#fef9c3", "stroke": "#eab308", "strokeWidth": 2, "rx": 4 },
    { "id": "val-11-text", "type": "text", "x": 510, "y": 255, "text": "11 (1011)", "fontSize": 16, "fontWeight": "bold", "fill": "#713f12", "textAlign": "center" },
    { "id": "arrow-insert", "type": "line", "x1": 430, "y1": 100, "x2": 280, "y2": 105, "stroke": "#7c3aed", "strokeWidth": 2, "markerEnd": "arrow" },
    { "id": "operation-info", "type": "text", "x": 450, "y": 300, "text": "Inserting...", "fontSize": 16, "fontWeight": "bold", "fill": "#0b0b0f", "textAlign": "center" },
    { "id": "xor-result", "type": "text", "x": 450, "y": 325, "text": "x ^ basis[i] = ...", "fontSize": 14, "fill": "#475569", "textAlign": "center" },
    { "id": "result-box", "type": "rect", "x": 50, "y": 380, "width": 800, "height": 70, "fill": "#fee2e2", "stroke": "#dc2626", "strokeWidth": 3, "rx": 6 },
    { "id": "result-text", "type": "text", "x": 450, "y": 420, "text": "max xor: 15 (3 XOR 5 XOR 9 = 1111)", "fontSize": 22, "fontWeight": "bold", "fill": "#7f1d1d", "textAlign": "center" }
  ],
  "chapters": [
    { "id": "intro", "title": "초기 상태", "startTime": 0, "endTime": 1500, "caption": "4개의 수 [3, 5, 9, 11] 에 대한 XOR 기저" },
    { "id": "insert-3", "title": "3 (0011) 삽입", "startTime": 1500, "endTime": 3500, "caption": "insert(3): bit 1 -> basis[1] = 3" },
    { "id": "insert-5", "title": "5 (0101) 삽입", "startTime": 3500, "endTime": 5500, "caption": "insert(5): bit 2 -> basis[2] = 5" },
    { "id": "insert-9", "title": "9 (1001) 삽입", "startTime": 5500, "endTime": 8000, "caption": "insert(9): bit 3 -> basis[3] = 9" },
    { "id": "insert-11", "title": "11 (1011) 삽입", "startTime": 8000, "endTime": 10500, "caption": "insert(11): 11^9=2, 2^3=1 -> basis[0] = 1" },
    { "id": "conclude", "title": "최대 XOR", "startTime": 10500, "endTime": 13000, "caption": "모든 basis 에 대해 maxXor() = 15" }
  ],
  "effects": [
    { "id": "fade-title", "elementId": "title", "type": "fade", "startTime": 0, "duration": 500, "from": 0, "to": 1 },
    { "id": "highlight-3", "elementId": "val-3", "type": "highlight", "startTime": 1500, "duration": 1000, "color": "#7c3aed" },
    { "id": "highlight-5", "elementId": "val-5", "type": "highlight", "startTime": 3500, "duration": 1000, "color": "#2563eb" },
    { "id": "highlight-9", "elementId": "val-9", "type": "highlight", "startTime": 5500, "duration": 1000, "color": "#16a34a" },
    { "id": "highlight-11", "elementId": "val-11", "type": "highlight", "startTime": 8000, "duration": 1000, "color": "#eab308" },
    { "id": "show-result", "elementId": "result-box", "type": "scale", "startTime": 10500, "duration": 1000, "from": 0.8, "to": 1 }
  ],
  "settings": { "loop": true, "autoplay": true, "showCaption": false, "showChapterList": true }
}
