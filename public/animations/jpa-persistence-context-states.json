      "y": 28,
      "content": "Entity Lifecycle in PersistenceContext",
      "fontSize": 20,
      "fontWeight": 700,
      "color": "#18181b",
      "textAnchor": "middle",
      "appearances": [{ "start": 0, "end": 18000 }],
      "tracks": []
    },
    {
      "type": "text",
      "id": "step",
      "rotation": 0,
      "x": 460,
      "y": 58,
      "content": "1) new User() : transient (JPA 모름)",
      "fontSize": 14,
      "fontWeight": 600,
      "color": "#6366f1",
      "textAnchor": "middle",
      "appearances": [{ "start": 0, "end": 18000 }],
      "tracks": [
        {
          "property": "content",
          "keyframes": [
            { "time": 0, "value": "1) new User() : transient (JPA 모름)" },
            { "time": 2500, "value": "2) em.persist(u) : managed (1차 캐시 등록, INSERT 대기)" },
            { "time": 5500, "value": "3) u.setName(...) : dirty checking 으로 변경 추적" },
            { "time": 8000, "value": "4) em.flush() / commit : DB 에 INSERT + UPDATE 한꺼번에" },
            { "time": 11000, "value": "5) em.detach(u) : detached (메모리 분리, 변경 추적 안 됨)" },
            { "time": 13500, "value": "6) em.merge(u) : 새 managed 인스턴스 반환 (원본은 여전히 detached)" },
            { "time": 16000, "value": "7) em.remove(u) : removed (DELETE 대기, flush 시 DB 반영)" }
          ]
        }
      ]
    },
