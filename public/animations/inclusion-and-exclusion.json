{
  "version": 4,
  "id": "inclusion-and-exclusion",
  "title": "포함-배제 원리 (Inclusion-Exclusion)",
  "description": "집합 합집합 크기를 교집합 항으로 계산하는 2^N 공식",
  "category": "algorithm",
  "tags": ["inclusion-exclusion", "combinatorics", "PIE", "set-theory"],
  "duration": 14000,
  "canvas": {
    "width": 900,
    "height": 500,
    "background": "transparent"
  },
  "elements": [
    {
      "id": "set_a",
      "type": "circle",
      "cx": 200,
      "cy": 150,
      "r": 70,
      "fill": "#dbeafe",
      "fillOpacity": 0.6,
      "stroke": "#2563eb",
      "strokeWidth": 2
    },
    {
      "id": "set_b",
      "type": "circle",
      "cx": 280,
      "cy": 150,
      "r": 70,
      "fill": "#dcfce7",
      "fillOpacity": 0.6,
      "stroke": "#16a34a",
      "strokeWidth": 2
    },
    {
      "id": "set_c",
      "type": "circle",
      "cx": 240,
      "cy": 220,
      "r": 70,
      "fill": "#fee2e2",
      "fillOpacity": 0.6,
      "stroke": "#dc2626",
      "strokeWidth": 2
    },
    {
      "id": "label_a",
      "type": "text",
      "x": 150,
      "y": 130,
      "text": "A",
      "fontSize": 20,
      "fontWeight": "bold",
      "fill": "#1e3a8a"
    },
    {
      "id": "label_b",
      "type": "text",
      "x": 320,
      "y": 130,
      "text": "B",
      "fontSize": 20,
      "fontWeight": "bold",
      "fill": "#14532d"
    },
    {
      "id": "label_c",
      "type": "text",
      "x": 240,
      "y": 280,
      "text": "C",
      "fontSize": 20,
      "fontWeight": "bold",
      "fill": "#7f1d1d"
    },
    {
      "id": "formula_2",
      "type": "text",
      "x": 450,
      "y": 80,
      "text": "2집합: |A ∪ B|",
      "fontSize": 15,
      "fontWeight": "bold",
      "fill": "#0b0b0f"
    },
    {
      "id": "formula_2_eq",
      "type": "text",
      "x": 450,
      "y": 110,
      "text": "= |A| + |B| - |A ∩ B|",
      "fontSize": 13,
      "fill": "#2563eb",
      "fontFamily": "monospace"
    },
    {
      "id": "formula_3",
      "type": "text",
      "x": 450,
      "y": 160,
      "text": "3집합: |A ∪ B ∪ C|",
      "fontSize": 15,
      "fontWeight": "bold",
      "fill": "#0b0b0f"
    },
    {
      "id": "formula_3_1",
      "type": "text",
      "x": 450,
      "y": 190,
      "text": "= |A| + |B| + |C|",
      "fontSize": 12,
      "fill": "#16a34a",
      "fontFamily": "monospace"
    },
    {
      "id": "formula_3_2",
      "type": "text",
      "x": 450,
      "y": 210,
      "text": "  - |A ∩ B| - |A ∩ C| - |B ∩ C|",
      "fontSize": 12,
      "fill": "#dc2626",
      "fontFamily": "monospace"
    },
    {
      "id": "formula_3_3",
      "type": "text",
      "x": 450,
      "y": 230,
      "text": "  + |A ∩ B ∩ C|",
      "fontSize": 12,
      "fill": "#7c3aed",
      "fontFamily": "monospace"
    },
    {
      "id": "general_title",
      "type": "text",
      "x": 450,
      "y": 280,
      "text": "일반 N집합 (2^N 항)",
      "fontSize": 15,
      "fontWeight": "bold",
      "fill": "#0b0b0f"
    },
    {
      "id": "general_formula",
      "type": "text",
      "x": 450,
      "y": 310,
      "text": "Σ (-1)^(|S|+1) |⋂ Aᵢ|",
      "fontSize": 13,
      "fill": "#5b21b6",
      "fontFamily": "monospace"
    },
    {
      "id": "example_title",
      "type": "text",
      "x": 50,
      "y": 360,
      "text": "예: 1..100 중 2, 3, 5로 나눠지는 수",
      "fontSize": 14,
      "fontWeight": "bold",
      "fill": "#0b0b0f"
    },
    {
      "id": "example_calc",
      "type": "text",
      "x": 50,
      "y": 390,
      "text": "= ⌊100/2⌋ + ⌊100/3⌋ + ⌊100/5⌋",
      "fontSize": 12,
      "fill": "#16a34a",
      "fontFamily": "monospace"
    },
    {
      "id": "example_calc2",
      "type": "text",
      "x": 50,
      "y": 410,
      "text": "  - ⌊100/6⌋ - ⌊100/10⌋ - ⌊100/15⌋",
      "fontSize": 12,
      "fill": "#dc2626",
      "fontFamily": "monospace"
    },
    {
      "id": "example_calc3",
      "type": "text",
      "x": 50,
      "y": 430,
      "text": "  + ⌊100/30⌋ = 74",
      "fontSize": 12,
      "fill": "#7c3aed",
      "fontFamily": "monospace"
    },
    {
      "id": "highlight_ab",
