  "effects": [
    {
      "id": "highlight-n",
      "elementId": "n-box",
      "type": "highlight",
      "startTime": 0,
      "duration": 1000,
      "color": "#7c3aed"
    },
    {
      "id": "reveal-2a",
      "elementId": "factor-2a",
      "type": "fade",
      "startTime": 2000,
      "duration": 600,
      "from": 0,
      "to": 1
    },
    {
      "id": "reveal-2b",
      "elementId": "factor-2b",
      "type": "fade",
      "startTime": 4000,
      "duration": 600,
      "from": 0,
      "to": 1
    },
    {
      "id": "reveal-3",
      "elementId": "factor-3",
      "type": "fade",
      "startTime": 6000,
      "duration": 600,
      "from": 0,
      "to": 1
    },
    {
      "id": "reveal-5",
      "elementId": "factor-5",
      "type": "fade",
      "startTime": 9000,
      "duration": 600,
      "from": 0,
      "to": 1
    },
    {
      "id": "show-result",
      "elementId": "result-box",
      "type": "scale",
      "startTime": 10000,
      "duration": 800,
      "from": 0.8,
      "to": 1
    }
