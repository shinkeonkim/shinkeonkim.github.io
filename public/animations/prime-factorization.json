      "startTime": 0,
      "endTime": 2000,
      "caption": "N=60 을 소인수분해"
    },
    {
      "id": "divide-2-first",
      "title": "2로 첫 나눗셈",
      "startTime": 2000,
      "endTime": 4000,
      "caption": "60 ÷ 2 = 30, 인수 [2]"
    },
    {
      "id": "divide-2-second",
      "title": "2로 재차 나눗셈",
      "startTime": 4000,
      "endTime": 6000,
      "caption": "30 ÷ 2 = 15, 인수 [2,2]"
    },
    {
      "id": "divide-3",
      "title": "3으로 나눗셈",
      "startTime": 6000,
      "endTime": 9000,
      "caption": "15 ÷ 3 = 5, 인수 [2,2,3]"
    },
    {
      "id": "final-prime",
      "title": "남은 소수 5",
      "startTime": 9000,
      "endTime": 12000,
      "caption": "5는 소수. 최종 인수 [2,2,3,5]"
