{
  "version": 4,
  "id": "li-chao-tree",
  "title": "Li Chao Tree",
  "description": "직선 추가 + 점에서 max/min, O(log N) per op",
  "category": "algorithm",
  "tags": ["data-structure", "li-chao-tree", "convex-hull-trick"],
  "duration": 13000,
  "canvas": {
    "width": 900,
    "height": 500,
    "background": "transparent"
  },
  "elements": [
    {
      "id": "axes",
      "type": "line",
      "x1": 50,
      "y1": 300,
      "x2": 750,
      "y2": 300,
      "stroke": "#475569",
      "strokeWidth": 2
    },
    {
      "id": "y-axis",
      "type": "line",
      "x1": 400,
      "y1": 50,
      "x2": 400,
      "y2": 450,
      "stroke": "#475569",
      "strokeWidth": 2
    },
    {
      "id": "line1",
      "type": "line",
      "x1": 100,
      "y1": 400,
      "x2": 700,
      "y2": 100,
      "stroke": "#2563eb",
      "strokeWidth": 2.5,
      "opacity": 0
    },
    {
      "id": "line1-label",
      "type": "text",
      "text": "y = 2x + 1",
      "x": 650,
      "y": 120,
      "fontSize": 12,
      "fill": "#2563eb",
      "opacity": 0
    },
    {
      "id": "line2",
      "type": "line",
      "x1": 100,
      "y1": 200,
      "x2": 700,
      "y2": 380,
      "stroke": "#16a34a",
      "strokeWidth": 2.5,
      "opacity": 0
    },
    {
      "id": "line2-label",
      "type": "text",
      "text": "y = -x + 5",
      "x": 150,
      "y": 220,
      "fontSize": 12,
      "fill": "#16a34a",
      "opacity": 0
    },
    {
      "id": "query-point",
      "type": "circle",
      "cx": 400,
      "cy": 300,
      "r": 0,
      "fill": "#dc2626",
      "stroke": "#7f1d1d",
      "strokeWidth": 2
    },
    {
      "id": "query-label",
      "type": "text",
      "text": "x = 2",
      "x": 420,
      "y": 295,
      "fontSize": 14,
      "fill": "#dc2626",
      "opacity": 0
    },
    {
      "id": "tree-root",
      "type": "rect",
      "x": 50,
      "y": 20,
      "width": 100,
      "height": 40,
      "fill": "#dbeafe",
      "stroke": "#2563eb",
      "strokeWidth": 2,
      "rx": 3
    },
    { "id": "root-text", "type": "text", "text": "[-1M,1M]", "x": 100, "y": 45, "fontSize": 11, "fill": "#1e3a8a", "textAnchor": "middle" },
    {
      "id": "tree-left",
      "type": "rect",
      "x": 180,
      "y": 80,
      "width": 90,
      "height": 35,
      "fill": "#dcfce7",
      "stroke": "#16a34a",
      "strokeWidth": 1.5,
      "rx": 2
    },
    { "id": "left-text", "type": "text", "text": "[-1M,0]", "x": 225, "y": 102, "fontSize": 10, "fill": "#14532d", "textAnchor": "middle" },
    {
      "id": "tree-right",
      "type": "rect",
      "x": 300,
      "y": 80,
      "width": 90,
      "height": 35,
      "fill": "#dcfce7",
      "stroke": "#16a34a",
      "strokeWidth": 1.5,
      "rx": 2
    },
    { "id": "right-text", "type": "text", "text": "[0,1M]", "x": 345, "y": 102, "fontSize": 10, "fill": "#14532d", "textAnchor": "middle" },
    {
      "id": "node-label",
      "type": "text",
      "text": "루트 mid에서 최대 직선 저장",
      "x": 100,
      "y": 140,
      "fontSize": 11,
      "fill": "#7c3aed",
      "opacity": 0
    },
    {
      "id": "result-label",
      "type": "text",
      "text": "max(2*2+1, -2+5) = 5",
      "x": 450,
      "y": 430,
      "fontSize": 14,
      "fontWeight": "bold",
      "fill": "#dc2626",
      "opacity": 0
    }
  ],
  "chapters": [
    {
      "id": "ch1",
      "title": "초기 상태",
      "start": 0,
      "end": 2000,
      "caption": "좌표 평면, 세그트리 구조"
    },
    {
      "id": "ch2",
      "title": "직선 추가",
      "start": 2000,
      "end": 5000,
      "caption": "y=2x+1, y=-x+5 삽입 O(log N)"
    },
    {
      "id": "ch3",
      "title": "mid 비교",
      "start": 5000,
      "end": 8000,
      "caption": "각 노드에서 mid 지점 최대 직선 저장"
    },
    {
      "id": "ch4",
      "title": "점 쿼리",
      "start": 8000,
      "end": 11000,
      "caption": "x=2 에서 최댓값? 루트→리프 경로 확인"
    },
    {
      "id": "ch5",
      "title": "결과",
      "start": 11000,
      "end": 13000,
      "caption": "max = 5 (y=-x+5)"
    }
  ],
  "effects": [
    {
      "target": ["line1", "line1-label"],
      "start": 2500,
      "end": 3500,
      "property": "opacity",
      "from": 0,
      "to": 1,
      "easing": "easeOut"
    },
    {
      "target": ["line2", "line2-label"],
      "start": 3500,
      "end": 4500,
      "property": "opacity",
      "from": 0,
      "to": 1,
      "easing": "easeOut"
    },
    {
      "target": ["node-label"],
      "start": 5500,
      "end": 6500,
      "property": "opacity",
      "from": 0,
      "to": 1,
      "easing": "easeIn"
    },
    {
      "target": ["tree-root"],
      "start": 6000,
      "end": 7000,
      "property": "fill",
      "from": "#dbeafe",
      "to": "#fef9c3",
      "easing": "linear"
    },
    {
      "target": ["query-point"],
      "start": 8500,
      "end": 9500,
      "property": "r",
      "from": 0,
      "to": 8,
      "easing": "easeOut"
    },
    {
      "target": ["query-label"],
      "start": 9000,
      "end": 10000,
      "property": "opacity",
      "from": 0,
      "to": 1,
      "easing": "easeIn"
    },
    {
      "target": ["tree-root", "tree-left", "tree-right"],
      "start": 9500,
      "end": 10500,
      "property": "stroke",
      "from": "#16a34a",
      "to": "#7c3aed",
      "easing": "linear"
    },
    {
      "target": ["result-label"],
      "start": 11500,
      "end": 12500,
      "property": "opacity",
      "from": 0,
      "to": 1,
      "easing": "easeIn"
    }
  ],
  "settings": {
    "loop": true,
    "autoplay": true,
    "showCaption": false,
    "showChapterList": true
  }
}
