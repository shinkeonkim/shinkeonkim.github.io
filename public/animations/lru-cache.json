{
  "version": 2,
  "id": "lru-cache",
  "title": "LRU Cache (capacity = 3)",
  "description": "PUT(A), PUT(B), PUT(C), GET(A), PUT(D) — D 삽입 시 가장 오래된 B 가 evict",
  "category": "algorithm",
  "tags": ["lru", "cache", "data-structure", "algorithm"],
  "canvas": { "width": 800, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "step-label", "rotation": 0, "x": 400, "y": 32, "content": "LRU Cache (capacity = 3) — 빈 상태", "fontSize": 18, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle" },

    { "type": "text", "id": "cache-title", "rotation": 0, "x": 400, "y": 105, "content": "Cache (head → tail · MRU → LRU)", "fontSize": 13, "fontWeight": 700, "color": "#64748b", "textAnchor": "middle" },
    { "type": "rect", "id": "slot1", "rotation": 0, "x": 220, "y": 140, "width": 110, "height": 80, "fill": "#f8fafc", "stroke": "#cbd5e1", "strokeWidth": 2, "strokeDasharray": "4 4", "cornerRadius": 10, "label": "", "labelColor": "#312e81", "labelSize": 28 },
    { "type": "rect", "id": "slot2", "rotation": 0, "x": 345, "y": 140, "width": 110, "height": 80, "fill": "#f8fafc", "stroke": "#cbd5e1", "strokeWidth": 2, "strokeDasharray": "4 4", "cornerRadius": 10, "label": "", "labelColor": "#312e81", "labelSize": 28 },
    { "type": "rect", "id": "slot3", "rotation": 0, "x": 470, "y": 140, "width": 110, "height": 80, "fill": "#f8fafc", "stroke": "#cbd5e1", "strokeWidth": 2, "strokeDasharray": "4 4", "cornerRadius": 10, "label": "", "labelColor": "#312e81", "labelSize": 28 },

    { "type": "text", "id": "slot1-tag", "rotation": 0, "x": 275, "y": 240, "content": "MRU", "fontSize": 11, "fontWeight": 700, "color": "#94a3b8", "textAnchor": "middle" },
    { "type": "text", "id": "slot3-tag", "rotation": 0, "x": 525, "y": 240, "content": "LRU", "fontSize": 11, "fontWeight": 700, "color": "#94a3b8", "textAnchor": "middle" },

    { "type": "text", "id": "ops-title", "rotation": 0, "x": 70, "y": 310, "content": "ops", "fontSize": 13, "fontWeight": 700, "color": "#64748b", "textAnchor": "start" },
    { "type": "text", "id": "op-current", "rotation": 0, "x": 400, "y": 330, "content": "—", "fontSize": 26, "fontWeight": 700, "color": "#0f172a", "textAnchor": "middle" },
    { "type": "text", "id": "op-desc", "rotation": 0, "x": 400, "y": 380, "content": "준비", "fontSize": 15, "fontWeight": 500, "color": "#64748b", "textAnchor": "middle" },

    { "type": "rect", "id": "evict-box", "rotation": 0, "x": 620, "y": 420, "width": 110, "height": 60, "fill": "#fecaca", "stroke": "#dc2626", "strokeWidth": 2, "cornerRadius": 8, "label": "", "labelColor": "#7f1d1d", "labelSize": 22 },
    { "type": "text", "id": "evict-label", "rotation": 0, "x": 675, "y": 412, "content": "evicted", "fontSize": 12, "fontWeight": 700, "color": "#991b1b", "textAnchor": "middle" }
  ],
  "initiallyHidden": ["evict-box", "evict-label"],
  "steps": [
    { "id": "s1", "label": "PUT A", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "slot1": { "fill": "#dcfce7", "stroke": "#16a34a", "strokeDasharray": "", "label": "A" },
        "op-current": { "content": "PUT(A)", "color": "#16a34a" },
        "op-desc": { "content": "A 삽입 → 캐시: [A]" },
        "step-label": { "content": "PUT(A) — 빈 slot 에 삽입" }
      },
      "effects": [{ "type": "pulse", "elementId": "slot1", "scale": 1.1, "duration": 500, "delay": 0 }] },
    { "id": "s2", "label": "PUT B", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "slot1": { "fill": "#e0f2fe", "stroke": "#0284c7", "label": "B" },
        "slot2": { "fill": "#dcfce7", "stroke": "#16a34a", "strokeDasharray": "", "label": "A" },
        "op-current": { "content": "PUT(B)", "color": "#16a34a" },
        "op-desc": { "content": "B 삽입 → [B, A] (B 가 MRU)" },
        "step-label": { "content": "PUT(B) — 새 항목은 head 로" }
      },
      "effects": [{ "type": "pulse", "elementId": "slot1", "scale": 1.1, "duration": 500, "delay": 0 }] },
    { "id": "s3", "label": "PUT C", "duration": 800, "ease": "easeOut",
      "keyframes": {
        "slot1": { "fill": "#dcfce7", "stroke": "#16a34a", "label": "C" },
        "slot2": { "fill": "#e0f2fe", "stroke": "#0284c7", "label": "B" },
        "slot3": { "fill": "#e0f2fe", "stroke": "#0284c7", "strokeDasharray": "", "label": "A" },
        "op-current": { "content": "PUT(C)", "color": "#16a34a" },
        "op-desc": { "content": "C 삽입 → [C, B, A] (가득 참)" },
        "step-label": { "content": "PUT(C) — capacity 도달" }
      },
      "effects": [{ "type": "pulse", "elementId": "slot1", "scale": 1.1, "duration": 500, "delay": 0 }] },
    { "id": "s4", "label": "GET A", "duration": 1000, "ease": "easeOut",
      "keyframes": {
        "slot1": { "fill": "#fef3c7", "stroke": "#d97706", "label": "A" },
        "slot2": { "fill": "#e0f2fe", "stroke": "#0284c7", "label": "C" },
        "slot3": { "fill": "#e0f2fe", "stroke": "#0284c7", "label": "B" },
        "op-current": { "content": "GET(A) → A", "color": "#d97706" },
        "op-desc": { "content": "A 를 head 로 이동 → [A, C, B]" },
        "step-label": { "content": "GET(A) — 최근 사용이므로 head 로 promote" }
      },
      "effects": [
        { "type": "highlight", "elementId": "slot1", "color": "#fbbf24", "duration": 600, "delay": 0 },
        { "type": "pulse", "elementId": "slot1", "scale": 1.15, "duration": 500, "delay": 200 }
      ] },
    { "id": "s5", "label": "PUT D - evict B", "duration": 1100, "ease": "easeOut",
      "keyframes": {
        "slot1": { "fill": "#dcfce7", "stroke": "#16a34a", "label": "D" },
        "slot2": { "fill": "#e0f2fe", "stroke": "#0284c7", "label": "A" },
        "slot3": { "fill": "#e0f2fe", "stroke": "#0284c7", "label": "C" },
        "evict-box": { "visible": true, "label": "B" },
        "evict-label": { "visible": true },
        "op-current": { "content": "PUT(D)", "color": "#16a34a" },
        "op-desc": { "content": "가득 참 → tail (LRU) = B 제거 → [D, A, C]" },
        "step-label": { "content": "PUT(D) — B 가 LRU 라 evict" }
      },
      "effects": [
        { "type": "pulse", "elementId": "slot1", "scale": 1.1, "duration": 500, "delay": 0 },
        { "type": "highlight", "elementId": "evict-box", "color": "#ef4444", "duration": 700, "delay": 200 }
      ] },
    { "id": "s6", "label": "재시작", "duration": 700, "ease": "linear",
      "keyframes": {
        "slot1": { "fill": "#f8fafc", "stroke": "#cbd5e1", "strokeDasharray": "4 4", "label": "" },
        "slot2": { "fill": "#f8fafc", "stroke": "#cbd5e1", "strokeDasharray": "4 4", "label": "" },
        "slot3": { "fill": "#f8fafc", "stroke": "#cbd5e1", "strokeDasharray": "4 4", "label": "" },
        "evict-box": { "visible": false, "label": "" },
        "evict-label": { "visible": false },
        "op-current": { "content": "—", "color": "#0f172a" },
        "op-desc": { "content": "준비" },
        "step-label": { "content": "LRU Cache (capacity = 3) — 빈 상태" }
      },
      "effects": [] }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 300 }
}
