      "fill": "#dbeafe",
      "stroke": "#475569",
      "strokeWidth": 1
    },
    {
      "id": "cell-1-1",
      "type": "rect",
      "x": 130,
      "y": 130,
      "width": 80,
      "height": 80,
      "fill": "#dbeafe",
      "stroke": "#475569",
      "strokeWidth": 1
    },
    {
      "id": "cell-1-2",
      "type": "rect",
      "x": 210,
      "y": 130,
      "width": 80,
      "height": 80,
      "fill": "#1e293b",
      "stroke": "#475569",
      "strokeWidth": 1
    },
    {
      "id": "cell-2-0",
      "type": "rect",
      "x": 50,
      "y": 210,
      "width": 80,
      "height": 80,
      "fill": "#dbeafe",
      "stroke": "#475569",
      "strokeWidth": 1
    },
    {
      "id": "cell-2-1",
      "type": "rect",
      "x": 130,
      "y": 210,
      "width": 80,
      "height": 80,
      "fill": "#1e293b",
      "stroke": "#475569",
      "strokeWidth": 1
    },
    {
      "id": "cell-2-2",
      "type": "rect",
      "x": 210,
      "y": 210,
      "width": 80,
      "height": 80,
      "fill": "#dbeafe",
      "stroke": "#475569",
      "strokeWidth": 1
    },
    {
      "id": "start-marker",
      "type": "circle",
      "cx": 90,
      "cy": 170,
      "r": 8,
      "fill": "#dc2626",
      "stroke": "#7f1d1d",
      "strokeWidth": 2
    },
    {
      "id": "queue-box",
      "type": "rect",
      "x": 520,
      "y": 50,
      "width": 320,
      "height": 80,
      "fill": "#1e293b",
      "stroke": "#475569",
      "strokeWidth": 2,
      "rx": 4
    },
    {
      "id": "queue-label",
      "type": "text",
      "x": 680,
      "y": 40,
      "content": "BFS Queue",
      "fontSize": 14,
      "fill": "#e2e8f0",
      "fontWeight": "bold",
      "textAnchor": "middle"
    },
    {
      "id": "queue-content",
      "type": "text",
      "x": 680,
      "y": 95,
      "content": "[(1, 0)]",
      "fontSize": 15,
      "fill": "#e2e8f0",
      "fontFamily": "monospace",
      "textAnchor": "middle"
    },
    {
      "id": "steps-box",
      "type": "rect",
      "x": 520,
      "y": 160,
      "width": 320,
      "height": 280,
      "fill": "#ede9fe",
      "stroke": "#7c3aed",
      "strokeWidth": 2,
      "rx": 4
    },
    {
      "id": "steps-label",
      "type": "text",
      "x": 680,
      "y": 150,
      "content": "Process Steps",
      "fontSize": 14,
      "fill": "#5b21b6",
      "fontWeight": "bold",
      "textAnchor": "middle"
    },
    {
      "id": "steps-content",
      "type": "text",
      "x": 680,
      "y": 220,
      "content": "1. Start at (1,0)\n2. Visit neighbors\n3. Add to queue\n4. Repeat",
      "fontSize": 14,
      "fill": "#5b21b6",
      "fontFamily": "monospace",
      "textAnchor": "middle"
    }
  ],
  "chapters": [
    {
      "id": "init",
      "title": "초기 상태",
      "startTime": 0,
      "endTime": 2000,
      "caption": "파란 영역 시작점 (1,0) 클릭. 빨간 마커 표시"
    },
    {
      "id": "fill-start",
      "title": "시작점 칠하기",
      "startTime": 2000,
      "endTime": 4000,
      "caption": "시작점을 초록색으로 칠하고 큐에 추가"
    },
    {
      "id": "expand-1",
      "title": "인접 칸 확장",
      "startTime": 4000,
      "endTime": 7000,
      "caption": "4방향 인접 칸 중 파란색 칸들을 큐에 추가"
    },
    {
      "id": "expand-2",
      "title": "연쇄 확장",
      "startTime": 7000,
      "endTime": 10000,
      "caption": "큐에서 꺼내며 연결된 모든 파란 칸을 초록색으로"
    },
    {
      "id": "done",
      "title": "완료",
      "startTime": 10000,
      "endTime": 12000,
      "caption": "연결된 영역 전체가 초록색으로 칠해짐. 검은 칸은 건너뜀"
    }
  ],
  "effects": [
    {
      "elementId": "start-marker",
      "property": "r",
      "startTime": 0,
      "endTime": 500,
      "from": 8,
      "to": 12
    },
    {
      "elementId": "start-marker",
      "property": "r",
      "startTime": 500,
      "endTime": 1000,
      "from": 12,
      "to": 8
    },
    {
      "elementId": "cell-1-0",
      "property": "fill",
      "startTime": 2000,
      "endTime": 2500,
      "from": "#dbeafe",
      "to": "#dcfce7"
    },
    {
      "elementId": "queue-content",
      "property": "content",
      "startTime": 2500,
      "endTime": 2600,
      "to": "[(0,0), (2,0)]"
    },
    {
      "elementId": "cell-0-0",
      "property": "fill",
      "startTime": 3000,
      "endTime": 3500,
      "from": "#dbeafe",
      "to": "#dcfce7"
    },
    {
      "elementId": "cell-2-0",
      "property": "fill",
      "startTime": 3500,
      "endTime": 4000,
      "from": "#dbeafe",
      "to": "#dcfce7"
    },
    {
      "elementId": "queue-content",
      "property": "content",
      "startTime": 4000,
      "endTime": 4100,
      "to": "[(0,1), (2,2)]"
    },
    {
      "elementId": "cell-0-1",
      "property": "fill",
      "startTime": 5000,
      "endTime": 5500,
      "from": "#dbeafe",
      "to": "#dcfce7"
    },
    {
      "elementId": "cell-2-2",
      "property": "fill",
      "startTime": 6000,
      "endTime": 6500,
      "from": "#dbeafe",
      "to": "#dcfce7"
    },
    {
      "elementId": "queue-content",
      "property": "content",
      "startTime": 7000,
      "endTime": 7100,
      "to": "[(0,2)]"
    },
    {
      "elementId": "cell-0-2",
      "property": "fill",
      "startTime": 8000,
      "endTime": 8500,
      "from": "#dbeafe",
      "to": "#dcfce7"
    },
    {
      "elementId": "queue-content",
      "property": "content",
      "startTime": 9000,
      "endTime": 9100,
      "to": "[]"
    },
    {
      "elementId": "steps-content",
      "property": "content",
      "startTime": 10000,
      "endTime": 10100,
      "to": "Flood Fill Complete!\n\nVisited: 7 cells\nSkipped: 2 cells\n(black walls)"
    }
  ],
  "settings": {
    "loop": true,
    "autoplay": true,
    "showCaption": false,
    "showChapterList": true
  }
}
