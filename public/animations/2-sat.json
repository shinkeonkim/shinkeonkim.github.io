{
  "version": 4,
  "id": "2-sat",
  "title": "2-SAT Implication Graph",
  "description": "2-CNF 판정, implication graph 구축과 SCC 기반 해 찾기",
  "category": "algorithm",
  "tags": ["2-sat", "graph", "scc"],
  "duration": 13000,
  "canvas": {
    "width": 900,
    "height": 500,
    "background": "transparent"
  },
  "elements": [
    {
      "id": "title",
      "type": "text",
      "x": 450,
      "y": 30,
      "text": "2-SAT: (x1 OR x2) AND (NOT x1 OR x3) AND (NOT x2 OR NOT x3)",
      "fontSize": 16,
      "fill": "#0b0b0f",
      "anchor": "middle"
    },
    {
      "id": "node-x1",
      "type": "circle",
      "x": 200,
      "y": 150,
      "radius": 30,
      "fill": "#e2e8f0",
      "stroke": "#475569",
      "strokeWidth": 2
    },
    {
      "id": "label-x1",
      "type": "text",
      "x": 200,
      "y": 150,
      "text": "x1",
      "fontSize": 14,
      "fill": "#0b0b0f",
      "anchor": "middle"
    },
    {
      "id": "node-not-x1",
      "type": "circle",
      "x": 200,
      "y": 350,
      "radius": 30,
      "fill": "#e2e8f0",
      "stroke": "#475569",
      "strokeWidth": 2
    },
    {
      "id": "label-not-x1",
      "type": "text",
      "x": 200,
      "y": 350,
      "text": "¬x1",
      "fontSize": 14,
      "fill": "#0b0b0f",
      "anchor": "middle"
    },
    {
      "id": "node-x2",
