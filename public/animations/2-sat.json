      "strokeWidth": 2
    },
    {
      "id": "label-x2",
      "type": "text",
      "x": 450,
      "y": 150,
      "text": "x2",
      "fontSize": 14,
      "fill": "#0b0b0f",
      "anchor": "middle"
    },
    {
      "id": "node-not-x2",
