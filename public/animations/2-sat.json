    {
      "id": "scc-box-2",
      "type": "rect",
      "x": 410,
      "y": 310,
      "width": 80,
      "height": 80,
      "fill": "#fef9c3",
      "stroke": "#eab308",
      "strokeWidth": 2,
      "opacity": 0
    }
