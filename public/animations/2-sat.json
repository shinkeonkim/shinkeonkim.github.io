  "chapters": [
    {
      "id": "intro",
      "title": "절을 implication 으로",
      "start": 0,
      "end": 3000
    },
    {
      "id": "clause1",
      "title": "(x1 OR x2) 변환",
      "start": 3000,
      "end": 6000
    },
    {
      "id": "clause2",
      "title": "(¬x1 OR x3) 변환",
      "start": 6000,
      "end": 9000
    },
    {
      "id": "scc",
      "title": "SCC 계산",
      "start": 9000,
      "end": 11000
    },
    {
      "id": "result",
      "title": "해 존재 확인",
      "start": 11000,
      "end": 13000
    }
  ],
  "effects": [
    {
      "chapterId": "clause1",
      "targetId": "edge-1",
      "type": "animate",
      "property": "opacity",
      "from": 0,
      "to": 1,
      "duration": 600
    },
    {
      "chapterId": "clause1",
      "targetId": "edge-2",
      "type": "animate",
      "property": "opacity",
      "from": 0,
      "to": 1,
      "duration": 600,
      "delay": 300
    },
    {
      "chapterId": "clause2",
      "targetId": "edge-3",
      "type": "animate",
      "property": "opacity",
      "from": 0,
      "to": 1,
      "duration": 600
    },
    {
      "chapterId": "clause2",
      "targetId": "edge-4",
      "type": "animate",
      "property": "opacity",
      "from": 0,
      "to": 1,
      "duration": 600,
      "delay": 300
    },
    {
      "chapterId": "scc",
      "targetId": "scc-box-1",
      "type": "animate",
      "property": "opacity",
      "from": 0,
      "to": 0.5,
      "duration": 800
    },
    {
      "chapterId": "scc",
      "targetId": "scc-box-2",
      "type": "animate",
      "property": "opacity",
      "from": 0,
      "to": 0.5,
      "duration": 800,
      "delay": 400
    },
    {
      "chapterId": "result",
      "targetId": "node-x1",
      "type": "animate",
      "property": "fill",
      "from": "#e2e8f0",
      "to": "#dcfce7",
      "duration": 500
    }
  ],
  "settings": {
    "loop": true,
    "autoplay": true,
    "showCaption": false,
    "showChapterList": true
  }
}
