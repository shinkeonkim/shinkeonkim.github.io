{
  "version": 4,
  "id": "lcs",
  "title": "LCS (Longest Common Subsequence)",
  "description": "O(NM) DP table construction and traceback for finding longest common subsequence",
  "category": "algorithm",
  "tags": ["dp", "lcs", "string", "sequence"],
  "duration": 14000,
  "canvas": {
    "width": 900,
    "height": 500,
    "background": "transparent"
  },
  "elements": [
    {
      "id": "title",
      "type": "text",
      "x": 450,
      "y": 30,
      "text": "LCS: O(NM) DP",
      "fontSize": 24,
      "fontWeight": "bold",
      "fill": "#0b0b0f",
      "anchor": "middle"
    },
    {
      "id": "seq-a-label",
      "type": "text",
      "x": 50,
      "y": 80,
      "text": "A:",
      "fontSize": 16,
      "fill": "#475569"
    },
    {
      "id": "seq-a",
      "type": "text",
      "x": 90,
      "y": 80,
      "text": "ABCBDAB",
      "fontSize": 18,
      "fill": "#0b0b0f",
      "fontFamily": "monospace"
    },
    {
      "id": "seq-b-label",
      "type": "text",
      "x": 50,
      "y": 110,
      "text": "B:",
      "fontSize": 16,
      "fill": "#475569"
    },
    {
      "id": "seq-b",
      "type": "text",
      "x": 90,
      "y": 110,
      "text": "BDCAB",
      "fontSize": 18,
      "fill": "#0b0b0f",
      "fontFamily": "monospace"
    },
    {
      "id": "dp-label",
      "type": "text",
      "x": 50,
      "y": 170,
      "text": "DP Table:",
      "fontSize": 16,
      "fill": "#475569"
    },
    {
      "id": "dp-0-0",
      "type": "rect",
      "x": 180,
      "y": 160,
      "width": 40,
      "height": 40,
      "fill": "#e2e8f0",
      "stroke": "#475569",
      "strokeWidth": 1
    },
    {
      "id": "dp-0-0-text",
      "type": "text",
      "x": 200,
      "y": 185,
      "text": "0",
      "fontSize": 14,
      "fill": "#0b0b0f",
      "anchor": "middle"
    },
    {
      "id": "dp-1-1",
      "type": "rect",
      "x": 230,
      "y": 210,
      "width": 40,
      "height": 40,
      "fill": "#e2e8f0",
      "stroke": "#475569",
      "strokeWidth": 1
    },
    {
      "id": "dp-1-1-text",
      "type": "text",
      "x": 250,
      "y": 235,
      "text": "0",
      "fontSize": 14,
      "fill": "#0b0b0f",
      "anchor": "middle"
    },
    {
      "id": "dp-match",
      "type": "rect",
      "x": 280,
      "y": 260,
      "width": 40,
      "height": 40,
      "fill": "#dcfce7",
      "stroke": "#16a34a",
      "strokeWidth": 2,
      "opacity": 0
    },
    {
      "id": "dp-match-text",
      "type": "text",
      "x": 300,
      "y": 285,
      "text": "1",
      "fontSize": 14,
      "fill": "#14532d",
      "anchor": "middle",
      "opacity": 0
    },
    {
      "id": "arrow-traceback",
      "type": "path",
      "path": "M 300 280 L 250 235",
      "stroke": "#7c3aed",
      "strokeWidth": 3,
      "opacity": 0,
      "arrowEnd": true
    },
    {
      "id": "lcs-result",
      "type": "text",
      "x": 450,
      "y": 380,
      "text": "",
      "fontSize": 20,
      "fill": "#16a34a",
      "anchor": "middle",
      "fontWeight": "bold"
    },
    {
      "id": "explanation",
      "type": "text",
      "x": 450,
      "y": 420,
      "text": "",
      "fontSize": 14,
      "fill": "#475569",
      "anchor": "middle",
      "width": 700
    }
  ],
  "chapters": [
    {
      "time": 0,
      "label": "초기 상태",
      "caption": "A = ABCBDAB, B = BDCAB. DP 테이블 초기화."
    },
    {
      "time": 2000,
      "label": "점화식",
      "caption": "dp[i][j] = A[i-1] == B[j-1] ? dp[i-1][j-1] + 1 : max(dp[i-1][j], dp[i][j-1])"
    },
    {
      "time": 5000,
      "label": "매칭 발견",
      "caption": "A[0] = B와 일치 없음. A[1] = B[0] = 'B' 매칭. dp[2][1] = 1."
    },
    {
      "time": 8000,
      "label": "테이블 채우기",
      "caption": "모든 (i, j) 순회하며 테이블 채움."
    },
    {
      "time": 11000,
      "label": "Traceback 시작",
      "caption": "dp[N][M] 에서 역추적. 매칭 셀은 대각선, 아니면 큰 쪽."
    },
    {
      "time": 13000,
      "label": "LCS = BCAB",
      "caption": "최종 LCS 길이 4, 수열 BCAB."
    }
  ],
  "effects": [
    {
      "target": "dp-1-1",
      "property": "fill",
      "from": "#e2e8f0",
      "to": "#fef9c3",
      "start": 1800,
      "duration": 400,
      "easing": "ease-in-out"
    },
    {
      "target": "explanation",
      "property": "text",
      "from": "",
      "to": "dp[i][j] 계산 중",
      "start": 2200,
      "duration": 100
    },
    {
      "target": "dp-match",
      "property": "opacity",
      "from": 0,
      "to": 1,
      "start": 5000,
      "duration": 400
    },
    {
      "target": "dp-match-text",
      "property": "opacity",
      "from": 0,
      "to": 1,
      "start": 5000,
      "duration": 400
    },
    {
      "target": "explanation",
      "property": "text",
      "from": "dp[i][j] 계산 중",
      "to": "A[i-1] == B[j-1] 매칭. dp = prev + 1",
      "start": 5200,
      "duration": 100
    },
    {
      "target": "dp-1-1",
      "property": "fill",
      "from": "#fef9c3",
      "to": "#dbeafe",
      "start": 8000,
      "duration": 400
    },
    {
      "target": "explanation",
      "property": "text",
      "from": "A[i-1] == B[j-1] 매칭. dp = prev + 1",
      "to": "테이블 전체 O(NM) 채움",
      "start": 8200,
      "duration": 100
    },
    {
      "target": "arrow-traceback",
      "property": "opacity",
      "from": 0,
      "to": 1,
      "start": 11000,
      "duration": 500
    },
    {
      "target": "explanation",
      "property": "text",
      "from": "테이블 전체 O(NM) 채움",
      "to": "Traceback: 매칭 셀 → 대각선 이동",
      "start": 11200,
      "duration": 100
    },
    {
      "target": "lcs-result",
      "property": "text",
      "from": "",
      "to": "LCS = BCAB (length 4)",
      "start": 13000,
      "duration": 200
    },
    {
      "target": "explanation",
      "property": "text",
      "from": "Traceback: 매칭 셀 → 대각선 이동",
      "to": "역추적 완료. LCS 복원 완료.",
      "start": 13200,
      "duration": 100
    }
  ],
  "settings": {
    "loop": true,
    "autoplay": true,
    "showCaption": false,
    "showChapterList": true
  }
}
