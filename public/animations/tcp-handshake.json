{
  "version": 2,
  "id": "tcp-handshake",
  "title": "TCP 3-way Handshake",
  "description": "TCP 연결 수립: SYN → SYN+ACK → ACK",
  "category": "protocol",
  "tags": ["tcp", "handshake", "protocol", "network"],
  "canvas": { "width": 800, "height": 460, "background": "transparent" },
  "elements": [
    { "type": "rect", "id": "client", "rotation": 0, "x": 80, "y": 60, "width": 160, "height": 70, "fill": "#dbeafe", "stroke": "#3b82f6", "strokeWidth": 2, "cornerRadius": 10, "label": "Client", "labelColor": "#1e3a8a", "labelSize": 16, "subtitle": "CLOSED" },
    { "type": "rect", "id": "server", "rotation": 0, "x": 560, "y": 60, "width": 160, "height": 70, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 10, "label": "Server", "labelColor": "#14532d", "labelSize": 16, "subtitle": "LISTEN" },
    { "type": "line", "id": "c-line", "rotation": 0, "x1": 160, "y1": 130, "x2": 160, "y2": 420, "stroke": "#94a3b8", "strokeWidth": 1, "strokeDasharray": "3 3" },
    { "type": "line", "id": "s-line", "rotation": 0, "x1": 640, "y1": 130, "x2": 640, "y2": 420, "stroke": "#94a3b8", "strokeWidth": 1, "strokeDasharray": "3 3" },
    { "type": "text", "id": "msg1", "rotation": 0, "x": 400, "y": 180, "content": "SYN (seq=x)", "fontSize": 14, "fontWeight": 600, "color": "#3b82f6", "textAnchor": "middle" },
    { "type": "text", "id": "msg2", "rotation": 0, "x": 400, "y": 270, "content": "SYN+ACK (seq=y, ack=x+1)", "fontSize": 14, "fontWeight": 600, "color": "#16a34a", "textAnchor": "middle" },
    { "type": "text", "id": "msg3", "rotation": 0, "x": 400, "y": 360, "content": "ACK (ack=y+1)", "fontSize": 14, "fontWeight": 600, "color": "#3b82f6", "textAnchor": "middle" },
    { "type": "circle", "id": "dot1", "rotation": 0, "cx": 160, "cy": 180, "r": 8, "fill": "#3b82f6", "stroke": "#1e40af", "strokeWidth": 2 },
    { "type": "circle", "id": "dot2", "rotation": 0, "cx": 640, "cy": 270, "r": 8, "fill": "#16a34a", "stroke": "#14532d", "strokeWidth": 2 },
    { "type": "circle", "id": "dot3", "rotation": 0, "cx": 160, "cy": 360, "r": 8, "fill": "#3b82f6", "stroke": "#1e40af", "strokeWidth": 2 },
    { "type": "text", "id": "step-label", "rotation": 0, "x": 400, "y": 35, "content": "1. SYN 전송", "fontSize": 20, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle" }
  ],
  "initiallyHidden": ["msg1", "msg2", "msg3", "dot1", "dot2", "dot3"],
  "steps": [
    { "id": "s1", "label": "Client → Server SYN", "duration": 1200, "ease": "easeOut",
      "keyframes": { "msg1": { "visible": true }, "dot1": { "visible": true, "cx": 640 }, "client": { "subtitle": "SYN_SENT" }, "step-label": { "content": "2. 서버가 SYN+ACK 응답" } },
      "effects": [] },
    { "id": "s2", "label": "Server → Client SYN+ACK", "duration": 1200, "ease": "easeOut",
      "keyframes": { "msg2": { "visible": true }, "dot2": { "visible": true, "cx": 160 }, "server": { "subtitle": "SYN_RCVD" }, "step-label": { "content": "3. Client 가 ACK 전송" } },
      "effects": [] },
    { "id": "s3", "label": "Client → Server ACK", "duration": 1200, "ease": "easeOut",
      "keyframes": { "msg3": { "visible": true }, "dot3": { "visible": true, "cx": 640 }, "client": { "subtitle": "ESTABLISHED" }, "step-label": { "content": "✓ 연결 수립" } },
      "effects": [] },
    { "id": "s4", "label": "ESTABLISHED", "duration": 800, "ease": "easeOut",
      "keyframes": { "server": { "subtitle": "ESTABLISHED" } },
      "effects": [
        { "type": "highlight", "elementId": "client", "color": "#34d399", "duration": 600, "delay": 0 },
        { "type": "highlight", "elementId": "server", "color": "#34d399", "duration": 600, "delay": 200 }
      ] },
    { "id": "s5", "label": "재시작", "duration": 700, "ease": "linear",
      "keyframes": {
        "msg1": { "visible": false }, "msg2": { "visible": false }, "msg3": { "visible": false },
        "dot1": { "visible": false, "cx": 160 }, "dot2": { "visible": false, "cx": 640 }, "dot3": { "visible": false, "cx": 160 },
        "client": { "subtitle": "CLOSED" }, "server": { "subtitle": "LISTEN" },
        "step-label": { "content": "1. SYN 전송" }
      },
      "effects": [] }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 250 }
}
