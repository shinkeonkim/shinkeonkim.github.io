{
  "version": 2,
  "id": "trie",
  "title": "트라이 (Trie) 접두사 검색",
  "description": "접두사 'ca'로 시작하는 모든 단어를 효율적으로 찾습니다. (저장된 단어: cat, car, card)",
  "category": "algorithm",
  "tags": ["tree", "trie", "string", "prefix"],
  "canvas": { "width": 800, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "step-label", "x": 400, "y": 20, "content": "접두사 'ca' 검색 시작", "fontSize": 18, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle" },
    
    { "type": "line", "id": "e_c", "fromId": "root", "toId": "n_c", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e_a", "fromId": "n_c", "toId": "n_a", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e_t", "fromId": "n_a", "toId": "n_t", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e_r", "fromId": "n_a", "toId": "n_r", "stroke": "#cbd5e1", "strokeWidth": 2 },
    { "type": "line", "id": "e_d", "fromId": "n_r", "toId": "n_d", "stroke": "#cbd5e1", "strokeWidth": 2 },

    { "type": "circle", "id": "root", "cx": 400, "cy": 60, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "root", "labelColor": "#312e81", "labelSize": 14 },
    { "type": "circle", "id": "n_c", "cx": 400, "cy": 140, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "c", "labelColor": "#312e81", "labelSize": 20 },
    { "type": "circle", "id": "n_a", "cx": 400, "cy": 220, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "a", "labelColor": "#312e81", "labelSize": 20 },
    { "type": "circle", "id": "n_t", "cx": 300, "cy": 320, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "t", "labelColor": "#312e81", "labelSize": 20 },
    { "type": "circle", "id": "n_r", "cx": 500, "cy": 320, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "r", "labelColor": "#312e81", "labelSize": 20 },
    { "type": "circle", "id": "n_d", "cx": 500, "cy": 420, "r": 28, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "label": "d", "labelColor": "#312e81", "labelSize": 20 },
    
    { "type": "text", "id": "term_t", "x": 340, "y": 326, "content": "✓ cat", "fontSize": 16, "fontWeight": 700, "color": "#64748b", "textAnchor": "start" },
    { "type": "text", "id": "term_r", "x": 540, "y": 326, "content": "✓ car", "fontSize": 16, "fontWeight": 700, "color": "#64748b", "textAnchor": "start" },
    { "type": "text", "id": "term_d", "x": 540, "y": 426, "content": "✓ card", "fontSize": 16, "fontWeight": 700, "color": "#64748b", "textAnchor": "start" }
  ],
  "initiallyHidden": [],
  "steps": [
    {
      "id": "s1",
      "label": "루트에서 시작",
      "duration": 800,
      "ease": "easeOut",
      "keyframes": {
        "root": { "fill": "#fbbf24", "stroke": "#d97706" },
        "step-label": { "content": "루트 노드에서 'c' 간선을 찾습니다." }
      },
      "effects": [{ "type": "pulse", "elementId": "root", "scale": 1.2, "duration": 500 }]
    },
    {
      "id": "s2",
      "label": "'c' 탐색",
      "duration": 800,
      "ease": "easeOut",
      "keyframes": {
        "root": { "fill": "#34d399", "stroke": "#059669" },
        "e_c": { "stroke": "#fbbf24", "strokeWidth": 3 },
        "n_c": { "fill": "#fbbf24", "stroke": "#d97706" },
        "step-label": { "content": "'c' 노드 도달. 다음 문자 'a' 간선을 찾습니다." }
      },
      "effects": [{ "type": "pulse", "elementId": "n_c", "scale": 1.2, "duration": 500 }]
    },
    {
      "id": "s3",
      "label": "'a' 탐색",
      "duration": 800,
      "ease": "easeOut",
      "keyframes": {
        "n_c": { "fill": "#34d399", "stroke": "#059669" },
        "e_c": { "stroke": "#10b981", "strokeWidth": 3 },
        "e_a": { "stroke": "#fbbf24", "strokeWidth": 3 },
        "n_a": { "fill": "#fbbf24", "stroke": "#d97706" },
        "step-label": { "content": "'a' 노드 도달. 접두사 'ca' 일치 완료!" }
      },
      "effects": [{ "type": "pulse", "elementId": "n_a", "scale": 1.2, "duration": 500 }]
    },
    {
      "id": "s4",
      "label": "서브트리 반환",
      "duration": 800,
      "ease": "easeOut",
      "keyframes": {
        "n_a": { "fill": "#34d399", "stroke": "#059669" },
        "e_a": { "stroke": "#10b981", "strokeWidth": 3 },
        "e_t": { "stroke": "#10b981", "strokeWidth": 3 },
        "e_r": { "stroke": "#10b981", "strokeWidth": 3 },
        "e_d": { "stroke": "#10b981", "strokeWidth": 3 },
        "n_t": { "fill": "#34d399", "stroke": "#059669" },
        "n_r": { "fill": "#34d399", "stroke": "#059669" },
        "n_d": { "fill": "#34d399", "stroke": "#059669" },
        "term_t": { "color": "#10b981" },
        "term_r": { "color": "#10b981" },
        "term_d": { "color": "#10b981" },
        "step-label": { "content": "'ca' 아래의 모든 경로(cat, car, card)가 결과로 반환됩니다." }
      },
      "effects": [
        { "type": "pulse", "elementId": "n_t", "scale": 1.2, "duration": 500 },
        { "type": "pulse", "elementId": "n_r", "scale": 1.2, "duration": 500, "delay": 100 },
        { "type": "pulse", "elementId": "n_d", "scale": 1.2, "duration": 500, "delay": 200 }
      ]
    },
    {
      "id": "s5",
      "label": "초기화",
      "duration": 600,
      "ease": "linear",
      "keyframes": {
        "root": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n_c": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n_a": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n_t": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n_r": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "n_d": { "fill": "#e0e7ff", "stroke": "#6366f1" },
        "e_c": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e_a": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e_t": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e_r": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "e_d": { "stroke": "#cbd5e1", "strokeWidth": 2 },
        "term_t": { "color": "#64748b" },
        "term_r": { "color": "#64748b" },
        "term_d": { "color": "#64748b" },
        "step-label": { "content": "접두사 'ca' 검색 시작" }
      },
      "effects": []
    }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 200 }
}