{
  "version": 4,
  "id": "floor-sum",
  "title": "Floor Sum: 유리 등차수열 내림 합",
  "description": "직선 y = (3x + 4)/5 아래 격자점을 세는 기하적 해석, ACL 재귀 변환",
  "category": "algorithm",
  "tags": ["floor-sum", "math", "number-theory"],
  "duration": 13000,
  "canvas": { "width": 900, "height": 500, "background": "transparent" },
  "elements": [
    { "id": "title", "type": "text", "x": 450, "y": 25, "text": "Floor Sum: y = (3x + 4)/5", "fontSize": 18, "fontWeight": "bold", "fill": "#0b0b0f", "textAnchor": "middle" },
    { "id": "grid", "type": "rect", "x": 50, "y": 60, "width": 400, "height": 350, "fill": "#f8fafc", "stroke": "#cbd5e1", "strokeWidth": 1 },
    { "id": "line-diag", "type": "line", "x1": 50, "y1": 410, "x2": 450, "y2": 60, "stroke": "#dc2626", "strokeWidth": 3, "strokeDasharray": "6,3" },
    { "id": "dots-area", "type": "text", "x": 250, "y": 230, "text": "... (lattice points)", "fontSize": 16, "fill": "#2563eb", "textAnchor": "middle", "opacity": 0.7 },
    { "id": "num-pts-0", "type": "text", "x": 130, "y": 390, "text": "i=0: y=0.8 floor=0", "fontSize": 12, "fill": "#475569" },
    { "id": "num-pts-1", "type": "text", "x": 220, "y": 390, "text": "i=1: y=1.4 floor=1", "fontSize": 12, "fill": "#475569" },
    { "id": "num-pts-2", "type": "text", "x": 310, "y": 390, "text": "i=2: y=2.0 floor=2", "fontSize": 12, "fill": "#475569" },
    { "id": "sum-display", "type": "text", "x": 250, "y": 465, "text": "sum = 0 + 1 + 2 = 3 (before swap)", "fontSize": 13, "fill": "#713f12", "textAnchor": "middle" },
    { "id": "grid-caption", "type": "text", "x": 250, "y": 440, "text": "격자점 계수 = sum floor((ai+b)/m)", "fontSize": 14, "fill": "#475569", "textAnchor": "middle" },
    { "id": "x-tick-0", "type": "line", "x1": 50, "y1": 410, "x2": 50, "y2": 415, "stroke": "#475569", "strokeWidth": 1 },
    { "id": "x-tick-1", "type": "line", "x1": 183, "y1": 410, "x2": 183, "y2": 415, "stroke": "#475569", "strokeWidth": 1 },
    { "id": "x-tick-2", "type": "line", "x1": 317, "y1": 410, "x2": 317, "y2": 415, "stroke": "#475569", "strokeWidth": 1 },
    { "id": "info-box", "type": "rect", "x": 520, "y": 80, "width": 330, "height": 130, "fill": "#1e293b", "stroke": "#475569", "strokeWidth": 1, "rx": 6 },
    { "id": "info-title", "type": "text", "x": 685, "y": 105, "text": "ACL floor_sum recursion", "fontSize": 16, "fontWeight": "bold", "fill": "#e2e8f0", "textAnchor": "middle" },
    { "id": "f-line1", "type": "text", "x": 540, "y": 135, "text": "1. a>=m: 몫 분리", "fontSize": 14, "fill": "#e2e8f0" },
    { "id": "f-line2", "type": "text", "x": 540, "y": 160, "text": "2. b>=m: 상수항 분리", "fontSize": 14, "fill": "#e2e8f0" },
    { "id": "f-line3", "type": "text", "x": 540, "y": 185, "text": "3. else: y축 변환 재귀", "fontSize": 14, "fill": "#e2e8f0" },
    { "id": "result-box", "type": "rect", "x": 520, "y": 250, "width": 330, "height": 70, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "rx": 6 },
    { "id": "result-val", "type": "text", "x": 685, "y": 280, "text": "ans = 0 + 0 + (2*2 - f(2,3,5,1)) = 2", "fontSize": 15, "fontWeight": "bold", "fill": "#14532d", "textAnchor": "middle" },
    { "id": "result-simple", "type": "text", "x": 685, "y": 305, "text": "floor sum = 2", "fontSize": 18, "fontWeight": "bold", "fill": "#14532d", "textAnchor": "middle" }
  ],
  "chapters": [
    { "id": "intro", "title": "문제 설정", "startTime": 0, "endTime": 2500, "description": "Sigma_{i=0}^{2} floor((3i+4)/5)" },
    { "id": "grid-show", "title": "격자점 계수", "startTime": 2500, "endTime": 5500, "description": "직선 아래 격자점 세기: i=0,1,2" },
    { "id": "transform", "title": "축 변환", "startTime": 5500, "endTime": 9000, "description": "y_max=2, 재귀 f(2,3,5,1) 호출" },
    { "id": "answer", "title": "결과", "startTime": 9000, "endTime": 13000, "description": "floor sum = 2, O(log m)" }
  ],
  "effects": [
    { "target": "grid", "type": "opacity", "from": 0, "to": 1, "startTime": 0, "duration": 800, "easing": "ease-in-out" },
    { "target": "line-diag", "type": "opacity", "from": 0, "to": 1, "startTime": 500, "duration": 1000, "easing": "ease-in-out" },
    { "target": "dots-area", "type": "opacity", "from": 0, "to": 0.7, "startTime": 2500, "duration": 1200, "easing": "ease-in-out" },
    { "target": "result-box", "type": "scale", "from": 0.5, "to": 1, "startTime": 9000, "duration": 1000, "easing": "ease-out" },
    { "target": "info-box", "type": "opacity", "from": 0, "to": 1, "startTime": 0, "duration": 600, "easing": "ease-in-out" },
    { "target": "sum-display", "type": "opacity", "from": 0, "to": 1, "startTime": 5500, "duration": 800, "easing": "ease-in-out" },
    { "target": "num-pts-0", "type": "opacity", "from": 0, "to": 1, "startTime": 2500, "duration": 500, "easing": "ease-in-out" },
    { "target": "num-pts-1", "type": "opacity", "from": 0, "to": 1, "startTime": 3000, "duration": 500, "easing": "ease-in-out" },
    { "target": "num-pts-2", "type": "opacity", "from": 0, "to": 1, "startTime": 3500, "duration": 500, "easing": "ease-in-out" }
  ],
  "settings": { "loop": true, "autoplay": true, "showCaption": false, "showChapterList": true }
}
