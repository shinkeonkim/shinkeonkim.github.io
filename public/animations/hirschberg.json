{
  "version": 4,
  "id": "hirschberg",
  "title": "Hirschberg LCS, O(N) 공간 분할 정복",
  "description": "ABCBDAB 와 BDCAB 의 LCS 를 Hirschberg 로. fwd/rev DP 행만 유지, 분할점 k=3 에서 재귀.",
  "category": "algorithm",
  "tags": ["algorithm", "dp", "lcs", "divide-and-conquer", "string"],
  "duration": 14000,
  "canvas": { "width": 900, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "title", "rotation": 0, "x": 450, "y": 28, "content": "Hirschberg LCS, O(N) space traceback", "fontSize": 17, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 14000 }], "tracks": [] },
    { "type": "text", "id": "step", "rotation": 0, "x": 450, "y": 58, "content": "A=ABCBDAB, B=BDCAB", "fontSize": 14, "fontWeight": 600, "color": "#6366f1", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 14000 }], "tracks": [{ "property": "content", "keyframes": [
      { "time": 0, "value": "A=ABCBDAB(7), B=BDCAB(5), LCS=BCAB(4)" },
      { "time": 3000, "value": "A 중간 i=3 에서 분할점 k 탐색" },
      { "time": 6000, "value": "fwd[3] vs B: [0,1,1,2,2,2] (O(3*5), 공간 O(5))" },
      { "time": 8000, "value": "rev[4] vs B 역: [0,2,2,2,2,2] (O(4*5), 공간 O(5))" },
      { "time": 10000, "value": "fwd[j]+rev[5-j] 최대=4 at k=3" },
      { "time": 12000, "value": "LCS(A[:3],B[:3]) + LCS(A[3:],B[3:]) = BC + AB = BCAB" }] }] },
    { "type": "text", "id": "s1", "rotation": 0, "x": 130, "y": 100, "content": "A = A B C B D A B", "fontSize": 15, "fontWeight": 600, "color": "#0b0b0f", "textAnchor": "start", "appearances": [{ "start": 0, "end": 14000 }], "tracks": [] },
    { "type": "text", "id": "s2", "rotation": 0, "x": 130, "y": 125, "content": "B = B D C A B", "fontSize": 15, "fontWeight": 600, "color": "#0b0b0f", "textAnchor": "start", "appearances": [{ "start": 0, "end": 14000 }], "tracks": [] },
    { "type": "text", "id": "lf", "rotation": 0, "x": 130, "y": 165, "content": "fwd[3] (A[:3] vs B 전체)", "fontSize": 13, "fontWeight": 600, "color": "#2563eb", "textAnchor": "start", "appearances": [{ "start": 3000, "end": 10000 }], "tracks": [] },
    { "type": "rect", "id": "fwd", "rotation": 0, "x": 130, "y": 185, "width": 320, "height": 30, "fill": "#dbeafe", "stroke": "#2563eb", "strokeWidth": 1.5, "cornerRadius": 6, "label": "[0, 1, 1, 2, 2, 2]", "labelColor": "#1e3a8a", "labelSize": 14, "appearances": [{ "start": 6000, "end": 10000 }], "tracks": [] },
    { "type": "text", "id": "lr", "rotation": 0, "x": 130, "y": 235, "content": "rev[4] (A[3:] 역순 vs B 역순)", "fontSize": 13, "fontWeight": 600, "color": "#7c3aed", "textAnchor": "start", "appearances": [{ "start": 6000, "end": 10000 }], "tracks": [] },
    { "type": "rect", "id": "rev", "rotation": 0, "x": 130, "y": 255, "width": 320, "height": 30, "fill": "#ede9fe", "stroke": "#7c3aed", "strokeWidth": 1.5, "cornerRadius": 6, "label": "[0, 2, 2, 2, 2, 2]", "labelColor": "#5b21b6", "labelSize": 14, "appearances": [{ "start": 8000, "end": 10000 }], "tracks": [] },
    { "type": "rect", "id": "sum", "rotation": 0, "x": 130, "y": 310, "width": 320, "height": 30, "fill": "#fef9c3", "stroke": "#eab308", "strokeWidth": 2, "cornerRadius": 6, "label": "j=0:2 j=1:3 j=2:3 j=3:4* j=4:4*", "labelColor": "#713f12", "labelSize": 12, "appearances": [{ "start": 9500, "end": 11000 }], "tracks": [] },
    { "type": "text", "id": "split", "rotation": 0, "x": 130, "y": 365, "content": "분할점 k=3 (fwd[3]+rev[2]=4)", "fontSize": 15, "fontWeight": 700, "color": "#16a34a", "textAnchor": "start", "appearances": [{ "start": 10000, "end": 14000 }], "tracks": [{ "property": "content", "keyframes": [
      { "time": 10000, "value": "분할점 k=3" },
      { "time": 12000, "value": "LCS = BC + AB = BCAB (길이 4)" }] }] },
    { "type": "rect", "id": "vl", "rotation": 0, "x": 530, "y": 180, "width": 140, "height": 80, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 10, "label": "L(A[:3],B[:3])\n= BC", "labelColor": "#14532d", "labelSize": 14, "appearances": [{ "start": 12000, "end": 14000 }], "tracks": [] },
    { "type": "rect", "id": "vr", "rotation": 0, "x": 700, "y": 180, "width": 140, "height": 80, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 10, "label": "L(A[3:],B[3:])\n= AB", "labelColor": "#14532d", "labelSize": 14, "appearances": [{ "start": 12000, "end": 14000 }], "tracks": [] },
    { "type": "text", "id": "plus", "rotation": 0, "x": 680, "y": 220, "content": "+", "fontSize": 24, "fontWeight": 700, "color": "#0b0b0f", "textAnchor": "middle", "appearances": [{ "start": 12000, "end": 14000 }], "tracks": [] },
    { "type": "rect", "id": "res", "rotation": 0, "x": 530, "y": 290, "width": 310, "height": 50, "fill": "#bbf7d0", "stroke": "#16a34a", "strokeWidth": 3, "cornerRadius": 12, "label": "LCS = BCAB (4)", "labelColor": "#14532d", "labelSize": 20, "appearances": [{ "start": 13000, "end": 14000, "entryMode": "zoom", "entryDuration": 500 }], "tracks": [] },
    { "type": "text", "id": "note", "rotation": 0, "x": 450, "y": 470, "content": "O(NM) 시간, O(min(N,M)) 공간, traceback 가능", "fontSize": 13, "color": "#475569", "textAnchor": "middle", "appearances": [{ "start": 10000, "end": 14000 }], "tracks": [] }
  ],
  "chapters": [
    { "id": "intro", "time": 0, "label": "Hirschberg", "subtitle": "ABCBDAB vs BDCAB" },
    { "id": "split", "time": 3000, "label": "분할점 탐색", "subtitle": "A 중간 i=3" },
    { "id": "fwd", "time": 6000, "label": "fwd[3] 계산", "subtitle": "왼쪽 절반 DP" },
    { "id": "rev", "time": 8000, "label": "rev[4] 계산", "subtitle": "오른쪽 DP 역순" },
    { "id": "merge", "time": 10000, "label": "k=3 결정", "subtitle": "fwd+rev 최대" },
    { "id": "recurse", "time": 12000, "label": "재귀", "subtitle": "BC + AB" },
    { "id": "done", "time": 13000, "label": "완료", "subtitle": "BCAB" }
  ],
  "effects": [
    { "type": "highlight", "id": "h-fwd", "elementId": "fwd", "time": 6000, "color": "#fef9c3", "duration": 1500 },
    { "type": "highlight", "id": "h-rev", "elementId": "rev", "time": 8000, "color": "#fef9c3", "duration": 1500 },
    { "type": "highlight", "id": "h-sum", "elementId": "sum", "time": 9500, "color": "#fef9c3", "duration": 1000 },
    { "type": "pulse", "id": "p-vl", "elementId": "vl", "time": 12500, "scale": 1.05, "duration": 500 },
    { "type": "pulse", "id": "p-vr", "elementId": "vr", "time": 12700, "scale": 1.05, "duration": 500 },
    { "type": "pulse", "id": "p-res", "elementId": "res", "time": 13500, "scale": 1.08, "duration": 700 }
