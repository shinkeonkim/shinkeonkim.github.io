{
  "version": 4,
  "id": "bitset-lcs",
  "title": "Bitset LCS, 64 비트 병렬 전이",
  "description": "Allison-Dix bitset LCS. A=ABC, B=AC 에서 cur/u/v 의 비트셋 변화. (u - v) & ~u 로 한 번에 DP 전이.",
  "category": "algorithm",
  "tags": ["algorithm", "dp", "lcs", "bitset", "string"],
  "duration": 13000,
  "canvas": { "width": 900, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "title", "rotation": 0, "x": 450, "y": 28, "content": "Allison-Dix Bitset LCS, O(NM/64)", "fontSize": 17, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "text", "id": "step", "rotation": 0, "x": 450, "y": 58, "content": "A=ABC, B=AC", "fontSize": 14, "fontWeight": 600, "color": "#6366f1", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [{ "property": "content", "keyframes": [
      { "time": 0, "value": "A=ABC, B=AC 에 대한 bitset LCS" },
      { "time": 2500, "value": "prec: A=01, C=10 (B 의 위치)" },
      { "time": 5000, "value": "i=0 A[i]=A: u=cur|01, v=(cur<<1)|1" },
      { "time": 7000, "value": "cur |= (u-v) & ~u = 00 (이미 있음)" },
      { "time": 9000, "value": "i=2 A[i]=C: u=cur|10=10, popcount=2" },
      { "time": 11000, "value": "LCS = 2 (AC)" }] }] },
    { "type": "text", "id": "str", "rotation": 0, "x": 130, "y": 100, "content": "A = A B C    B = A C", "fontSize": 16, "fontWeight": 700, "color": "#0b0b0f", "textAnchor": "start", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
