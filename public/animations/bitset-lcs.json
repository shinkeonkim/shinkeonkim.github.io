    { "type": "rect", "id": "b1", "rotation": 0, "x": 165, "y": 150, "width": 30, "height": 30, "fill": "#e2e8f0", "stroke": "#475569", "strokeWidth": 1.5, "cornerRadius": 4, "label": "0", "labelColor": "#0b0b0f", "labelSize": 16, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [{ "property": "label", "keyframes": [{ "time": 0, "value": "0" }, { "time": 9000, "value": "1" }] }, { "property": "fill", "keyframes": [{ "time": 0, "value": "#e2e8f0" }, { "time": 9000, "value": "#bbf7d0" }] }] },
    { "type": "rect", "id": "b0", "rotation": 0, "x": 235, "y": 150, "width": 30, "height": 30, "fill": "#e2e8f0", "stroke": "#475569", "strokeWidth": 1.5, "cornerRadius": 4, "label": "0", "labelColor": "#0b0b0f", "labelSize": 16, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [{ "property": "label", "keyframes": [{ "time": 0, "value": "0" }, { "time": 5000, "value": "1" }, { "time": 7000, "value": "1" }] }, { "property": "fill", "keyframes": [{ "time": 0, "value": "#e2e8f0" }, { "time": 5000, "value": "#bbf7d0" }] }] },
