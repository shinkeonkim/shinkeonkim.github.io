    { "type": "text", "id": "formula", "rotation": 0, "x": 130, "y": 270, "content": "cur |= (u - v) & ~u", "fontSize": 18, "fontWeight": 700, "color": "#0b0b0f", "textAnchor": "start", "appearances": [{ "start": 5000, "end": 13000 }], "tracks": [] },
    { "type": "text", "id": "result", "rotation": 0, "x": 450, "y": 450, "content": "LCS(ABC, AC) = 2", "fontSize": 20, "fontWeight": 700, "color": "#16a34a", "textAnchor": "middle", "appearances": [{ "start": 11000, "end": 13000, "entryMode": "fade", "entryDuration": 500 }], "tracks": [] }
