{
  "version": 4,
  "id": "primality-test",
  "title": "소수 판정 (Primality Test)",
  "description": "Miller-Rabin 알고리즘으로 N=561 (Carmichael 수) 이 합성수임을 판정",
  "category": "algorithm",
  "tags": ["primality-test", "miller-rabin", "number-theory", "math"],
  "duration": 13000,
  "canvas": {
    "width": 900,
    "height": 500,
    "background": "transparent"
  },
  "elements": [
    {
      "id": "title",
      "type": "text",
      "x": 450,
      "y": 30,
      "text": "Miller-Rabin: N=561, a=2",
      "fontSize": 20,
      "fontWeight": "bold",
      "fill": "#0b0b0f",
      "textAlign": "center"
    },
    {
      "id": "step1-label",
      "type": "text",
      "x": 50,
      "y": 80,
      "text": "1. N-1 = 2^s · d 분해",
      "fontSize": 16,
      "fill": "#475569"
    },
    {
      "id": "decomp-box",
      "type": "rect",
      "x": 50,
      "y": 100,
      "width": 300,
      "height": 60,
      "fill": "#dbeafe",
      "stroke": "#2563eb",
      "strokeWidth": 2,
      "rx": 4
    },
    {
      "id": "decomp-text",
      "type": "text",
      "x": 200,
      "y": 135,
      "text": "560 = 2^4 · 35",
      "fontSize": 18,
      "fontWeight": "bold",
      "fill": "#1e3a8a",
      "textAlign": "center"
    },
    {
      "id": "step2-label",
      "type": "text",
      "x": 50,
      "y": 190,
      "text": "2. x = a^d mod N",
      "fontSize": 16,
      "fill": "#475569"
    },
    {
      "id": "power-box",
      "type": "rect",
      "x": 50,
      "y": 210,
      "width": 300,
      "height": 60,
      "fill": "#fef9c3",
      "stroke": "#eab308",
      "strokeWidth": 2,
      "rx": 4
    },
    {
      "id": "power-text",
      "type": "text",
      "x": 200,
      "y": 245,
      "text": "x = 2^35 mod 561 = 263",
      "fontSize": 18,
      "fill": "#713f12",
      "textAlign": "center"
    },
    {
      "id": "step3-label",
      "type": "text",
      "x": 50,
      "y": 300,
      "text": "3. x^2 반복 (s-1 회)",
      "fontSize": 16,
      "fill": "#475569"
    },
    {
      "id": "square-0",
      "type": "rect",
      "x": 50,
      "y": 330,
      "width": 120,
      "height": 50,
      "fill": "#e2e8f0",
      "stroke": "#475569",
      "strokeWidth": 2,
      "rx": 4
    },
    {
      "id": "square-0-text",
      "type": "text",
      "x": 110,
      "y": 360,
      "text": "263",
      "fontSize": 16,
      "fill": "#0b0b0f",
      "textAlign": "center"
    },
    {
      "id": "square-1",
      "type": "rect",
      "x": 190,
      "y": 330,
      "width": 120,
      "height": 50,
      "fill": "#e2e8f0",
      "stroke": "#475569",
      "strokeWidth": 2,
      "rx": 4
    },
    {
      "id": "square-1-text",
      "type": "text",
      "x": 250,
      "y": 360,
      "text": "166",
      "fontSize": 16,
      "fill": "#0b0b0f",
      "textAlign": "center"
    },
    {
      "id": "square-2",
      "type": "rect",
      "x": 330,
      "y": 330,
      "width": 120,
      "height": 50,
      "fill": "#e2e8f0",
      "stroke": "#475569",
      "strokeWidth": 2,
      "rx": 4
    },
    {
      "id": "square-2-text",
      "type": "text",
      "x": 390,
      "y": 360,
      "text": "67",
      "fontSize": 16,
      "fill": "#0b0b0f",
      "textAlign": "center"
    },
    {
      "id": "square-3",
      "type": "rect",
      "x": 470,
      "y": 330,
      "width": 120,
      "height": 50,
      "fill": "#fee2e2",
      "stroke": "#dc2626",
      "strokeWidth": 3,
      "rx": 4
    },
    {
      "id": "square-3-text",
      "type": "text",
      "x": 530,
      "y": 360,
      "text": "1",
      "fontSize": 16,
      "fontWeight": "bold",
      "fill": "#7f1d1d",
      "textAlign": "center"
    },
    {
      "id": "check-label",
      "type": "text",
      "x": 50,
      "y": 410,
      "text": "67^2 ≡ 1 (mod 561) 이지만 67 ≠ 560",
      "fontSize": 16,
      "fill": "#dc2626",
      "fontWeight": "bold"
    },
    {
      "id": "result-box",
      "type": "rect",
      "x": 50,
      "y": 430,
      "width": 800,
      "height": 50,
      "fill": "#fee2e2",
      "stroke": "#dc2626",
      "strokeWidth": 3,
      "rx": 6
    },
    {
      "id": "result-text",
      "type": "text",
      "x": 450,
      "y": 460,
      "text": "이차잉여 위반 → 561 은 합성수",
      "fontSize": 20,
      "fontWeight": "bold",
      "fill": "#7f1d1d",
      "textAlign": "center"
    }
  ],
  "chapters": [
    {
      "id": "intro",
      "title": "문제 설정",
      "startTime": 0,
      "endTime": 2000,
      "caption": "N=561 은 Carmichael 수. Fermat test 는 통과하지만 합성수."
    },
    {
      "id": "decompose",
      "title": "N-1 분해",
      "startTime": 2000,
      "endTime": 5000,
      "caption": "560 = 2^4 · 35, s=4, d=35"
    },
    {
      "id": "power",
      "title": "a^d mod N",
      "startTime": 5000,
      "endTime": 8000,
      "caption": "2^35 mod 561 = 263. 1 도 560 도 아님."
    },
    {
      "id": "square",
      "title": "x^2 반복",
      "startTime": 8000,
      "endTime": 11000,
      "caption": "263 → 166 → 67 → 1. 67^2 ≡ 1 인데 67 ≠ N-1."
    },
    {
      "id": "conclude",
      "title": "합성수 판정",
      "startTime": 11000,
      "endTime": 13000,
      "caption": "이차잉여 위반 → 561 은 합성수 (= 3·11·17)."
    }
  ],
  "effects": [
    {
      "id": "fade-in-decomp",
      "elementId": "decomp-box",
      "type": "fade",
      "startTime": 2000,
      "duration": 500,
      "from": 0,
      "to": 1
    },
    {
      "id": "highlight-power",
      "elementId": "power-box",
      "type": "highlight",
      "startTime": 5000,
      "duration": 1000,
      "color": "#eab308"
    },
    {
      "id": "reveal-square-0",
      "elementId": "square-0",
      "type": "fade",
      "startTime": 8000,
      "duration": 400,
      "from": 0,
      "to": 1
    },
    {
      "id": "reveal-square-1",
      "elementId": "square-1",
      "type": "fade",
      "startTime": 8800,
      "duration": 400,
      "from": 0,
      "to": 1
    },
    {
      "id": "reveal-square-2",
      "elementId": "square-2",
      "type": "fade",
      "startTime": 9600,
      "duration": 400,
      "from": 0,
      "to": 1
    },
    {
      "id": "reveal-square-3",
      "elementId": "square-3",
      "type": "fade",
      "startTime": 10400,
      "duration": 400,
      "from": 0,
      "to": 1
    },
    {
      "id": "show-result",
      "elementId": "result-box",
      "type": "scale",
      "startTime": 11000,
      "duration": 800,
      "from": 0.8,
      "to": 1
    }
  ],
  "settings": {
    "loop": true,
    "autoplay": true,
    "showCaption": false,
    "showChapterList": true
  }
}
