    { "type": "text", "id": "verdict", "rotation": 0, "x": 450, "y": 450, "content": "3D 외적 = 두 벡터에 수직인 법선 벡터 | Right-hand rule", "fontSize": 13, "fontWeight": 700, "color": "#7c3aed", "textAnchor": "middle", "appearances": [{ "start": 11000, "end": 13000, "entryMode": "fade", "entryDuration": 400 }], "tracks": [] }
