    { "type": "text", "id": "step", "rotation": 0, "x": 450, "y": 58, "content": "3D 좌표계: x(red), y(green), z(blue)", "fontSize": 14, "fontWeight": 600, "color": "#6366f1", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [
