    { "type": "circle", "id": "point-w", "rotation": 0, "cx": 300, "cy": 130, "r": 6, "fill": "#ede9fe", "stroke": "#7c3aed", "strokeWidth": 2, "label": "", "appearances": [{ "start": 5000, "end": 13000, "entryMode": "fade", "entryDuration": 300 }], "tracks": [] },
    { "type": "rect", "id": "plane-viz", "rotation": 0, "x": 100, "y": 340, "width": 200, "height": 40, "fill": "#dbeafe", "stroke": "#2563eb", "strokeWidth": 2, "cornerRadius": 4, "label": "평면 z=0 (xy-평면)", "labelColor": "#1e3a8a", "labelSize": 14, "appearances": [{ "start": 8000, "end": 13000, "entryMode": "fade", "entryDuration": 300 }], "tracks": [] },
