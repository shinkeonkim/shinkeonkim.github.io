    { "type": "line", "id": "axis-y", "rotation": 0, "x1": 300, "y1": 300, "x2": 500, "y2": 120, "stroke": "#16a34a", "strokeWidth": 2, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
