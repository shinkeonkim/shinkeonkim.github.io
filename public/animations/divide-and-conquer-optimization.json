{
  "version": 4,
  "id": "divide-and-conquer-optimization",
  "title": "Divide and Conquer Optimization",
  "description": "분할정복 DP 최적화. dp[k][i] = min(dp[k-1][j] + cost(j+1, i)) 에서 opt[i] 단조성을 이용, 각 레이어를 O(N log N) 에 채운다. mid 의 최적 분할점을 찾고 좌/우 재귀.",
  "category": "algorithm",
  "tags": ["algorithm", "dp", "optimization", "divide-and-conquer"],
  "duration": 13000,
  "canvas": { "width": 900, "height": 500, "background": "transparent" },
  "elements": [
    { "type": "text", "id": "title", "rotation": 0, "x": 450, "y": 25, "content": "Divide and Conquer DP Optimization", "fontSize": 18, "fontWeight": 700, "color": "#0b0b0f", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "text", "id": "subtitle", "rotation": 0, "x": 450, "y": 52, "content": "dp[k][i] = min(dp[k-1][j] + cost(j+1, i)), opt[i] monotonic", "fontSize": 12, "color": "#475569", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "line", "id": "dp-axis", "rotation": 0, "x1": 80, "y1": 95, "x2": 520, "y2": 95, "stroke": "#cbd5e1", "strokeWidth": 1, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
