    { "type": "text", "id": "value-label", "rotation": 0, "x": 450, "y": 240, "content": "bestK found for mid", "fontSize": 12, "color": "#475569", "textAnchor": "middle", "appearances": [{ "start": 0, "end": 13000 }], "tracks": [{ "property": "content", "keyframes": [{ "time": 0, "value": "dp[2][4] = ???, finding bestK..." }, { "time": 500, "value": "bestK=3, dp[2][4]=52" }, { "time": 3500, "value": "bestK=1, dp[2][2]=5" }, { "time": 6500, "value": "bestK=5, dp[2][6]=?" }, { "time": 9500, "value": "bestK=0, dp[2][1]=INF" }] }] },
    { "type": "rect", "id": "dp-layer-label", "rotation": 0, "x": 80, "y": 300, "width": 440, "height": 30, "fill": "#e2e8f0", "stroke": "#475569", "strokeWidth": 1, "cornerRadius": 4, "label": "Layer k=2: dp[2][1] ... dp[2][8]", "labelColor": "#0b0b0f", "labelSize": 13, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [{ "property": "label", "keyframes": [{ "time": 0, "value": "Layer k=1: dp[1][i] = cost(1, i) (complete)" }, { "time": 500, "value": "Layer k=2: dp[2][1] ... dp[2][8]" }, { "time": 3500, "value": "Layer k=2: recurse left" }, { "time": 6500, "value": "Layer k=2: recurse right" }, { "time": 9500, "value": "Layer k=2: all cells filled" }] }] },
    { "type": "rect", "id": "cost-box", "rotation": 0, "x": 100, "y": 370, "width": 680, "height": 55, "fill": "#ede9fe", "stroke": "#7c3aed", "strokeWidth": 2, "cornerRadius": 6, "label": "cost(l,r) = (prefix[r] - prefix[l-1])^2  |  사각 부등식 만족 -> opt monotonic", "labelColor": "#5b21b6", "labelSize": 13, "appearances": [{ "start": 0, "end": 13000 }], "tracks": [] },
    { "type": "rect", "id": "final-result", "rotation": 0, "x": 100, "y": 450, "width": 300, "height": 40, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 6, "label": "dp[K][N] = 52  (K=2, N=4)", "labelColor": "#14532d", "labelSize": 14, "appearances": [{ "start": 11000, "end": 13000 }], "tracks": [] }
  ],
  "chapters": [
    { "id": "init", "time": 0, "label": "Layer 1 완료", "subtitle": "dp[1][i] = cost(1, i)" },
    { "id": "mid", "time": 500, "label": "Find mid", "subtitle": "mid=4, bestK=3, dp=52" },
    { "id": "recurse-left", "time": 3500, "label": "Left half", "subtitle": "dac(1, 3, 0, 3)" },
    { "id": "recurse-right", "time": 6500, "label": "Right half", "subtitle": "dac(5, 8, 3, 8)" },
    { "id": "done", "time": 11000, "label": "Layer Done", "subtitle": "dp[2][*] 완성" }
  ],
  "effects": [
