{
  "version": 2,
  "id": "redis-cache-miss",
  "title": "Redis 캐시 미스 (MISS)",
  "description": "캐시에 데이터가 없을 때 DB 조회 + 캐시 갱신 흐름",
  "category": "cache",
  "tags": ["redis", "cache", "miss", "database"],
  "canvas": { "width": 900, "height": 460, "background": "transparent" },
  "elements": [
    { "type": "rect", "id": "client", "rotation": 0, "x": 60, "y": 200, "width": 130, "height": 70, "fill": "#dbeafe", "stroke": "#3b82f6", "strokeWidth": 2, "cornerRadius": 10, "label": "Client", "labelColor": "#1e3a8a", "labelSize": 15 },
    { "type": "rect", "id": "app", "rotation": 0, "x": 280, "y": 200, "width": 130, "height": 70, "fill": "#e0e7ff", "stroke": "#6366f1", "strokeWidth": 2, "cornerRadius": 10, "label": "App", "labelColor": "#312e81", "labelSize": 15 },
    { "type": "rect", "id": "redis", "rotation": 0, "x": 500, "y": 70, "width": 130, "height": 70, "fill": "#fee2e2", "stroke": "#dc2626", "strokeWidth": 2, "cornerRadius": 10, "label": "Redis", "labelColor": "#7f1d1d", "labelSize": 15, "subtitle": "cache" },
    { "type": "rect", "id": "db", "rotation": 0, "x": 720, "y": 200, "width": 130, "height": 70, "fill": "#dcfce7", "stroke": "#16a34a", "strokeWidth": 2, "cornerRadius": 10, "label": "DB", "labelColor": "#14532d", "labelSize": 15, "subtitle": "PostgreSQL" },
    { "type": "circle", "id": "req", "rotation": 0, "cx": 125, "cy": 235, "r": 10, "fill": "#facc15", "stroke": "#a16207", "strokeWidth": 2 },
    { "type": "text", "id": "step-label", "rotation": 0, "x": 450, "y": 40, "content": "1. 요청 전송", "fontSize": 20, "fontWeight": 700, "color": "#18181b", "textAnchor": "middle" },
    { "type": "text", "id": "latency", "rotation": 0, "x": 450, "y": 410, "content": "총 ~72ms (DB 왕복 포함)", "fontSize": 14, "fontWeight": 400, "color": "#71717a", "textAnchor": "middle" }
  ],
  "initiallyHidden": [],
  "steps": [
    { "id": "s1", "label": "Client → App", "duration": 800, "ease": "easeInOut",
      "keyframes": { "req": { "cx": 345 }, "step-label": { "content": "2. App 이 캐시 조회" } },
      "effects": [{ "type": "highlight", "elementId": "app", "color": "#a5b4fc", "duration": 400, "delay": 0 }] },
    { "id": "s2", "label": "App → Redis (miss)", "duration": 700, "ease": "easeInOut",
      "keyframes": { "req": { "cx": 565, "cy": 105 }, "step-label": { "content": "3. ✗ MISS - 캐시에 없음" } },
      "effects": [{ "type": "highlight", "elementId": "redis", "color": "#f87171", "duration": 500, "delay": 0 }] },
    { "id": "s3", "label": "App → DB 조회", "duration": 900, "ease": "easeInOut",
      "keyframes": { "req": { "cx": 785, "cy": 235, "fill": "#facc15" }, "step-label": { "content": "4. DB 에서 조회 (느림)" } },
      "effects": [
        { "type": "highlight", "elementId": "db", "color": "#86efac", "duration": 700, "delay": 0 },
        { "type": "pulse", "elementId": "db", "scale": 1.1, "duration": 700, "delay": 0 }
      ] },
    { "id": "s4", "label": "DB → App 데이터", "duration": 900, "ease": "easeInOut",
      "keyframes": { "req": { "cx": 345, "fill": "#34d399" }, "step-label": { "content": "5. 캐시에 저장 (다음번엔 HIT)" } },
      "effects": [] },
    { "id": "s5", "label": "App → Redis 갱신", "duration": 600, "ease": "easeInOut",
      "keyframes": { "req": { "cx": 565, "cy": 105 }, "step-label": { "content": "5. 캐시에 저장 (다음번엔 HIT)" } },
      "effects": [{ "type": "highlight", "elementId": "redis", "color": "#34d399", "duration": 500, "delay": 0 }] },
    { "id": "s6", "label": "App → Client 응답", "duration": 900, "ease": "easeInOut",
      "keyframes": { "req": { "cx": 125, "cy": 235 }, "step-label": { "content": "✓ 완료" } },
      "effects": [] },
    { "id": "s7", "label": "재시작", "duration": 500, "ease": "linear",
      "keyframes": { "req": { "cx": 125, "cy": 235, "fill": "#facc15" }, "step-label": { "content": "1. 요청 전송" } },
      "effects": [] }
  ],
  "settings": { "loop": true, "autoplay": true, "stepGapMs": 150 }
}
