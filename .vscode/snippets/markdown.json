{
  "Blog Post Frontmatter": {
    "prefix": "post",
    "body": [
      "---",
      "title: \"$1\"",
      "description: \"$2\"",
      "date: $CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATE",
      "tags: [$3]",
      "draft: true",
      "---",
      "",
      "$0"
    ],
    "description": "src/content/posts/*.md frontmatter"
  },
  "Quick Note": {
    "prefix": "note",
    "body": [
      "---",
      "date: $CURRENT_YEAR-$CURRENT_MONTH-${CURRENT_DATE}T$CURRENT_HOUR:$CURRENT_MINUTE:00+09:00",
      "tags: [$1]",
      "---",
      "",
      "$0"
    ],
    "description": "src/content/notes/*.md frontmatter"
  },
  "Wiki Page": {
    "prefix": "wiki",
    "body": [
      "---",
      "title: \"$1\"",
      "aliases: []",
      "tags: [$2]",
      "updated: $CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATE",
      "---",
      "",
      "## 개요",
      "",
      "$0"
    ],
    "description": "src/content/wiki/*.md frontmatter"
  }
}
